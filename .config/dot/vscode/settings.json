{
  "[c]": {
    "editor.formatOnSave": true
  },
  "[cpp]": {
    "editor.formatOnSave": true
  },
  "[cuda-cpp]": {
    "editor.formatOnSave": true
  },
  "[go]": {
    "editor.formatOnSave": true
  },
  "[java]": {
    "editor.formatOnSave": true
  },
  "[kotlin]": {
    "editor.formatOnSave": true
  },
  "[objective-c]": {
    "editor.formatOnSave": true
  },
  "[objective-cpp]": {
    "editor.formatOnSave": true
  },
  "[ocaml]": {
    "editor.formatOnSave": true
  },
  "[proto]": {
    "editor.formatOnSave": true
  },
  "[python]": {
    "diffEditor.ignoreTrimWhitespace": false,
    "editor.codeActionsOnSave": {
      "source.organizeImports": "explicit"
    },
    "editor.formatOnSave": true,
    "editor.tabSize": 4
  },
  "[rust]": {
    "editor.formatOnSave": true
  },
  "[starlark]": {
    "editor.formatOnSave": true
  },
  "[swift]": {
    "editor.formatOnSave": true
  },
  "accessibility.openChatEditedFiles": false,
  "accessibility.signals.terminalBell": {
    "sound": "on"
  },
  "cSpell.diagnosticLevel": "Hint",
  "debug.saveBeforeStart": "nonUntitledEditorsInActiveGroup",
  "diffEditor.ignoreTrimWhitespace": false,
  "diffEditor.renderSideBySide": false,
  "editor.bracketPairColorization.enabled": true,
  "editor.fontFamily": "JetBrainsMono Nerd Font, FiraCode Nerd Font, MesloLGM Nerd Font Mono, monospace",
  "editor.letterSpacing": 0.2,
  "editor.guides.bracketPairs": "active",
  "editor.indentSize": "tabSize",
  "editor.inlineSuggest.allowSuggestOnTriggerCharacters": true,
  "editor.lightbulb.enabled": "on",
  "editor.renderWhitespace": "boundary",
  "editor.stickyScroll.enabled": true,
  "editor.suggest.snippetsPreventQuickSuggestions": false,
  "editor.tabSize": 2,
  "emmet.showAbbreviationSuggestions": false,
  "emmet.showExpandedAbbreviation": "never",
  "files.insertFinalNewline": true,
  "files.trimFinalNewlines": true,
  "homepage.startup": "Never",
  "isort.args": [
    "--profile",
    "black"
  ],
  "multiCommand.commands": [
    {
      "command": "multiCommand.focusEditor",
      "sequence": [
        "workbench.action.focusActiveEditorGroup"
      ]
    },
    {
      "command": "multiCommand.findNextAndFocusEditor",
      "sequence": [
        "editor.action.nextMatchFindAction",
        "workbench.action.focusActiveEditorGroup"
      ]
    }
  ],
  "terminal.explorerKind": "external",
  "terminal.external.osxExec": "iTerm.app",
  "terminal.integrated.defaultProfile.linux": "bash",
  "terminal.integrated.defaultProfile.osx": "bash",
  "terminal.integrated.defaultProfile.windows": "WSL",
  "terminal.integrated.fontFamily": "JetBrainsMono Nerd Font, FiraCode Nerd Font, MesloLGM Nerd Font Mono, monospace",
  "terminal.integrated.letterSpacing": 0,
  "terminal.integrated.profiles.linux": {
    "bash": {
      "args": [
        "-l"
      ],
      "icon": "terminal-bash",
      "path": "bash"
    },
    "tmux": {
      "icon": "terminal-tmux",
      "path": "tmux"
    },
    "zsh": {
      "args": [
        "-l"
      ],
      "path": "zsh"
    }
  },
  "terminal.integrated.profiles.osx": {
    "bash": {
      "args": [
        "-l"
      ],
      "icon": "terminal-bash",
      "path": "bash"
    },
    "tmux": {
      "icon": "terminal-tmux",
      "path": "tmux"
    },
    "zsh": {
      "args": [
        "-l"
      ],
      "path": "zsh"
    }
  },
  "terminal.integrated.profiles.windows": {
    "Command Prompt": {
      "icon": "terminal-cmd",
      "path": "cmd.exe"
    },
    "PowerShell": {
      "icon": "terminal-powershell",
      "path": "pwsh.exe"
    },
    "WSL": {
      "icon": "terminal-bash",
      "path": "wsl.exe"
    }
  },
  "terminal.integrated.scrollback": 10000,
  "terminal.integrated.systemd.shouldUse": true,
  "trailing-spaces.deleteModifiedLinesOnly": true,
  "trailing-spaces.trimOnSave": true,
  "vsicons.dontShowNewVersionMessage": true,
  "window.nativeTabs": true,
  "window.openNewWindowsInNativeTabs": true,
  "window.restoreWindows": "all",
  "window.zoomPerWindow": false,
  "workbench.colorTheme": "Night Owl (No Italics)",
  "workbench.editor.enablePreview": true,
  "workbench.iconTheme": "vscode-icons",
  "workbench.panel.defaultLocation": "left",
  "workbench.preferredDarkColorTheme": "Night Owl (No Italics)",
  "workbench.secondarySideBar.defaultVisibility": "hidden",
  "workbench.startupEditor": "none"
}

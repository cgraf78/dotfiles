{
  "enabledPlugins": {
    "clangd-lsp@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "hookify@claude-plugins-official": true,
    "memory-sync@cgraf78-claude-plugins": true,
    "plugin-dev@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "ralph-loop@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "status-line@cgraf78-claude-plugins": true,
    "superpowers@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true
  },
  "env": {},
  "extraKnownMarketplaces": {
    "cgraf78-claude-plugins": {
      "source": {
        "repo": "cgraf78/claude-plugins",
        "source": "github"
      }
    }
  },
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "command": "printf '\\a' > /dev/tty 2>/dev/null || true",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "claude-hook-post-edit",
            "timeout": 60,
            "type": "command"
          }
        ],
        "matcher": "Edit|Write"
      },
      {
        "hooks": [
          {
            "command": "claude-hook-post-bash",
            "timeout": 120,
            "type": "command"
          }
        ],
        "matcher": "Bash"
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "claude-hook-pre-bash",
            "timeout": 120,
            "type": "command"
          }
        ],
        "matcher": "Bash"
      },
      {
        "hooks": [
          {
            "command": "claude-hook-pre-edit",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "Edit|Write"
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "command": "claude-hook-session-end",
            "timeout": 30,
            "type": "command"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "claude-hook-session-start",
            "timeout": 10,
            "type": "command"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "claude-hook-stop",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "claude-hook-prompt-submit",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ]
  },
  "model": "sonnet",
  "permissions": {
    "additionalDirectories": [
      "/home/chris",
      "/Users/chris"
    ],
    "allow": [
      "Bash(dot *)",
      "Bash(cd *)",
      "Bash(ls *)",
      "Bash(which *)",
      "Bash(echo *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(env)",
      "Bash(printenv *)",
      "Bash(mkdir *)",
      "Bash(test *)",
      "Bash(diff *)",
      "Bash(file *)",
      "Bash(realpath *)",
      "Bash(basename *)",
      "Bash(dirname *)",
      "Bash(sort *)",
      "Bash(uniq *)",
      "Bash(cut *)",
      "Bash(touch *)",
      "Bash(chmod *)",
      "Bash(ln *)",
      "Bash(xattr *)",
      "Bash(stat *)",
      "Bash(mdfind*)",
      "Bash(tree *)",
      "Bash(date *)",
      "Bash(whoami)",
      "Bash(uname *)",
      "Bash(tr *)",
      "Bash(python3 *)",
      "Bash(python *)",
      "Bash(pip3 list*)",
      "Bash(pip3 show *)",
      "Bash(pip3 freeze*)",
      "Bash(c++filt *)",
      "Bash(nm *)",
      "Bash(otool *)",
      "Bash(strings *)",
      "Bash(git *)",
      "Bash(tmux *)",
      "Bash(locate *)",
      "Bash(code *)",
      "Bash(gh *)",
      "Bash(xargs *)",
      "Bash(sed *)",
      "Bash(awk *)",
      "Bash(curl -s *)",
      "Bash(curl --silent *)",
      "Bash(jq *)",
      "Bash(sha256sum *)",
      "Bash(md5sum *)",
      "Bash(readlink *)",
      "Bash(type *)",
      "Bash(hostname*)",
      "Bash(df *)",
      "Bash(du *)",
      "Read(*)",
      "Glob(*)",
      "Grep(*)",
      "WebFetch(*)",
      "Bash(bash tests/*)",
      "WebSearch(*)",
      "Bash(shellcheck *)",
      "Bash(rsync *)",
      "Bash(brew *)",
      "Bash(claude *)",
      "Bash(dotsync *)",
      "Bash(ds *)",
      "Skill(commit-commands:*)"
    ]
  },
  "statusLine": {
    "command": "bash ~/.claude/plugins/cache/cgraf78-claude-plugins/status-line/*/scripts/status-line.sh",
    "type": "command"
  },
  "voiceEnabled": true
}

#!/usr/bin/env bash
# Smart dotfiles manager.
#
# Two repos:
#   ~/.dotfiles      — bare repo, personal dotfiles (public)
#   ~/.dotfiles-work — regular clone, work dotfiles (private, optional)
#
# Commands:
#   dot update [--cron]        Sync everything (--cron: quiet, skip if dirty)
#   dot pull/push/status/diff  Operates on both repos (requires bare repo)
#   dot refresh                Fixes phantom dirty files from clean filters
#   dot cron                   Show installed cron entries
#   dot <anything>             Passes through to git (personal repo)

set -euo pipefail

# shellcheck source=../../.config/dot/helpers.sh
. "$HOME/.config/dot/helpers.sh"

# ---------------------------------------------------------------------------
# Global flags
# ---------------------------------------------------------------------------

CRON_MODE=0

# ---------------------------------------------------------------------------
# Functions (defined before case statements so all commands can use them)
# ---------------------------------------------------------------------------

# Re-checkout files that are byte-different but identical after clean filter.
# Fixes phantom dirty status from tools rewriting JSON with different key order.
_normalize_filtered() {
  # Warn if required filters from .gitattributes are missing in local config.
  if [[ -f "$HOME/.gitattributes" ]] && grep -q "filter=json-sort" "$HOME/.gitattributes"; then
    # shellcheck disable=SC2086
    if ! $GIT config filter.json-sort.clean >/dev/null 2>&1; then
      _warn "warning: json-sort filter is not configured. run 'dotbootstrap' to fix."
    fi
  fi

  local dirty
  dirty=$($GIT diff-files --name-only 2>/dev/null) || true
  [[ -n "$dirty" ]] || return 0
  echo "$dirty" | while IFS= read -r f; do
    if $GIT diff --quiet -- "$f" 2>/dev/null; then
      $GIT checkout -- "$f" 2>/dev/null || true
    fi
  done
}

# Pull both repos (personal + work) with proper unstash/normalize handling.
_pull_all() {
  _normalize_filtered
  _unstash_work_overrides
  _log "==> Pulling personal dotfiles..."
  if [[ "$DOT_QUIET" -eq 1 ]]; then
    $GIT pull --quiet "$@" || _warn "  warning: personal dotfiles pull failed"
  else
    $GIT pull "$@"
  fi
  _pull_work_repo "$@"
}

# ---------------------------------------------------------------------------
# Commands that work without the bare repo
# ---------------------------------------------------------------------------

case "${1:-}" in
  update)
    shift
    # Parse flags
    while [[ "${1:-}" == --* ]]; do
      case "$1" in
        --cron) CRON_MODE=1; export DOT_QUIET=1; shift ;;
        *) break ;;
      esac
    done

    # In cron mode, skip pull if worktree is dirty.  First try to resolve
    # dirty files that match the remote (e.g. dotsync wrote the same content
    # that would be pulled).
    if [[ "$CRON_MODE" -eq 1 ]] && _is_worktree_dirty; then
      if ! _try_resolve_dirty; then
        exit 0
      fi
    fi

    if [[ -d "$DOTFILES" ]]; then
      _pull_all "$@"
    else
      _pull_work_repo
    fi
    _update_deps
    _run_merges
    if [[ -d "$DOTFILES" ]]; then
      _normalize_filtered
    fi
    _log "==> Done! Run 'source ~/.bashrc' to activate."
    exit 0
    ;;
  cron)
    crontab -l 2>/dev/null || echo "  no crontab installed"
    exit 0
    ;;
  "")
    cat <<EOF
usage: dot <command> [<args>]

Multi-repo commands (personal + work):
  update [--cron]  Sync everything: pull repos, merge configs, update deps
  pull             Same as update (requires bare repo)
  fetch            Fetch both repos (without updating working copy)
  push             Push both repos
  status           Show status of both repos
  diff             Show diff of both repos
  refresh          Fix phantom dirty files from clean/smudge filters
  cron             Show installed cron entries

All other commands pass through to git (personal repo only).

Flags:
  --cron    Quiet mode for cron: skip pull if worktree dirty, suppress output

'update' installs cron entries from ~/.config/dot/cron (tracked) and
cron.local (machine-local, untracked) into the user crontab.
EOF
    exit 0
    ;;
esac

# ---------------------------------------------------------------------------
# Commands below require the bare repo
# ---------------------------------------------------------------------------

if [[ ! -d "$DOTFILES" ]]; then
  cat >&2 <<EOF
error: bare repo not found at $DOTFILES

Clone it first:
  git clone --bare https://github.com/cgraf78/dotfiles.git $DOTFILES
  $DOTFILES/../.local/bin/dotbootstrap personal
EOF
  exit 1
fi

case "${1:-}" in
  fetch)
    shift
    echo "==> Fetching personal dotfiles..."
    $GIT fetch "$@"
    if [[ -d "$WORK_DIR/.git" ]]; then
      echo "==> Fetching work dotfiles..."
      git -C "$WORK_DIR" fetch "$@"
    fi
    ;;
  push)
    shift
    _normalize_filtered
    echo "==> Pushing personal dotfiles..."
    $GIT push "$@"
    _push_work_repo "$@"
    ;;
  pull)
    shift
    _pull_all "$@"
    _update_deps
    _run_merges
    _normalize_filtered
    echo "==> Done! Run 'source ~/.bashrc' to activate."
    ;;
  refresh)
    _normalize_filtered
    ;;
  diff)
    shift
    _normalize_filtered
    echo "==> Personal dotfiles"
    $GIT diff "$@"
    if [[ -d "$WORK_DIR" ]]; then
      echo ""
      echo "==> Work dotfiles"
      git -C "$WORK_DIR" diff "$@"
    fi
    ;;
  status)
    shift
    _normalize_filtered
    echo "==> Personal dotfiles"
    $GIT status "$@"
    if [[ -d "$WORK_DIR" ]]; then
      echo ""
      echo "==> Work dotfiles"
      git -C "$WORK_DIR" status "$@"
    fi
    ;;
  *)
    $GIT "$@"
    ;;
esac

#!/usr/bin/env bash
# Smart dotfiles manager.
#
# One base bare repo at ~/.dotfiles, plus overlay repos discovered
# from config files in ~/.config/dot/overlays.d/*.conf.
#
# Commands:
#   dot update [--cron]        Sync everything (--cron: quiet, skip if dirty)
#   dot pull                   Same as update
#   dot push/status/diff       Operates on base + all active overlays
#   dot cron                   Show installed cron entries
#   dot git <command>           Run any git command on the base repo

set -euo pipefail

# Pre-scan for --force before sourcing init.sh so that shdeps self-update
# (which runs at source time) can bypass the TTL cache.
case "${1:-}" in
  update | pull)
    for _arg in "$@"; do
      case "$_arg" in
        -f | --force)
          export SHDEPS_FORCE=1
          break
          ;;
      esac
    done
    unset _arg
    ;;
esac

# shellcheck source=../../.local/lib/dot/init.sh
. "$HOME/.local/lib/dot/init.sh"

# Bootstrap shdeps for commands that need it (update, pull need deps +
# platform filtering). Read-only commands skip it — non-matching overlay
# dirs simply won't exist, so unfiltered discovery is harmless.
case "${1:-}" in update | pull) _ensure_shdeps ;; esac

_discover_overlays

# ---------------------------------------------------------------------------
# Global flags
# ---------------------------------------------------------------------------

CRON_MODE=0

# Pull all repos (base + overlays) with proper unstash/normalize handling.
# Does NOT link overlay files — _finalize_update handles that after deps.
_pull_all() {
  _ensure_repo_config
  _normalize_filtered
  _unstash_overlay_overrides
  _log_header "==> Pulling dotfiles..."
  if ! _pull_base "$@"; then
    if [[ "$DOT_QUIET" -eq 1 ]]; then
      _warn "  warning: dotfiles pull failed"
    else
      return 1
    fi
  fi
  _pull_overlays "$@"
}

# ---------------------------------------------------------------------------
# Commands that work without the bare repo
# ---------------------------------------------------------------------------

case "${1:-}" in
  update)
    shift
    # Parse flags
    SKIP_PULL=0
    while [[ "${1:-}" == -* ]]; do
      case "$1" in
        --cron)
          CRON_MODE=1
          export DOT_QUIET=1
          export SHDEPS_QUIET=1
          shift
          ;;
        -f | --force)
          export DOT_FORCE=1
          export SHDEPS_FORCE=1
          shift
          ;;
        --skip-pull)
          SKIP_PULL=1
          shift
          ;;
        *) break ;;
      esac
    done

    # In cron mode, skip pull if worktree is dirty.  First try to resolve
    # dirty files that match the remote (e.g. dotsync wrote the same content
    # that would be pulled).
    if [[ "$CRON_MODE" -eq 1 ]] && _is_worktree_dirty; then
      if ! _try_resolve_dirty; then
        exit 0
      fi
    fi

    # Merge overlay SSH configs so host aliases resolve for pulls
    _merge_overlay_ssh_configs

    if [[ "$SKIP_PULL" -eq 0 ]]; then
      # Record HEAD before pull to detect infrastructure changes
      _head_before=""
      if [[ -d "$DOTFILES" ]]; then
        _head_before=$($GIT rev-parse HEAD 2>/dev/null || true)
      fi

      if [[ -d "$DOTFILES" ]]; then
        _pull_all "$@"
      else
        _ensure_repo_config
        _pull_overlays
      fi

      # Re-exec if pull changed dot infrastructure so the rest runs with new code.
      # Skip if autostash left conflict markers in infrastructure files —
      # re-exec would source broken code.
      if [[ -d "$DOTFILES" && -n "$_head_before" && -z "${DOT_REEXEC:-}" ]]; then
        _head_after=$($GIT rev-parse HEAD 2>/dev/null || true)
        if [[ "$_head_before" != "$_head_after" ]] &&
          $GIT diff --name-only "$_head_before" "$_head_after" 2>/dev/null |
          grep -qE '^(\.local/lib/dot/|\.local/bin/dot$)'; then
          # Verify infrastructure files are clean before re-exec.
          # Autostash conflicts can leave conflict markers in source files.
          if grep -rqE '^<{7} |^={7}$|^>{7} ' "$HOME/.local/lib/dot/" "$HOME/.local/bin/dot" 2>/dev/null; then
            _warn "  warning: conflict markers in dot infrastructure — skipping re-exec"
          else
            _log_header "==> Dot infrastructure updated, re-running..."
            _reexec_flags=(--skip-pull)
            [[ "$CRON_MODE" -eq 1 ]] && _reexec_flags+=(--cron)
            [[ "${DOT_FORCE:-0}" -eq 1 ]] && _reexec_flags+=(--force)
            export DOT_REEXEC=1
            exec "$0" update "${_reexec_flags[@]}" "$@"
          fi
        fi
      fi
    else
      _log_header "==> Skipping pull (re-exec after infrastructure update)..."
    fi

    _finalize_update
    exit 0
    ;;
  pull)
    shift
    exec "$0" update "$@"
    ;;
  cron)
    crontab -l 2>/dev/null || echo "  no crontab installed"
    exit 0
    ;;
  doctor)
    _dot_doctor
    exit $?
    ;;
  "")
    cat <<EOF
usage: dot <command> [<args>]

Multi-repo commands (base + overlays):
  update [--cron]  Sync everything: pull repos, merge configs, update deps
  pull             Same as update
  fetch            Fetch base + all active overlays
  push             Push base + all active overlays
  status           Show status of base + all active overlays
  diff             Show diff of base + all active overlays
  cron             Show installed cron entries
  doctor           Run health checks on the installation
  git <command>    Run any git command on the base repo

Flags:
  --cron    Quiet mode for cron: skip pull if worktree dirty, suppress output

Overlays are configured in ~/.config/dot/overlays.d/*.conf.
'update' installs cron entries from ~/.config/dot/merge-hooks.d/cron
(tracked) and cron.local (machine-local, untracked) into the user crontab.
EOF
    exit 0
    ;;
esac

# ---------------------------------------------------------------------------
# Commands below require the bare repo
# ---------------------------------------------------------------------------

if [[ ! -d "$DOTFILES" ]]; then
  cat >&2 <<EOF
error: bare repo not found at $DOTFILES

Clone it first:
  git clone --bare https://github.com/cgraf78/dotfiles.git $DOTFILES
  $DOTFILES/../.local/bin/dotbootstrap
EOF
  exit 1
fi

case "${1:-}" in
  fetch)
    shift
    _header "==> Fetching dotfiles..."
    $GIT fetch "$@"
    for entry in "${OVERLAYS[@]+"${OVERLAYS[@]}"}"; do
      IFS='|' read -r name path _ <<<"$entry"
      if [[ -d "$path/.git" ]]; then
        _header "==> Fetching $name dotfiles..."
        git -C "$path" fetch "$@"
      fi
    done
    ;;
  push)
    shift
    _normalize_filtered
    _header "==> Pushing dotfiles..."
    $GIT push "$@"
    _push_overlays "$@"
    ;;
  diff)
    shift
    _normalize_filtered
    _header "==> dotfiles"
    $GIT diff "$@"
    for entry in "${OVERLAYS[@]+"${OVERLAYS[@]}"}"; do
      IFS='|' read -r name path _ <<<"$entry"
      if [[ -d "$path/.git" ]]; then
        echo ""
        _header "==> $name dotfiles"
        git -C "$path" diff "$@"
      fi
    done
    ;;
  status)
    shift
    _normalize_filtered
    _header "==> dotfiles"
    $GIT status "$@"
    for entry in "${OVERLAYS[@]+"${OVERLAYS[@]}"}"; do
      IFS='|' read -r name path _ <<<"$entry"
      if [[ -d "$path/.git" ]]; then
        echo ""
        _header "==> $name dotfiles"
        git -C "$path" status "$@"
      fi
    done
    ;;
  git)
    shift
    $GIT "$@"
    ;;
  *)
    printf 'dot: unknown command: %s\n' "$1" >&2
    printf 'tip: use "dot git %s" for raw git operations\n' "$1" >&2
    exit 1
    ;;
esac

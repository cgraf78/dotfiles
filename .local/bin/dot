#!/usr/bin/env bash
# Smart dotfiles manager.
#
# Two repos:
#   ~/.dotfiles      — bare repo, personal dotfiles (public)
#   ~/.dotfiles-work — regular clone, work dotfiles (private, optional)
#
# Commands:
#   dot update [--cron]        Sync everything (--cron: quiet, skip if dirty)
#   dot pull/push/status/diff  Operates on both repos (requires bare repo)
#   dot refresh                Fixes phantom dirty files from clean filters
#   dot cron                   Show installed cron entries
#   dot <anything>             Passes through to git (personal repo)

set -euo pipefail

# shellcheck source=../../.config/dot/init.sh
. "$HOME/.config/dot/init.sh"

# ---------------------------------------------------------------------------
# Global flags
# ---------------------------------------------------------------------------

CRON_MODE=0

# Pull both repos (personal + work) with proper unstash/normalize handling.
# Does NOT link work files — _finalize_update handles that after deps.
_pull_all() {
  _normalize_filtered
  _unstash_work_overrides
  _log_header "==> Pulling personal dotfiles..."
  if ! _pull_personal "$@"; then
    if [[ "$DOT_QUIET" -eq 1 ]]; then
      _warn "  warning: personal dotfiles pull failed"
    else
      return 1
    fi
  fi
  _pull_work_repo "$@"
}

# ---------------------------------------------------------------------------
# Commands that work without the bare repo
# ---------------------------------------------------------------------------

case "${1:-}" in
update)
  shift
  # Parse flags
  SKIP_PULL=0
  while [[ "${1:-}" == -* ]]; do
    case "$1" in
    --cron)
      CRON_MODE=1
      export DOT_QUIET=1
      shift
      ;;
    -f | --force)
      export DOT_FORCE=1
      shift
      ;;
    --skip-pull)
      SKIP_PULL=1
      shift
      ;;
    *) break ;;
    esac
  done

  # In cron mode, skip pull if worktree is dirty.  First try to resolve
  # dirty files that match the remote (e.g. dotsync wrote the same content
  # that would be pulled).
  if [[ "$CRON_MODE" -eq 1 ]] && _is_worktree_dirty; then
    if ! _try_resolve_dirty; then
      exit 0
    fi
  fi

  if [[ "$SKIP_PULL" -eq 0 ]]; then
    # Record HEAD before pull to detect infrastructure changes
    _head_before=""
    if [[ -d "$DOTFILES" ]]; then
      _head_before=$($GIT rev-parse HEAD 2>/dev/null || true)
    fi

    if [[ -d "$DOTFILES" ]]; then
      _pull_all "$@"
    else
      _pull_work_repo
    fi

    # Re-exec if pull changed dot infrastructure so the rest runs with new code
    if [[ -d "$DOTFILES" && -n "$_head_before" && -z "${DOT_REEXEC:-}" ]]; then
      _head_after=$($GIT rev-parse HEAD 2>/dev/null || true)
      if [[ "$_head_before" != "$_head_after" ]] &&
        $GIT diff --name-only "$_head_before" "$_head_after" 2>/dev/null |
        grep -qE '^(\.config/dot/|\.local/bin/dot$)'; then
        _log_header "==> Dot infrastructure updated, re-running..."
        _reexec_flags=(--skip-pull)
        [[ "$CRON_MODE" -eq 1 ]] && _reexec_flags+=(--cron)
        [[ "${DOT_FORCE:-0}" -eq 1 ]] && _reexec_flags+=(--force)
        export DOT_REEXEC=1
        exec "$0" update "${_reexec_flags[@]}" "$@"
      fi
    fi
  else
    _log_header "==> Skipping pull (re-exec after infrastructure update)..."
  fi

  _finalize_update
  exit 0
  ;;
cron)
  crontab -l 2>/dev/null || echo "  no crontab installed"
  exit 0
  ;;
"")
  cat <<EOF
usage: dot <command> [<args>]

Multi-repo commands (personal + work):
  update [--cron]  Sync everything: pull repos, merge configs, update deps
  pull             Same as update (requires bare repo)
  fetch            Fetch both repos (without updating working copy)
  push             Push both repos
  status           Show status of both repos
  diff             Show diff of both repos
  refresh          Fix phantom dirty files from clean/smudge filters
  cron             Show installed cron entries

All other commands pass through to git (personal repo only).

Flags:
  --cron    Quiet mode for cron: skip pull if worktree dirty, suppress output

'update' installs cron entries from ~/.config/dot/cron (tracked) and
cron.local (machine-local, untracked) into the user crontab.
EOF
  exit 0
  ;;
esac

# ---------------------------------------------------------------------------
# Commands below require the bare repo
# ---------------------------------------------------------------------------

if [[ ! -d "$DOTFILES" ]]; then
  cat >&2 <<EOF
error: bare repo not found at $DOTFILES

Clone it first:
  git clone --bare https://github.com/cgraf78/dotfiles.git $DOTFILES
  $DOTFILES/../.local/bin/dotbootstrap personal
EOF
  exit 1
fi

case "${1:-}" in
fetch)
  shift
  _header "==> Fetching personal dotfiles..."
  $GIT fetch "$@"
  if [[ -d "$WORK_DIR/.git" ]]; then
    _header "==> Fetching work dotfiles..."
    git -C "$WORK_DIR" fetch "$@"
  fi
  ;;
push)
  shift
  _normalize_filtered
  _header "==> Pushing personal dotfiles..."
  $GIT push "$@"
  _push_work_repo "$@"
  ;;
pull)
  shift
  _pull_all "$@"
  _finalize_update
  ;;
refresh)
  _normalize_filtered
  ;;
diff)
  shift
  _normalize_filtered
  _header "==> Personal dotfiles"
  $GIT diff "$@"
  if [[ -d "$WORK_DIR" ]]; then
    echo ""
    _header "==> Work dotfiles"
    git -C "$WORK_DIR" diff "$@"
  fi
  ;;
status)
  shift
  _normalize_filtered
  _header "==> Personal dotfiles"
  $GIT status "$@"
  if [[ -d "$WORK_DIR" ]]; then
    echo ""
    _header "==> Work dotfiles"
    git -C "$WORK_DIR" status "$@"
  fi
  ;;
*)
  $GIT "$@"
  ;;
esac

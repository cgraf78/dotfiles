#!/usr/bin/env bash
# autoformat-test — unit tests for the autoformat script.
#
# Tests formatting dispatch, config file discovery, fallback defaults,
# shebang detection, and no-op behavior for unsupported/missing files.
#
# Usage: autoformat-test

set -o pipefail
export NO_COLOR=1

# Formatter/linter dev tooling is expected to come from the global
# mise toolset, so seed the shim dir explicitly for direct test runs.
[ -d "$HOME/.local/share/mise/shims" ] &&
  PATH="$HOME/.local/share/mise/shims:$PATH"

# shellcheck source=../lib/dot/test-helpers.sh
. "$HOME/.local/lib/dot/test-helpers.sh"

AUTOFORMAT="$HOME/.local/bin/autoformat"

# ---------------------------------------------------------------------------
# Tests: basic dispatch by extension
# ---------------------------------------------------------------------------

echo "=== Dispatch by extension ==="

_td=$(_tmpdir)

cat >"$_td/test.py" <<'EOF'
x=1
y =    2
EOF
"$AUTOFORMAT" "$_td/test.py"
_assert_contains "py: ruff formats" "x = 1" "$(cat "$_td/test.py")"

cat >"$_td/test.sh" <<'EOF'
#!/bin/bash
if true; then
echo "hello"
fi
EOF
"$AUTOFORMAT" "$_td/test.sh"
_assert_contains "sh: shfmt formats" "  echo" "$(cat "$_td/test.sh")"

cat >"$_td/test.cpp" <<'EOF'
int main() {
int x = 0;
if (x) {
return 0;
}
}
EOF
"$AUTOFORMAT" "$_td/test.cpp"
_assert_contains "cpp: clang-format formats" "  int x" "$(cat "$_td/test.cpp")"

cat >"$_td/test.bash" <<'EOF'
#!/bin/bash
if true; then
echo "hello"
fi
EOF
"$AUTOFORMAT" "$_td/test.bash"
_assert_contains "bash ext: shfmt formats" "  echo" "$(cat "$_td/test.bash")"

cat >"$_td/test.zsh" <<'EOF'
#!/usr/bin/env zsh
if true; then
echo "hello"
fi
EOF
"$AUTOFORMAT" "$_td/test.zsh"
_assert_contains "zsh ext: shfmt formats" "  echo" "$(cat "$_td/test.zsh")"

cat >"$_td/test.c" <<'EOF'
int main() {
int x = 0;
}
EOF
"$AUTOFORMAT" "$_td/test.c"
_assert_contains "c: clang-format formats" "  int x" "$(cat "$_td/test.c")"

cat >"$_td/test.h" <<'EOF'
void foo() {
int x = 0;
}
EOF
"$AUTOFORMAT" "$_td/test.h"
_assert_contains "h: clang-format formats" "  int x" "$(cat "$_td/test.h")"

cat >"$_td/test.lua" <<'EOF'
if true then
print("hello")
end
EOF
"$AUTOFORMAT" "$_td/test.lua"
_assert_contains "lua: stylua formats" "  print" "$(cat "$_td/test.lua")"

cat >"$_td/test.json" <<'EOF'
{"x":1}
EOF
"$AUTOFORMAT" "$_td/test.json"
_assert_contains "json: prettier formats" '"x": 1' "$(cat "$_td/test.json")"

cat >"$_td/test.toml" <<'EOF'
x=1
EOF
"$AUTOFORMAT" "$_td/test.toml"
_assert_contains "toml: taplo formats" 'x = 1' "$(cat "$_td/test.toml")"

cat >"$_td/test.rs" <<'EOF'
fn main( ){ }
EOF
"$AUTOFORMAT" "$_td/test.rs"
_assert_eq "rust: rustfmt formats" 'fn main() {}' "$(cat "$_td/test.rs")"

# ---------------------------------------------------------------------------
# Tests: default indent values
# ---------------------------------------------------------------------------

echo "=== Default indent values ==="

cat >"$_td/test.py" <<'EOF'
def foo():
  if True:
    print("hello")
EOF
"$AUTOFORMAT" "$_td/test.py"
_assert_contains "py: 4-space indent" "    if True:" "$(cat "$_td/test.py")"

cat >"$_td/test.sh" <<'EOF'
#!/bin/bash
if true; then
echo "hello"
fi
EOF
"$AUTOFORMAT" "$_td/test.sh"
_assert_contains "sh: 2-space indent" "  echo" "$(cat "$_td/test.sh")"
_assert_not_contains "sh: no tabs" "	" "$(cat "$_td/test.sh")"

cat >"$_td/test.lua" <<'EOF'
if true then
print("hello")
end
EOF
"$AUTOFORMAT" "$_td/test.lua"
_assert_contains "lua: 2-space indent" "  print" "$(cat "$_td/test.lua")"
_assert_not_contains "lua: no tabs" "	" "$(cat "$_td/test.lua")"

# ---------------------------------------------------------------------------
# Tests: C++ fallback config
# ---------------------------------------------------------------------------

echo "=== C++ fallback config ==="

cat >"$_td/test.cpp" <<'EOF'
int main() {
int *x = nullptr;
}
EOF
"$AUTOFORMAT" "$_td/test.cpp"
_assert_contains "cpp: pointer left (fallback)" "int* x" "$(cat "$_td/test.cpp")"

# ---------------------------------------------------------------------------
# Tests: repo config overrides defaults
# ---------------------------------------------------------------------------

echo "=== Repo config overrides ==="

_repo_sh=$(_tmpdir)
cat >"$_repo_sh/.editorconfig" <<'EOF'
root = true
[*.sh]
indent_style = space
indent_size = 4
EOF
cat >"$_repo_sh/test.sh" <<'EOF'
#!/bin/bash
if true; then
echo "hello"
fi
EOF
"$AUTOFORMAT" "$_repo_sh/test.sh"
_assert_contains "sh: editorconfig overrides default" "    echo" "$(cat "$_repo_sh/test.sh")"

_repo_py=$(_tmpdir)
cat >"$_repo_py/ruff.toml" <<'EOF'
indent-width = 2
EOF
cat >"$_repo_py/test.py" <<'EOF'
def foo():
    if True:
        print("hello")
EOF
"$AUTOFORMAT" "$_repo_py/test.py"
_assert_contains "py: ruff.toml overrides default" "  if True:" "$(cat "$_repo_py/test.py")"

_repo_py2=$(_tmpdir)
cat >"$_repo_py2/.ruff.toml" <<'EOF'
indent-width = 2
EOF
cat >"$_repo_py2/test.py" <<'EOF'
def foo():
    if True:
        print("hello")
EOF
"$AUTOFORMAT" "$_repo_py2/test.py"
_assert_contains "py: .ruff.toml overrides default" "  if True:" "$(cat "$_repo_py2/test.py")"

_repo_py3=$(_tmpdir)
cat >"$_repo_py3/pyproject.toml" <<'EOF'
[project]
name = "demo"
version = "0.1.0"
EOF
cat >"$_repo_py3/test.py" <<'EOF'
def foo():
  if True:
    print("hello")
EOF
"$AUTOFORMAT" "$_repo_py3/test.py"
_assert_contains "py: unrelated pyproject keeps fallback" "    if True:" "$(cat "$_repo_py3/test.py")"

_repo_py4=$(_tmpdir)
cat >"$_repo_py4/pyproject.toml" <<'EOF'
[tool.ruff]
indent-width = 2
EOF
cat >"$_repo_py4/test.py" <<'EOF'
def foo():
    if True:
        print("hello")
EOF
"$AUTOFORMAT" "$_repo_py4/test.py"
_assert_contains "py: pyproject ruff config overrides fallback" "  if True:" "$(cat "$_repo_py4/test.py")"

_repo_cpp=$(_tmpdir)
cat >"$_repo_cpp/.clang-format" <<'EOF'
PointerAlignment: Right
IndentWidth: 4
EOF
cat >"$_repo_cpp/test.cpp" <<'EOF'
int main() {
int* x = nullptr;
}
EOF
"$AUTOFORMAT" "$_repo_cpp/test.cpp"
_assert_contains "cpp: .clang-format overrides fallback" "int *x" "$(cat "$_repo_cpp/test.cpp")"

_repo_cpp2=$(_tmpdir)
cat >"$_repo_cpp2/_clang-format" <<'EOF'
PointerAlignment: Right
IndentWidth: 4
EOF
cat >"$_repo_cpp2/test.cpp" <<'EOF'
int main() {
int* x = nullptr;
}
EOF
"$AUTOFORMAT" "$_repo_cpp2/test.cpp"
_assert_contains "cpp: _clang-format overrides fallback" "int *x" "$(cat "$_repo_cpp2/test.cpp")"

_repo_lua=$(_tmpdir)
cat >"$_repo_lua/stylua.toml" <<'EOF'
indent_type = "Tabs"
EOF
cat >"$_repo_lua/test.lua" <<'EOF'
if true then
print("hello")
end
EOF
"$AUTOFORMAT" "$_repo_lua/test.lua"
_assert_contains "lua: stylua.toml overrides default" "	print" "$(cat "$_repo_lua/test.lua")"

# Rust: per-repo rustfmt.toml overrides fallback
_repo_rs=$(_tmpdir)
cat >"$_repo_rs/rustfmt.toml" <<'EOF'
max_width = 40
EOF
cat >"$_repo_rs/test.rs" <<'EOF'
fn very_long_function_name(a:i32,b:i32,c:i32)->i32{a+b+c}
EOF
"$AUTOFORMAT" "$_repo_rs/test.rs"
# max_width=40 forces per-arg wrapping; signature must span multiple lines
_rustout=$(cat "$_repo_rs/test.rs")
_assert_contains "rust: rustfmt.toml overrides fallback (wraps args)" "    a: i32," "$_rustout"
_assert_contains "rust: rustfmt.toml overrides fallback (wraps args)" "    b: i32," "$_rustout"

# TOML: per-repo taplo.toml overrides fallback. Autoformat now
# detects the per-repo config and passes it via --config explicitly,
# since taplo's own auto-discovery walks cwd rather than file path.
_repo_tm=$(_tmpdir)
cat >"$_repo_tm/taplo.toml" <<'EOF'
[formatting]
reorder_keys = true
EOF
cat >"$_repo_tm/test.toml" <<'EOF'
z = 1
a = 2
EOF
"$AUTOFORMAT" "$_repo_tm/test.toml"
_assert_contains "toml: taplo.toml overrides fallback (reorder)" "a = 2
z = 1" "$(cat "$_repo_tm/test.toml")"

# Prettier: per-repo .prettierrc overrides fallback
_repo_pr=$(_tmpdir)
cat >"$_repo_pr/.prettierrc" <<'EOF'
{"tabWidth": 4, "singleQuote": true}
EOF
cat >"$_repo_pr/test.js" <<'EOF'
const x={a:"b"}
EOF
"$AUTOFORMAT" "$_repo_pr/test.js"
_assert_contains "prettier: .prettierrc overrides fallback" "'b'" "$(cat "$_repo_pr/test.js")"

# Prettier: package.json "prettier" key counts as per-repo config,
# so the global fallback must NOT apply. Fallback says printWidth=100
# + double quotes; repo's package.json says printWidth=20 +
# singleQuote=true. Result should reflect the package.json settings.
_repo_pkg=$(_tmpdir)
cat >"$_repo_pkg/package.json" <<'EOF'
{ "name": "demo", "version": "1.0.0", "prettier": { "printWidth": 20, "singleQuote": true } }
EOF
cat >"$_repo_pkg/test.js" <<'EOF'
const x = {a: "hello world"};
EOF
"$AUTOFORMAT" "$_repo_pkg/test.js"
_assert_contains "prettier: package.json prettier key overrides fallback" "'hello world'" "$(cat "$_repo_pkg/test.js")"

# Prettier: package.json WITHOUT a "prettier" key must NOT be treated
# as per-repo config — fallback should still apply (double quotes).
_repo_pkg_no=$(_tmpdir)
cat >"$_repo_pkg_no/package.json" <<'EOF'
{ "name": "demo", "version": "1.0.0" }
EOF
cat >"$_repo_pkg_no/test.js" <<'EOF'
const x = {a: 'single'};
EOF
"$AUTOFORMAT" "$_repo_pkg_no/test.js"
_assert_contains "prettier: package.json without prettier key → fallback applies" '"single"' "$(cat "$_repo_pkg_no/test.js")"

# Rust fallback: autoformat passes --config-path when no per-repo config
_td_rs=$(_tmpdir)
cat >"$_td_rs/t.rs" <<'EOF'
fn main(){ }
EOF
"$AUTOFORMAT" "$_td_rs/t.rs"
_assert_eq "rust: fallback rustfmt.toml applied" 'fn main() {}' "$(cat "$_td_rs/t.rs")"

# TOML fallback: autoformat passes --config when no per-repo config
_td_tm=$(_tmpdir)
cat >"$_td_tm/t.toml" <<'EOF'
z=1
a=2
EOF
"$AUTOFORMAT" "$_td_tm/t.toml"
# Fallback reorder_keys=false, so original order preserved
_assert_contains "toml: fallback taplo.toml applied (no reorder)" "z = 1
a = 2" "$(cat "$_td_tm/t.toml")"

# Prettier fallback: autoformat passes --config when no per-repo config
_td_pr=$(_tmpdir)
cat >"$_td_pr/t.json" <<'EOF'
{"x":1,"y":2}
EOF
"$AUTOFORMAT" "$_td_pr/t.json"
_assert_contains "prettier: fallback prettierrc.json applied" '"x": 1' "$(cat "$_td_pr/t.json")"

# ---------------------------------------------------------------------------
# Tests: config in parent directory
# ---------------------------------------------------------------------------

echo "=== Config in parent directory ==="

_parent=$(_tmpdir)
mkdir -p "$_parent/sub"
cat >"$_parent/.editorconfig" <<'EOF'
root = true
[*.sh]
indent_style = space
indent_size = 4
EOF
cat >"$_parent/sub/test.sh" <<'EOF'
#!/bin/bash
if true; then
echo "hello"
fi
EOF
"$AUTOFORMAT" "$_parent/sub/test.sh"
_assert_contains "sh: parent editorconfig found" "    echo" "$(cat "$_parent/sub/test.sh")"

# ---------------------------------------------------------------------------
# Tests: config at search root
# ---------------------------------------------------------------------------

echo "=== Config at search root ==="

_cfg_root=$(_tmpdir)
mkdir -p "$_cfg_root/sub"
cat >"$_cfg_root/.editorconfig" <<'EOF'
root = true
[*.sh]
indent_style = space
indent_size = 4
EOF

# shellcheck source=../lib/dot/autofmt.sh
. "$HOME/.local/lib/dot/autofmt.sh"

_has_config "$_cfg_root/sub" ".editorconfig" "$_cfg_root"
rc=$?
_assert_exit "has_config: checks search root" 0 "$rc"

# Regression: relative root and relative starting dir must terminate.
_has_config "." ".editorconfig" "."
rc=$?
_assert_exit "has_config: relative root terminates" 1 "$rc"

# ---------------------------------------------------------------------------
# Tests: shebang detection for extensionless files
# ---------------------------------------------------------------------------

echo "=== Shebang detection ==="

cat >"$_td/myscript" <<'EOF'
#!/bin/bash
if true; then
echo "hello"
fi
EOF
"$AUTOFORMAT" "$_td/myscript"
_assert_contains "shebang bash: formatted" "  echo" "$(cat "$_td/myscript")"

cat >"$_td/shscript" <<'EOF'
#!/bin/sh
if true; then
echo "hello"
fi
EOF
"$AUTOFORMAT" "$_td/shscript"
_assert_contains "shebang sh: formatted" "  echo" "$(cat "$_td/shscript")"

cat >"$_td/envscript" <<'EOF'
#!/usr/bin/env bash
if true; then
echo "hello"
fi
EOF
"$AUTOFORMAT" "$_td/envscript"
_assert_contains "shebang env bash: formatted" "  echo" "$(cat "$_td/envscript")"

cat >"$_td/.zshrc" <<'EOF'
if true; then
echo "hello"
fi
EOF
"$AUTOFORMAT" "$_td/.zshrc"
_assert_contains "dotfile zshrc: formatted" "  echo" "$(cat "$_td/.zshrc")"

cat >"$_td/.zshenv" <<'EOF'
if true; then
echo "hello"
fi
EOF
"$AUTOFORMAT" "$_td/.zshenv"
_assert_contains "dotfile zshenv: formatted" "  echo" "$(cat "$_td/.zshenv")"

cat >"$_td/.bashrc" <<'EOF'
if true; then
echo "hello"
fi
EOF
"$AUTOFORMAT" "$_td/.bashrc"
_assert_contains "dotfile bashrc: formatted" "  echo" "$(cat "$_td/.bashrc")"

cat >"$_td/.profile" <<'EOF'
if true; then
echo "hello"
fi
EOF
"$AUTOFORMAT" "$_td/.profile"
_assert_contains "dotfile profile: formatted" "  echo" "$(cat "$_td/.profile")"

cat >"$_td/zshscript" <<'EOF'
#!/usr/bin/env zsh
if true; then
echo "hello"
fi
EOF
"$AUTOFORMAT" "$_td/zshscript"
_assert_contains "shebang zsh: formatted" "  echo" "$(cat "$_td/zshscript")"

cat >"$_td/pyscript" <<'EOF'
#!/usr/bin/env python3
x=1
EOF
cp "$_td/pyscript" "$_td/pyscript.orig"
"$AUTOFORMAT" "$_td/pyscript"
_assert_eq "shebang python: not formatted as shell" "$(cat "$_td/pyscript.orig")" "$(cat "$_td/pyscript")"

# ---------------------------------------------------------------------------
# Tests: skip known non-shell extensionless files
# ---------------------------------------------------------------------------

echo "=== Skip non-shell files ==="

cat >"$_td/Makefile" <<'EOF'
#!/bin/bash
echo "fake"
EOF
cp "$_td/Makefile" "$_td/Makefile.orig"
"$AUTOFORMAT" "$_td/Makefile"
_assert_eq "Makefile: not formatted" "$(cat "$_td/Makefile.orig")" "$(cat "$_td/Makefile")"

cat >"$_td/Dockerfile" <<'EOF'
#!/bin/bash
echo "fake"
EOF
cp "$_td/Dockerfile" "$_td/Dockerfile.orig"
"$AUTOFORMAT" "$_td/Dockerfile"
_assert_eq "Dockerfile: not formatted" "$(cat "$_td/Dockerfile.orig")" "$(cat "$_td/Dockerfile")"

# ---------------------------------------------------------------------------
# Tests: _classify_shell (shared lib)
# ---------------------------------------------------------------------------

echo "=== _classify_shell ==="

cat >"$_td/zshrc_file" <<'EOF'
echo hi
EOF
mv "$_td/zshrc_file" "$_td/.zshrc"
_assert_eq "classify: .zshrc → zsh" "zsh" "$(_classify_shell "$_td/.zshrc")"

cat >"$_td/.bashrc" <<'EOF'
echo hi
EOF
_assert_eq "classify: .bashrc → bash" "bash" "$(_classify_shell "$_td/.bashrc")"

cat >"$_td/.profile" <<'EOF'
echo hi
EOF
_assert_eq "classify: .profile → bash" "bash" "$(_classify_shell "$_td/.profile")"

cat >"$_td/Dockerfile2" <<'EOF'
FROM alpine
EOF
mv "$_td/Dockerfile2" "$_td/Dockerfile"
_assert_eq "classify: Dockerfile → skip" "skip" "$(_classify_shell "$_td/Dockerfile")"

cat >"$_td/bashscript" <<'EOF'
#!/usr/bin/env bash
echo hi
EOF
_assert_eq "classify: bash shebang → bash" "bash" "$(_classify_shell "$_td/bashscript")"

cat >"$_td/zshshebang" <<'EOF'
#!/usr/bin/env zsh
echo hi
EOF
_assert_eq "classify: zsh shebang → zsh" "zsh" "$(_classify_shell "$_td/zshshebang")"

cat >"$_td/pyshebang" <<'EOF'
#!/usr/bin/env python3
print("hi")
EOF
_assert_eq "classify: python shebang → unknown" "unknown" "$(_classify_shell "$_td/pyshebang")"

cat >"$_td/noshebang" <<'EOF'
hello
EOF
_assert_eq "classify: no shebang → unknown" "unknown" "$(_classify_shell "$_td/noshebang")"

# Regression: binary files must not leak null bytes through the
# `first=$(head -n1 ...)` command substitution. Classifier should
# short-circuit to `unknown` with zero warnings on stderr.
printf '\x7fELF\x02\x01\x01\x00%.0s' {1..10} >"$_td/binary"
set +e
_stderr=$(_classify_shell "$_td/binary" 2>&1 >/dev/null)
result=$(_classify_shell "$_td/binary" 2>/dev/null)
set -e
_assert_eq "classify: binary → unknown" "unknown" "$result"
_assert_not_contains "classify: binary emits no null-byte warning" "null byte" "$_stderr"

# ---------------------------------------------------------------------------
# Tests: no-op for missing/empty input
# ---------------------------------------------------------------------------

echo "=== No-op edge cases ==="

rc=0
"$AUTOFORMAT" "" || rc=$?
_assert_exit "empty arg: exits 0" 0 "$rc"

rc=0
"$AUTOFORMAT" "/nonexistent/file.py" || rc=$?
_assert_exit "missing file: exits 0" 0 "$rc"

rc=0
"$AUTOFORMAT" || rc=$?
_assert_exit "no args: exits 0" 0 "$rc"

# Multi-file rejection: silently dropping arg2+ would hide data loss
# (caller thinks all files were formatted). Exit 2 = usage error.
cat >"$_td/a.py" <<'EOF'
x=1
EOF
cat >"$_td/b.py" <<'EOF'
y=2
EOF
set +e
output=$("$AUTOFORMAT" "$_td/a.py" "$_td/b.py" 2>&1)
rc=$?
set -e
_assert_exit "multi-file args: exits 2" 2 "$rc"
_assert_contains "multi-file args: prints error" "expected a single file path" "$output"

# ---------------------------------------------------------------------------
# Tests: required tools
# ---------------------------------------------------------------------------

echo "=== Required tools ==="

_noyq_bin=$(_mock_bin)
ln -s "$(command -v bash)" "$_noyq_bin/bash"

set +e
output=$(PATH="$_noyq_bin" "$AUTOFORMAT" "$_td/test.py" 2>&1)
rc=$?
set -e
_assert_exit "missing yq: exits 1" 1 "$rc"
_assert_contains "missing yq: prints error" "autoformat: yq is required" "$output"

# ---------------------------------------------------------------------------
# Tests: formatter failures are surfaced
# ---------------------------------------------------------------------------

echo "=== Formatter failures ==="

_mockbin=$(_mock_bin)
cat >"$_mockbin/shfmt" <<'EOF'
#!/usr/bin/env bash
echo "mock shfmt parse error" >&2
exit 2
EOF
chmod +x "$_mockbin/shfmt"

cat >"$_td/fail.sh" <<'EOF'
#!/bin/bash
if true; then
echo "hello"
fi
EOF
cp "$_td/fail.sh" "$_td/fail.sh.orig"

set +e
output=$(PATH="$_mockbin:$PATH" "$AUTOFORMAT" "$_td/fail.sh" 2>&1)
rc=$?
set -e
_assert_exit "formatter failure: autoformat still exits 0" 0 "$rc"
_assert_contains "formatter failure: prints stderr" "mock shfmt parse error" "$output"
_assert_eq "formatter failure: file left unchanged" "$(cat "$_td/fail.sh.orig")" "$(cat "$_td/fail.sh")"

# ---------------------------------------------------------------------------
# Tests: AUTOFORMAT_DIR override
# ---------------------------------------------------------------------------

echo "=== AUTOFORMAT_DIR override ==="

_custom_cfg=$(_tmpdir)
cat >"$_custom_cfg/shfmt.toml" <<'EOF'
indent = 4
EOF
cat >"$_td/custom.sh" <<'EOF'
#!/bin/bash
if true; then
echo "hello"
fi
EOF
AUTOFORMAT_DIR="$_custom_cfg" "$AUTOFORMAT" "$_td/custom.sh"
_assert_contains "custom config dir: 4-space" "    echo" "$(cat "$_td/custom.sh")"

# ---------------------------------------------------------------------------
# Tests: missing config dir gracefully falls back to tool defaults
# ---------------------------------------------------------------------------

echo "=== Missing config dir ==="

cat >"$_td/noconfig.sh" <<'EOF'
#!/bin/bash
if true; then
echo "hello"
fi
EOF
AUTOFORMAT_DIR="/nonexistent/path" "$AUTOFORMAT" "$_td/noconfig.sh"
# shfmt default is tabs when no config
_assert_contains "no config dir: shfmt uses tabs" "	echo" "$(cat "$_td/noconfig.sh")"

# ---------------------------------------------------------------------------
# Tests: relative paths terminate (regression for _has_config loop on ".")
# ---------------------------------------------------------------------------

echo "=== Relative paths ==="

_reldir=$(_tmpdir)
cat >"$_reldir/rel.py" <<'EOF'
x=1
EOF
set +e
output=$(cd "$_reldir" && _with_timeout 10 "$AUTOFORMAT" rel.py 2>&1)
rc=$?
set -e
_assert_exit "rel py: terminates (no infinite loop)" 0 "$rc"
_assert_contains "rel py: formatted via relative path" "x = 1" "$(cat "$_reldir/rel.py")"

cat >"$_reldir/rel.cpp" <<'EOF'
int main(){int x=0;}
EOF
set +e
cd "$_reldir" && _with_timeout 10 "$AUTOFORMAT" rel.cpp
rc=$?
cd - >/dev/null
set -e
_assert_exit "rel cpp: terminates" 0 "$rc"
_assert_contains "rel cpp: formatted via relative path" "  int x" "$(cat "$_reldir/rel.cpp")"

cat >"$_reldir/rel.sh" <<'EOF'
#!/bin/bash
if true; then
echo "hello"
fi
EOF
set +e
cd "$_reldir" && _with_timeout 10 "$AUTOFORMAT" rel.sh
rc=$?
cd - >/dev/null
set -e
_assert_exit "rel sh: terminates" 0 "$rc"
_assert_contains "rel sh: formatted via relative path" "  echo" "$(cat "$_reldir/rel.sh")"

cat >"$_reldir/rel.lua" <<'EOF'
if true then
print("hi")
end
EOF
set +e
cd "$_reldir" && _with_timeout 10 "$AUTOFORMAT" rel.lua
rc=$?
cd - >/dev/null
set -e
_assert_exit "rel lua: terminates" 0 "$rc"
_assert_contains "rel lua: formatted via relative path" "  print" "$(cat "$_reldir/rel.lua")"

# ---------------------------------------------------------------------------
# Summary
# ---------------------------------------------------------------------------

_test_summary

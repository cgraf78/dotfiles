#!/usr/bin/env bash
# claude-hook-notification — Notification hook.
# Audible alert on permission prompts and other attention requests.
# Base logic runs first, then delegates to -work variant if present.

set -u

# --- Audible alert ---
term-notify-sound 2>/dev/null || true

# --- Delegate to work variant if present ---
work_variant=$(command -v claude-hook-notification-work 2>/dev/null)
[ -n "$work_variant" ] && [ -x "$work_variant" ] && exec "$work_variant"

exit 0

#!/usr/bin/env bash
# ds-test — unit tests for the ds dev-session launcher.
#
# Creates temp directories to simulate $HOME and tests internal functions
# in isolation. Mocks tmux to avoid real session management.
#
# Usage: ds-test

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

# shellcheck source=../../.config/dot/test-helpers.sh
. "$HOME/.config/dot/test-helpers.sh"

# ---------------------------------------------------------------------------
# Setup: override HOME, source ds for internal functions
# ---------------------------------------------------------------------------

TEST_HOME=$(_tmpdir)
export HOME="$TEST_HOME"
export CONF_DIR="$TEST_HOME/.config/ds"
mkdir -p "$CONF_DIR"

# Create a minimal profile for testing
cat > "$CONF_DIR/profile-dev.sh" <<'PROFILE'
_profile_dev() {
    local session="$1" chatbot="$2" dir="$3"
    : # no-op for testing
}
PROFILE

cat > "$CONF_DIR/profile-orc.sh" <<'PROFILE'
_profile_orc() {
    local session="$1" dir="$3"
    : # no-op for testing
}
PROFILE

export DS_SOURCED=1
export DS_UPTERM_PRIVATE_KEY="$TEST_HOME/.ssh/test_upterm_key"
mkdir -p "$TEST_HOME/.ssh"
printf 'dummy' > "$DS_UPTERM_PRIVATE_KEY"
# shellcheck source=ds
. "$SCRIPT_DIR/ds"

# Create a mock tmux in a temp bin dir and prepend to PATH
MOCK_BIN=$(_tmpdir)
TMUX_LOG="$MOCK_BIN/tmux.log"

cat > "$MOCK_BIN/tmux" <<'MOCK'
#!/usr/bin/env bash
# Mock tmux that logs calls and simulates responses
echo "tmux $*" >> "${TMUX_LOG:-/dev/null}"
args=("$@")
case "${args[0]:-}" in
    has-session)
        # Check MOCK_SESSIONS for existence
        session="${args[2]#=}"  # strip = prefix
        if [[ " ${MOCK_SESSIONS:-} " == *" $session "* ]]; then
            exit 0
        else
            exit 1
        fi
        ;;
    ls)
        echo "${MOCK_TMUX_LS:-}" | grep -v '^$' || true
        ;;
    set-environment)
        # Track DS_MANAGED sessions: set-environment -t <session> DS_MANAGED 1
        if [[ "${args[3]:-}" == "DS_MANAGED" ]]; then
            export MOCK_DS_MANAGED="${MOCK_DS_MANAGED:-} ${args[2]}"
        fi
        exit 0
        ;;
    show-environment)
        # show-environment -t =<session> DS_MANAGED
        _se_name="${args[2]#=}"
        if [[ " ${MOCK_DS_MANAGED:-} " == *" $_se_name "* ]]; then
            echo "DS_MANAGED=1"
            exit 0
        else
            exit 1
        fi
        ;;
    display-message)
        # display-message -t =<session> -p '<format>'
        echo "1 windows (detached)"
        exit 0
        ;;
    new-session|attach|switch-client|kill-session|rename-window|split-window|new-window|select-window|send-keys)
        exit 0
        ;;
esac
MOCK
chmod +x "$MOCK_BIN/tmux"

cat > "$MOCK_BIN/upterm" <<'MOCK'
#!/usr/bin/env bash
echo "upterm $*" >> "${TMUX_LOG:-/dev/null}"
if [[ "$1" == "host" ]]; then
  printf '%s\n' "${MOCK_UPTERM_INFO:-ssh session: ssh test@upterm.example\nssh session read only: ssh ro@test.upterm.example\nweb session: https://upterm.example/test\nweb session read only: https://ro.upterm.example/test}"
  # Keep background process alive briefly if launched with & so kill -0 works.
  sleep "${MOCK_UPTERM_SLEEP:-1}"
  exit 0
fi
exit 0
MOCK
chmod +x "$MOCK_BIN/upterm"

export PATH="$MOCK_BIN:$PATH"
export TMUX_LOG

_reset_tmux_log() {
    : > "$TMUX_LOG"
}

_tmux_log() {
    cat "$TMUX_LOG" 2>/dev/null || true
}

# ---------------------------------------------------------------------------
# Tests: Host config lookup
# ---------------------------------------------------------------------------

echo "=== Host config lookup ==="

cat > "$CONF_DIR/hosts" <<'EOF'
# hostname    connect   chatbot   dir
clark2        -         argus     ~
nas           autossh   argus     ~
EOF

# Reset globals before each lookup test
_reset_lookup() {
    CONNECT="ssh"
    CHATBOT="claude"
    DIR="$HOME"
}

_reset_lookup
lookup_host "clark2"
_assert_eq "clark2: connect method" "-" "$CONNECT"
_assert_eq "clark2: chatbot" "argus" "$CHATBOT"
_assert_eq "clark2: dir expands ~" "$HOME" "$DIR"

_reset_lookup
lookup_host "nas"
_assert_eq "nas: connect method" "autossh" "$CONNECT"
_assert_eq "nas: chatbot" "argus" "$CHATBOT"

# Unknown host returns failure, doesn't change globals
_reset_lookup
if lookup_host "unknown-host"; then
    _fail "unknown host should return 1"
else
    _pass "unknown host returns 1"
fi
_assert_eq "unknown host: connect unchanged" "ssh" "$CONNECT"

# Glob pattern matching in hosts file
cat > "$CONF_DIR/hosts-work" <<'EOF'
dev*          et        claude    ~/fbsource
cgrafdev      autossh   claude    ~/fbsource
EOF

_reset_lookup
lookup_host "dev2"
_assert_eq "glob dev*: connect" "et" "$CONNECT"
_assert_eq "glob dev*: chatbot" "claude" "$CHATBOT"
_assert_contains "glob dev*: dir" "fbsource" "$DIR"

# First match wins (dev* before cgrafdev in file order, but cgrafdev is
# in a separate file — hosts is searched before hosts-work)
_reset_lookup
lookup_host "cgrafdev"
_assert_eq "cgrafdev: connect (hosts-work)" "autossh" "$CONNECT"

# Multiple hosts files are searched (additive)
_reset_lookup
lookup_host "clark2"
_assert_eq "clark2 still found with hosts-work present" "-" "$CONNECT"

rm -f "$CONF_DIR/hosts-work"

# No hosts files at all
rm -f "$CONF_DIR/hosts"
_reset_lookup
if lookup_host "anyhost"; then
    _fail "no hosts files should return 1"
else
    _pass "no hosts files returns 1"
fi

# Restore hosts for remaining tests
cat > "$CONF_DIR/hosts" <<'EOF'
# hostname    connect   chatbot   dir
clark2        -         argus     ~
nas           autossh   argus     ~
server1       ssh       claude    ~/projects
EOF

# ---------------------------------------------------------------------------
# Tests: Profile discovery
# ---------------------------------------------------------------------------

echo ""
echo "=== Profile discovery ==="

result=$(_profiles)
_assert_contains "discovers bare profile" "bare" "$result"
_assert_contains "discovers dev profile" "dev" "$result"
_assert_contains "discovers orc profile" "orc" "$result"

# ---------------------------------------------------------------------------
# Tests: Profile validation
# ---------------------------------------------------------------------------

echo ""
echo "=== Profile validation ==="

PROFILE="bare"
# _validate_profile calls exit on failure, so run in subshell
if (PROFILE="bare"; _validate_profile) 2>/dev/null; then
    _pass "bare profile validates"
else
    _fail "bare profile validates"
fi

if (PROFILE="dev"; _validate_profile) 2>/dev/null; then
    _pass "dev profile validates"
else
    _fail "dev profile validates"
fi

result=$( (PROFILE="nonexistent"; _validate_profile) 2>&1 || true)
_assert_contains "invalid profile error mentions name" "nonexistent" "$result"
_assert_contains "invalid profile lists valid options" "bare" "$result"

# ---------------------------------------------------------------------------
# Tests: Upterm sharing backend
# ---------------------------------------------------------------------------

echo ""
echo "=== Upterm sharing backend ==="

# With the daemon model, --share-via upterm starts a background daemon even
# with --no-attach. The daemon calls setsid + upterm host, but with mock
# upterm it won't produce an admin socket, so _start_upterm_daemon times out.
# We test the daemon start separately. Here we verify the core tmux behavior.

_reset_tmux_log
export MOCK_SESSIONS=""
export MOCK_DS_MANAGED=""
PROFILE="bare"
NAME_OVERRIDE=""
DIR="$HOME"
DS_SHARE_VIA=""
DS_NO_ATTACH=1
DS_SHARE_INFO_FILE="$(_default_share_info_file)"
DS_UPTERM_PID_FILE="$(_default_upterm_pid_file)"
result=$(_do_session 2>&1)
log=$(_tmux_log)
_assert_contains "no-attach: creates tmux session" "tmux new-session -d -s ds" "$log"
if echo "$log" | grep -qx 'tmux attach -t =ds'; then
    _fail "no-attach: skips local attach"
else
    _pass "no-attach: skips local attach"
fi

# Test --share action with existing session
_reset_tmux_log
export MOCK_SESSIONS="ds"
DS_SHARE_VIA=""
SHARE_TARGET="ds"
# _do_share calls _start_upterm_daemon which needs real upterm; just verify
# it checks for the session first
result=$(_do_share 2>&1) || true
_assert_not_contains "share action: no 'no session' error for existing session" "no session" "$result"

# Test --share action with nonexistent session
_reset_tmux_log
export MOCK_SESSIONS=""
SHARE_TARGET="nonexistent"
result=$(_do_share 2>&1) || true
_assert_contains "share action: error for nonexistent session" "no session" "$result"

# Test --unshare action (no daemon running)
result=$(_do_unshare 2>&1)
_assert_contains "unshare: reports not sharing" "not currently sharing" "$result"

# Test normalization of upterm host output variants (e.g., WSL fallback log parse)
result=$(_normalize_share_info upterm $'Command: ssh token123@uptermd.upterm.dev')
_assert_contains "normalize upterm: command format" "ssh: ssh token123@uptermd.upterm.dev" "$result"

# Test reading share info directly from upterm log fallback
log_file="$(_tmpdir)/upterm.log"
printf '%s\n' 'Some startup text' 'Command: ssh abc123@uptermd.upterm.dev' > "$log_file"
result=$(_read_share_info_from_upterm_log "$log_file")
_assert_contains "log fallback: extracts ssh command" "ssh: ssh abc123@uptermd.upterm.dev" "$result"

# Test PID validation — _upterm_running rejects non-numeric PID files
pid_dir=$(_tmpdir)
DS_UPTERM_PID_FILE="$pid_dir/test.pid"

echo "not-a-pid" > "$DS_UPTERM_PID_FILE"
if _upterm_running; then
    _fail "upterm_running: rejects non-numeric PID"
else
    _pass "upterm_running: rejects non-numeric PID"
fi

echo "12345; rm -rf /" > "$DS_UPTERM_PID_FILE"
if _upterm_running; then
    _fail "upterm_running: rejects PID with injection"
else
    _pass "upterm_running: rejects PID with injection"
fi

echo "" > "$DS_UPTERM_PID_FILE"
if _upterm_running; then
    _fail "upterm_running: rejects empty PID"
else
    _pass "upterm_running: rejects empty PID"
fi

rm -f "$DS_UPTERM_PID_FILE"
if _upterm_running; then
    _fail "upterm_running: rejects missing PID file"
else
    _pass "upterm_running: rejects missing PID file"
fi

# Reset sharing vars for remaining tmux tests
DS_SHARE_VIA=""
DS_NO_ATTACH=0
DS_SHARE_INFO_FILE=""
DS_UPTERM_PID_FILE=""
SHARE_TARGET=""

# ---------------------------------------------------------------------------
# Tests: Session naming
# ---------------------------------------------------------------------------

echo ""
echo "=== Session naming ==="

# --name sets the exact session name; profile doesn't affect the name.
# Default (no --name) → session "ds".

_reset_tmux_log
export MOCK_SESSIONS=""
export MOCK_DS_MANAGED=""
PROFILE="bare"
NAME_OVERRIDE=""
DIR="$HOME"
_do_session
log=$(_tmux_log)
_assert_contains "no name → session 'ds'" "new-session -d -s ds" "$log"
_assert_contains "tags session with DS_MANAGED" "set-environment -t ds DS_MANAGED 1" "$log"

_reset_tmux_log
export MOCK_DS_MANAGED=""
PROFILE="dev"
NAME_OVERRIDE=""
_do_session
log=$(_tmux_log)
_assert_contains "dev profile, no name → session 'ds'" "new-session -d -s ds" "$log"

_reset_tmux_log
export MOCK_DS_MANAGED=""
PROFILE="bare"
NAME_OVERRIDE="myproject"
_do_session
log=$(_tmux_log)
_assert_contains "name=myproject → session 'myproject'" "new-session -d -s myproject" "$log"

_reset_tmux_log
export MOCK_DS_MANAGED=""
PROFILE="dev"
NAME_OVERRIDE="work"
_do_session
log=$(_tmux_log)
_assert_contains "dev + name=work → session 'work'" "new-session -d -s work" "$log"

# ---------------------------------------------------------------------------
# Tests: Existing session attachment
# ---------------------------------------------------------------------------

echo ""
echo "=== Session attachment ==="

# When session exists, _do_session should attach instead of creating
_reset_tmux_log
export MOCK_SESSIONS="ds"
PROFILE="bare"
NAME_OVERRIDE=""
unset TMUX 2>/dev/null || true
_do_session
log=$(_tmux_log)
_assert_contains "existing session: attaches" "attach -t =ds" "$log"
_assert_not_contains "existing session: no new-session" "new-session" "$log"

# Inside tmux: switch-client instead of attach
_reset_tmux_log
export TMUX="/tmp/tmux-test/default,12345,0"
_do_session
log=$(_tmux_log)
_assert_contains "inside tmux: switch-client" "switch-client -t =ds" "$log"
_assert_not_contains "inside tmux: no attach" "attach -t" "$log"
unset TMUX

# ---------------------------------------------------------------------------
# Tests: List sessions
# ---------------------------------------------------------------------------

echo ""
echo "=== List sessions ==="

export MOCK_TMUX_LS="myproject
work
other-session"
export MOCK_DS_MANAGED=" myproject work"

result=$(_do_list)
_assert_contains "list shows managed session myproject" "myproject:" "$result"
_assert_contains "list shows managed session work" "work:" "$result"
_assert_not_contains "list excludes unmanaged session" "other-session" "$result"

export MOCK_TMUX_LS="only-unmanaged"
export MOCK_DS_MANAGED=""
result=$(_do_list)
_assert_contains "no managed sessions shows message" "no active ds sessions" "$result"

export MOCK_TMUX_LS=""
export MOCK_DS_MANAGED=""
result=$(_do_list)
_assert_contains "empty list shows message" "no active ds sessions" "$result"

# ---------------------------------------------------------------------------
# Tests: Kill session
# ---------------------------------------------------------------------------

echo ""
echo "=== Kill session ==="

# Kill with explicit target
_reset_tmux_log
export MOCK_SESSIONS="myproject"
KILL_TARGET="myproject"
result=$(_do_kill)
log=$(_tmux_log)
_assert_contains "kill explicit: kills target" "kill-session -t =myproject" "$log"
_assert_contains "kill explicit: reports killed" "killed myproject" "$result"

# Kill without target errors
export MOCK_SESSIONS=""
export MOCK_TMUX_LS=""
export MOCK_DS_MANAGED=""
KILL_TARGET=""
result=$( (_do_kill) 2>&1 || true)
_assert_contains "kill no target: requires session name" "session name required" "$result"

# Kill nonexistent session
export MOCK_SESSIONS=""
export MOCK_TMUX_LS=""
KILL_TARGET="nosuch"
result=$( (_do_kill) 2>&1 || true)
_assert_contains "kill nonexistent: error message" "no session 'nosuch'" "$result"

# ---------------------------------------------------------------------------
# Tests: Kill all sessions
# ---------------------------------------------------------------------------

echo ""
echo "=== Kill all sessions ==="

export MOCK_TMUX_LS="myproject
work
other-session"
export MOCK_DS_MANAGED=" myproject work"
_reset_tmux_log
result=$(_do_killall)
log=$(_tmux_log)
_assert_contains "killall: kills myproject" "kill-session -t =myproject" "$log"
_assert_contains "killall: kills work" "kill-session -t =work" "$log"
_assert_not_contains "killall: skips unmanaged" "kill-session -t =other-session" "$log"

export MOCK_TMUX_LS="unmanaged-only"
export MOCK_DS_MANAGED=""
_reset_tmux_log
result=$(_do_killall)
_assert_contains "killall no managed: shows message" "no active ds sessions" "$result"

export MOCK_TMUX_LS=""
export MOCK_DS_MANAGED=""
result=$(_do_killall)
_assert_contains "killall empty: shows message" "no active ds sessions" "$result"

# ---------------------------------------------------------------------------
# Tests: Usage
# ---------------------------------------------------------------------------

echo ""
echo "=== Usage ==="

result=$(_usage)
_assert_contains "usage shows -p" "-p" "$result"
_assert_contains "usage shows -l" "-l" "$result"
_assert_contains "usage shows -k" "-k" "$result"
_assert_contains "usage shows --share-via" "--share-via" "$result"
_assert_contains "usage shows --share" "--share" "$result"
_assert_contains "usage shows --unshare" "--unshare" "$result"

# ---------------------------------------------------------------------------
# Tests: Argument parsing (via subprocess)
# ---------------------------------------------------------------------------

echo ""
echo "=== Argument parsing ==="

# Run ds as a subprocess with mock tmux. We test that the right tmux
# commands are invoked based on CLI args.

# Reset state for subprocess tests
export HOME="$TEST_HOME"
export MOCK_SESSIONS=""
export MOCK_TMUX_LS=""
unset DS_SOURCED

# -l flag → list action
export MOCK_TMUX_LS="ds"
export MOCK_DS_MANAGED=" ds"
result=$("$SCRIPT_DIR/ds" -l 2>&1)
_assert_contains "ds -l: lists sessions" "ds:" "$result"
export MOCK_TMUX_LS=""
export MOCK_DS_MANAGED=""

# --help flag → usage
result=$("$SCRIPT_DIR/ds" -h 2>&1)
_assert_contains "ds -h: shows usage" "-p" "$result"

# Invalid flag → error + usage
result=$("$SCRIPT_DIR/ds" --invalid 2>&1 || true)
_assert_contains "ds --invalid: shows usage" "-p" "$result"

# -l with no sessions
result=$("$SCRIPT_DIR/ds" -l 2>&1)
_assert_contains "ds -l empty: shows message" "no active ds sessions" "$result"

# -k with nonexistent session
result=$("$SCRIPT_DIR/ds" -k nosuch 2>&1 || true)
_assert_contains "ds -k nosuch: error" "no session" "$result"

# -k without session name requires a target
result=$("$SCRIPT_DIR/ds" -k 2>&1 || true)
_assert_contains "ds -k (no target): requires session name" "session name required" "$result"

# --killall with no sessions
result=$("$SCRIPT_DIR/ds" --killall 2>&1)
_assert_contains "ds --killall empty: shows message" "no active ds sessions" "$result"

# Restore DS_SOURCED for remaining in-process tests
export DS_SOURCED=1

# ---------------------------------------------------------------------------
# Tests: Profile function invocation
# ---------------------------------------------------------------------------

echo ""
echo "=== Profile function invocation ==="

# _do_session calls _profile_<PROFILE> after creating the session.
# Verify the profile function is actually invoked by checking tmux log
# for calls that only the profile function would make.

# Define a test profile that makes a distinctive tmux call
_profile_testprofile() {
    local session="$1" chatbot="$2" dir="$3"
    tmux rename-window -t "$session:1" "TEST_MARKER_$chatbot"
}

_reset_tmux_log
export MOCK_SESSIONS=""
export MOCK_DS_MANAGED=""
PROFILE="testprofile"
NAME_OVERRIDE=""
CHATBOT="testbot"
DIR="$HOME"
_do_session
log=$(_tmux_log)
_assert_contains "profile function invoked" "TEST_MARKER_testbot" "$log"

# ---------------------------------------------------------------------------
# Tests: _attach behavior
# ---------------------------------------------------------------------------

echo ""
echo "=== Attach behavior ==="

# Outside tmux: uses attach
_reset_tmux_log
unset TMUX 2>/dev/null || true
_attach "test-session"
log=$(_tmux_log)
_assert_contains "outside tmux: attach" "attach -t =test-session" "$log"

# Inside tmux: uses switch-client
_reset_tmux_log
export TMUX="/tmp/tmux-test/default,12345,0"
_attach "test-session"
log=$(_tmux_log)
_assert_contains "inside tmux: switch-client" "switch-client -t =test-session" "$log"
unset TMUX

# ---------------------------------------------------------------------------
# Tests: Host dir expansion
# ---------------------------------------------------------------------------

echo ""
echo "=== Host dir expansion ==="

cat > "$CONF_DIR/hosts" <<'EOF'
server1       ssh       claude    ~/projects
server2       et        claude    /opt/data
EOF

_reset_lookup
lookup_host "server1"
_assert_eq "tilde expanded" "$HOME/projects" "$DIR"

_reset_lookup
lookup_host "server2"
_assert_eq "absolute dir preserved" "/opt/data" "$DIR"

# Empty dir field — DIR stays at default
cat > "$CONF_DIR/hosts" <<'EOF'
minimal       ssh       claude
EOF
_reset_lookup
lookup_host "minimal"
_assert_eq "missing dir keeps default" "$HOME" "$DIR"

# Restore hosts
cat > "$CONF_DIR/hosts" <<'EOF'
clark2        -         argus     ~
nas           autossh   argus     ~
server1       ssh       claude    ~/projects
EOF

# ---------------------------------------------------------------------------
# Tests: Remote command building
# ---------------------------------------------------------------------------

echo ""
echo "=== Remote command building ==="

# Mock ssh/et/autossh to capture args instead of connecting
cat > "$MOCK_BIN/ssh" <<'MOCK'
#!/usr/bin/env bash
echo "SSH_HOST=$1" > "${REMOTE_LOG:-/dev/null}"
shift  # host
echo "SSH_ARGS=$*" >> "${REMOTE_LOG:-/dev/null}"
MOCK
chmod +x "$MOCK_BIN/ssh"

cat > "$MOCK_BIN/autossh" <<'MOCK'
#!/usr/bin/env bash
echo "AUTOSSH_ARGS=$*" > "${REMOTE_LOG:-/dev/null}"
MOCK
chmod +x "$MOCK_BIN/autossh"

cat > "$MOCK_BIN/x2ssh" <<'MOCK'
#!/usr/bin/env bash
echo "X2SSH_ARGS=$*" > "${REMOTE_LOG:-/dev/null}"
MOCK
chmod +x "$MOCK_BIN/x2ssh"

REMOTE_LOG="$MOCK_BIN/remote.log"
export REMOTE_LOG

# _remote calls exec, which doesn't play well with $() subshells.
# Run each test in a fresh bash process that sources ds.
# Uses timeout (Linux) or gtimeout (macOS/Homebrew) with bash fallback.
_timeout() {
    if command -v timeout >/dev/null 2>&1; then
        timeout "$@"
    elif command -v gtimeout >/dev/null 2>&1; then
        gtimeout "$@"
    else
        # bash-native fallback: run in background, kill after $1 seconds
        local secs="$1"; shift
        "$@" &
        local pid=$!
        ( sleep "$secs"; kill "$pid" 2>/dev/null ) &
        local watchdog=$!
        wait "$pid" 2>/dev/null
        kill "$watchdog" 2>/dev/null
        wait "$watchdog" 2>/dev/null
    fi
}

_run_remote() {
    : > "$REMOTE_LOG"
    local env_args="$1"
    _timeout 3 bash -c "
        export DS_SOURCED=1
        . '$SCRIPT_DIR/ds'
        $env_args _remote
    " 2>&1 || true
}

# Test SSH remote dispatch
result=$(_run_remote "HOST=server1 ACTION=session PROFILE_OVERRIDE=dev \
    CHATBOT_OVERRIDE= DIR_OVERRIDE= NAME_OVERRIDE= CONNECT_OVERRIDE=")
remote_log=$(cat "$REMOTE_LOG" 2>/dev/null || true)
_assert_contains "ssh remote: host" "SSH_HOST=server1" "$remote_log"
_assert_contains "ssh remote: runs ds" "~/.local/bin/ds" "$remote_log"

# Test autossh connection method
result=$(_run_remote "HOST=nas ACTION=session PROFILE_OVERRIDE= \
    CHATBOT_OVERRIDE= DIR_OVERRIDE= NAME_OVERRIDE= CONNECT_OVERRIDE=")
remote_log=$(cat "$REMOTE_LOG" 2>/dev/null || true)
_assert_contains "autossh remote: uses autossh" "AUTOSSH_ARGS=" "$remote_log"

# Test local-only host (connect = "-")
result=$(_run_remote "HOST=clark2 ACTION=session PROFILE_OVERRIDE= \
    CHATBOT_OVERRIDE= DIR_OVERRIDE= NAME_OVERRIDE= CONNECT_OVERRIDE=")
_assert_contains "local-only host: error" "local-only" "$result"

# Test list action on remote
result=$(_run_remote "HOST=server1 ACTION=list PROFILE_OVERRIDE= CONNECT_OVERRIDE=")
remote_log=$(cat "$REMOTE_LOG" 2>/dev/null || true)
_assert_contains "remote list: passes -l" "-l" "$remote_log"

# Test kill action on remote
result=$(_run_remote "HOST=server1 ACTION=kill KILL_TARGET=ds-myproject \
    PROFILE_OVERRIDE= CONNECT_OVERRIDE= NAME_OVERRIDE=")
remote_log=$(cat "$REMOTE_LOG" 2>/dev/null || true)
_assert_contains "remote kill: passes -k" "-k" "$remote_log"
_assert_contains "remote kill: passes target" "ds-myproject" "$remote_log"

# Test name override passed to remote
result=$(_run_remote "HOST=server1 ACTION=session PROFILE_OVERRIDE=dev \
    CHATBOT_OVERRIDE= DIR_OVERRIDE= NAME_OVERRIDE=myname CONNECT_OVERRIDE=")
remote_log=$(cat "$REMOTE_LOG" 2>/dev/null || true)
_assert_contains "remote name: passes -n" "-n" "$remote_log"
_assert_contains "remote name: passes name value" "myname" "$remote_log"

# Test share backend/no-attach passed to remote
result=$(_run_remote "HOST=server1 ACTION=session PROFILE_OVERRIDE=dev \
    CHATBOT_OVERRIDE= DIR_OVERRIDE= NAME_OVERRIDE= CONNECT_OVERRIDE= DS_SHARE_VIA=upterm DS_NO_ATTACH=1")
remote_log=$(cat "$REMOTE_LOG" 2>/dev/null || true)
_assert_contains "remote share backend: passes --share-via" "--share-via" "$remote_log"
_assert_contains "remote share backend: passes upterm" "upterm" "$remote_log"
_assert_contains "remote share backend: passes --no-attach" "--no-attach" "$remote_log"

# ---------------------------------------------------------------------------
# Tests: Hosts file comments and blank lines
# ---------------------------------------------------------------------------

echo ""
echo "=== Edge cases ==="

cat > "$CONF_DIR/hosts" <<'EOF'
# This is a comment

  # Indented comment
host1       ssh       claude    ~

host2       et        claude    ~/work
EOF

_reset_lookup
lookup_host "host1"
_assert_eq "host1 found (blank lines ignored)" "ssh" "$CONNECT"

_reset_lookup
lookup_host "host2"
_assert_eq "host2 found (blank lines ignored)" "et" "$CONNECT"

# Restore hosts
cat > "$CONF_DIR/hosts" <<'EOF'
clark2        -         argus     ~
nas           autossh   argus     ~
server1       ssh       claude    ~/projects
EOF

_test_summary

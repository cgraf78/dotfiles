#!/usr/bin/env bash
# term-notify-sound — Play a terminal notification sound.
# Detects the terminal emulator and uses the appropriate mechanism:
#   WezTerm:  OSC 1337 user var (triggers Glass.aiff via wezterm.on handler)
#   VS Code:  touch a signal file watched by the term-notify-sound extension
#   Other:    standard bell (BEL)
# Wraps OSC in DCS passthrough inside tmux; falls back to the pane's pty
# when /dev/tty is unavailable.

set -u

SIGNAL_DIR="$HOME/.local/state/term-notify"
SIGNAL_FILE="$SIGNAL_DIR/signal"

notify_osc() {
  local val
  val=$(printf 1 | base64)
  if [ -n "${TMUX:-}" ]; then
    # shellcheck disable=SC1003  # \033\\ is an ESC+backslash (ST), not a quote escape
    printf '\ePtmux;\e\033]1337;SetUserVar=term_notify=%s\033\\\e\\' "$val"
  else
    # shellcheck disable=SC1003
    printf '\033]1337;SetUserVar=term_notify=%s\033\\' "$val"
  fi
}

# Detect terminal emulator, even through tmux.
_client_termtype() {
  if [ -n "${TMUX:-}" ]; then
    tmux display-message -p '#{client_termtype}' 2>/dev/null
  else
    echo "${TERM_PROGRAM:-}"
  fi
}

send_tty_notify() {
  # Caller passes the already-resolved client termtype to avoid a
  # redundant `tmux display-message` fork on every notification.
  local ct="${1:-$(_client_termtype)}"

  case "$ct" in
    WezTerm*)
      notify_osc
      ;;
    *)
      # Unknown terminal — try OSC (harmless if ignored) + bell fallback
      notify_osc
      printf '\a'
      ;;
  esac
}

# VS Code: signal via file (no pty interaction needed).
ct=$(_client_termtype)
if [[ "$ct" == xterm.js* ]]; then
  mkdir -p "$SIGNAL_DIR"
  touch "$SIGNAL_FILE"
elif (send_tty_notify "$ct" >/dev/tty) 2>/dev/null; then
  : # sent directly
elif [ -n "${TMUX:-}" ] && [ -n "${TMUX_PANE:-}" ]; then
  pane_tty=$(tmux display-message -t "${TMUX_PANE}" -p '#{pane_tty}' 2>/dev/null)
  if [ -n "$pane_tty" ]; then
    send_tty_notify "$ct" >"$pane_tty" 2>/dev/null || true
  fi
fi

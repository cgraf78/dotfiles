_DEPS=("hook-test|custom")
mkdir -p "$TEST_HOME/.config/dot/deps-hooks.d"
cat >"$TEST_HOME/.config/dot/deps-hooks.d/hook-test.sh" <<'HOOK'
post() {
  echo "CUSTOM_HOOK_RAN" > "$HOME/.custom-hook-result"
}
HOOK
_run_post_hooks

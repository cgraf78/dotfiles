#!/usr/bin/env bash
# dotbootstrap-test — unit tests for the dotbootstrap machine bootstrapper.
#
# Tests functions in isolation by sourcing with DOTBOOTSTRAP_SOURCED=1,
# and tests arg validation via subprocess.
#
# Usage: dotbootstrap-test

set -euo pipefail
export NO_COLOR=1

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

# shellcheck source=../../.config/dot/test-helpers.sh
. "$HOME/.config/dot/test-helpers.sh"

# ---------------------------------------------------------------------------
# Setup: mock HOME with bare repo structure
# ---------------------------------------------------------------------------

_mock_home

# Create a bare repo to serve as .dotfiles
DOTFILES="$TEST_HOME/.dotfiles"
git init --bare "$DOTFILES" >/dev/null 2>&1
GIT="git --git-dir=$DOTFILES --work-tree=$TEST_HOME"
$GIT config user.email "test@test.com"
$GIT config user.name "Test"

# Seed the repo with tracked files so we have a branch
echo "initial" >"$TEST_HOME/.testrc"
mkdir -p "$TEST_HOME/.config/dot"
echo "# placeholder" >"$TEST_HOME/.config/dot/placeholder"
$GIT add .testrc .config/dot/placeholder
$GIT commit -m "initial" >/dev/null 2>&1

# Source shared helpers and dotbootstrap functions (without running main logic)
# shellcheck source=../../.config/dot/init.sh
. "$REAL_HOME/.config/dot/init.sh"
WORK_DIR="$TEST_HOME/.dotfiles-work"
BACKUP="$TEST_HOME/.dotfiles-backup/test"
BRANCH=""
declare _name _method _cmd _cmd_alt _pkg_overrides _repo _platforms
export DOTBOOTSTRAP_SOURCED=1
# shellcheck source=dotbootstrap
. "$SCRIPT_DIR/dotbootstrap"

# ---------------------------------------------------------------------------
# Tests: _detect_branch
# ---------------------------------------------------------------------------

echo "=== Branch detection ==="

# Priority 1: DOTFILES_BRANCH env var
BRANCH=""
DOTFILES_BRANCH="custom-branch"
_detect_branch
_assert_eq "env var override" "custom-branch" "$BRANCH"
unset DOTFILES_BRANCH

# Priority 2: current local branch in bare repo
BRANCH=""
_detect_branch
DEFAULT_BRANCH=$($GIT branch --show-current 2>/dev/null || echo "master")
_assert_eq "current local branch" "$DEFAULT_BRANCH" "$BRANCH"

# Priority 3: origin/HEAD fallback
ORIGIN_BARE=$(_tmpdir)
git clone --bare "$DOTFILES" "$ORIGIN_BARE" >/dev/null 2>&1
$GIT remote add origin "$ORIGIN_BARE" 2>/dev/null || $GIT remote set-url origin "$ORIGIN_BARE"
$GIT fetch origin >/dev/null 2>&1
$GIT remote set-head origin "$DEFAULT_BRANCH" 2>/dev/null || true

# Detach HEAD so current branch is empty, forcing origin/HEAD fallback
$GIT checkout --detach HEAD 2>/dev/null || true
BRANCH=""
_detect_branch
_assert_eq "origin/HEAD fallback" "$DEFAULT_BRANCH" "$BRANCH"

# Priority 4: fallback to "main" when nothing else works
$GIT remote remove origin 2>/dev/null || true
BRANCH=""
_detect_branch
_assert_eq "fallback to main" "main" "$BRANCH"

# Re-attach to branch for remaining tests
$GIT checkout "$DEFAULT_BRANCH" 2>/dev/null || $GIT checkout -b main 2>/dev/null

# ---------------------------------------------------------------------------
# Tests: merge-wezterm
# ---------------------------------------------------------------------------

echo ""
echo "=== WezTerm merge ==="

# Source the real merge-wezterm script from the repo under test.
# It should copy ~/.wezterm.lua into the Windows home when running under WSL.
# Use a test-only Windows-home override so we don't depend on the host environment.
# shellcheck disable=SC1091  # sourced via repo-relative test path
. "$SCRIPT_DIR/../../.config/dot/merge-hooks.d/50-wezterm.sh"

WEZ_HOME=$(_tmpdir)
WEZ_WIN_HOME=$(_tmpdir)
if [[ "$(uname -s)" == "Linux" ]]; then
  # Run in a subshell so HOME/WSL_DISTRO_NAME/USER changes don't leak.
  (
    # shellcheck disable=SC2030  # intentionally scoped to the subshell
    export HOME="$WEZ_HOME"
    export WSL_DISTRO_NAME="archlinux"
    # shellcheck disable=SC2030  # intentionally scoped to the subshell
    export USER="chris"
    export DOT_TEST_WINDOWS_HOME="$WEZ_WIN_HOME"
    mkdir -p "$HOME/.config/wezterm"
    echo "return { test = true }" >"$HOME/.config/wezterm/wezterm.lua"
    merge
  )

  _assert_file_exists "merge wezterm: created Windows-home file under WSL" "$WEZ_WIN_HOME/.wezterm.lua"
  _assert_file_content "merge wezterm: copied file content" "return { test = true }" "$WEZ_WIN_HOME/.wezterm.lua"

  # Non-WSL Linux should be a no-op.
  rm -f "$WEZ_WIN_HOME/.wezterm.lua"
  (
    # shellcheck disable=SC2031  # previous subshell mutation is intentionally not reused
    export HOME="$WEZ_HOME"
    unset WSL_DISTRO_NAME
    # shellcheck disable=SC2031  # previous subshell mutation is intentionally not reused
    export USER="chris"
    merge
  )
  _assert_file_missing "merge wezterm: no-op on non-WSL Linux" "$WEZ_WIN_HOME/.wezterm.lua"
else
  echo "  SKIP: merge wezterm WSL-specific assertions (non-Linux runner)"
fi

# ---------------------------------------------------------------------------
# Tests: _dep_load
# ---------------------------------------------------------------------------

echo ""
echo "=== Dep registry loading ==="

# Valid deps.conf
mkdir -p "$TEST_HOME/.config/dot"
cat >"$TEST_HOME/.config/dot/deps.conf" <<'CONF'
# comment line
jq    pkg

bat   pkg   bat   batcat
test-tool  git   test-tool   -   -   fixture/test-tool.git   .local/share/test-tool
CONF

_dep_load
_assert_eq "dep_load: correct count" "3" "${#_DEPS[@]}"

# Missing deps.conf
rm "$TEST_HOME/.config/dot/deps.conf"
result=$(_dep_load 2>&1)
_assert_contains "dep_load: warns on missing file" "not found" "$result"
# _dep_load sets _DEPS=() at start, but the warning test ran in a subshell.
# Call again in the current shell to verify the array is cleared.
_dep_load 2>/dev/null
_assert_eq "dep_load: empty array on missing" "0" "${#_DEPS[@]}"

# Restore for later tests
cat >"$TEST_HOME/.config/dot/deps.conf" <<'CONF'
jq    pkg
bat   pkg   bat   batcat
test-tool  git   test-tool   -   -   fixture/test-tool.git   .local/share/test-tool
CONF

# ---------------------------------------------------------------------------
# Tests: _dep_parse
# ---------------------------------------------------------------------------

echo ""
echo "=== Dep registry parsing ==="

# Full entry with all fields
_dep_parse "fd|pkg|fd|fdfind|apt:fd-find,dnf:fd-find||"
# shellcheck disable=SC2154  # globals assigned by _dep_parse
_assert_eq "dep_parse: name" "fd" "$_name"
_assert_eq "dep_parse: method" "pkg" "$_method"
_assert_eq "dep_parse: cmd" "fd" "$_cmd"
_assert_eq "dep_parse: cmd_alt" "fdfind" "$_cmd_alt"
_assert_eq "dep_parse: pkg_overrides" "apt:fd-find,dnf:fd-find" "$_pkg_overrides"

# Dash fields default to empty, cmd defaults to name
_dep_parse "cfg-pack|git|-|-|-|example/cfg-pack.git|.local/share/cfg-pack"
_assert_eq "dep_parse: cmd defaults to name" "cfg-pack" "$_cmd"
_assert_eq "dep_parse: dash becomes empty" "" "$_cmd_alt"
_assert_eq "dep_parse: repo" "example/cfg-pack.git" "$_repo"
_assert_eq "dep_parse: dir" ".local/share/cfg-pack" "$_dir"

# Minimal entry (just name and method)
_dep_parse "jq|pkg"
_assert_eq "dep_parse: minimal name" "jq" "$_name"
_assert_eq "dep_parse: minimal cmd defaults" "jq" "$_cmd"
_assert_eq "dep_parse: minimal empty fields" "" "$_repo"

# Platforms column
_dep_parse "tool|pkg|-|-|-|-|-|linux,darwin"
_assert_eq "dep_parse: platforms" "linux,darwin" "$_platforms"

_dep_parse "tool|pkg|-|-|-|-|-|-"
_assert_eq "dep_parse: dash platforms" "" "$_platforms"

_dep_parse "tool|pkg"
_assert_eq "dep_parse: omitted platforms" "" "$_platforms"

# ---------------------------------------------------------------------------
# Tests: _platform_match
# ---------------------------------------------------------------------------

echo ""
echo "=== Platform matching ==="

# Empty spec matches everything
rc=0
_platform_match "" || rc=$?
_assert_exit "platform: empty matches all" 0 "$rc"

# Detect current platform for conditional assertions
_current_platform=$(uname -s | tr '[:upper:]' '[:lower:]')
_is_wsl && _current_platform="wsl"

# Include: current platform listed
rc=0
_platform_match "$_current_platform" || rc=$?
_assert_exit "platform: include current" 0 "$rc"

# Include: current platform not listed
if [[ "$_current_platform" == "darwin" ]]; then
  rc=0
  _platform_match "linux" || rc=$?
  _assert_exit "platform: exclude by omission" 1 "$rc"
else
  rc=0
  _platform_match "darwin" || rc=$?
  _assert_exit "platform: exclude by omission" 1 "$rc"
fi

# Exclude: current platform excluded
rc=0
_platform_match "!$_current_platform" || rc=$?
_assert_exit "platform: exclude current" 1 "$rc"

# Exclude: other platform excluded (should match)
if [[ "$_current_platform" == "darwin" ]]; then
  rc=0
  _platform_match "!linux" || rc=$?
  _assert_exit "platform: exclude other matches" 0 "$rc"
else
  rc=0
  _platform_match "!darwin" || rc=$?
  _assert_exit "platform: exclude other matches" 0 "$rc"
fi

# Multiple excludes
rc=0
_platform_match "!fakeos1,!fakeos2" || rc=$?
_assert_exit "platform: exclude non-matching" 0 "$rc"

rc=0
_platform_match "!$_current_platform,!fakeos" || rc=$?
_assert_exit "platform: exclude with current" 1 "$rc"

# Include list with multiple platforms
rc=0
_platform_match "$_current_platform,fakeos" || rc=$?
_assert_exit "platform: include list with current" 0 "$rc"

rc=0
_platform_match "fakeos1,fakeos2" || rc=$?
_assert_exit "platform: include list without current" 1 "$rc"

# ---------------------------------------------------------------------------
# Tests: remote-check cache helpers and behavior
# ---------------------------------------------------------------------------

echo ""
echo "=== Remote check cache ==="

XDG_STATE_HOME="$TEST_HOME/.local/state"
export XDG_STATE_HOME
export DOT_DEPS_REMOTE_TTL=3600
declare -gA _DEPS_CHANGED=()

stamp=$(_dep_remote_stamp "helper-tool" "git")
_assert_contains "remote_stamp: uses state dir" "$TEST_HOME/.local/state/dot/deps/helper-tool.git.stamp" "$stamp"

rc=0
_dep_remote_fresh "$stamp" || rc=$?
_assert_exit "remote_fresh: missing stamp is stale" 1 "$rc"

_dep_remote_touch "$stamp"
rc=0
_dep_remote_fresh "$stamp" || rc=$?
_assert_exit "remote_fresh: touched stamp is fresh" 0 "$rc"

export DOT_FORCE=1
rc=0
_dep_remote_fresh "$stamp" || rc=$?
_assert_exit "remote_fresh: force bypasses cache" 1 "$rc"
export DOT_FORCE=0

REMOTE_FIXTURE=$(_tmpdir)
git init --bare "$REMOTE_FIXTURE" >/dev/null 2>&1
REMOTE_SEED=$(_tmpdir)
git clone "$REMOTE_FIXTURE" "$REMOTE_SEED" >/dev/null 2>&1
git -C "$REMOTE_SEED" config user.email "test@test.com"
git -C "$REMOTE_SEED" config user.name "Test"
echo "tool" >"$REMOTE_SEED/README"
git -C "$REMOTE_SEED" add README
git -C "$REMOTE_SEED" commit -m "seed" >/dev/null 2>&1
git -C "$REMOTE_SEED" push >/dev/null 2>&1

GIT_CACHE_INSTALL="$TEST_HOME/.local/share/cache-tool"
mkdir -p "$(dirname "$GIT_CACHE_INSTALL")"
git clone "$REMOTE_FIXTURE" "$GIT_CACHE_INSTALL" >/dev/null 2>&1

REMOTE_CACHE_BIN=$(_tmpdir)
REAL_GIT_BIN=$(command -v git)
GIT_PULL_COUNT="$TEST_HOME/.git-pull-count"
echo 0 >"$GIT_PULL_COUNT"
cat >"$REMOTE_CACHE_BIN/git" <<'EOF'
#!/usr/bin/env bash
pull=0
for arg in "$@"; do
    if [[ "$arg" == "pull" ]]; then
        pull=1
        break
    fi
done
if [[ "$pull" -eq 1 && -n "${DOT_TEST_GIT_PULL_COUNT_FILE:-}" ]]; then
    count=0
    if [[ -f "$DOT_TEST_GIT_PULL_COUNT_FILE" ]]; then
        read -r count < "$DOT_TEST_GIT_PULL_COUNT_FILE" || count=0
    fi
    echo $((count + 1)) > "$DOT_TEST_GIT_PULL_COUNT_FILE"
fi
exec "$DOT_TEST_REAL_GIT" "$@"
EOF
chmod +x "$REMOTE_CACHE_BIN/git"

PATH="$REMOTE_CACHE_BIN:$PATH" \
  DOT_TEST_REAL_GIT="$REAL_GIT_BIN" \
  DOT_TEST_GIT_PULL_COUNT_FILE="$GIT_PULL_COUNT" \
  _install_from_github "cache-tool" "fixture/cache-tool.git" "$GIT_CACHE_INSTALL" >/dev/null 2>&1
PATH="$REMOTE_CACHE_BIN:$PATH" \
  DOT_TEST_REAL_GIT="$REAL_GIT_BIN" \
  DOT_TEST_GIT_PULL_COUNT_FILE="$GIT_PULL_COUNT" \
  _install_from_github "cache-tool" "fixture/cache-tool.git" "$GIT_CACHE_INSTALL" >/dev/null 2>&1
read -r git_pull_count <"$GIT_PULL_COUNT"
_assert_eq "install_from_github: fresh cache skips second pull" "1" "$git_pull_count"

export DOT_FORCE=1
PATH="$REMOTE_CACHE_BIN:$PATH" \
  DOT_TEST_REAL_GIT="$REAL_GIT_BIN" \
  DOT_TEST_GIT_PULL_COUNT_FILE="$GIT_PULL_COUNT" \
  _install_from_github "cache-tool" "fixture/cache-tool.git" "$GIT_CACHE_INSTALL" >/dev/null 2>&1
export DOT_FORCE=0
read -r git_pull_count <"$GIT_PULL_COUNT"
_assert_eq "install_from_github: force bypasses cache" "2" "$git_pull_count"

BIN_DIR="$TEST_HOME/.local/bin"
mkdir -p "$BIN_DIR"
cat >"$BIN_DIR/mockimg" <<'EOF'
#!/usr/bin/env bash
echo "mockimg v1.2.3"
EOF
chmod +x "$BIN_DIR/mockimg"

CURL_CACHE_BIN=$(_tmpdir)
REAL_CURL_BIN=$(command -v curl)
BIN_API_COUNT="$TEST_HOME/.appimg-api-count"
echo 0 >"$BIN_API_COUNT"
_mock_os=$(uname -s | tr '[:upper:]' '[:lower:]')
_mock_arch=$(uname -m)
cat >"$CURL_CACHE_BIN/curl" <<EOF
#!/usr/bin/env bash
if [[ "\$*" == *"/releases/latest"* ]]; then
    count=0
    if [[ -f "\$DOT_TEST_CURL_API_COUNT_FILE" ]]; then
        read -r count < "\$DOT_TEST_CURL_API_COUNT_FILE" || count=0
    fi
    echo \$((count + 1)) > "\$DOT_TEST_CURL_API_COUNT_FILE"
    printf '%s\n' '{"tag_name":"v1.2.3","assets":[{"browser_download_url":"https://example.com/mockimg-${_mock_os}-${_mock_arch}"}]}'
    exit 0
fi
# Handle HEAD requests (asset URL existence check)
if [[ "\$*" == *"--head"* ]]; then
    exit 0
fi
out=""
while [[ "\$#" -gt 0 ]]; do
    if [[ "\$1" == "-o" && "\$#" -ge 2 ]]; then
        out="\$2"
        break
    fi
    shift
done
if [[ -n "\$out" ]]; then
    printf '%s\n' '#!/usr/bin/env bash' 'echo "mockimg v1.2.3"' > "\$out"
    exit 0
fi
exec "\$DOT_TEST_REAL_CURL" "\$@"
EOF
chmod +x "$CURL_CACHE_BIN/curl"

PATH="$CURL_CACHE_BIN:$BIN_DIR:$PATH" \
  DOT_TEST_REAL_CURL="$REAL_CURL_BIN" \
  DOT_TEST_CURL_API_COUNT_FILE="$BIN_API_COUNT" \
  _install_binary "mockapp" "mockimg" "fixture/mockapp" >/dev/null 2>&1
PATH="$CURL_CACHE_BIN:$BIN_DIR:$PATH" \
  DOT_TEST_REAL_CURL="$REAL_CURL_BIN" \
  DOT_TEST_CURL_API_COUNT_FILE="$BIN_API_COUNT" \
  _install_binary "mockapp" "mockimg" "fixture/mockapp" >/dev/null 2>&1
read -r bin_api_count <"$BIN_API_COUNT"
_assert_eq "install_binary: fresh cache skips second API check" "1" "$bin_api_count"

export DOT_FORCE=1
PATH="$CURL_CACHE_BIN:$BIN_DIR:$PATH" \
  DOT_TEST_REAL_CURL="$REAL_CURL_BIN" \
  DOT_TEST_CURL_API_COUNT_FILE="$BIN_API_COUNT" \
  _install_binary "mockapp" "mockimg" "fixture/mockapp" >/dev/null 2>&1
export DOT_FORCE=0
read -r bin_api_count <"$BIN_API_COUNT"
_assert_eq "install_binary: force bypasses cache" "2" "$bin_api_count"

# Tarball extraction: when only .tar.gz assets are available, _install_binary
# should download the tarball, extract it, and find the binary inside.
TAR_BIN_DIR=$(_tmpdir)
mkdir -p "$TAR_BIN_DIR/.local/bin"
TAR_CURL_BIN=$(_tmpdir)

# Build a real .tar.gz containing a nested binary and runtime files
# (mimics neovim's layout: top-dir/bin/nvim + top-dir/share/...)
TAR_STAGING=$(_tmpdir)
mkdir -p "$TAR_STAGING/mocktool-${_mock_os}-${_mock_arch}/bin"
mkdir -p "$TAR_STAGING/mocktool-${_mock_os}-${_mock_arch}/share/mocktool/runtime"
cat >"$TAR_STAGING/mocktool-${_mock_os}-${_mock_arch}/bin/mocktool" <<'TOOL'
#!/usr/bin/env bash
echo "mocktool v2.0.0"
TOOL
chmod +x "$TAR_STAGING/mocktool-${_mock_os}-${_mock_arch}/bin/mocktool"
echo "runtime-data" >"$TAR_STAGING/mocktool-${_mock_os}-${_mock_arch}/share/mocktool/runtime/init.lua"
TAR_FILE="$TAR_STAGING/mocktool.tar.gz"
tar czf "$TAR_FILE" -C "$TAR_STAGING" "mocktool-${_mock_os}-${_mock_arch}"

cat >"$TAR_CURL_BIN/curl" <<EOF
#!/usr/bin/env bash
if [[ "\$*" == *"/releases/latest"* ]]; then
    printf '%s\n' '{"tag_name":"v2.0.0","assets":[{"browser_download_url":"https://example.com/mocktool-${_mock_os}-${_mock_arch}.tar.gz"}]}'
    exit 0
fi
out=""
while [[ "\$#" -gt 0 ]]; do
    if [[ "\$1" == "-o" && "\$#" -ge 2 ]]; then
        out="\$2"
        break
    fi
    shift
done
if [[ -n "\$out" ]]; then
    cp "$TAR_FILE" "\$out"
    exit 0
fi
exit 1
EOF
chmod +x "$TAR_CURL_BIN/curl"

export DOT_FORCE=1
HOME="$TAR_BIN_DIR" \
  PATH="$TAR_CURL_BIN:$PATH" \
  DOT_TEST_REAL_CURL="$REAL_CURL_BIN" \
  _install_binary "mocktool" "mocktool" "fixture/mocktool" >/dev/null 2>&1
export DOT_FORCE=0

_assert_file_exists "install_binary tarball: symlink created" "$TAR_BIN_DIR/.local/bin/mocktool"
if [[ -L "$TAR_BIN_DIR/.local/bin/mocktool" ]]; then
  _pass "install_binary tarball: is a symlink"
else
  _fail "install_binary tarball: is a symlink"
fi
_assert_file_exists "install_binary tarball: full tree in share" "$TAR_BIN_DIR/.local/share/mocktool/share/mocktool/runtime/init.lua"
_assert_file_content "install_binary tarball: runtime data intact" "runtime-data" "$TAR_BIN_DIR/.local/share/mocktool/share/mocktool/runtime/init.lua"
tar_result=$("$TAR_BIN_DIR/.local/bin/mocktool" 2>&1)
_assert_eq "install_binary tarball: binary runs" "mocktool v2.0.0" "$tar_result"

# Custom hooks should not be due again immediately after a successful run.
rc=0
_dep_hook_due "nerd-fonts" || rc=$?
_assert_exit "hook_due: custom hook initially due" 0 "$rc"
_dep_hook_touch "nerd-fonts"
rc=0
_dep_hook_due "nerd-fonts" || rc=$?
_assert_exit "hook_due: touched hook is skipped" 1 "$rc"
export DOT_FORCE=1
rc=0
_dep_hook_due "nerd-fonts" || rc=$?
_assert_exit "hook_due: force bypasses hook cache" 0 "$rc"
export DOT_FORCE=0

LOCAL_CLONE_NAME="local-tool"
LOCAL_CLONE_DIR="$TEST_HOME/git/$LOCAL_CLONE_NAME"
mkdir -p "$TEST_HOME/git"
git clone "$REMOTE_FIXTURE" "$LOCAL_CLONE_DIR" >/dev/null 2>&1
git -C "$LOCAL_CLONE_DIR" config user.email "test@test.com"
git -C "$LOCAL_CLONE_DIR" config user.name "Test"
LOCAL_INSTALL_DIR="$TEST_HOME/.local/share/$LOCAL_CLONE_NAME"
unset "_DEPS_CHANGED[$LOCAL_CLONE_NAME]" 2>/dev/null || true
_install_from_github "$LOCAL_CLONE_NAME" "fixture/${LOCAL_CLONE_NAME}.git" "$LOCAL_INSTALL_DIR" >/dev/null 2>&1
if [[ -n "${_DEPS_CHANGED[$LOCAL_CLONE_NAME]+x}" ]]; then
  _pass "install_from_github: first local clone marks changed"
else
  _fail "install_from_github: first local clone marks changed"
fi
unset "_DEPS_CHANGED[$LOCAL_CLONE_NAME]" 2>/dev/null || true
_install_from_github "$LOCAL_CLONE_NAME" "fixture/${LOCAL_CLONE_NAME}.git" "$LOCAL_INSTALL_DIR" >/dev/null 2>&1
if [[ -n "${_DEPS_CHANGED[$LOCAL_CLONE_NAME]+x}" ]]; then
  _fail "install_from_github: steady local clone skips changed marker"
else
  _pass "install_from_github: steady local clone skips changed marker"
fi
echo "tool 2" >"$LOCAL_CLONE_DIR/README"
git -C "$LOCAL_CLONE_DIR" add README
git -C "$LOCAL_CLONE_DIR" commit -m "local update" >/dev/null 2>&1
unset "_DEPS_CHANGED[$LOCAL_CLONE_NAME]" 2>/dev/null || true
_install_from_github "$LOCAL_CLONE_NAME" "fixture/${LOCAL_CLONE_NAME}.git" "$LOCAL_INSTALL_DIR" >/dev/null 2>&1
if [[ -n "${_DEPS_CHANGED[$LOCAL_CLONE_NAME]+x}" ]]; then
  _pass "install_from_github: local clone revision change marks changed"
else
  _fail "install_from_github: local clone revision change marks changed"
fi
echo "tool 3" >"$LOCAL_CLONE_DIR/README"
unset "_DEPS_CHANGED[$LOCAL_CLONE_NAME]" 2>/dev/null || true
_install_from_github "$LOCAL_CLONE_NAME" "fixture/${LOCAL_CLONE_NAME}.git" "$LOCAL_INSTALL_DIR" >/dev/null 2>&1
if [[ -n "${_DEPS_CHANGED[$LOCAL_CLONE_NAME]+x}" ]]; then
  _pass "install_from_github: dirty local clone marks changed"
else
  _fail "install_from_github: dirty local clone marks changed"
fi
git -C "$LOCAL_CLONE_DIR" add README
unset "_DEPS_CHANGED[$LOCAL_CLONE_NAME]" 2>/dev/null || true
_install_from_github "$LOCAL_CLONE_NAME" "fixture/${LOCAL_CLONE_NAME}.git" "$LOCAL_INSTALL_DIR" >/dev/null 2>&1
if [[ -n "${_DEPS_CHANGED[$LOCAL_CLONE_NAME]+x}" ]]; then
  _pass "install_from_github: staged local clone marks changed"
else
  _fail "install_from_github: staged local clone marks changed"
fi
git -C "$LOCAL_CLONE_DIR" reset --hard HEAD >/dev/null 2>&1
echo "extra" >"$LOCAL_CLONE_DIR/EXTRA"
unset "_DEPS_CHANGED[$LOCAL_CLONE_NAME]" 2>/dev/null || true
_install_from_github "$LOCAL_CLONE_NAME" "fixture/${LOCAL_CLONE_NAME}.git" "$LOCAL_INSTALL_DIR" >/dev/null 2>&1
if [[ -n "${_DEPS_CHANGED[$LOCAL_CLONE_NAME]+x}" ]]; then
  _pass "install_from_github: untracked local clone marks changed"
else
  _fail "install_from_github: untracked local clone marks changed"
fi

_DEPS=("fail-hook|custom")
mkdir -p "$TEST_HOME/.config/dot/deps-hooks.d"
cat >"$TEST_HOME/.config/dot/deps-hooks.d/fail-hook.sh" <<'HOOK'
post() { return 1; }
HOOK
declare -gA _DEPS_CHANGED=(["fail-hook"]=1)
rc=0
_dep_hook_due "fail-hook" || rc=$?
_assert_exit "hook_due: failing hook starts due" 0 "$rc"
_run_post_hooks >/dev/null 2>&1
rc=0
_dep_hook_due "fail-hook" || rc=$?
_assert_exit "hook_due: failing hook remains due" 0 "$rc"
rm -f "$TEST_HOME/.config/dot/deps-hooks.d/fail-hook.sh"

# ---------------------------------------------------------------------------
# Tests: _dep_exists
# ---------------------------------------------------------------------------

echo ""
echo "=== Dep existence checks ==="

rc=0
_dep_exists "bash" "" || rc=$?
_assert_exit "dep_exists: present cmd" 0 "$rc"

rc=0
_dep_exists "nonexistent_xyz_123" "bash" || rc=$?
_assert_exit "dep_exists: alt cmd present" 0 "$rc"

rc=0
_dep_exists "nonexistent_xyz_123" "nonexistent_abc_456" || rc=$?
_assert_exit "dep_exists: neither present" 1 "$rc"

rc=0
_dep_exists "" "" || rc=$?
_assert_exit "dep_exists: empty cmd and name" 1 "$rc"

# Package manager fallback — mock brew list
DEP_MOCK_BIN=$(_mock_bin)
export PATH="$DEP_MOCK_BIN:$PATH"
cat >"$DEP_MOCK_BIN/brew" <<'BREW'
#!/bin/bash
# Mock brew: "list <name>" succeeds for "installed-font", fails for others
if [[ "$1" == "list" && "$2" == "installed-font" ]]; then exit 0; fi
exit 1
BREW
chmod +x "$DEP_MOCK_BIN/brew"
# Mock uname for _pkg_detect
cat >"$DEP_MOCK_BIN/uname" <<'UNAME'
#!/bin/bash
echo "Darwin"
UNAME
chmod +x "$DEP_MOCK_BIN/uname"
PATH="$DEP_MOCK_BIN:$PATH" _pkg_detect

rc=0
PATH="$DEP_MOCK_BIN:$PATH" _dep_exists "" "" "installed-font" || rc=$?
_assert_exit "dep_exists: pkg mgr fallback found" 0 "$rc"

rc=0
PATH="$DEP_MOCK_BIN:$PATH" _dep_exists "" "" "not-installed-font" || rc=$?
_assert_exit "dep_exists: pkg mgr fallback not found" 1 "$rc"

# cmd takes priority over pkg manager fallback
rc=0
_dep_exists "bash" "" "not-installed-font" || rc=$?
_assert_exit "dep_exists: cmd found ignores pkg mgr" 0 "$rc"

# ---------------------------------------------------------------------------
# Tests: _pkg_detect
# ---------------------------------------------------------------------------

echo ""
echo "=== Package manager detection ==="

PKG_BIN=$(_tmpdir)
_make_pkg_cmd() {
  echo '#!/usr/bin/env bash' >"$PKG_BIN/$1"
  chmod +x "$PKG_BIN/$1"
}

# All present on macOS → brew wins
_make_pkg_cmd brew
_make_pkg_cmd apt-get
_make_pkg_cmd dnf
_make_pkg_cmd pacman
# Mock uname to return Darwin for brew detection
cat >"$PKG_BIN/uname" <<'UNAME'
#!/bin/bash
echo "Darwin"
UNAME
chmod +x "$PKG_BIN/uname"
PATH="$PKG_BIN" _pkg_detect
_assert_eq "pkg_detect: brew priority (macOS)" "brew" "$_PKG_MGR"

# brew on Linux → skipped, apt wins
rm -f "$PKG_BIN/uname"
PATH="$PKG_BIN" _pkg_detect
_assert_eq "pkg_detect: brew skipped on Linux" "apt" "$_PKG_MGR"

# No brew → apt wins
rm -f "$PKG_BIN/brew"
PATH="$PKG_BIN" _pkg_detect
_assert_eq "pkg_detect: apt priority" "apt" "$_PKG_MGR"

# No brew/apt → dnf wins
rm -f "$PKG_BIN/apt-get"
PATH="$PKG_BIN" _pkg_detect
_assert_eq "pkg_detect: dnf priority" "dnf" "$_PKG_MGR"

# No brew/apt/dnf → pacman wins
rm -f "$PKG_BIN/dnf"
PATH="$PKG_BIN" _pkg_detect
_assert_eq "pkg_detect: pacman priority" "pacman" "$_PKG_MGR"

# None → empty
rm -f "$PKG_BIN/pacman"
PATH="$PKG_BIN" _pkg_detect
_assert_eq "pkg_detect: none available" "" "$_PKG_MGR"

# ---------------------------------------------------------------------------
# Tests: _pkg_resolve
# ---------------------------------------------------------------------------

echo ""
echo "=== Package name resolution ==="

_PKG_MGR="dnf"
result=$(_pkg_resolve "fd" "apt:fd-find,dnf:fd-find")
_assert_eq "pkg_resolve: dnf override" "fd-find" "$result"

_PKG_MGR="brew"
result=$(_pkg_resolve "fd" "apt:fd-find,dnf:fd-find")
_assert_eq "pkg_resolve: no override match" "fd" "$result"

_PKG_MGR="apt"
result=$(_pkg_resolve "fd" "apt:fd-find,dnf:fd-find")
_assert_eq "pkg_resolve: apt override" "fd-find" "$result"

result=$(_pkg_resolve "tmux" "")
_assert_eq "pkg_resolve: empty overrides" "tmux" "$result"

# NONE sentinel — skip on specific platforms
_PKG_MGR="apt"
result=$(_pkg_resolve "myfont" "apt:NONE,dnf:NONE,pacman:NONE")
_assert_eq "pkg_resolve: NONE for apt" "NONE" "$result"

_PKG_MGR="brew"
result=$(_pkg_resolve "myfont" "apt:NONE,dnf:NONE,pacman:NONE")
_assert_eq "pkg_resolve: no NONE for brew" "myfont" "$result"

_PKG_MGR="dnf"
result=$(_pkg_resolve "myfont" "apt:NONE,dnf:NONE,pacman:NONE")
_assert_eq "pkg_resolve: NONE for dnf" "NONE" "$result"

_PKG_MGR="pacman"
result=$(_pkg_resolve "myfont" "apt:NONE,dnf:NONE,pacman:NONE")
_assert_eq "pkg_resolve: NONE for pacman" "NONE" "$result"

# ---------------------------------------------------------------------------
# Tests: _pkg_queue
# ---------------------------------------------------------------------------

echo ""
echo "=== Package queuing ==="

# Stub _pkg_available so tests don't hit real package managers
# shellcheck disable=SC2329,SC2317  # invoked indirectly via _pkg_queue
_pkg_available() { return 0; }

_PKG_MGR="dnf"
_PKG_BATCH=()
# Run in current shell so _PKG_BATCH is modified, capture output via temp file
_pkg_queue "fd" "apt:fd-find,dnf:fd-find" >/tmp/_pkg_queue_out 2>&1
result=$(cat /tmp/_pkg_queue_out)
rm -f /tmp/_pkg_queue_out
_assert_eq "pkg_queue: resolved name in batch" "fd-find" "${_PKG_BATCH[0]}"
_assert_contains "pkg_queue: logs queuing" "queued" "$result"

# NONE override — pkg_queue skips instead of queuing
_PKG_MGR="apt"
_PKG_BATCH=()
_PKG_BATCH_NAMES=()
_pkg_queue "myfont" "apt:NONE" >/tmp/_pkg_queue_out 2>&1
result=$(cat /tmp/_pkg_queue_out)
rm -f /tmp/_pkg_queue_out
_assert_eq "pkg_queue NONE: batch empty" "0" "${#_PKG_BATCH[@]}"
_assert_eq "pkg_queue NONE: silent skip" "" "$result"

# Same dep on brew — should queue normally
_PKG_MGR="brew"
_PKG_BATCH=()
_PKG_BATCH_NAMES=()
_pkg_queue "myfont" "apt:NONE" >/tmp/_pkg_queue_out 2>&1
result=$(cat /tmp/_pkg_queue_out)
rm -f /tmp/_pkg_queue_out
_assert_eq "pkg_queue brew: queued" "1" "${#_PKG_BATCH[@]}"
_assert_eq "pkg_queue brew: correct name" "myfont" "${_PKG_BATCH[0]}"

# Unavailable package — pkg_queue skips with warning
# shellcheck disable=SC2329,SC2317  # invoked indirectly via _pkg_queue
_pkg_available() { return 1; }
_PKG_MGR="apt"
_PKG_BATCH=()
_PKG_BATCH_NAMES=()
_pkg_queue "nosuchpkg" "" >/tmp/_pkg_queue_out 2>&1
result=$(cat /tmp/_pkg_queue_out)
rm -f /tmp/_pkg_queue_out
_assert_eq "pkg_queue unavailable: batch empty" "0" "${#_PKG_BATCH[@]}"
_assert_contains "pkg_queue unavailable: warns" "not available" "$result"
# shellcheck disable=SC2329,SC2317  # invoked indirectly via _pkg_queue
_pkg_available() { return 0; }


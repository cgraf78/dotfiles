rm -f "$TEST_HOME/.custom-hook-result"

# ---------------------------------------------------------------------------
# Tests: deps-hooks.d hook system
# ---------------------------------------------------------------------------

echo ""
echo "=== Hook auto-discovery ==="

# Setup: clean slate with two deps that have hook files
rm -rf "$TEST_HOME/.config/dot/deps-hooks.d"
mkdir -p "$TEST_HOME/.config/dot/deps-hooks.d"
cat >"$TEST_HOME/.config/dot/deps.conf" <<'CONF'
alpha  custom
beta   custom
CONF
_dep_load

# Create hook files for both deps
cat >"$TEST_HOME/.config/dot/deps-hooks.d/alpha.sh" <<'HOOK'
post() { echo "ALPHA" > "$HOME/.alpha-result"; }
status() { return 0; }
HOOK
cat >"$TEST_HOME/.config/dot/deps-hooks.d/beta.sh" <<'HOOK'
post() { echo "BETA" > "$HOME/.beta-result"; }
HOOK

# Source hooks the way _run_post_hooks does, then verify discovery
declare -gA _DEPS_CHANGED=([alpha]=1 [beta]=1)
_run_post_hooks >/dev/null 2>&1
_assert_file_exists "discovery: alpha post() ran" "$TEST_HOME/.alpha-result"
_assert_file_content "discovery: alpha post() output" "ALPHA" "$TEST_HOME/.alpha-result"
_assert_file_exists "discovery: beta post() ran" "$TEST_HOME/.beta-result"
_assert_file_content "discovery: beta post() output" "BETA" "$TEST_HOME/.beta-result"
rm -f "$TEST_HOME/.alpha-result" "$TEST_HOME/.beta-result"

# Status hook ran — functions are unset between files, so verify via side effect
# Re-run with a status hook that creates a marker file
cat >"$TEST_HOME/.config/dot/deps-hooks.d/alpha.sh" <<'HOOK'
post() { echo "ALPHA" > "$HOME/.alpha-result"; }
status() { echo "STATUS_RAN" > "$HOME/.alpha-status"; return 0; }
HOOK
declare -gA _DEPS_CHANGED=([alpha]=1)
_run_post_hooks >/dev/null 2>&1
_assert_file_exists "discovery: status() ran" "$TEST_HOME/.alpha-status"
rm -f "$TEST_HOME/.alpha-result" "$TEST_HOME/.alpha-status"

echo ""
echo "=== Hook isolation ==="

# Create an orphan hook file for a dep NOT in deps.conf
cat >"$TEST_HOME/.config/dot/deps-hooks.d/orphan.sh" <<'HOOK'
post() { echo "ORPHAN" > "$HOME/.orphan-result"; }
HOOK

# Re-run hooks — orphan should NOT be sourced
declare -gA _DEPS_CHANGED=([alpha]=1)
_run_post_hooks >/dev/null 2>&1
_assert_file_missing "isolation: orphan hook not sourced" "$TEST_HOME/.orphan-result"
rm -f "$TEST_HOME/.config/dot/deps-hooks.d/orphan.sh"

echo ""
echo "=== Hook error handling ==="

# Create a hook file with a syntax error
cat >"$TEST_HOME/.config/dot/deps-hooks.d/alpha.sh" <<'HOOK'
post() {
  if [[ true; then echo broken; fi
}
HOOK

# _run_post_hooks should warn but not crash
declare -gA _DEPS_CHANGED=([alpha]=1)
result=$(_run_post_hooks 2>&1) && rc=0 || rc=$?
_assert_exit "error: broken hook file does not crash" 0 "$rc"
_assert_contains "error: broken hook file warns" "warning" "$result"

echo ""
echo "=== Hook syntax (bash -n) ==="

# Verify all real hook files pass syntax check
syntax_ok=1
for f in "$REAL_HOME/.config/dot/deps-hooks.d"/*.sh; do
  if ! bash -n "$f" 2>/dev/null; then
    _fail "syntax: $(basename "$f")"
    syntax_ok=0
  fi
done
if [[ "$syntax_ok" -eq 1 ]]; then
  _pass "syntax: all hook files pass bash -n"
fi


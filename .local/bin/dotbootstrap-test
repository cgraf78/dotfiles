#!/usr/bin/env bash
# dotbootstrap-test — unit tests for the dotbootstrap machine bootstrapper.
#
# Tests functions in isolation by sourcing with DOTBOOTSTRAP_SOURCED=1,
# and tests arg validation via subprocess.
#
# Usage: dotbootstrap-test

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

# shellcheck source=../../.config/dot/test-helpers.sh
. "$HOME/.config/dot/test-helpers.sh"

# ---------------------------------------------------------------------------
# Setup: mock HOME with bare repo structure
# ---------------------------------------------------------------------------

_mock_home

# Create a bare repo to serve as .dotfiles
DOTFILES="$TEST_HOME/.dotfiles"
git init --bare "$DOTFILES" >/dev/null 2>&1
GIT="git --git-dir=$DOTFILES --work-tree=$TEST_HOME"
$GIT config user.email "test@test.com"
$GIT config user.name "Test"

# Seed the repo with tracked files so we have a branch
echo "initial" > "$TEST_HOME/.testrc"
mkdir -p "$TEST_HOME/.config/dot"
echo "# placeholder" > "$TEST_HOME/.config/dot/placeholder"
$GIT add .testrc .config/dot/placeholder
$GIT commit -m "initial" >/dev/null 2>&1

# Source shared helpers and dotbootstrap functions (without running main logic)
# shellcheck source=../../.config/dot/helpers.sh
. "$REAL_HOME/.config/dot/helpers.sh"
WORK_DIR="$TEST_HOME/.dotfiles-work"
BACKUP="$TEST_HOME/.dotfiles-backup/test"
BRANCH=""
export DOTBOOTSTRAP_SOURCED=1
# shellcheck source=dotbootstrap
. "$SCRIPT_DIR/dotbootstrap"

# ---------------------------------------------------------------------------
# Tests: _detect_branch
# ---------------------------------------------------------------------------

echo "=== Branch detection ==="

# Priority 1: DOTFILES_BRANCH env var
BRANCH=""
DOTFILES_BRANCH="custom-branch"
_detect_branch
_assert_eq "env var override" "custom-branch" "$BRANCH"
unset DOTFILES_BRANCH

# Priority 2: current local branch in bare repo
BRANCH=""
_detect_branch
DEFAULT_BRANCH=$($GIT branch --show-current 2>/dev/null || echo "master")
_assert_eq "current local branch" "$DEFAULT_BRANCH" "$BRANCH"

# Priority 3: origin/HEAD fallback
ORIGIN_BARE=$(_tmpdir)
git clone --bare "$DOTFILES" "$ORIGIN_BARE" >/dev/null 2>&1
$GIT remote add origin "$ORIGIN_BARE" 2>/dev/null || $GIT remote set-url origin "$ORIGIN_BARE"
$GIT fetch origin >/dev/null 2>&1
$GIT remote set-head origin "$DEFAULT_BRANCH" 2>/dev/null || true

# Detach HEAD so current branch is empty, forcing origin/HEAD fallback
$GIT checkout --detach HEAD 2>/dev/null || true
BRANCH=""
_detect_branch
_assert_eq "origin/HEAD fallback" "$DEFAULT_BRANCH" "$BRANCH"

# Priority 4: fallback to "main" when nothing else works
$GIT remote remove origin 2>/dev/null || true
BRANCH=""
_detect_branch
_assert_eq "fallback to main" "main" "$BRANCH"

# Re-attach to branch for remaining tests
$GIT checkout "$DEFAULT_BRANCH" 2>/dev/null || $GIT checkout -b main 2>/dev/null


# ---------------------------------------------------------------------------
# Tests: merge-wezterm
# ---------------------------------------------------------------------------

echo ""
echo "=== WezTerm merge ==="

# Source the real merge-wezterm script from the repo under test.
# It should copy ~/.wezterm.lua into the Windows home when running under WSL.
# Use a test-only Windows-home override so we don't depend on the host environment.
# shellcheck source=../.config/dot/merge-wezterm.sh
. "$SCRIPT_DIR/../../.config/dot/merge-wezterm.sh"

WEZ_HOME=$(_tmpdir)
WEZ_WIN_HOME=$(_tmpdir)
if [[ "$(uname -s)" == "Linux" ]]; then
  # Run in a subshell so HOME/WSL_DISTRO_NAME/USER changes don't leak.
  (
    export HOME="$WEZ_HOME"
    export WSL_DISTRO_NAME="archlinux"
    export USER="chris"
    export DOT_TEST_WINDOWS_HOME="$WEZ_WIN_HOME"
    mkdir -p "$HOME/.config/wezterm"
    echo "return { test = true }" > "$HOME/.config/wezterm/wezterm.lua"
    merge_wezterm
  )

  _assert_file_exists "merge_wezterm: created Windows-home file under WSL" "$WEZ_WIN_HOME/.wezterm.lua"
  _assert_file_content "merge_wezterm: copied file content" "return { test = true }" "$WEZ_WIN_HOME/.wezterm.lua"

  # Non-WSL Linux should be a no-op.
  rm -f "$WEZ_WIN_HOME/.wezterm.lua"
  (
    export HOME="$WEZ_HOME"
    unset WSL_DISTRO_NAME
    export USER="chris"
    merge_wezterm
  )
  _assert_file_missing "merge_wezterm: no-op on non-WSL Linux" "$WEZ_WIN_HOME/.wezterm.lua"
else
  echo "  SKIP: merge_wezterm WSL-specific assertions (non-Linux runner)"
fi

# ---------------------------------------------------------------------------
# Tests: _dep_load
# ---------------------------------------------------------------------------

echo ""
echo "=== Dep registry loading ==="

# Valid deps.conf
mkdir -p "$TEST_HOME/.config/dot"
cat > "$TEST_HOME/.config/dot/deps.conf" <<'CONF'
# comment line
jq    pkg

bat   pkg   bat   batcat
test-tool  git   test-tool   -   -   fixture/test-tool.git   .local/share/test-tool
CONF

_dep_load
_assert_eq "dep_load: correct count" "3" "${#_DEPS[@]}"

# Missing deps.conf
rm "$TEST_HOME/.config/dot/deps.conf"
result=$(_dep_load 2>&1)
_assert_contains "dep_load: warns on missing file" "not found" "$result"
# _dep_load sets _DEPS=() at start, but the warning test ran in a subshell.
# Call again in the current shell to verify the array is cleared.
_dep_load 2>/dev/null
_assert_eq "dep_load: empty array on missing" "0" "${#_DEPS[@]}"

# Restore for later tests
cat > "$TEST_HOME/.config/dot/deps.conf" <<'CONF'
jq    pkg
bat   pkg   bat   batcat
test-tool  git   test-tool   -   -   fixture/test-tool.git   .local/share/test-tool
CONF

# ---------------------------------------------------------------------------
# Tests: _dep_parse
# ---------------------------------------------------------------------------

echo ""
echo "=== Dep registry parsing ==="

# Full entry with all fields
_dep_parse "fd|pkg|fd|fdfind|apt:fd-find,dnf:fd-find||"
_assert_eq "dep_parse: name" "fd" "$_name"
_assert_eq "dep_parse: method" "pkg" "$_method"
_assert_eq "dep_parse: cmd" "fd" "$_cmd"
_assert_eq "dep_parse: cmd_alt" "fdfind" "$_cmd_alt"
_assert_eq "dep_parse: pkg_overrides" "apt:fd-find,dnf:fd-find" "$_pkg_overrides"

# Dash fields default to empty, cmd defaults to name
_dep_parse "cfg-pack|git|-|-|-|example/cfg-pack.git|.local/share/cfg-pack"
_assert_eq "dep_parse: cmd defaults to name" "cfg-pack" "$_cmd"
_assert_eq "dep_parse: dash becomes empty" "" "$_cmd_alt"
_assert_eq "dep_parse: repo" "example/cfg-pack.git" "$_repo"
_assert_eq "dep_parse: dir" ".local/share/cfg-pack" "$_dir"

# Minimal entry (just name and method)
_dep_parse "jq|pkg"
_assert_eq "dep_parse: minimal name" "jq" "$_name"
_assert_eq "dep_parse: minimal cmd defaults" "jq" "$_cmd"
_assert_eq "dep_parse: minimal empty fields" "" "$_repo"

# ---------------------------------------------------------------------------
# Tests: _dep_exists
# ---------------------------------------------------------------------------

echo ""
echo "=== Dep existence checks ==="

rc=0; _dep_exists "bash" "" || rc=$?
_assert_exit "dep_exists: present cmd" 0 "$rc"

rc=0; _dep_exists "nonexistent_xyz_123" "bash" || rc=$?
_assert_exit "dep_exists: alt cmd present" 0 "$rc"

rc=0; _dep_exists "nonexistent_xyz_123" "nonexistent_abc_456" || rc=$?
_assert_exit "dep_exists: neither present" 1 "$rc"

rc=0; _dep_exists "" "" || rc=$?
_assert_exit "dep_exists: empty cmd" 1 "$rc"

# ---------------------------------------------------------------------------
# Tests: _pkg_detect
# ---------------------------------------------------------------------------

echo ""
echo "=== Package manager detection ==="

PKG_BIN=$(_tmpdir)
_make_pkg_cmd() {
    echo '#!/usr/bin/env bash' > "$PKG_BIN/$1"
    chmod +x "$PKG_BIN/$1"
}

# All present on macOS → brew wins
_make_pkg_cmd brew
_make_pkg_cmd apt-get
_make_pkg_cmd dnf
_make_pkg_cmd pacman
# Mock uname to return Darwin for brew detection
cat > "$PKG_BIN/uname" <<'UNAME'
#!/bin/bash
echo "Darwin"
UNAME
chmod +x "$PKG_BIN/uname"
PATH="$PKG_BIN" _pkg_detect
_assert_eq "pkg_detect: brew priority (macOS)" "brew" "$_PKG_MGR"

# brew on Linux → skipped, apt wins
rm -f "$PKG_BIN/uname"
PATH="$PKG_BIN" _pkg_detect
_assert_eq "pkg_detect: brew skipped on Linux" "apt" "$_PKG_MGR"

# No brew → apt wins
rm -f "$PKG_BIN/brew"
PATH="$PKG_BIN" _pkg_detect
_assert_eq "pkg_detect: apt priority" "apt" "$_PKG_MGR"

# No brew/apt → dnf wins
rm -f "$PKG_BIN/apt-get"
PATH="$PKG_BIN" _pkg_detect
_assert_eq "pkg_detect: dnf priority" "dnf" "$_PKG_MGR"

# No brew/apt/dnf → pacman wins
rm -f "$PKG_BIN/dnf"
PATH="$PKG_BIN" _pkg_detect
_assert_eq "pkg_detect: pacman priority" "pacman" "$_PKG_MGR"

# None → empty
rm -f "$PKG_BIN/pacman"
PATH="$PKG_BIN" _pkg_detect
_assert_eq "pkg_detect: none available" "" "$_PKG_MGR"

# ---------------------------------------------------------------------------
# Tests: _pkg_resolve
# ---------------------------------------------------------------------------

echo ""
echo "=== Package name resolution ==="

_PKG_MGR="dnf"
result=$(_pkg_resolve "fd" "apt:fd-find,dnf:fd-find")
_assert_eq "pkg_resolve: dnf override" "fd-find" "$result"

_PKG_MGR="brew"
result=$(_pkg_resolve "fd" "apt:fd-find,dnf:fd-find")
_assert_eq "pkg_resolve: no override match" "fd" "$result"

_PKG_MGR="apt"
result=$(_pkg_resolve "fd" "apt:fd-find,dnf:fd-find")
_assert_eq "pkg_resolve: apt override" "fd-find" "$result"

result=$(_pkg_resolve "tmux" "")
_assert_eq "pkg_resolve: empty overrides" "tmux" "$result"

# ---------------------------------------------------------------------------
# Tests: _pkg_queue
# ---------------------------------------------------------------------------

echo ""
echo "=== Package queuing ==="

_PKG_MGR="dnf"
_PKG_BATCH=()
# Run in current shell so _PKG_BATCH is modified, capture output via temp file
_pkg_queue "fd" "apt:fd-find,dnf:fd-find" > /tmp/_pkg_queue_out 2>&1
result=$(cat /tmp/_pkg_queue_out)
rm -f /tmp/_pkg_queue_out
_assert_eq "pkg_queue: resolved name in batch" "fd-find" "${_PKG_BATCH[0]}"
_assert_contains "pkg_queue: logs queuing" "queued" "$result"

# ---------------------------------------------------------------------------
# Tests: _pkg_install_batch
# ---------------------------------------------------------------------------

echo ""
echo "=== Batch install ==="

# Empty batch → no-op
_PKG_BATCH=()
_PKG_MGR="dnf"
result=$(_pkg_install_batch 2>&1)
_assert_eq "pkg_batch: empty no-op" "" "$result"

# Cron mode (non-root) → silently skips
_PKG_BATCH=("eza" "tmux")
DOT_QUIET=1
result=$(_pkg_install_batch 2>&1)
_assert_eq "pkg_batch: cron silent skip" "" "$result"
DOT_QUIET=0

# ---------------------------------------------------------------------------
# Tests: _backup_and_checkout
# ---------------------------------------------------------------------------

echo ""
echo "=== Backup and checkout ==="

# Re-add origin so checkout can work
ORIGIN_BARE2=$(_tmpdir)
git clone --bare "$DOTFILES" "$ORIGIN_BARE2" >/dev/null 2>&1
$GIT remote add origin "$ORIGIN_BARE2" 2>/dev/null || $GIT remote set-url origin "$ORIGIN_BARE2"
$GIT fetch origin >/dev/null 2>&1
BRANCH=$($GIT branch --show-current 2>/dev/null || echo "main")

# Create a conflicting file (same path as a repo-tracked file)
echo "local content" > "$TEST_HOME/.testrc"

BACKUP="$TEST_HOME/.dotfiles-backup/test1"
result=$(_backup_and_checkout 2>&1)

_assert_contains "shows backup message" "backed up" "$result"
_assert_contains "shows checkout message" "checking out" "$result"

# Conflicting file was backed up
if [[ -f "$BACKUP/.testrc" ]]; then
    _pass "conflicting file backed up"
    _assert_file_content "backup has original content" "local content" "$BACKUP/.testrc"
else
    _fail "conflicting file backed up"
fi

# Checked-out file restored from repo
_assert_file_exists "repo file restored" "$TEST_HOME/.testrc"
_assert_file_content "restored file has repo content" "initial" "$TEST_HOME/.testrc"

# Untracked file is NOT backed up or removed
echo "untracked" > "$TEST_HOME/untracked_file"
BACKUP="$TEST_HOME/.dotfiles-backup/test2"
_backup_and_checkout >/dev/null 2>&1
_assert_file_missing "untracked file not backed up" "$BACKUP/untracked_file"
_assert_file_content "untracked file untouched" "untracked" "$TEST_HOME/untracked_file"
rm -f "$TEST_HOME/untracked_file"

# Empty backup dir is removed (no conflicts)
rm -f "$TEST_HOME/.testrc" "$TEST_HOME/.config/dot/placeholder"
BACKUP="$TEST_HOME/.dotfiles-backup/test3"
_backup_and_checkout >/dev/null 2>&1
if [[ ! -d "$BACKUP" ]]; then
    _pass "empty backup dir removed"
else
    _fail "empty backup dir removed"
fi

# ---------------------------------------------------------------------------
# Tests: Subprocess — usage errors
# ---------------------------------------------------------------------------

echo ""
echo "=== Usage errors (subprocess) ==="

unset DOTBOOTSTRAP_SOURCED

# No args → no usage error (defaults to personal or work)
result=$("$SCRIPT_DIR/dotbootstrap" 2>&1 || true)
_assert_not_contains "no args: no usage error" "Usage:" "$result"

# Invalid machine type
rc=0
result=$("$SCRIPT_DIR/dotbootstrap" invalid 2>&1) || rc=$?
_assert_exit "invalid type exits 1" 1 "$rc"
_assert_contains "invalid type shows usage" "Usage:" "$result"
_assert_contains "invalid type mentions personal" "personal" "$result"
_assert_contains "invalid type mentions work" "work" "$result"

# Both valid types are accepted (they fail later on git operations,
# but they pass arg validation — verify no usage error)
for mtype in personal work; do
    result=$("$SCRIPT_DIR/dotbootstrap" "$mtype" 2>&1 || true)
    _assert_not_contains "$mtype: passes arg validation" "Usage:" "$result"
done

# ---------------------------------------------------------------------------
# Tests: Full bootstrap flow (subprocess with local repos)
# ---------------------------------------------------------------------------

# Build local repos that stand in for remote origins.
# dotbootstrap supports per-dependency DOTBOOTSTRAP_<NAME>_REPO env var
# overrides so we can point generic fixture deps at these test repos.

_seed_repo() {
    # $1 = bare repo path (will be created)
    # $2 = staging dir (caller populates before calling)
    # Inits bare, clones, commits staging content, pushes.
    local bare="$1" staging="$2"
    git init --bare "$bare" >/dev/null 2>&1
    git clone "$bare" "$staging/.git-tmp" >/dev/null 2>&1
    # Move .git into staging dir
    mv "$staging/.git-tmp/.git" "$staging/.git"
    rm -rf "$staging/.git-tmp"
    git -C "$staging" config user.email "test@test.com"
    git -C "$staging" config user.name "Test"
    git -C "$staging" add -A >/dev/null 2>&1
    git -C "$staging" commit -m "seed" >/dev/null 2>&1
    git -C "$staging" push >/dev/null 2>&1
}

# --- Personal dotfiles origin ---
PERSONAL_STAGING=$(_tmpdir)
mkdir -p "$PERSONAL_STAGING/.config/dot"
echo "bashrc content" > "$PERSONAL_STAGING/.bashrc"

cp "$REAL_HOME/.config/dot/helpers.sh" "$PERSONAL_STAGING/.config/dot/helpers.sh"
cp "$REAL_HOME/.config/dot/deps.sh" "$PERSONAL_STAGING/.config/dot/deps.sh"
cat > "$PERSONAL_STAGING/.config/dot/deps.conf" <<'CONF'
test-tool  git  -  -  -  fixture/test-tool.git  .local/share/test-tool
hook-pack  git  -  -  -  fixture/hook-pack.git  .local/share/hook-pack
CONF
cat > "$PERSONAL_STAGING/.config/dot/deps-hooks.sh" <<'HOOK'
_post_hook_pack() {
  mkdir -p "$HOME/.test-hooks"
  printf '%s\n' "$HOME/.local/share/hook-pack" > "$HOME/.test-hooks/hook-pack"
}
HOOK

cat > "$PERSONAL_STAGING/.config/dot/merge-testapp.sh" <<'MERGE'
merge_testapp() { echo "MERGE_TESTAPP_RAN"; }
MERGE

PERSONAL_ORIGIN=$(_tmpdir)
_seed_repo "$PERSONAL_ORIGIN" "$PERSONAL_STAGING"

# --- Work dotfiles origin ---
WORK_STAGING=$(_tmpdir)
echo "work config" > "$WORK_STAGING/work-config"
cat > "$WORK_STAGING/bootstrap" <<'BOOT'
#!/bin/bash
echo "WORK_BOOTSTRAP_RAN"
BOOT
chmod +x "$WORK_STAGING/bootstrap"

WORK_ORIGIN=$(_tmpdir)
_seed_repo "$WORK_ORIGIN" "$WORK_STAGING"

# --- test tool origin (stub with bin/test-tool) ---
TEST_TOOL_STAGING=$(_tmpdir)
mkdir -p "$TEST_TOOL_STAGING/bin"
echo '#!/bin/bash' > "$TEST_TOOL_STAGING/bin/test-tool"
chmod +x "$TEST_TOOL_STAGING/bin/test-tool"

TEST_TOOL_ORIGIN=$(_tmpdir)
_seed_repo "$TEST_TOOL_ORIGIN" "$TEST_TOOL_STAGING"

# --- hook pack origin (stub content for a generic post-install hook) ---
HOOK_PACK_STAGING=$(_tmpdir)
mkdir -p "$HOOK_PACK_STAGING/review"
echo "# hook pack" > "$HOOK_PACK_STAGING/review/README.md"

HOOK_PACK_ORIGIN=$(_tmpdir)
_seed_repo "$HOOK_PACK_ORIGIN" "$HOOK_PACK_STAGING"

# Helper to run dotbootstrap in a fresh HOME with local repos.
# Pre-clones the personal bare repo (dotbootstrap no longer auto-clones).
# Usage: _run_bootstrap <home> [<machine-type>]
_run_bootstrap() {
    local home="$1"
    shift
    if [[ ! -d "$home/.dotfiles" ]]; then
        git clone --bare "$PERSONAL_ORIGIN" "$home/.dotfiles" >/dev/null 2>&1
    fi
    HOME="$home" \
        DOTBOOTSTRAP_WORK_REPO="$WORK_ORIGIN" \
        DOTBOOTSTRAP_TEST_TOOL_REPO="$TEST_TOOL_ORIGIN" \
        DOTBOOTSTRAP_HOOK_PACK_REPO="$HOOK_PACK_ORIGIN" \
        "$SCRIPT_DIR/dotbootstrap" "$@" 2>&1
}

# ---- Fresh personal install ----

echo ""
echo "=== Fresh install (personal) ==="

FRESH=$(_tmpdir)
result=$(_run_bootstrap "$FRESH" personal)

# Bare repo present (pre-cloned by _run_bootstrap)
if [[ -d "$FRESH/.dotfiles" ]]; then
    _pass "personal: .dotfiles present"
else
    _fail "personal: .dotfiles present"
fi

# Git config applied
_fgit="git --git-dir=$FRESH/.dotfiles --work-tree=$FRESH"
_assert_eq "personal: showUntrackedFiles" "no" "$($_fgit config status.showUntrackedFiles)"
_assert_eq "personal: pull.rebase" "true" "$($_fgit config pull.rebase)"
_assert_contains "personal: json-sort filter" "jq" "$($_fgit config filter.json-sort.clean)"

# Files checked out
_assert_file_exists "personal: .bashrc checked out" "$FRESH/.bashrc"
_assert_file_content "personal: .bashrc content" "bashrc content" "$FRESH/.bashrc"
_assert_file_exists "personal: helpers.sh checked out" "$FRESH/.config/dot/helpers.sh"

# Work repo NOT cloned
if [[ ! -d "$FRESH/.dotfiles-work" ]]; then
    _pass "personal: no work repo"
else
    _fail "personal: no work repo"
fi

# Merge scripts ran
_assert_contains "personal: merge ran" "MERGE_TESTAPP_RAN" "$result"

# Git-based deps installed (validates the general mechanism)
_assert_contains "personal: git deps installed" "installed" "$result"
_assert_file_exists "personal: generic tool installed" "$FRESH/.local/share/test-tool/bin/test-tool"
_assert_file_exists "personal: generic tool linked" "$FRESH/.local/bin/test-tool"
_assert_file_content "personal: generic hook ran" "$FRESH/.local/share/hook-pack" "$FRESH/.test-hooks/hook-pack"

# Done message
_assert_contains "personal: done message" "Done" "$result"
_assert_contains "personal: source bashrc hint" "source ~/.bashrc" "$result"

# ---- Fresh work install ----

echo ""
echo "=== Fresh install (work) ==="

FRESH_WORK=$(_tmpdir)
result=$(_run_bootstrap "$FRESH_WORK" work)

# Personal dotfiles set up
_assert_file_exists "work: .bashrc checked out" "$FRESH_WORK/.bashrc"

# Work repo cloned
if [[ -d "$FRESH_WORK/.dotfiles-work" ]]; then
    _pass "work: work repo cloned"
else
    _fail "work: work repo cloned"
fi
_assert_file_exists "work: work config present" "$FRESH_WORK/.dotfiles-work/work-config"
_assert_contains "work: bootstrap ran" "WORK_BOOTSTRAP_RAN" "$result"

# Done message
_assert_contains "work: done message" "Done" "$result"

# ---- Re-run on existing machine ----

echo ""
echo "=== Re-run (existing setup) ==="

# Run again on the same FRESH_WORK home — should succeed without re-cloning
result=$(_run_bootstrap "$FRESH_WORK" work)

# Should NOT try to clone (repo already exists)
_assert_not_contains "re-run: skips clone" "Cloning personal" "$result"

# Work repo exists → pulls instead of cloning
_assert_contains "re-run: pulls work repo" "Pulling work" "$result"
_assert_not_contains "re-run: no work clone" "Cloning work" "$result"

# Still succeeds
_assert_contains "re-run: done message" "Done" "$result"

# ---- Auto-detect machine type ----

echo ""
echo "=== Auto-detect machine type ==="

# No args + work repo present → defaults to work (pulls work repo)
result=$(_run_bootstrap "$FRESH_WORK")
_assert_contains "auto-detect: work mode" "Pulling work" "$result"
_assert_contains "auto-detect: done" "Done" "$result"

# No args + no work repo → defaults to personal (no work pull)
result=$(_run_bootstrap "$FRESH")
_assert_not_contains "auto-detect: personal mode" "Pulling work" "$result"
_assert_contains "auto-detect: personal done" "Done" "$result"

_test_summary

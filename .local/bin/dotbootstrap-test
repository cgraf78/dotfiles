#!/usr/bin/env bash
# dotbootstrap-test — unit tests for the dotbootstrap machine bootstrapper.
#
# Tests functions in isolation by sourcing with DOTBOOTSTRAP_SOURCED=1,
# and tests arg validation via subprocess.
#
# Usage: dotbootstrap-test

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

# shellcheck source=../../.config/dot/test-helpers.sh
. "$HOME/.config/dot/test-helpers.sh"

# ---------------------------------------------------------------------------
# Setup: mock HOME with bare repo structure
# ---------------------------------------------------------------------------

_mock_home

# Create a bare repo to serve as .dotfiles
DOTFILES="$TEST_HOME/.dotfiles"
git init --bare "$DOTFILES" >/dev/null 2>&1
GIT="git --git-dir=$DOTFILES --work-tree=$TEST_HOME"
$GIT config user.email "test@test.com"
$GIT config user.name "Test"

# Seed the repo with tracked files so we have a branch
echo "initial" > "$TEST_HOME/.testrc"
mkdir -p "$TEST_HOME/.config/dot"
echo "# placeholder" > "$TEST_HOME/.config/dot/placeholder"
$GIT add .testrc .config/dot/placeholder
$GIT commit -m "initial" >/dev/null 2>&1

# Source dotbootstrap functions (without running main logic)
WORK_DIR="$TEST_HOME/.dotfiles-work"
BACKUP="$TEST_HOME/.dotfiles-backup-test"
BRANCH=""
export DOTBOOTSTRAP_SOURCED=1
# shellcheck source=dotbootstrap
. "$SCRIPT_DIR/dotbootstrap"

# ---------------------------------------------------------------------------
# Tests: _detect_branch
# ---------------------------------------------------------------------------

echo "=== Branch detection ==="

# Priority 1: DOTFILES_BRANCH env var
BRANCH=""
DOTFILES_BRANCH="custom-branch"
_detect_branch
_assert_eq "env var override" "custom-branch" "$BRANCH"
unset DOTFILES_BRANCH

# Priority 2: current local branch in bare repo
BRANCH=""
_detect_branch
DEFAULT_BRANCH=$($GIT branch --show-current 2>/dev/null || echo "master")
_assert_eq "current local branch" "$DEFAULT_BRANCH" "$BRANCH"

# Priority 3: origin/HEAD fallback
ORIGIN_BARE=$(_tmpdir)
git clone --bare "$DOTFILES" "$ORIGIN_BARE" >/dev/null 2>&1
$GIT remote add origin "$ORIGIN_BARE" 2>/dev/null || $GIT remote set-url origin "$ORIGIN_BARE"
$GIT fetch origin >/dev/null 2>&1
$GIT remote set-head origin "$DEFAULT_BRANCH" 2>/dev/null || true

# Detach HEAD so current branch is empty, forcing origin/HEAD fallback
$GIT checkout --detach HEAD 2>/dev/null || true
BRANCH=""
_detect_branch
_assert_eq "origin/HEAD fallback" "$DEFAULT_BRANCH" "$BRANCH"

# Priority 4: fallback to "main" when nothing else works
$GIT remote remove origin 2>/dev/null || true
BRANCH=""
_detect_branch
_assert_eq "fallback to main" "main" "$BRANCH"

# Re-attach to branch for remaining tests
$GIT checkout "$DEFAULT_BRANCH" 2>/dev/null || $GIT checkout -b main 2>/dev/null


# ---------------------------------------------------------------------------
# Tests: merge-wezterm
# ---------------------------------------------------------------------------

echo ""
echo "=== WezTerm merge ==="

# Source the real merge-wezterm script from the repo under test.
# It should link ~/.wezterm.lua into the Windows home when running under WSL.
# Use mocked powershell.exe + wslpath so we don't depend on the host environment.
# shellcheck source=../.config/dot/merge-wezterm.sh
. "$SCRIPT_DIR/../../.config/dot/merge-wezterm.sh"

WEZ_HOME=$(_tmpdir)
WEZ_WIN_HOME=$(_tmpdir)
WEZ_BIN=$(_mock_bin)

cat > "$WEZ_BIN/powershell.exe" <<'EOF'
#!/usr/bin/env bash
printf 'C:\\Users\\Chris'
EOF
chmod +x "$WEZ_BIN/powershell.exe"

cat > "$WEZ_BIN/wslpath" <<EOF
#!/usr/bin/env bash
echo "$WEZ_WIN_HOME"
EOF
chmod +x "$WEZ_BIN/wslpath"

# Run in a subshell so HOME/WSL_DISTRO_NAME/USER changes don't leak.
(
  export HOME="$WEZ_HOME"
  export WSL_DISTRO_NAME="archlinux"
  export USER="chris"
  echo "return { test = true }" > "$HOME/.wezterm.lua"
  merge_wezterm
)

if [[ -L "$WEZ_WIN_HOME/.wezterm.lua" ]]; then
  _pass "merge_wezterm: created Windows-home symlink under WSL"
else
  _fail "merge_wezterm: created Windows-home symlink under WSL"
fi

WEZ_LINK_TARGET=$(readlink "$WEZ_WIN_HOME/.wezterm.lua" 2>/dev/null || true)
_assert_eq "merge_wezterm: symlink target" "$WEZ_HOME/.wezterm.lua" "$WEZ_LINK_TARGET"

# Non-WSL Linux should be a no-op.
rm -f "$WEZ_WIN_HOME/.wezterm.lua"
(
  export HOME="$WEZ_HOME"
  unset WSL_DISTRO_NAME
  export USER="chris"
  merge_wezterm
)
_assert_file_missing "merge_wezterm: no-op on non-WSL Linux" "$WEZ_WIN_HOME/.wezterm.lua"

# ---------------------------------------------------------------------------
# Tests: _install_hint
# ---------------------------------------------------------------------------

echo ""
echo "=== Install hints ==="

# _install_hint uses `command -v` to detect package managers.
# Use isolated PATH per test so real system binaries don't interfere.
# command/echo are builtins, so an empty PATH still works for _install_hint.
PKG_BIN=$(_tmpdir)
_make_pkg_cmd() {
    echo '#!/usr/bin/env bash' > "$PKG_BIN/$1"
    chmod +x "$PKG_BIN/$1"
}

# All present → brew wins (highest priority)
_make_pkg_cmd brew
_make_pkg_cmd apt-get
_make_pkg_cmd dnf
_make_pkg_cmd pacman
result=$(PATH="$PKG_BIN" _install_hint "tmux")
_assert_contains "brew hint" "brew install tmux" "$result"

# No brew → apt-get wins
rm -f "$PKG_BIN/brew"
result=$(PATH="$PKG_BIN" _install_hint "tmux")
_assert_contains "apt-get hint" "apt-get" "$result"
_assert_contains "apt-get package" "tmux" "$result"

# No brew/apt-get → dnf wins
rm -f "$PKG_BIN/apt-get"
result=$(PATH="$PKG_BIN" _install_hint "tmux")
_assert_contains "dnf hint" "dnf install" "$result"

# No brew/apt-get/dnf → pacman wins
rm -f "$PKG_BIN/dnf"
result=$(PATH="$PKG_BIN" _install_hint "tmux")
_assert_contains "pacman hint" "pacman" "$result"

# None available → generic message
rm -f "$PKG_BIN/pacman"
result=$(PATH="$PKG_BIN" _install_hint "tmux")
_assert_contains "generic hint" "install" "$result"
_assert_contains "generic pkg name" "tmux" "$result"

# ---------------------------------------------------------------------------
# Tests: _check_dep
# ---------------------------------------------------------------------------

echo ""
echo "=== Dependency checking ==="

# Present command → returns 0, no output
rc=0
result=$(_check_dep "bash" "bash" 2>&1) || rc=$?
_assert_exit "present dep returns 0" 0 "$rc"
_assert_eq "present dep no warning" "" "$result"

# Missing command → returns 1, prints warning
rc=0
result=$(_check_dep "nonexistent_cmd_xyz" "nonexistent" 2>&1) || rc=$?
_assert_exit "missing dep returns 1" 1 "$rc"
_assert_contains "missing dep warning" "missing dependency" "$result"
_assert_contains "missing dep names command" "nonexistent_cmd_xyz" "$result"

# ---------------------------------------------------------------------------
# Tests: _backup_and_checkout
# ---------------------------------------------------------------------------

echo ""
echo "=== Backup and checkout ==="

# Re-add origin so checkout can work
ORIGIN_BARE2=$(_tmpdir)
git clone --bare "$DOTFILES" "$ORIGIN_BARE2" >/dev/null 2>&1
$GIT remote add origin "$ORIGIN_BARE2" 2>/dev/null || $GIT remote set-url origin "$ORIGIN_BARE2"
$GIT fetch origin >/dev/null 2>&1
BRANCH=$($GIT branch --show-current 2>/dev/null || echo "main")

# Create a conflicting file (same path as a repo-tracked file)
echo "local content" > "$TEST_HOME/.testrc"

BACKUP="$TEST_HOME/.dotfiles-backup-test1"
result=$(_backup_and_checkout 2>&1)

_assert_contains "shows backup message" "backing up" "$result"
_assert_contains "shows checkout message" "checking out" "$result"

# Conflicting file was backed up
if [[ -f "$BACKUP/.testrc" ]]; then
    _pass "conflicting file backed up"
    _assert_file_content "backup has original content" "local content" "$BACKUP/.testrc"
else
    _fail "conflicting file backed up"
fi

# Checked-out file restored from repo
_assert_file_exists "repo file restored" "$TEST_HOME/.testrc"
_assert_file_content "restored file has repo content" "initial" "$TEST_HOME/.testrc"

# Untracked file is NOT backed up or removed
echo "untracked" > "$TEST_HOME/untracked_file"
BACKUP="$TEST_HOME/.dotfiles-backup-test2"
_backup_and_checkout >/dev/null 2>&1
_assert_file_missing "untracked file not backed up" "$BACKUP/untracked_file"
_assert_file_content "untracked file untouched" "untracked" "$TEST_HOME/untracked_file"
rm -f "$TEST_HOME/untracked_file"

# Empty backup dir is removed (no conflicts)
rm -f "$TEST_HOME/.testrc" "$TEST_HOME/.config/dot/placeholder"
BACKUP="$TEST_HOME/.dotfiles-backup-test3"
_backup_and_checkout >/dev/null 2>&1
if [[ ! -d "$BACKUP" ]]; then
    _pass "empty backup dir removed"
else
    _fail "empty backup dir removed"
fi

# ---------------------------------------------------------------------------
# Tests: Subprocess — usage errors
# ---------------------------------------------------------------------------

echo ""
echo "=== Usage errors (subprocess) ==="

unset DOTBOOTSTRAP_SOURCED

# No args → usage error
rc=0
result=$("$SCRIPT_DIR/dotbootstrap" 2>&1) || rc=$?
_assert_exit "no args exits 1" 1 "$rc"
_assert_contains "no args shows usage" "Usage:" "$result"

# Invalid machine type
rc=0
result=$("$SCRIPT_DIR/dotbootstrap" invalid 2>&1) || rc=$?
_assert_exit "invalid type exits 1" 1 "$rc"
_assert_contains "invalid type mentions personal" "personal" "$result"
_assert_contains "invalid type mentions work" "work" "$result"

# Both valid types are accepted (they fail later on git operations,
# but they pass arg validation — verify no "error: argument" message)
for mtype in personal work; do
    result=$("$SCRIPT_DIR/dotbootstrap" "$mtype" 2>&1 || true)
    _assert_not_contains "$mtype: passes arg validation" "error: argument" "$result"
done

# ---------------------------------------------------------------------------
# Tests: Full bootstrap flow (subprocess with local repos)
# ---------------------------------------------------------------------------

# Build local repos that stand in for the real GitHub remotes.
# dotbootstrap supports DOTBOOTSTRAP_REPO / _WORK_REPO / _VIMRC_REPO
# env var overrides so we can point it at these.

_seed_repo() {
    # $1 = bare repo path (will be created)
    # $2 = staging dir (caller populates before calling)
    # Inits bare, clones, commits staging content, pushes.
    local bare="$1" staging="$2"
    git init --bare "$bare" >/dev/null 2>&1
    git clone "$bare" "$staging/.git-tmp" >/dev/null 2>&1
    # Move .git into staging dir
    mv "$staging/.git-tmp/.git" "$staging/.git"
    rm -rf "$staging/.git-tmp"
    git -C "$staging" config user.email "test@test.com"
    git -C "$staging" config user.name "Test"
    git -C "$staging" add -A >/dev/null 2>&1
    git -C "$staging" commit -m "seed" >/dev/null 2>&1
    git -C "$staging" push >/dev/null 2>&1
}

# --- Personal dotfiles origin ---
PERSONAL_STAGING=$(_tmpdir)
mkdir -p "$PERSONAL_STAGING/.config/dot"
echo "bashrc content" > "$PERSONAL_STAGING/.bashrc"

cat > "$PERSONAL_STAGING/.config/dot/helpers.sh" <<'HELPERS'
#!/bin/bash
DOTFILES="$HOME/.dotfiles"
GIT="git --git-dir=$DOTFILES --work-tree=$HOME"
WORK_DIR="$HOME/.dotfiles-work"

_pull_work_repo() {
  [[ -d "$WORK_DIR" ]] || return 0
  echo "==> Pulling work dotfiles..."
  git -C "$WORK_DIR" pull || echo "  warning: work pull failed" >&2
  [[ -x "$WORK_DIR/bootstrap" ]] && "$WORK_DIR/bootstrap" || true
}
_push_work_repo() { :; }
_run_merges() {
  for _script in "$HOME/.config/dot"/merge-*.sh; do
    [[ -f "$_script" ]] || continue
    . "$_script"
    _fn="merge_${_script##*merge-}"; _fn="${_fn%.sh}"
    "$_fn" || true
  done
}
HELPERS

cat > "$PERSONAL_STAGING/.config/dot/merge-testapp.sh" <<'MERGE'
merge_testapp() { echo "MERGE_TESTAPP_RAN"; }
MERGE

PERSONAL_ORIGIN=$(_tmpdir)
_seed_repo "$PERSONAL_ORIGIN" "$PERSONAL_STAGING"

# --- Work dotfiles origin ---
WORK_STAGING=$(_tmpdir)
echo "work config" > "$WORK_STAGING/work-config"
cat > "$WORK_STAGING/bootstrap" <<'BOOT'
#!/bin/bash
echo "WORK_BOOTSTRAP_RAN"
BOOT
chmod +x "$WORK_STAGING/bootstrap"

WORK_ORIGIN=$(_tmpdir)
_seed_repo "$WORK_ORIGIN" "$WORK_STAGING"

# --- Vimrc origin ---
VIMRC_STAGING=$(_tmpdir)
cat > "$VIMRC_STAGING/install_awesome_vimrc.sh" <<'VIM'
#!/bin/sh
echo "VIMRC_INSTALLED"
VIM

VIMRC_ORIGIN=$(_tmpdir)
_seed_repo "$VIMRC_ORIGIN" "$VIMRC_STAGING"

# Helper to run dotbootstrap in a fresh HOME with local repos
_run_bootstrap() {
    local home="$1" mtype="$2"
    HOME="$home" \
        DOTBOOTSTRAP_REPO="$PERSONAL_ORIGIN" \
        DOTBOOTSTRAP_WORK_REPO="$WORK_ORIGIN" \
        DOTBOOTSTRAP_VIMRC_REPO="$VIMRC_ORIGIN" \
        "$SCRIPT_DIR/dotbootstrap" "$mtype" 2>&1
}

# ---- Fresh personal install ----

echo ""
echo "=== Fresh install (personal) ==="

FRESH=$(_tmpdir)
result=$(_run_bootstrap "$FRESH" personal)

# Bare repo cloned
if [[ -d "$FRESH/.dotfiles" ]]; then
    _pass "personal: .dotfiles created"
else
    _fail "personal: .dotfiles created"
fi

# Git config applied
_fgit="git --git-dir=$FRESH/.dotfiles --work-tree=$FRESH"
_assert_eq "personal: showUntrackedFiles" "no" "$($_fgit config status.showUntrackedFiles)"
_assert_eq "personal: pull.rebase" "true" "$($_fgit config pull.rebase)"
_assert_contains "personal: json-sort filter" "jq" "$($_fgit config filter.json-sort.clean)"

# Files checked out
_assert_file_exists "personal: .bashrc checked out" "$FRESH/.bashrc"
_assert_file_content "personal: .bashrc content" "bashrc content" "$FRESH/.bashrc"
_assert_file_exists "personal: helpers.sh checked out" "$FRESH/.config/dot/helpers.sh"

# Dependencies checked
_assert_contains "personal: deps checked" "Checking dependencies" "$result"

# Work repo NOT cloned
if [[ ! -d "$FRESH/.dotfiles-work" ]]; then
    _pass "personal: no work repo"
else
    _fail "personal: no work repo"
fi

# Merge scripts ran
_assert_contains "personal: merge ran" "MERGE_TESTAPP_RAN" "$result"

# Vim runtime installed
_assert_file_exists "personal: vim runtime cloned" "$FRESH/.vim_runtime/install_awesome_vimrc.sh"
_assert_contains "personal: vimrc install ran" "VIMRC_INSTALLED" "$result"

# Done message
_assert_contains "personal: done message" "Done" "$result"
_assert_contains "personal: source bashrc hint" "source ~/.bashrc" "$result"

# ---- Fresh work install ----

echo ""
echo "=== Fresh install (work) ==="

FRESH_WORK=$(_tmpdir)
result=$(_run_bootstrap "$FRESH_WORK" work)

# Personal dotfiles set up
_assert_file_exists "work: .bashrc checked out" "$FRESH_WORK/.bashrc"

# Work repo cloned
if [[ -d "$FRESH_WORK/.dotfiles-work" ]]; then
    _pass "work: work repo cloned"
else
    _fail "work: work repo cloned"
fi
_assert_file_exists "work: work config present" "$FRESH_WORK/.dotfiles-work/work-config"
_assert_contains "work: bootstrap ran" "WORK_BOOTSTRAP_RAN" "$result"

# Done message
_assert_contains "work: done message" "Done" "$result"

# ---- Re-run on existing machine ----

echo ""
echo "=== Re-run (existing setup) ==="

# Run again on the same FRESH_WORK home — should succeed without re-cloning
result=$(_run_bootstrap "$FRESH_WORK" work)

# Should NOT try to clone (repo already exists)
_assert_not_contains "re-run: skips clone" "Cloning personal" "$result"

# Should skip vim runtime (already installed)
_assert_not_contains "re-run: skips vimrc" "Installing vim runtime" "$result"

# Work repo exists → pulls instead of cloning
_assert_contains "re-run: pulls work repo" "Pulling work" "$result"
_assert_not_contains "re-run: no work clone" "Cloning work" "$result"

# Still succeeds
_assert_contains "re-run: done message" "Done" "$result"

_test_summary

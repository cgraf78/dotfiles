# Build local repos that stand in for remote origins.
# dotbootstrap supports per-dependency DOTBOOTSTRAP_<NAME>_REPO env var
# overrides so we can point generic fixture deps at these test repos.

_seed_repo() {
  # $1 = bare repo path (will be created)
  # $2 = staging dir (caller populates before calling)
  # Inits bare, clones, commits staging content, pushes.
  local bare="$1" staging="$2"
  git init --bare "$bare" >/dev/null 2>&1
  git clone "$bare" "$staging/.git-tmp" >/dev/null 2>&1
  # Move .git into staging dir
  mv "$staging/.git-tmp/.git" "$staging/.git"
  rm -rf "$staging/.git-tmp"
  git -C "$staging" config user.email "test@test.com"
  git -C "$staging" config user.name "Test"
  git -C "$staging" add -A >/dev/null 2>&1
  git -C "$staging" commit -m "seed" >/dev/null 2>&1
  git -C "$staging" push >/dev/null 2>&1
}

# --- Personal dotfiles origin ---
PERSONAL_STAGING=$(_tmpdir)
mkdir -p "$PERSONAL_STAGING/.config/dot"
echo "bashrc content" >"$PERSONAL_STAGING/.bashrc"

for _f in init.sh core.sh repos.sh merges.sh cron.sh deps.sh; do
  cp "$REAL_HOME/.config/dot/$_f" "$PERSONAL_STAGING/.config/dot/$_f"
done
cat >"$PERSONAL_STAGING/.config/dot/deps.conf" <<'CONF'
test-tool  git  -  -  -  fixture/test-tool.git  .local/share/test-tool
hook-pack  git  -  -  -  fixture/hook-pack.git  .local/share/hook-pack
CONF
mkdir -p "$PERSONAL_STAGING/.config/dot/deps-hooks.d"
cat >"$PERSONAL_STAGING/.config/dot/deps-hooks.d/hook-pack.sh" <<'HOOK'
post() {
  mkdir -p "$HOME/.test-hooks"
  printf '%s\n' "$HOME/.local/share/hook-pack" > "$HOME/.test-hooks/hook-pack"
}
HOOK

mkdir -p "$PERSONAL_STAGING/.config/dot/merge-hooks.d"
cat >"$PERSONAL_STAGING/.config/dot/merge-hooks.d/testapp.sh" <<'MERGE'
merge() { echo "MERGE_TESTAPP_RAN"; }
MERGE

PERSONAL_ORIGIN=$(_tmpdir)
_seed_repo "$PERSONAL_ORIGIN" "$PERSONAL_STAGING"

# --- Work dotfiles origin ---
WORK_STAGING=$(_tmpdir)
echo "work config" >"$WORK_STAGING/work-config"
mkdir -p "$WORK_STAGING/home"
echo "work shell" >"$WORK_STAGING/home/.testrc_work"

WORK_ORIGIN=$(_tmpdir)
_seed_repo "$WORK_ORIGIN" "$WORK_STAGING"

# --- test tool origin (stub with bin/test-tool) ---
TEST_TOOL_STAGING=$(_tmpdir)
mkdir -p "$TEST_TOOL_STAGING/bin"
echo '#!/bin/bash' >"$TEST_TOOL_STAGING/bin/test-tool"
chmod +x "$TEST_TOOL_STAGING/bin/test-tool"

TEST_TOOL_ORIGIN=$(_tmpdir)
_seed_repo "$TEST_TOOL_ORIGIN" "$TEST_TOOL_STAGING"

# --- hook pack origin (stub content for a generic post-install hook) ---
HOOK_PACK_STAGING=$(_tmpdir)
mkdir -p "$HOOK_PACK_STAGING/review"
echo "# hook pack" >"$HOOK_PACK_STAGING/review/README.md"

HOOK_PACK_ORIGIN=$(_tmpdir)
_seed_repo "$HOOK_PACK_ORIGIN" "$HOOK_PACK_STAGING"

# Helper to run dotbootstrap in a fresh HOME with local repos.
# Pre-clones the personal bare repo (dotbootstrap no longer auto-clones).
# Usage: _run_bootstrap <home> [<machine-type>]
_run_bootstrap() {
  local home="$1"
  shift
  if [[ ! -d "$home/.dotfiles" ]]; then
    git clone --bare "$PERSONAL_ORIGIN" "$home/.dotfiles" >/dev/null 2>&1
  fi
  HOME="$home" \
    DOTBOOTSTRAP_WORK_REPO="$WORK_ORIGIN" \
    DOTBOOTSTRAP_TEST_TOOL_REPO="$TEST_TOOL_ORIGIN" \
    DOTBOOTSTRAP_HOOK_PACK_REPO="$HOOK_PACK_ORIGIN" \
    "$SCRIPT_DIR/dotbootstrap" "$@" 2>&1
}

# ---- Fresh personal install ----

echo ""
echo "=== Fresh install (personal) ==="

FRESH=$(_tmpdir)
result=$(_run_bootstrap "$FRESH" personal)

# Bare repo present (pre-cloned by _run_bootstrap)
if [[ -d "$FRESH/.dotfiles" ]]; then
  _pass "personal: .dotfiles present"
else
  _fail "personal: .dotfiles present"
fi

# Git config applied
_fgit="git --git-dir=$FRESH/.dotfiles --work-tree=$FRESH"
_assert_eq "personal: showUntrackedFiles" "no" "$($_fgit config status.showUntrackedFiles)"
_assert_eq "personal: pull.rebase" "true" "$($_fgit config pull.rebase)"
_assert_contains "personal: json-sort filter" "jq" "$($_fgit config filter.json-sort.clean)"

# Files checked out
_assert_file_exists "personal: .bashrc checked out" "$FRESH/.bashrc"
_assert_file_content "personal: .bashrc content" "bashrc content" "$FRESH/.bashrc"
_assert_file_exists "personal: init.sh checked out" "$FRESH/.config/dot/init.sh"

# Work repo NOT cloned
if [[ ! -d "$FRESH/.dotfiles-work" ]]; then
  _pass "personal: no work repo"
else
  _fail "personal: no work repo"
fi

# Merge scripts ran
_assert_contains "personal: merge ran" "MERGE_TESTAPP_RAN" "$result"

# Git-based deps installed (validates the general mechanism)
_assert_contains "personal: git deps installed" "installed" "$result"
_assert_file_exists "personal: generic tool installed" "$FRESH/.local/share/test-tool/bin/test-tool"
_assert_file_exists "personal: generic tool linked" "$FRESH/.local/bin/test-tool"
_assert_file_content "personal: generic hook ran" "$FRESH/.local/share/hook-pack" "$FRESH/.test-hooks/hook-pack"

# Done message
_assert_contains "personal: done message" "Done" "$result"
_assert_contains "personal: shell activation hint" "source ~/.bashrc' or 'source ~/.zshrc" "$result"

# ---- Fresh work install ----

echo ""
echo "=== Fresh install (work) ==="

FRESH_WORK=$(_tmpdir)
result=$(_run_bootstrap "$FRESH_WORK" work)

# Personal dotfiles set up
_assert_file_exists "work: .bashrc checked out" "$FRESH_WORK/.bashrc"

# Work repo cloned

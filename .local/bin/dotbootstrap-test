if [[ -L "$FRESH_WORK/.testrc_work" ]]; then
  _pass "work: symlink created"
else
  _fail "work: symlink created"
fi

# Done message
_assert_contains "work: done message" "Done" "$result"

# ---- Re-run on existing machine ----

echo ""
echo "=== Re-run (existing setup) ==="

# Run again on the same FRESH_WORK home — should succeed without re-cloning
result=$(_run_bootstrap "$FRESH_WORK" work)

# Should NOT try to clone (repo already exists)
_assert_not_contains "re-run: skips clone" "Cloning personal" "$result"

# Work repo exists → pulls instead of cloning
_assert_contains "re-run: pulls work repo" "Pulling work" "$result"
_assert_not_contains "re-run: no work clone" "Cloning work" "$result"

# Still succeeds
_assert_contains "re-run: done message" "Done" "$result"

# ---- Auto-detect machine type ----

echo ""
echo "=== Auto-detect machine type ==="

# No args + work repo present → defaults to work (pulls work repo)
result=$(_run_bootstrap "$FRESH_WORK")
_assert_contains "auto-detect: work mode" "Pulling work" "$result"
_assert_contains "auto-detect: done" "Done" "$result"

# No args + no work repo → defaults to personal (no work pull)
result=$(_run_bootstrap "$FRESH")
_assert_not_contains "auto-detect: personal mode" "Pulling work" "$result"
_assert_contains "auto-detect: personal done" "Done" "$result"

_test_summary

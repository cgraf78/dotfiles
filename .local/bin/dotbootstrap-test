#!/usr/bin/env bash
# dotbootstrap-test — unit tests for the dotbootstrap machine bootstrapper.
#
# Tests functions in isolation by sourcing with DOTBOOTSTRAP_SOURCED=1,
# and tests full bootstrap flow via subprocess with local repos.
#
# Usage: dotbootstrap-test

set -o pipefail
export NO_COLOR=1

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

# shellcheck source=../../.local/lib/dot/test-helpers.sh
. "$HOME/.local/lib/dot/test-helpers.sh"

# ---------------------------------------------------------------------------
# Setup: mock HOME with bare repo structure
# ---------------------------------------------------------------------------

_mock_home

# Export SHDEPS_LIB so subprocess commands find shdeps in the mock HOME
if [[ -f "$REAL_HOME/git/shdeps/shdeps.sh" ]]; then
  export SHDEPS_LIB="$REAL_HOME/git/shdeps/shdeps.sh"
elif [[ -f "$REAL_HOME/.local/share/shdeps/shdeps.sh" ]]; then
  export SHDEPS_LIB="$REAL_HOME/.local/share/shdeps/shdeps.sh"
fi

# Create a bare repo to serve as .dotfiles
DOTFILES="$TEST_HOME/.dotfiles"
git init --bare "$DOTFILES" >/dev/null 2>&1
GIT="git --git-dir=$DOTFILES --work-tree=$TEST_HOME"
$GIT config user.email "test@test.com"
$GIT config user.name "Test"

# Seed the repo with tracked files so we have a branch
echo "initial" >"$TEST_HOME/.testrc"
mkdir -p "$TEST_HOME/.config/dot"
echo "# placeholder" >"$TEST_HOME/.config/dot/placeholder"
$GIT add .testrc .config/dot/placeholder
$GIT commit -m "initial" >/dev/null 2>&1

# Source shared helpers and dotbootstrap functions (without running main logic)
# shellcheck source=../../.local/lib/dot/init.sh
. "$REAL_HOME/.local/lib/dot/init.sh"
_ensure_shdeps
BACKUP="$TEST_HOME/.dotfiles-backup/test"
BRANCH=""
export DOTBOOTSTRAP_SOURCED=1
# shellcheck source=dotbootstrap
. "$SCRIPT_DIR/dotbootstrap"

# ---------------------------------------------------------------------------
# Tests: _detect_branch
# ---------------------------------------------------------------------------

echo "=== Branch detection ==="

# Priority 1: DOTFILES_BRANCH env var — export so shellcheck sees
# it as an external-consumer var rather than flagging SC2034.
BRANCH=""
export DOTFILES_BRANCH="custom-branch"
_detect_branch
_assert_eq "env var override" "custom-branch" "$BRANCH"
unset DOTFILES_BRANCH

# Priority 2: current local branch in bare repo
BRANCH=""
_detect_branch
DEFAULT_BRANCH=$($GIT branch --show-current 2>/dev/null || echo "master")
_assert_eq "current local branch" "$DEFAULT_BRANCH" "$BRANCH"

# Priority 3: origin/HEAD fallback
ORIGIN_BARE=$(_tmpdir)
git clone --bare "$DOTFILES" "$ORIGIN_BARE" >/dev/null 2>&1
$GIT remote add origin "$ORIGIN_BARE" 2>/dev/null || $GIT remote set-url origin "$ORIGIN_BARE"
$GIT fetch origin >/dev/null 2>&1
$GIT remote set-head origin "$DEFAULT_BRANCH" 2>/dev/null || true

# Detach HEAD so current branch is empty, forcing origin/HEAD fallback
$GIT checkout --detach HEAD 2>/dev/null || true
BRANCH=""
_detect_branch
_assert_eq "origin/HEAD fallback" "$DEFAULT_BRANCH" "$BRANCH"

# Priority 4: fallback to "main" when nothing else works
$GIT remote remove origin 2>/dev/null || true
BRANCH=""
_detect_branch
_assert_eq "fallback to main" "main" "$BRANCH"

# Re-attach to branch for remaining tests
$GIT checkout "$DEFAULT_BRANCH" 2>/dev/null || $GIT checkout -b main 2>/dev/null

# ---------------------------------------------------------------------------
# Tests: merge-wezterm
# ---------------------------------------------------------------------------

echo ""
echo "=== WezTerm merge ==="

# Source the real merge-wezterm script from the repo under test.
# shellcheck disable=SC1091  # sourced via repo-relative test path
. "$SCRIPT_DIR/../../.config/dot/merge-hooks.d/50-wezterm.sh"

WEZ_HOME=$(_tmpdir)
WEZ_WIN_HOME=$(_tmpdir)
if [[ "$(uname -s)" == "Linux" ]]; then
  # Run in a subshell so HOME/WSL_DISTRO_NAME/USER changes don't leak.
  (
    # shellcheck disable=SC2030  # intentionally scoped to the subshell
    export HOME="$WEZ_HOME"
    export WSL_DISTRO_NAME="archlinux"
    # shellcheck disable=SC2030  # intentionally scoped to the subshell
    export USER="chris"
    export DOT_TEST_WINDOWS_HOME="$WEZ_WIN_HOME"
    mkdir -p "$HOME/.config/wezterm"
    echo "return { test = true }" >"$HOME/.config/wezterm/wezterm.lua"
    merge
  )

  _assert_file_exists "merge wezterm: created Windows-home file under WSL" "$WEZ_WIN_HOME/.wezterm.lua"
  _assert_file_content "merge wezterm: copied file content" "return { test = true }" "$WEZ_WIN_HOME/.wezterm.lua"

  # Non-WSL Linux should be a no-op.
  rm -f "$WEZ_WIN_HOME/.wezterm.lua"
  (
    # shellcheck disable=SC2031  # previous subshell mutation is intentionally not reused
    export HOME="$WEZ_HOME"
    unset WSL_DISTRO_NAME
    # shellcheck disable=SC2031  # previous subshell mutation is intentionally not reused
    export USER="chris"
    merge
  )
  _assert_file_missing "merge wezterm: no-op on non-WSL Linux" "$WEZ_WIN_HOME/.wezterm.lua"
else
  echo "  SKIP: merge wezterm WSL-specific assertions (non-Linux runner)"
fi

# ---------------------------------------------------------------------------
# Tests: hook file syntax (dotfiles-specific — shdeps tests cover hook logic)
# ---------------------------------------------------------------------------

echo ""
echo "=== Hook syntax (bash -n) ==="
# Verify all real dotfiles hook files pass syntax check.
syntax_ok=1
while IFS= read -r -d '' f; do
  if ! bash -n "$f" 2>/dev/null; then
    _fail "syntax: $(basename "$f")"
    syntax_ok=0
  fi
done < <(
  find \
    "$REAL_HOME/.config/dot/merge-hooks.d" \
    "$REAL_HOME/.config/shdeps/hooks.d" \
    -type f -name '*.sh' -print0 2>/dev/null |
    LC_ALL=C sort -z
)
if [[ "$syntax_ok" -eq 1 ]]; then
  _pass "syntax: all hook files pass bash -n"
fi
# ---------------------------------------------------------------------------
# Tests: _backup_and_checkout
# ---------------------------------------------------------------------------

echo ""
echo "=== Backup and checkout ==="

# Re-add origin so checkout can work
ORIGIN_BARE2=$(_tmpdir)
git clone --bare "$DOTFILES" "$ORIGIN_BARE2" >/dev/null 2>&1
$GIT remote add origin "$ORIGIN_BARE2" 2>/dev/null || $GIT remote set-url origin "$ORIGIN_BARE2"
$GIT fetch origin >/dev/null 2>&1
BRANCH=$($GIT branch --show-current 2>/dev/null || echo "main")

# Create a conflicting file (same path as a repo-tracked file)
echo "local content" >"$TEST_HOME/.testrc"

BACKUP="$TEST_HOME/.dotfiles-backup/test1"
result=$(_backup_and_checkout 2>&1)

_assert_contains "shows backup message" "backed up" "$result"
_assert_contains "shows checkout message" "checking out" "$result"

# Conflicting file was backed up
if [[ -f "$BACKUP/.testrc" ]]; then
  _pass "conflicting file backed up"
  _assert_file_content "backup has original content" "local content" "$BACKUP/.testrc"
else
  _fail "conflicting file backed up"
fi

# Checked-out file restored from repo
_assert_file_exists "repo file restored" "$TEST_HOME/.testrc"
_assert_file_content "restored file has repo content" "initial" "$TEST_HOME/.testrc"

# Untracked file is NOT backed up or removed
echo "untracked" >"$TEST_HOME/untracked_file"
BACKUP="$TEST_HOME/.dotfiles-backup/test2"
_backup_and_checkout >/dev/null 2>&1
_assert_file_missing "untracked file not backed up" "$BACKUP/untracked_file"
_assert_file_content "untracked file untouched" "untracked" "$TEST_HOME/untracked_file"
rm -f "$TEST_HOME/untracked_file"

# Empty backup dir is removed (no conflicts)
rm -f "$TEST_HOME/.testrc" "$TEST_HOME/.config/dot/placeholder"
BACKUP="$TEST_HOME/.dotfiles-backup/test3"
_backup_and_checkout >/dev/null 2>&1
if [[ ! -d "$BACKUP" ]]; then
  _pass "empty backup dir removed"
else
  _fail "empty backup dir removed"
fi

# ---------------------------------------------------------------------------
# Tests: Full bootstrap flow (subprocess with local repos)
# ---------------------------------------------------------------------------

# Build local repos that stand in for remote origins.

_seed_repo() {
  # $1 = bare repo path (will be created)
  # $2 = staging dir (caller populates before calling)
  local bare="$1" staging="$2"
  git init --bare "$bare" >/dev/null 2>&1
  git clone "$bare" "$staging/.git-tmp" >/dev/null 2>&1
  mv "$staging/.git-tmp/.git" "$staging/.git"
  rm -rf "$staging/.git-tmp"
  git -C "$staging" config user.email "test@test.com"
  git -C "$staging" config user.name "Test"
  git -C "$staging" add -A >/dev/null 2>&1
  git -C "$staging" commit -m "seed" >/dev/null 2>&1
  git -C "$staging" push >/dev/null 2>&1
}

# --- Base dotfiles origin ---
BASE_STAGING=$(_tmpdir)
mkdir -p "$BASE_STAGING/.local/lib/dot"
echo "bashrc content" >"$BASE_STAGING/.bashrc"

for _f in init.sh core.sh repos.sh merges.sh merge-block.sh; do
  cp "$REAL_HOME/.local/lib/dot/$_f" "$BASE_STAGING/.local/lib/dot/$_f"
done
mkdir -p "$BASE_STAGING/.config/shdeps"
cat >"$BASE_STAGING/.config/shdeps/deps.conf" <<'CONF'
fixture/test-tool  github:repo
fixture/hook-pack  github:repo
CONF
mkdir -p "$BASE_STAGING/.config/shdeps/hooks.d"
mkdir -p "$BASE_STAGING/.config/shdeps/hooks.d/fixture"
cat >"$BASE_STAGING/.config/shdeps/hooks.d/fixture/hook-pack.sh" <<'HOOK'
post() {
  mkdir -p "$HOME/.test-hooks"
  printf '%s\n' "$HOME/.local/share/fixture/hook-pack" > "$HOME/.test-hooks/hook-pack"
}
HOOK

mkdir -p "$BASE_STAGING/.config/dot/merge-hooks.d"
cat >"$BASE_STAGING/.config/dot/merge-hooks.d/testapp.sh" <<'MERGE'
merge() { echo "MERGE_TESTAPP_RAN"; }
MERGE

BASE_ORIGIN=$(_tmpdir)
_seed_repo "$BASE_ORIGIN" "$BASE_STAGING"

# --- Overlay (work) dotfiles origin ---
WORK_STAGING=$(_tmpdir)
echo "work config" >"$WORK_STAGING/work-config"
mkdir -p "$WORK_STAGING/home"
echo "work shell" >"$WORK_STAGING/home/.testrc_work"

WORK_ORIGIN=$(_tmpdir)
_seed_repo "$WORK_ORIGIN" "$WORK_STAGING"

# --- test tool origin (stub with bin/test-tool) ---
TEST_TOOL_STAGING=$(_tmpdir)
mkdir -p "$TEST_TOOL_STAGING/bin"
echo '#!/bin/bash' >"$TEST_TOOL_STAGING/bin/test-tool"
chmod +x "$TEST_TOOL_STAGING/bin/test-tool"

TEST_TOOL_ORIGIN=$(_tmpdir)
_seed_repo "$TEST_TOOL_ORIGIN" "$TEST_TOOL_STAGING"

# --- hook pack origin (stub content for a generic post-install hook) ---
HOOK_PACK_STAGING=$(_tmpdir)
mkdir -p "$HOOK_PACK_STAGING/review"
echo "# hook pack" >"$HOOK_PACK_STAGING/review/README.md"

HOOK_PACK_ORIGIN=$(_tmpdir)
_seed_repo "$HOOK_PACK_ORIGIN" "$HOOK_PACK_STAGING"

# Helper to run dotbootstrap in a fresh HOME with local repos.
# Pre-clones the base bare repo (dotbootstrap no longer auto-clones).
# Creates overlay conf pointing at the test work repo origin.
# Usage: _run_bootstrap <home> [extra-args...]
_run_bootstrap() {
  local home="$1"
  shift
  if [[ ! -d "$home/.dotfiles" ]]; then
    git clone --bare "$BASE_ORIGIN" "$home/.dotfiles" >/dev/null 2>&1
  fi
  # Create overlay conf pointing at test work origin.
  # Intentionally overwrites any conf from base checkout.
  mkdir -p "$home/.config/dot/overlays.d"
  cat >"$home/.config/dot/overlays.d/10-work.conf" <<CONF
url=$WORK_ORIGIN
CONF
  DOTBOOTSTRAP_SOURCED="" \
    HOME="$home" \
    SHDEPS_TEST_TOOL_REPO="$TEST_TOOL_ORIGIN" \
    SHDEPS_HOOK_PACK_REPO="$HOOK_PACK_ORIGIN" \
    "$SCRIPT_DIR/dotbootstrap" "$@" 2>&1
}

# Helper for base-only bootstrap (no overlay conf)
_run_bootstrap_base() {
  local home="$1"
  shift
  if [[ ! -d "$home/.dotfiles" ]]; then
    git clone --bare "$BASE_ORIGIN" "$home/.dotfiles" >/dev/null 2>&1
  fi
  # No overlay conf
  DOTBOOTSTRAP_SOURCED="" \
    HOME="$home" \
    SHDEPS_TEST_TOOL_REPO="$TEST_TOOL_ORIGIN" \
    SHDEPS_HOOK_PACK_REPO="$HOOK_PACK_ORIGIN" \
    "$SCRIPT_DIR/dotbootstrap" "$@" 2>&1
}

# ---- Fresh install (no overlays) ----

echo ""
echo "=== Fresh install (no overlays) ==="

FRESH=$(_tmpdir)
result=$(_run_bootstrap_base "$FRESH")

# Bare repo present (pre-cloned by helper)
if [[ -d "$FRESH/.dotfiles" ]]; then
  _pass "base: .dotfiles present"
else
  _fail "base: .dotfiles present"
fi

# Git config applied
_fgit="git --git-dir=$FRESH/.dotfiles --work-tree=$FRESH"
_assert_eq "base: showUntrackedFiles" "no" "$($_fgit config status.showUntrackedFiles)"
_assert_eq "base: pull.rebase" "true" "$($_fgit config pull.rebase)"
_assert_contains "base: json-normalize filter" "jq" "$($_fgit config filter.json-normalize.clean)"

# Files checked out
_assert_file_exists "base: .bashrc checked out" "$FRESH/.bashrc"
_assert_file_content "base: .bashrc content" "bashrc content" "$FRESH/.bashrc"
_assert_file_exists "base: init.sh checked out" "$FRESH/.local/lib/dot/init.sh"

# No overlay repo cloned (no conf)
if [[ ! -d "$FRESH/.dotfiles-work" ]]; then
  _pass "base: no overlay repo"
else
  _fail "base: no overlay repo"
fi

# Merge scripts ran
_assert_contains "base: merge ran" "MERGE_TESTAPP_RAN" "$result"

# Git-based deps added
_assert_contains "base: git deps added" "added" "$result"
_assert_file_exists "base: generic tool installed" "$FRESH/.local/share/fixture/test-tool/bin/test-tool"
_assert_file_exists "base: generic tool linked" "$FRESH/.local/bin/test-tool"
_assert_file_content "base: generic hook ran" "$FRESH/.local/share/fixture/hook-pack" "$FRESH/.test-hooks/hook-pack"

# Done message
_assert_contains "base: done message" "Done" "$result"
_assert_contains "base: shell activation hint" "source ~/.bashrc' or 'source ~/.zshrc" "$result"

# ---- Fresh install (with overlay) ----

echo ""
echo "=== Fresh install (with overlay) ==="

FRESH_WORK=$(_tmpdir)
result=$(_run_bootstrap "$FRESH_WORK")

# Base dotfiles set up
_assert_file_exists "overlay: .bashrc checked out" "$FRESH_WORK/.bashrc"

# Overlay repo cloned
if [[ -d "$FRESH_WORK/.dotfiles-work" ]]; then
  _pass "overlay: work repo cloned"
else
  _fail "overlay: work repo cloned"
fi
_assert_file_exists "overlay: work config present" "$FRESH_WORK/.dotfiles-work/work-config"
_assert_contains "overlay: work files linked" "Linking work dotfiles" "$result"
if [[ -L "$FRESH_WORK/.testrc_work" ]]; then
  _pass "overlay: symlink created"
else
  _fail "overlay: symlink created"
fi

# Done message
_assert_contains "overlay: done message" "Done" "$result"

# ---- Re-run on existing machine ----

echo ""
echo "=== Re-run (existing setup) ==="

# Run again on the same home — should succeed without re-cloning
result=$(_run_bootstrap "$FRESH_WORK")

# Should NOT try to clone (repo already exists)
_assert_not_contains "re-run: skips clone" "Cloning dotfiles" "$result"

# Overlay repo exists → pulls instead of cloning
_assert_contains "re-run: pulls overlay repo" "Pulling work" "$result"
_assert_not_contains "re-run: no overlay clone" "Cloning work" "$result"

# Still succeeds
_assert_contains "re-run: done message" "Done" "$result"

# ---- Auto-detect: overlays present → processes them ----

echo ""
echo "=== Auto-detect overlays ==="

# No args + overlay conf present → clones/pulls overlay
result=$(_run_bootstrap "$FRESH_WORK")
_assert_contains "auto-detect: overlay processed" "Pulling work" "$result"
_assert_contains "auto-detect: done" "Done" "$result"

# No args + no overlay conf → base only
result=$(_run_bootstrap_base "$FRESH")
_assert_not_contains "auto-detect: no overlay" "Pulling work" "$result"
_assert_not_contains "auto-detect: no clone" "Cloning work" "$result"
_assert_contains "auto-detect: base done" "Done" "$result"

# ---- Filter skipping ----

echo ""
echo "=== Filter skipping ==="

FRESH_FILTER=$(_tmpdir)
if [[ ! -d "$FRESH_FILTER/.dotfiles" ]]; then
  git clone --bare "$BASE_ORIGIN" "$FRESH_FILTER/.dotfiles" >/dev/null 2>&1
fi
# Create overlay conf with wrong platform filter
mkdir -p "$FRESH_FILTER/.config/dot/overlays.d"
cat >"$FRESH_FILTER/.config/dot/overlays.d/10-work.conf" <<CONF
url=$WORK_ORIGIN
platforms=nonexistent-platform
CONF
result=$(
  DOTBOOTSTRAP_SOURCED="" \
    HOME="$FRESH_FILTER" \
    SHDEPS_TEST_TOOL_REPO="$TEST_TOOL_ORIGIN" \
    SHDEPS_HOOK_PACK_REPO="$HOOK_PACK_ORIGIN" \
    "$SCRIPT_DIR/dotbootstrap" 2>&1
)
if [[ ! -d "$FRESH_FILTER/.dotfiles-work" ]]; then
  _pass "filter: overlay not cloned (wrong platform)"
else
  _fail "filter: overlay not cloned (wrong platform)"
fi
_assert_contains "filter: still completes" "Done" "$result"

# ---- Broken partial clone recovery ----

echo ""
echo "=== Broken partial clone ==="

FRESH_BROKEN=$(_tmpdir)
git clone --bare "$BASE_ORIGIN" "$FRESH_BROKEN/.dotfiles" >/dev/null 2>&1
mkdir -p "$FRESH_BROKEN/.config/dot/overlays.d"
cat >"$FRESH_BROKEN/.config/dot/overlays.d/10-work.conf" <<CONF
url=$WORK_ORIGIN
CONF
# Create a broken overlay dir (exists but no .git)
mkdir -p "$FRESH_BROKEN/.dotfiles-work"
echo "stale" >"$FRESH_BROKEN/.dotfiles-work/junk"
result=$(
  DOTBOOTSTRAP_SOURCED="" \
    HOME="$FRESH_BROKEN" \
    SHDEPS_TEST_TOOL_REPO="$TEST_TOOL_ORIGIN" \
    SHDEPS_HOOK_PACK_REPO="$HOOK_PACK_ORIGIN" \
    "$SCRIPT_DIR/dotbootstrap" 2>&1
)
_assert_contains "broken clone: warns" "isn't a git repo" "$result"
# Should have re-cloned successfully
if [[ -d "$FRESH_BROKEN/.dotfiles-work/.git" ]]; then
  _pass "broken clone: re-cloned successfully"
else
  _fail "broken clone: re-cloned successfully"
fi
_assert_file_exists "broken clone: work content present" "$FRESH_BROKEN/.dotfiles-work/work-config"
_assert_contains "broken clone: completes" "Done" "$result"

_test_summary

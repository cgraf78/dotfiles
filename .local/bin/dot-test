#!/usr/bin/env bash
# dot-test — unit tests for the dot dotfiles manager.
#
# Creates temp directories with mock git repos to test command routing,
# overlay handling, normalize/filtered logic, and merge scripts.
#
# Usage: dot-test

set -o pipefail
export NO_COLOR=1

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REAL_HOME="$HOME"

# Export SHDEPS_LIB so subprocess dot commands find shdeps in the mock HOME
if [[ -f "$REAL_HOME/git/shdeps/shdeps.sh" ]]; then
  export SHDEPS_LIB="$REAL_HOME/git/shdeps/shdeps.sh"
elif [[ -f "$REAL_HOME/.local/share/shdeps/shdeps.sh" ]]; then
  export SHDEPS_LIB="$REAL_HOME/.local/share/shdeps/shdeps.sh"
fi

# shellcheck source=../../.local/lib/dot/test-helpers.sh
. "$HOME/.local/lib/dot/test-helpers.sh"

# ---------------------------------------------------------------------------
# Tests: static analysis (shellcheck, JSON sorting)
# ---------------------------------------------------------------------------

# Determine repo root and git command.
# Bare dotfiles repo when available; regular checkout (CI) as fallback.
# Use --git-dir only (no --work-tree) — bare repos with core.bare=true
# suppress ls-files/ls-tree output when --work-tree is present.
_lint_root="$REAL_HOME"
_lint_git=(git --git-dir="${REAL_HOME}/.dotfiles")
if ! "${_lint_git[@]}" rev-parse HEAD >/dev/null 2>&1; then
  _lint_root="$(cd "${SCRIPT_DIR}/../.." && pwd)"
  _lint_git=(git -C "${_lint_root}")
fi

echo "=== ShellCheck ==="

_sc_files=()
while IFS= read -r _tracked; do
  _f="${_lint_root}/${_tracked}"
  [[ -f "$_f" && ! -L "$_f" ]] || continue
  case "$_tracked" in
    .bashrc | .bash_profile | *.sh | *.bash)
      _sc_files+=("$_f")
      continue
      ;;
  esac
  IFS= read -r _first <"$_f" || true
  case "$_first" in
    '#!/usr/bin/env bash' | '#!/bin/bash')
      _sc_files+=("$_f")
      ;;
  esac
done < <("${_lint_git[@]}" ls-tree -r --name-only HEAD)

if [[ "${#_sc_files[@]}" -eq 0 ]]; then
  _fail "shellcheck: no files discovered"
  printf '    repo root: %s\n' "${_lint_root}" >&2
elif _sc_output=$(shellcheck -x -P SCRIPTDIR -e SC1091 "${_sc_files[@]}" 2>&1); then
  _pass "shellcheck: all files clean"
else
  _fail "shellcheck: findings detected"
  while IFS= read -r _line; do
    printf '    %s\n' "$_line" >&2
  done <<<"$_sc_output"
fi

# ---------------------------------------------------------------------------
# Setup: mock HOME with bare repo structure
# ---------------------------------------------------------------------------

TEST_HOME=$(_tmpdir)
export HOME="$TEST_HOME"

# Create a bare repo to serve as .dotfiles
git init --bare "$TEST_HOME/.dotfiles" >/dev/null 2>&1

# Set GIT and DOTFILES to match what init.sh would set
DOTFILES="$TEST_HOME/.dotfiles"
GIT="git --git-dir=$DOTFILES --work-tree=$TEST_HOME"

# Configure git identity for commits
$GIT config user.email "test@test.com"
$GIT config user.name "Test"

# Create dot config dir and copy modules
mkdir -p "$TEST_HOME/.local/lib/dot"
for _f in init.sh core.sh repos.sh merges.sh; do
  cp "$REAL_HOME/.local/lib/dot/$_f" "$TEST_HOME/.local/lib/dot/$_f"
done
mkdir -p "$TEST_HOME/.config/shdeps"
cat >"$TEST_HOME/.config/shdeps/deps.conf" <<'CONF'
test-tool  git  -  -  -  fixture/test-tool.git  .local/share/test-tool
hook-pack  git  -  -  -  fixture/hook-pack.git  .local/share/hook-pack
CONF
mkdir -p "$TEST_HOME/.config/shdeps/hooks.d"
cat >"$TEST_HOME/.config/shdeps/hooks.d/hook-pack.sh" <<'HOOK'
post() {
  mkdir -p "$HOME/.test-hooks"
  printf '%s\n' "$HOME/.local/share/hook-pack" > "$HOME/.test-hooks/hook-pack"
}
HOOK

# Seed the repo with a tracked file so we have a branch
echo "initial" >"$TEST_HOME/.testrc"
$GIT add .testrc
$GIT commit -m "initial" >/dev/null 2>&1

# ---------------------------------------------------------------------------
# Tests: init.sh setup
# ---------------------------------------------------------------------------

echo "=== init.sh setup ==="

# Source init in test HOME context
. "$TEST_HOME/.local/lib/dot/init.sh"

_assert_eq "DOTFILES points to bare repo" "$TEST_HOME/.dotfiles" "$DOTFILES"
_assert_contains "GIT uses bare repo" "--git-dir=$DOTFILES" "$GIT"
_assert_contains "GIT uses HOME as worktree" "--work-tree=$TEST_HOME" "$GIT"

echo ""
echo "=== Helper primitives ==="

_backup_dir
backup_one="$REPLY"
_backup_dir
backup_two="$REPLY"
if [[ -d "$backup_one" && -d "$backup_two" && "$backup_one" != "$backup_two" ]]; then
  _pass "backup_dir: creates unique directories"
else
  _fail "backup_dir: creates unique directories"
fi

conflict_log=$(_tmpdir)/pull.log
cat >"$conflict_log" <<'LOG'
error: The following untracked working tree files would be overwritten by checkout:
	.config/nvim/lazy-lock.json
	.config/example/tool.conf
Please move or remove them before you switch branches.
LOG
result=$(_pull_conflicts_from_log "$conflict_log")
_assert_contains "pull_conflicts: captures first file" ".config/nvim/lazy-lock.json" "$result"
_assert_contains "pull_conflicts: captures second file" ".config/example/tool.conf" "$result"

# ---------------------------------------------------------------------------
# Tests: overlay discovery
# ---------------------------------------------------------------------------

echo ""
echo "=== Overlay discovery ==="

# No overlays.d → empty
_discover_overlays
_assert_eq "no overlays dir: empty" "0" "${#OVERLAYS[@]}"

# Create overlays.d with a conf
mkdir -p "$TEST_HOME/.config/dot/overlays.d"
cat >"$TEST_HOME/.config/dot/overlays.d/10-work.conf" <<'CONF'
url=git@example.com:work.git
CONF
_discover_overlays
_assert_eq "one conf: one overlay" "1" "${#OVERLAYS[@]}"
_assert_contains "one conf: name=work" "work|" "${OVERLAYS[0]}"
_assert_contains "one conf: url" "git@example.com:work.git" "${OVERLAYS[0]}"
_assert_contains "one conf: path" ".dotfiles-work" "${OVERLAYS[0]}"

# Multiple confs → sorted order
cat >"$TEST_HOME/.config/dot/overlays.d/20-nas.conf" <<'CONF'
url=git@example.com:nas.git
CONF
_discover_overlays
_assert_eq "two confs: two overlays" "2" "${#OVERLAYS[@]}"
_assert_contains "two confs: first is work" "work|" "${OVERLAYS[0]}"
_assert_contains "two confs: second is nas" "nas|" "${OVERLAYS[1]}"

# Missing url → skipped
cat >"$TEST_HOME/.config/dot/overlays.d/30-bad.conf" <<'CONF'
platforms=linux
CONF
_discover_overlays
_assert_eq "missing url: skipped" "2" "${#OVERLAYS[@]}"
rm -f "$TEST_HOME/.config/dot/overlays.d/30-bad.conf"

# Duplicate names → warned and skipped
cat >"$TEST_HOME/.config/dot/overlays.d/99-work.conf" <<'CONF'
url=git@example.com:other-work.git
CONF
result=$(_discover_overlays 2>&1)
_assert_eq "duplicate: still two" "2" "${#OVERLAYS[@]}"
_assert_contains "duplicate: warns" "duplicate overlay name" "$result"
rm -f "$TEST_HOME/.config/dot/overlays.d/99-work.conf"

# Name extraction
_assert_eq "name: 10-work.conf" "work" "$(_overlay_name "10-work.conf")"
_assert_eq "name: 20-my-nas.conf" "my-nas" "$(_overlay_name "20-my-nas.conf")"
_assert_eq "name: work.conf" "work" "$(_overlay_name "work.conf")"
_assert_eq "name: 5-x.conf" "x" "$(_overlay_name "5-x.conf")"

# Comments are skipped
cat >"$TEST_HOME/.config/dot/overlays.d/30-commented.conf" <<'CONF'
# This is a comment
url=git@example.com:commented.git

# Another comment
CONF
_discover_overlays
_assert_eq "comments: three overlays" "3" "${#OVERLAYS[@]}"
_assert_contains "comments: url parsed" "git@example.com:commented.git" "${OVERLAYS[2]}"
rm -f "$TEST_HOME/.config/dot/overlays.d/30-commented.conf"

# Unknown key warns
cat >"$TEST_HOME/.config/dot/overlays.d/30-typo.conf" <<'CONF'
url=git@example.com:typo.git
platfoms=linux
CONF
result=$(_discover_overlays 2>&1)
_assert_contains "unknown key: warns" "unknown key" "$result"
rm -f "$TEST_HOME/.config/dot/overlays.d/30-typo.conf"

# Clean up for remaining tests — keep only work
rm -f "$TEST_HOME/.config/dot/overlays.d/20-nas.conf"

# ---------------------------------------------------------------------------
# Tests: overlay helpers
# ---------------------------------------------------------------------------

echo ""
echo "=== Overlay helpers ==="

# No overlay repos → silent no-op
_discover_overlays
result=$(_pull_overlays 2>&1)
_assert_eq "pull_overlays: no overlay dir → no output" "" "$result"

result=$(_push_overlays 2>&1)
_assert_eq "push_overlays: no overlay dir → no output" "" "$result"

# Create an overlay repo (regular clone of a bare repo)
OVERLAY_BARE=$(_tmpdir)
git init --bare "$OVERLAY_BARE" >/dev/null 2>&1
OVERLAY_DIR="$TEST_HOME/.dotfiles-work"
git clone "$OVERLAY_BARE" "$OVERLAY_DIR" >/dev/null 2>&1
git -C "$OVERLAY_DIR" config user.email "test@test.com"
git -C "$OVERLAY_DIR" config user.name "Test"

# Seed overlay repo so pull/push have a branch
echo "work content" >"$OVERLAY_DIR/work-file"
git -C "$OVERLAY_DIR" add work-file
git -C "$OVERLAY_DIR" commit -m "seed" >/dev/null 2>&1
git -C "$OVERLAY_DIR" push >/dev/null 2>&1

# Pull overlay succeeds
_discover_overlays
result=$(_pull_overlays 2>&1)
_assert_contains "pull_overlays: shows pulling" "Pulling work" "$result"

# Push overlay succeeds
result=$(_push_overlays 2>&1)
_assert_contains "push_overlays: shows pushing" "Pushing work" "$result"

rm -rf "$OVERLAY_DIR" "$OVERLAY_BARE"

# ---------------------------------------------------------------------------
# Tests: _link_overlay / _link_overlays
# ---------------------------------------------------------------------------

echo ""
echo "=== Overlay linking ==="

# No overlay dir → no-op
_discover_overlays
result=$(_link_overlays 2>&1)
# (no output expected — overlay dir doesn't exist)

# Create overlay dir with home/ structure
OVERLAY_BARE=$(_tmpdir)
git init --bare "$OVERLAY_BARE" >/dev/null 2>&1
OVERLAY_DIR="$TEST_HOME/.dotfiles-work"
git clone "$OVERLAY_BARE" "$OVERLAY_DIR" >/dev/null 2>&1
git -C "$OVERLAY_DIR" config user.email "test@test.com"
git -C "$OVERLAY_DIR" config user.name "Test"

mkdir -p "$OVERLAY_DIR/home/.config/test"
echo "work config" >"$OVERLAY_DIR/home/.config/test/config.conf"
echo "work shell" >"$OVERLAY_DIR/home/.testrc_work"

# Link overlay — creates symlinks
_discover_overlays
result=$(_link_overlays 2>&1)
_assert_contains "link: shows header" "Linking work dotfiles" "$result"
_assert_contains "link: reports new symlinks" "linked:" "$result"
if [[ -L "$TEST_HOME/.config/test/config.conf" ]]; then
  _pass "link: symlink created for nested file"
else
  _fail "link: symlink created for nested file"
fi
if [[ -L "$TEST_HOME/.testrc_work" ]]; then
  _pass "link: symlink created for top-level file"
else
  _fail "link: symlink created for top-level file"
fi

# Verify symlinks are relative
target=$(readlink "$TEST_HOME/.testrc_work")
_assert_contains "link: relative symlink" ".dotfiles-work/home" "$target"

# Idempotent: re-run produces no per-file output
result=$(_link_overlays 2>&1)
_assert_contains "link idempotent: header still shown" "Linking work dotfiles" "$result"
_assert_not_contains "link idempotent: no per-file output" "linked:" "$result"

# Quiet mode: no output
DOT_QUIET=1
rm "$TEST_HOME/.testrc_work" # force re-link
result=$(_link_overlays 2>&1)
# shellcheck disable=SC2034  # read by sourced helpers
DOT_QUIET=0
_assert_eq "link quiet: no output" "" "$result"
if [[ -L "$TEST_HOME/.testrc_work" ]]; then
  _pass "link quiet: still creates symlink"
else
  _fail "link quiet: still creates symlink"
fi

# Manifest is written
_assert_file_exists "link: manifest written" "$TEST_HOME/.local/state/dot/overlay-links"
manifest_content=$(cat "$TEST_HOME/.local/state/dot/overlay-links")
_assert_contains "link: manifest has testrc_work" ".testrc_work" "$manifest_content"

# Skip-worktree: overlay file shadowing a personal-repo file
echo "personal version" >"$TEST_HOME/.testrc"
$GIT add .testrc
$GIT commit -m "add testrc" >/dev/null 2>&1
echo "overlay version" >"$OVERLAY_DIR/home/.testrc"
_discover_overlays
_link_overlays >/dev/null 2>&1
# Symlink should exist
if [[ -L "$TEST_HOME/.testrc" ]]; then
  _pass "skip-worktree: symlink created for shadowed file"
else
  _fail "skip-worktree: symlink created for shadowed file"
fi
# skip-worktree should be set
sw_flag=$($GIT ls-files -v .testrc 2>/dev/null | cut -c1)
_assert_eq "skip-worktree: flag set" "S" "$sw_flag"
# Clean up the override
rm -f "$OVERLAY_DIR/home/.testrc"

# Last-wins: two overlays providing the same file
OVERLAY_BARE2=$(_tmpdir)
git init --bare "$OVERLAY_BARE2" >/dev/null 2>&1
OVERLAY_DIR2="$TEST_HOME/.dotfiles-extra"
git clone "$OVERLAY_BARE2" "$OVERLAY_DIR2" >/dev/null 2>&1
git -C "$OVERLAY_DIR2" config user.email "test@test.com"
git -C "$OVERLAY_DIR2" config user.name "Test"
mkdir -p "$OVERLAY_DIR2/home"
echo "extra version" >"$OVERLAY_DIR2/home/.shared_file"
echo "work version" >"$OVERLAY_DIR/home/.shared_file"
cat >"$TEST_HOME/.config/dot/overlays.d/20-extra.conf" <<'CONF'
url=git@example.com:extra.git
CONF
_discover_overlays
_link_overlays >/dev/null 2>&1
# Last overlay (20-extra) should win
link_target=$(readlink "$TEST_HOME/.shared_file")
_assert_contains "last-wins: extra overlay wins" ".dotfiles-extra/home" "$link_target"
# Clean up
rm -f "$TEST_HOME/.config/dot/overlays.d/20-extra.conf"
rm -f "$OVERLAY_DIR/home/.shared_file"
rm -rf "$OVERLAY_DIR2" "$OVERLAY_BARE2"

# Stale symlink cleanup: remove overlay conf, re-link → symlinks removed
rm -f "$TEST_HOME/.config/dot/overlays.d/10-work.conf"
_discover_overlays
result=$(_link_overlays 2>&1)
_assert_contains "cleanup: removes stale" "Cleaning stale" "$result"
if [[ ! -L "$TEST_HOME/.testrc_work" ]]; then
  _pass "cleanup: symlink removed"
else
  _fail "cleanup: symlink removed"
fi

# Stale cleanup restores personal repo version of shadowed file
# (.testrc was shadowed by overlay, now overlay is gone)
if [[ -f "$TEST_HOME/.testrc" && ! -L "$TEST_HOME/.testrc" ]]; then
  _pass "cleanup: personal file restored"
  _assert_file_content "cleanup: personal content" "personal version" "$TEST_HOME/.testrc"
else
  _fail "cleanup: personal file restored"
fi
# skip-worktree should be cleared
sw_flag=$($GIT ls-files -v .testrc 2>/dev/null | cut -c1)
_assert_not_contains "cleanup: skip-worktree cleared" "S" "$sw_flag"

# Restore conf for remaining tests
cat >"$TEST_HOME/.config/dot/overlays.d/10-work.conf" <<'CONF'
url=git@example.com:work.git
CONF

rm -rf "$OVERLAY_DIR" "$OVERLAY_BARE"

# ---------------------------------------------------------------------------
# Tests: _merge_overlay_ssh_configs
# ---------------------------------------------------------------------------

echo ""
echo "=== Overlay SSH config merge ==="

SSH_DIR="$TEST_HOME/.ssh"
SSH_CONFIG="$SSH_DIR/config"
rm -rf "$SSH_DIR"

# No .ssh files → no-op
_merge_overlay_ssh_configs
if [[ ! -f "$SSH_CONFIG" ]]; then
  _pass "ssh merge: no .ssh files → no config created"
else
  _fail "ssh merge: no .ssh files → no config created"
fi

# Create a .ssh file → appended to config
cat >"$TEST_HOME/.config/dot/overlays.d/10-work.ssh" <<'SSH'
Host test-alias
  HostName example.com
  User git
  IdentityFile ~/.ssh/test-key
SSH
_merge_overlay_ssh_configs
_assert_file_exists "ssh merge: config created" "$SSH_CONFIG"
ssh_content=$(cat "$SSH_CONFIG")
_assert_contains "ssh merge: host appended" "Host test-alias" "$ssh_content"
_assert_contains "ssh merge: options present" "HostName example.com" "$ssh_content"

# Idempotent — running again doesn't duplicate
_merge_overlay_ssh_configs
count=$(grep -c "^Host test-alias" "$SSH_CONFIG")
_assert_eq "ssh merge: idempotent" "1" "$count"

# Changed block → replaced
cat >"$TEST_HOME/.config/dot/overlays.d/10-work.ssh" <<'SSH'
Host test-alias
  HostName changed.example.com
  User deploy
  IdentityFile ~/.ssh/new-key
SSH
_merge_overlay_ssh_configs
ssh_content=$(cat "$SSH_CONFIG")
_assert_contains "ssh merge: updated hostname" "changed.example.com" "$ssh_content"
_assert_not_contains "ssh merge: old hostname removed" "HostName example.com" "$ssh_content"
count=$(grep -c "^Host test-alias" "$SSH_CONFIG")
_assert_eq "ssh merge: still one block" "1" "$count"

# Preserves other entries
cat >"$SSH_CONFIG" <<'EXISTING'
Host myserver
  HostName myserver.com
  User me
EXISTING
cat >"$TEST_HOME/.config/dot/overlays.d/10-work.ssh" <<'SSH'
Host test-alias
  HostName example.com
  User git
SSH
_merge_overlay_ssh_configs
ssh_content=$(cat "$SSH_CONFIG")
_assert_contains "ssh merge: preserves existing" "Host myserver" "$ssh_content"
_assert_contains "ssh merge: adds new" "Host test-alias" "$ssh_content"

# Permissions
perms=$(stat -c '%a' "$SSH_CONFIG" 2>/dev/null || stat -f '%Lp' "$SSH_CONFIG" 2>/dev/null)
_assert_eq "ssh merge: config is 600" "600" "$perms"

# Clean up
rm -rf "$SSH_DIR"
rm -f "$TEST_HOME/.config/dot/overlays.d/10-work.ssh"

# ---------------------------------------------------------------------------
# Tests: _run_merges
# ---------------------------------------------------------------------------

echo ""
echo "=== Merge scripts ==="

# No merge scripts → no-op
result=$(_run_merges 2>&1)
_assert_eq "no merge scripts → no output" "" "$result"

# Create test merge scripts
mkdir -p "$TEST_HOME/.config/dot/merge-hooks.d"
cat >"$TEST_HOME/.config/dot/merge-hooks.d/testapp.sh" <<'MERGE'
merge() {
    echo "MERGED_TESTAPP"
}
MERGE

cat >"$TEST_HOME/.config/dot/merge-hooks.d/otherapp.sh" <<'MERGE'
merge() {
    echo "MERGED_OTHERAPP"
}
MERGE

result=$(_run_merges 2>&1)
_assert_contains "merge header printed once" "==> Merging app config..." "$result"
_assert_contains "runs testapp merge" "MERGED_TESTAPP" "$result"
_assert_contains "runs otherapp merge" "MERGED_OTHERAPP" "$result"
merge_header_count=$(printf '%s\n' "$result" | grep -c '^==> Merging app config\.\.\.$' || true)
_assert_eq "merge header count" "1" "$merge_header_count"

# Quiet mode should still run merges without tripping log redirection bugs.
DOT_QUIET=1
result=$(_run_merges 2>&1)
DOT_QUIET=0
: "$DOT_QUIET"
_assert_eq "quiet merges: no output on success" "" "$result"

# Failing merge script doesn't abort
cat >"$TEST_HOME/.config/dot/merge-hooks.d/failapp.sh" <<'MERGE'
merge() {
    return 1
}
MERGE

result=$(_run_merges 2>&1)
_assert_contains "surviving merges still run" "MERGED_TESTAPP" "$result"

rm -f "$TEST_HOME/.config/dot/merge-hooks.d"/*.sh

# ---------------------------------------------------------------------------
# Tests: _normalize_filtered (via subprocess since dot has no sourcing guard)
# ---------------------------------------------------------------------------

echo ""
echo "=== Normalize filtered ==="

echo "modified" >"$TEST_HOME/.testrc"
$GIT add .testrc
$GIT commit -m "modified" >/dev/null 2>&1

# Clean worktree → no-op, no output
result=$("$SCRIPT_DIR/dot" refresh 2>&1)
_assert_eq "normalize: clean tree → no output" "" "$result"

# Touch the file so stat differs (mtime) but content is same
cp "$TEST_HOME/.testrc" "$TEST_HOME/.testrc.tmp"
mv "$TEST_HOME/.testrc.tmp" "$TEST_HOME/.testrc"

# File should show as "dirty" in diff-files (stat mismatch) but not in diff
dirty=$($GIT diff-files --name-only 2>/dev/null || true)
if [[ -n "$dirty" ]]; then
  # Stat-dirty but content-clean — normalize should fix it
  "$SCRIPT_DIR/dot" refresh 2>/dev/null
  dirty_after=$($GIT diff-files --name-only 2>/dev/null || true)
  _assert_eq "normalize: clears phantom dirty file" "" "$dirty_after"
else
  _pass "normalize: file not stat-dirty (nothing to test)"
fi

# ---------------------------------------------------------------------------
# Tests: dot command routing (via subprocess)
# ---------------------------------------------------------------------------

echo ""
echo "=== Command routing ==="

# dot status shows personal dotfiles header
result=$("$SCRIPT_DIR/dot" status 2>&1)
_assert_contains "status: personal header" "dotfiles" "$result"

# dot status without overlay dir: no overlay section
_assert_not_contains "status: no overlay section without overlay dir" "work dotfiles" "$result"

# dot status with overlay dir: shows both
OVERLAY_BARE=$(_tmpdir)
git init --bare "$OVERLAY_BARE" >/dev/null 2>&1
OVERLAY_DIR="$TEST_HOME/.dotfiles-work"
git clone "$OVERLAY_BARE" "$OVERLAY_DIR" >/dev/null 2>&1
git -C "$OVERLAY_DIR" config user.email "test@test.com"
git -C "$OVERLAY_DIR" config user.name "Test"
echo "x" >"$OVERLAY_DIR/f"
git -C "$OVERLAY_DIR" add f
git -C "$OVERLAY_DIR" commit -m "init" >/dev/null 2>&1
git -C "$OVERLAY_DIR" push >/dev/null 2>&1

result=$("$SCRIPT_DIR/dot" status 2>&1)
_assert_contains "status: personal with overlay dir" "dotfiles" "$result"
_assert_contains "status: overlay section present" "work dotfiles" "$result"

rm -rf "$OVERLAY_DIR" "$OVERLAY_BARE"

# dot refresh is a valid command (runs _normalize_filtered)
result=$("$SCRIPT_DIR/dot" refresh 2>&1)
_assert_eq "refresh: no output on clean tree" "" "$result"

# dot <anything> passes through to git
result=$("$SCRIPT_DIR/dot" log --oneline -1 2>&1)
_assert_contains "passthrough: git log works" "modified" "$result"

# Detect the default branch name (master or main)
DEFAULT_BRANCH=$($GIT branch --show-current 2>/dev/null || echo "master")
result=$("$SCRIPT_DIR/dot" branch 2>&1)
_assert_contains "passthrough: git branch works" "$DEFAULT_BRANCH" "$result"

# dot with no args passes through (shows usage)
result=$("$SCRIPT_DIR/dot" 2>&1 || true)
_assert_contains "no args: usage" "usage:" "$result"

# ---------------------------------------------------------------------------
# Tests: dot pull (with mock remote)
# ---------------------------------------------------------------------------

echo ""
echo "=== Pull command ==="

# Set up a remote so pull doesn't fail
REMOTE_BARE=$(_tmpdir)
git clone --bare "$DOTFILES" "$REMOTE_BARE" >/dev/null 2>&1
$GIT remote add origin "$REMOTE_BARE" 2>/dev/null || $GIT remote set-url origin "$REMOTE_BARE"
$GIT fetch origin >/dev/null 2>&1
$GIT branch --set-upstream-to="origin/$DEFAULT_BRANCH" "$DEFAULT_BRANCH" 2>/dev/null || true

TEST_TOOL_STAGING=$(_tmpdir)
mkdir -p "$TEST_TOOL_STAGING/bin"
cat >"$TEST_TOOL_STAGING/bin/test-tool" <<'TOOL'
#!/bin/bash
echo "test-tool"
TOOL
chmod +x "$TEST_TOOL_STAGING/bin/test-tool"
TEST_TOOL_ORIGIN=$(_tmpdir)
git init --bare "$TEST_TOOL_ORIGIN" >/dev/null 2>&1
TEST_TOOL_WORK=$(_tmpdir)
git clone "$TEST_TOOL_ORIGIN" "$TEST_TOOL_WORK" >/dev/null 2>&1
git -C "$TEST_TOOL_WORK" config user.email "test@test.com"
git -C "$TEST_TOOL_WORK" config user.name "Test"
cp -R "$TEST_TOOL_STAGING"/. "$TEST_TOOL_WORK/"
git -C "$TEST_TOOL_WORK" add .
git -C "$TEST_TOOL_WORK" commit -m "seed test tool" >/dev/null 2>&1
git -C "$TEST_TOOL_WORK" push >/dev/null 2>&1

HOOK_PACK_STAGING=$(_tmpdir)
mkdir -p "$HOOK_PACK_STAGING/review"
echo "# hook pack" >"$HOOK_PACK_STAGING/review/README.md"
HOOK_PACK_ORIGIN=$(_tmpdir)
git init --bare "$HOOK_PACK_ORIGIN" >/dev/null 2>&1
HOOK_PACK_WORK=$(_tmpdir)
git clone "$HOOK_PACK_ORIGIN" "$HOOK_PACK_WORK" >/dev/null 2>&1
git -C "$HOOK_PACK_WORK" config user.email "test@test.com"
git -C "$HOOK_PACK_WORK" config user.name "Test"
cp -R "$HOOK_PACK_STAGING"/. "$HOOK_PACK_WORK/"
git -C "$HOOK_PACK_WORK" add .
git -C "$HOOK_PACK_WORK" commit -m "seed hook pack" >/dev/null 2>&1
git -C "$HOOK_PACK_WORK" push >/dev/null 2>&1

result=$(
  SHDEPS_TEST_TOOL_REPO="$TEST_TOOL_ORIGIN" \
    SHDEPS_HOOK_PACK_REPO="$HOOK_PACK_ORIGIN" \
    "$SCRIPT_DIR/dot" pull 2>&1
)
_assert_contains "pull: shows pulling" "Pulling dotfiles" "$result"
_assert_contains "pull: shows done message" "Done" "$result"
_assert_contains "pull: mentions shell activation hint" "source ~/.bashrc' or 'source ~/.zshrc" "$result"

# Upstream starts tracking a file that exists locally as untracked → backup and continue.
REMOTE_WORK=$(_tmpdir)
git clone "$REMOTE_BARE" "$REMOTE_WORK" >/dev/null 2>&1
git -C "$REMOTE_WORK" config user.email "test@test.com"
git -C "$REMOTE_WORK" config user.name "Test"
mkdir -p "$REMOTE_WORK/.config/nvim"
printf '%s\n' "remote-lock" >"$REMOTE_WORK/.config/nvim/lazy-lock.json"
git -C "$REMOTE_WORK" add .config/nvim/lazy-lock.json
git -C "$REMOTE_WORK" commit -m "track lazy lock" >/dev/null 2>&1
git -C "$REMOTE_WORK" push >/dev/null 2>&1

mkdir -p "$TEST_HOME/.config/nvim"
printf '%s\n' "local-lock" >"$TEST_HOME/.config/nvim/lazy-lock.json"

result=$(
  SHDEPS_TEST_TOOL_REPO="$TEST_TOOL_ORIGIN" \
    SHDEPS_HOOK_PACK_REPO="$HOOK_PACK_ORIGIN" \
    "$SCRIPT_DIR/dot" pull 2>&1
)
_assert_contains "pull: backs up tracked-file adoption conflict" "backed up 1 conflicting untracked files" "$result"
_assert_file_content "pull: installs tracked file after backup" "remote-lock" "$TEST_HOME/.config/nvim/lazy-lock.json"

backup_lock=$(find "$TEST_HOME/.dotfiles-backup" -path '*/.config/nvim/lazy-lock.json' -print | head -1)
if [[ -n "$backup_lock" ]]; then
  _assert_file_content "pull: preserves local untracked file in backup" "local-lock" "$backup_lock"
else
  _fail "pull: preserves local untracked file in backup (backup file not found)"
fi

# ---------------------------------------------------------------------------
# Tests: dot push (with mock remote)
# ---------------------------------------------------------------------------

echo ""
echo "=== Push command ==="

result=$("$SCRIPT_DIR/dot" push 2>&1)
_assert_contains "push: shows pushing" "Pushing dotfiles" "$result"

# ---------------------------------------------------------------------------
# Tests: dot update (with mock remote + deps)
# ---------------------------------------------------------------------------

echo ""
echo "=== Update command ==="

# Update with repo: pulls, runs merges, updates deps, shows done
result=$(
  SHDEPS_TEST_TOOL_REPO="$TEST_TOOL_ORIGIN" \
    SHDEPS_HOOK_PACK_REPO="$HOOK_PACK_ORIGIN" \
    "$SCRIPT_DIR/dot" update 2>&1
)
_assert_contains "update: shows pulling" "Pulling dotfiles" "$result"
_assert_contains "update: shows installing" "Installing/upgrading" "$result"
_assert_contains "update: shows done" "Done" "$result"
_assert_file_exists "update: generic tool install dir exists" "$TEST_HOME/.local/share/test-tool/bin/test-tool"
_assert_file_exists "update: generic tool linked into PATH" "$TEST_HOME/.local/bin/test-tool"
_assert_file_content "update: generic hook ran" "$TEST_HOME/.local/share/hook-pack" "$TEST_HOME/.test-hooks/hook-pack"

# Update without bare repo: no error, no pull, still succeeds
NO_REPO_HOME=$(_tmpdir)
mkdir -p "$NO_REPO_HOME/.local/lib/dot"
for _f in init.sh core.sh repos.sh merges.sh; do
  cp "$REAL_HOME/.local/lib/dot/$_f" "$NO_REPO_HOME/.local/lib/dot/$_f"
done
mkdir -p "$NO_REPO_HOME/.config/shdeps"
cp "$TEST_HOME/.config/shdeps/deps.conf" "$NO_REPO_HOME/.config/shdeps/deps.conf"
cp -r "$TEST_HOME/.config/shdeps/hooks.d" "$NO_REPO_HOME/.config/shdeps/hooks.d"

result=$(
  HOME="$NO_REPO_HOME" \
    SHDEPS_TEST_TOOL_REPO="$TEST_TOOL_ORIGIN" \
    SHDEPS_HOOK_PACK_REPO="$HOOK_PACK_ORIGIN" \
    "$SCRIPT_DIR/dot" update 2>&1
)
_assert_not_contains "update no-repo: no pull" "Pulling dotfiles" "$result"
_assert_contains "update no-repo: shows installing" "Installing/upgrading" "$result"
_assert_contains "update no-repo: shows done" "Done" "$result"
_assert_file_exists "update no-repo: generic tool installed" "$NO_REPO_HOME/.local/share/test-tool/bin/test-tool"
_assert_file_content "update no-repo: generic hook ran" "$NO_REPO_HOME/.local/share/hook-pack" "$NO_REPO_HOME/.test-hooks/hook-pack"

# ---------------------------------------------------------------------------
# Tests: _is_worktree_dirty
# ---------------------------------------------------------------------------

echo ""
echo "=== Worktree dirty check ==="

# Clean worktree → not dirty
if _is_worktree_dirty; then
  _fail "clean worktree: should not be dirty"
else
  _pass "clean worktree: not dirty"
fi

# Modify a tracked file → dirty
echo "dirty change" >>"$TEST_HOME/.testrc"
if _is_worktree_dirty; then
  _pass "modified file: is dirty"
else
  _fail "modified file: should be dirty"
fi

# Restore clean state
$GIT checkout -- .testrc

# Overlay repo dirty → dirty
OVERLAY_BARE2=$(_tmpdir)
git init --bare "$OVERLAY_BARE2" >/dev/null 2>&1
OVERLAY_DIR="$TEST_HOME/.dotfiles-work"
git clone "$OVERLAY_BARE2" "$OVERLAY_DIR" >/dev/null 2>&1
git -C "$OVERLAY_DIR" config user.email "test@test.com"
git -C "$OVERLAY_DIR" config user.name "Test"
echo "work" >"$OVERLAY_DIR/work-file"
git -C "$OVERLAY_DIR" add work-file
git -C "$OVERLAY_DIR" commit -m "init" >/dev/null 2>&1
git -C "$OVERLAY_DIR" push >/dev/null 2>&1

# Re-discover with overlay present
_discover_overlays

# Clean overlay repo → not dirty
if _is_worktree_dirty; then
  _fail "clean overlay repo: should not be dirty"
else
  _pass "clean overlay repo: not dirty"
fi

# Modify overlay repo file → dirty
echo "dirty" >>"$OVERLAY_DIR/work-file"
if _is_worktree_dirty; then
  _pass "dirty overlay repo: is dirty"
else
  _fail "dirty overlay repo: should be dirty"
fi

git -C "$OVERLAY_DIR" checkout -- work-file
rm -rf "$OVERLAY_DIR" "$OVERLAY_BARE2"

# ---------------------------------------------------------------------------
# Tests: dot update --cron (skip if dirty)
# ---------------------------------------------------------------------------

echo ""
echo "=== Cron mode ==="

# Dirty worktree + --cron → exits immediately (no pull)
echo "dirty" >>"$TEST_HOME/.testrc"
result=$(
  SHDEPS_TEST_TOOL_REPO="$TEST_TOOL_ORIGIN" \
    SHDEPS_HOOK_PACK_REPO="$HOOK_PACK_ORIGIN" \
    "$SCRIPT_DIR/dot" update --cron 2>&1
)
_assert_eq "cron dirty: no output (skipped)" "" "$result"
$GIT checkout -- .testrc

# Clean worktree + --cron → runs but quiet (no "Done" message)
result=$(
  SHDEPS_TEST_TOOL_REPO="$TEST_TOOL_ORIGIN" \
    SHDEPS_HOOK_PACK_REPO="$HOOK_PACK_ORIGIN" \
    "$SCRIPT_DIR/dot" update --cron 2>&1
)
_assert_not_contains "cron clean: no Done message" "Done" "$result"
_assert_not_contains "cron clean: no Pulling message" "Pulling" "$result"

# ---------------------------------------------------------------------------
# Tests: cron file install
# ---------------------------------------------------------------------------

echo ""
echo "=== Cron file install ==="

# Source the cron merge hook so we can call merge() directly.
_CRON_HOOK="$REAL_HOME/.config/dot/merge-hooks.d/50-cron.sh"

_run_cron_merge() {
  unset -f merge 2>/dev/null
  # shellcheck source=/dev/null
  . "$_CRON_HOOK"
  merge
}

# Mock crontab with a file-backed implementation
MOCK_CRONTAB=$(_tmpdir)/crontab
touch "$MOCK_CRONTAB"
MOCK_BIN=$(_mock_bin)
export PATH="$MOCK_BIN:$PATH"
cat >"$MOCK_BIN/crontab" <<CRON
#!/bin/bash
case "\${1:-}" in
  -l) cat "$MOCK_CRONTAB" 2>/dev/null || { echo "no crontab" >&2; exit 1; } ;;
  -r) > "$MOCK_CRONTAB" ;;
  -)  cat > "$MOCK_CRONTAB" ;;
  *)  echo "mock crontab: unknown arg \$1" >&2; exit 1 ;;
esac
CRON
chmod +x "$MOCK_BIN/crontab"

# No cron file → no-op
rm -f "$TEST_HOME/.config/dot/merge-hooks.d/cron"
_run_cron_merge 2>/dev/null
result=$(crontab -l 2>/dev/null)
_assert_eq "no cron file: crontab empty" "" "$result"

# Cron file with one entry → installed
cat >"$TEST_HOME/.config/dot/merge-hooks.d/cron" <<'EOF'
# comment line
*/30 * * * * $HOME/.local/bin/dot update --cron
EOF
_run_cron_merge 2>/dev/null
result=$(crontab -l 2>/dev/null)
_assert_contains "installs entry" "dot update --cron" "$result"
_assert_contains "expands \$HOME" "$TEST_HOME" "$result"
_assert_contains "injects PATH" "PATH=" "$result"
_assert_contains "has begin marker" "dot-managed-cron begin" "$result"
_assert_contains "has end marker" "dot-managed-cron end" "$result"
_assert_not_contains "strips comments" "comment line" "$result"

# Idempotent — running again doesn't duplicate
_run_cron_merge 2>/dev/null
count=$(crontab -l 2>/dev/null | grep -c "dot update --cron" || true)
_assert_eq "idempotent: one entry" "1" "$count"

# Cron file with multiple entries → all installed
cat >"$TEST_HOME/.config/dot/merge-hooks.d/cron" <<'EOF'
*/30 * * * * $HOME/.local/bin/dot update --cron
0 3 * * * $HOME/.local/bin/cleanup
EOF
_run_cron_merge 2>/dev/null
result=$(crontab -l 2>/dev/null)
_assert_contains "multi: dot entry" "dot update --cron" "$result"
_assert_contains "multi: cleanup entry" "cleanup" "$result"

# Preserves non-managed cron entries
echo "0 6 * * * /usr/bin/other-job" | crontab -
cat >"$TEST_HOME/.config/dot/merge-hooks.d/cron" <<'EOF'
*/30 * * * * $HOME/.local/bin/dot update --cron
EOF
_run_cron_merge 2>/dev/null
result=$(crontab -l 2>/dev/null)
_assert_contains "preserves other jobs" "other-job" "$result"
_assert_contains "installs managed entry" "dot update --cron" "$result"

# cron.local entries are merged with cron entries
: >"$MOCK_CRONTAB"
cat >"$TEST_HOME/.config/dot/merge-hooks.d/cron" <<'EOF'
*/30 * * * * $HOME/.local/bin/dot update --cron
EOF
cat >"$TEST_HOME/.config/dot/merge-hooks.d/cron.local" <<'EOF'
0 4 * * * $HOME/.local/bin/backup
EOF
_run_cron_merge 2>/dev/null
result=$(crontab -l 2>/dev/null)
_assert_contains "local: tracked entry present" "dot update --cron" "$result"
_assert_contains "local: local entry present" "backup" "$result"
count=$(crontab -l 2>/dev/null | grep -c "dot-managed-cron begin" || true)
_assert_eq "local: single managed block" "1" "$count"
rm -f "$TEST_HOME/.config/dot/merge-hooks.d/cron.local"

# cron.local alone (no tracked cron file) works
: >"$MOCK_CRONTAB"
rm -f "$TEST_HOME/.config/dot/merge-hooks.d/cron"
cat >"$TEST_HOME/.config/dot/merge-hooks.d/cron.local" <<'EOF'
0 5 * * * $HOME/.local/bin/local-only
EOF
_run_cron_merge 2>/dev/null
result=$(crontab -l 2>/dev/null)
_assert_contains "local-only: entry installed" "local-only" "$result"
rm -f "$TEST_HOME/.config/dot/merge-hooks.d/cron.local"

# Restore cron file for remaining tests
cat >"$TEST_HOME/.config/dot/merge-hooks.d/cron" <<'EOF'
*/30 * * * * $HOME/.local/bin/dot update --cron
EOF

# All-comments cron file strips old managed block
: >"$MOCK_CRONTAB"
cat >"$TEST_HOME/.config/dot/merge-hooks.d/cron" <<'EOF'
*/30 * * * * $HOME/.local/bin/dot update --cron
EOF
_run_cron_merge 2>/dev/null
result=$(crontab -l 2>/dev/null)
_assert_contains "pre-remove: entry exists" "dot update --cron" "$result"
cat >"$TEST_HOME/.config/dot/merge-hooks.d/cron" <<'EOF'
# everything commented out
EOF
_run_cron_merge 2>/dev/null
result=$(crontab -l 2>/dev/null)
_assert_not_contains "remove: old entries stripped" "dot update --cron" "$result"
_assert_not_contains "remove: markers stripped" "dot-managed-cron" "$result"

# All-comments cron file preserves non-managed entries
echo "0 6 * * * /usr/bin/other-job" | crontab -
cat >"$TEST_HOME/.config/dot/merge-hooks.d/cron" <<'EOF'
# only comments here
EOF
_run_cron_merge 2>/dev/null
result=$(crontab -l 2>/dev/null)
_assert_contains "all-comments: preserves other jobs" "other-job" "$result"

# ---------------------------------------------------------------------------
# Tests: cron filter directives
# ---------------------------------------------------------------------------

echo ""
echo "=== Cron filter directives ==="

_current_host=$(hostname -s 2>/dev/null || hostname 2>/dev/null)
_current_host="${_current_host,,}"
_current_os=$(uname -s | tr '[:upper:]' '[:lower:]')
if [[ "$_current_os" == "darwin" ]]; then _current_os="macos"; fi

# Entries before any filter default to all
: >"$MOCK_CRONTAB"
cat >"$TEST_HOME/.config/dot/merge-hooks.d/cron" <<'EOF'
*/30 * * * * $HOME/.local/bin/dot update --cron
EOF
_run_cron_merge 2>/dev/null
result=$(crontab -l 2>/dev/null)
_assert_contains "filter default: entry included" "dot update --cron" "$result"

# Filter skips non-matching host
: >"$MOCK_CRONTAB"
cat >"$TEST_HOME/.config/dot/merge-hooks.d/cron" <<EOF
# filter: hosts=nonexistent-host-xyz
*/30 * * * * \$HOME/.local/bin/dot update --cron
EOF
_run_cron_merge 2>/dev/null
result=$(crontab -l 2>/dev/null)
_assert_not_contains "filter host miss: entry skipped" "dot update --cron" "$result"

# Filter includes matching host
: >"$MOCK_CRONTAB"
cat >"$TEST_HOME/.config/dot/merge-hooks.d/cron" <<EOF
# filter: hosts=$_current_host
*/30 * * * * \$HOME/.local/bin/dot update --cron
EOF
_run_cron_merge 2>/dev/null
result=$(crontab -l 2>/dev/null)
_assert_contains "filter host match: entry included" "dot update --cron" "$result"

# Filter reset with `# filter: *`
: >"$MOCK_CRONTAB"
cat >"$TEST_HOME/.config/dot/merge-hooks.d/cron" <<EOF
# filter: hosts=nonexistent-host-xyz
0 3 * * * \$HOME/.local/bin/skipped
# filter: *
*/30 * * * * \$HOME/.local/bin/dot update --cron
EOF
_run_cron_merge 2>/dev/null
result=$(crontab -l 2>/dev/null)
_assert_not_contains "filter reset: filtered entry skipped" "skipped" "$result"
_assert_contains "filter reset: reset entry included" "dot update --cron" "$result"

# Platform filtering skips non-matching platform
: >"$MOCK_CRONTAB"
if [[ "$_current_os" == "linux" ]]; then
  _wrong_plat="macos"
else
  _wrong_plat="linux"
fi
cat >"$TEST_HOME/.config/dot/merge-hooks.d/cron" <<EOF
# filter: platforms=$_wrong_plat
0 3 * * * \$HOME/.local/bin/wrong-platform
EOF
_run_cron_merge 2>/dev/null
result=$(crontab -l 2>/dev/null)
_assert_not_contains "filter platform miss: entry skipped" "wrong-platform" "$result"

# AND logic: matching host + wrong platform excludes
: >"$MOCK_CRONTAB"
cat >"$TEST_HOME/.config/dot/merge-hooks.d/cron" <<EOF
# filter: hosts=$_current_host platforms=$_wrong_plat
0 3 * * * \$HOME/.local/bin/and-logic
EOF
_run_cron_merge 2>/dev/null
result=$(crontab -l 2>/dev/null)
_assert_not_contains "filter AND: right host + wrong platform skipped" "and-logic" "$result"

# Multiple filter directives: each replaces previous
: >"$MOCK_CRONTAB"
cat >"$TEST_HOME/.config/dot/merge-hooks.d/cron" <<EOF
# filter: hosts=nonexistent-host-xyz
0 1 * * * \$HOME/.local/bin/skipped-entry
# filter: hosts=$_current_host
0 2 * * * \$HOME/.local/bin/included-entry
EOF
_run_cron_merge 2>/dev/null
result=$(crontab -l 2>/dev/null)
_assert_not_contains "filter replace: first section skipped" "skipped-entry" "$result"
_assert_contains "filter replace: second section included" "included-entry" "$result"

# Missing key defaults to * (hosts only → all platforms)
: >"$MOCK_CRONTAB"
cat >"$TEST_HOME/.config/dot/merge-hooks.d/cron" <<EOF
# filter: hosts=$_current_host
*/30 * * * * \$HOME/.local/bin/dot update --cron
EOF
_run_cron_merge 2>/dev/null
result=$(crontab -l 2>/dev/null)
_assert_contains "filter missing key: hosts only, all platforms" "dot update --cron" "$result"

# cron.local filter state independent from cron
: >"$MOCK_CRONTAB"
cat >"$TEST_HOME/.config/dot/merge-hooks.d/cron" <<EOF
# filter: hosts=nonexistent-host-xyz
0 1 * * * \$HOME/.local/bin/cron-filtered
EOF
cat >"$TEST_HOME/.config/dot/merge-hooks.d/cron.local" <<'EOF'
0 2 * * * $HOME/.local/bin/local-unfiltered
EOF
_run_cron_merge 2>/dev/null
result=$(crontab -l 2>/dev/null)
_assert_not_contains "filter independence: cron entry filtered" "cron-filtered" "$result"
_assert_contains "filter independence: local entry unfiltered" "local-unfiltered" "$result"
rm -f "$TEST_HOME/.config/dot/merge-hooks.d/cron.local"

# Exclude syntax in filter
: >"$MOCK_CRONTAB"
cat >"$TEST_HOME/.config/dot/merge-hooks.d/cron" <<EOF
# filter: hosts=!$_current_host
0 3 * * * \$HOME/.local/bin/skip-this-host
# filter: hosts=!nonexistent-host-xyz
0 4 * * * \$HOME/.local/bin/keep-this-host
EOF
_run_cron_merge 2>/dev/null
result=$(crontab -l 2>/dev/null)
_assert_not_contains "filter exclude: current host excluded" "skip-this-host" "$result"
_assert_contains "filter exclude: other host not excluded" "keep-this-host" "$result"

_test_summary

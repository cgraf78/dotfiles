#!/usr/bin/env bash
# ds — connect to (or create) a tmux dev session, locally or on a remote host.
#
# Usage: ds [-p <profile>] [-n <name>] [-b <chatbot>] [-c <method>] [-d <path>] [<hostname>]
#        ds -l            list active ds sessions
#        ds -k [<name>]   kill a ds session
#
# Profiles are pluggable scripts in ~/.config/ds/profile-<name>.sh.
# Each defines a _profile_<name>() function for the tmux layout.
# Built-in profiles: bare (default), dev, orc.

CONF_DIR="${HOME}/.config/ds"
ACTION="session"
PROFILE="bare"
PROFILE_OVERRIDE=""
CHATBOT_OVERRIDE=""
CONNECT_OVERRIDE=""
DIR_OVERRIDE=""
NAME_OVERRIDE=""
KILL_TARGET=""
HOST=""
CONNECT="ssh"
CHATBOT="claude"
DIR="$HOME"
DS_TMUX_SOCKET="${DS_TMUX_SOCKET:-/tmp/ds-shared.sock}"
DS_TMUX_ACCESS_USER="${DS_TMUX_ACCESS_USER:-openclaw}"
DS_SHARE_VIA="${DS_SHARE_VIA:-}"
DS_NO_ATTACH="${DS_NO_ATTACH:-0}"
DS_SHARE_INFO_FILE="${DS_SHARE_INFO_FILE:-}"
DS_UPTERM_HOST="${DS_UPTERM_HOST:-uptermd.upterm.dev:22}"
DS_UPTERM_PRIVATE_KEY="${DS_UPTERM_PRIVATE_KEY:-}"
DS_UPTERM_KNOWN_HOSTS="${DS_UPTERM_KNOWN_HOSTS:-}"
DS_UPTERM_PID_FILE="${DS_UPTERM_PID_FILE:-}"

_usage() {
    echo "Usage: ds [-p <profile>] [-n <name>] [-b <chatbot>] [-c <method>] [-d <path>] [--share-via upterm] [--no-attach] [<hostname>]"
    echo "       ds -l [<hostname>]          list active ds sessions"
    echo "       ds -k [<session>] [<host>]  kill a ds session"
    echo "       ds --killall                kill all ds sessions"
}

# --- Profile layouts ---

_profile_bare() {
    : # default tmux window is already what we want
}

for _profile_file in "$CONF_DIR"/profile-*.sh; do
    # shellcheck source=/dev/null
    [[ -f "$_profile_file" ]] && . "$_profile_file"
done
unset _profile_file

# List valid profile names (derived from discovered _profile_* functions).
_profiles() {
    declare -F | sed -n 's/.*_profile_//p' | sort
}

# --- Host config ---

# Look up a hostname in all ~/.config/ds/hosts* files (additive).
# Sets CONNECT, CHATBOT, and DIR from the first matching entry.
# Returns 1 if no match was found (script defaults apply).
# Hostnames support glob patterns (e.g., server* matches server1, server2).
# CLI overrides (-p, -b, -c, -d) take precedence.
lookup_host() {
    local target="$1"
    local conf_files=("$CONF_DIR"/hosts*)
    [[ -e "${conf_files[0]}" ]] || return 1
    # Search all hosts* files (additive) for a match
    local f
    for f in "${conf_files[@]}"; do
        while read -r name connect chatbot dir; do
            [[ -z "$name" || "$name" == \#* ]] && continue
            # shellcheck disable=SC2053  # intentional glob matching
            if [[ "$target" == $name ]]; then
                CONNECT="$connect"
                CHATBOT="$chatbot"
                [[ -n "$dir" ]] && DIR="${dir/#\~/$HOME}"
                return 0
            fi
        done < "$f"
    done
    return 1
}

# --- Tmux helpers ---

# Run tmux through the ds-managed socket.
_tmux() {
    tmux -S "$DS_TMUX_SOCKET" "$@"
}

# Make the shared socket accessible across users when possible.
_fix_socket_perms() {
    [[ -S "$DS_TMUX_SOCKET" ]] || return 0
    chmod 777 "$DS_TMUX_SOCKET" 2>/dev/null || true
}

# Grant tmux server access to a local user when available.
_fix_server_access() {
    [[ -n "${DS_TMUX_ACCESS_USER:-}" ]] || return 0
    id -u "$DS_TMUX_ACCESS_USER" >/dev/null 2>&1 || return 0
    _tmux server-access -a "$DS_TMUX_ACCESS_USER" 2>/dev/null || true
}

_default_share_info_file() {
    echo "${DS_TMUX_SOCKET}.share"
}

_default_upterm_pid_file() {
    echo "${DS_TMUX_SOCKET}.upterm.pid"
}

_resolve_upterm_key() {
    if [[ -n "${DS_UPTERM_PRIVATE_KEY:-}" && -f "$DS_UPTERM_PRIVATE_KEY" ]]; then
        echo "$DS_UPTERM_PRIVATE_KEY"
        return 0
    fi

    local candidate
    for candidate in \
        "$HOME/.ssh/id_ed25519" \
        "$HOME/.ssh/id_rsa" \
        "$HOME/.ssh/id_ecdsa" \
        "$HOME/.ssh/argus_github_ed25519"
    do
        if [[ -f "$candidate" ]]; then
            echo "$candidate"
            return 0
        fi
    done

    return 1
}

_upterm_running() {
    [[ -n "${DS_UPTERM_PID_FILE:-}" && -f "$DS_UPTERM_PID_FILE" ]] || return 1
    local pid
    pid=$(cat "$DS_UPTERM_PID_FILE" 2>/dev/null || true)
    [[ -n "$pid" ]] || return 1
    kill -0 "$pid" 2>/dev/null
}

_normalize_share_info() {
    local backend="$1"
    local content="$2"

    case "$backend" in
        upterm)
            # Extract the SSH connection command from upterm output.
            # Format: "➤ SSH:\n    ssh SESSION@HOST" or legacy "ssh session: ssh ..."
            local ssh_cmd
            ssh_cmd=$(printf '%s\n' "$content" | grep -E '^\s+ssh\s+\S+@\S+' | head -1 | sed 's/^[[:space:]]*//' || true)
            if [[ -z "$ssh_cmd" ]]; then
                # Try legacy format
                ssh_cmd=$(printf '%s\n' "$content" | sed -n 's/^ssh session: //p' | head -1 || true)
            fi
            if [[ -n "$ssh_cmd" ]]; then
                printf 'ssh: %s\n' "$ssh_cmd"
            else
                printf '%s\n' "$content"
            fi
            ;;
        *)
            printf '%s\n' "$content"
            ;;
    esac
}

_write_share_info() {
    local content="$1"
    [[ -n "${DS_SHARE_INFO_FILE:-}" ]] || return 0
    printf '%s\n' "$content" > "$DS_SHARE_INFO_FILE"
    chmod 644 "$DS_SHARE_INFO_FILE" 2>/dev/null || true
}

_show_share_info() {
    [[ -n "${DS_SHARE_INFO_FILE:-}" && -f "$DS_SHARE_INFO_FILE" ]] || return 0
    cat "$DS_SHARE_INFO_FILE"
}

_default_upterm_admin_file() {
    echo "${DS_TMUX_SOCKET}.upterm-admin"
}

_collect_upterm_share_info() {
    # Background sidecar: waits for the admin socket path file (written by
    # the hosted command), then calls `upterm session current` to get share
    # info and writes it to the share info file.
    local admin_file="$1"
    (
        local admin_sock content
        # Wait for the hosted command to write the admin socket path
        for _ in $(seq 1 30); do
            if [[ -s "$admin_file" ]]; then
                admin_sock=$(cat "$admin_file")
                break
            fi
            sleep 0.5
        done
        [[ -n "${admin_sock:-}" ]] || return 1

        # Poll upterm session current until share info is available
        for _ in $(seq 1 30); do
            content=$(upterm session current --admin-socket "$admin_sock" 2>/dev/null || true)
            if [[ -n "$content" ]]; then
                content=$(_normalize_share_info upterm "$content")
                _write_share_info "$content"
                return 0
            fi
            sleep 0.5
        done
    ) &
}

_upterm_attach() {
    # Run upterm host as the foreground terminal process (replaces _attach).
    # This is the single attachment point — no separate _attach call needed.
    local session="$1"

    if _upterm_running; then
        _show_share_info
        # Upterm is already hosting; just do a normal attach.
        _attach "$session"
        return
    fi

    local key
    key=$(_resolve_upterm_key) || {
        echo "ds: no usable SSH private key found for upterm" >&2
        return 1
    }

    local host_args=(--accept --server "ssh://$DS_UPTERM_HOST" --private-key "$key")
    [[ -n "${DS_UPTERM_KNOWN_HOSTS:-}" ]] && host_args+=(--known-hosts "$DS_UPTERM_KNOWN_HOSTS")

    local admin_file
    admin_file=$(_default_upterm_admin_file)
    rm -f "$admin_file"

    # Start background sidecar to collect share info
    _collect_upterm_share_info "$admin_file"

    # The hosted command writes the UPTERM_ADMIN_SOCKET path to a file so
    # the background sidecar can query share info via `upterm session current`.
    local hosted_cmd="echo \"\$UPTERM_ADMIN_SOCKET\" > '$admin_file'; exec tmux -S '$DS_TMUX_SOCKET' attach -t '=$session'"

    # Run upterm host in the foreground — this IS the user's terminal session.
    env -u TMUX upterm host \
        "${host_args[@]}" \
        --force-command "tmux -S $DS_TMUX_SOCKET attach -t =$session" \
        -- bash -c "$hosted_cmd"
}

# Attach to an existing tmux session, or switch to it if already inside tmux.
# No exec — returns after tmux detaches so the calling shell can exit cleanly.
# This is important for ET connections where exec prevents proper cleanup.
# Uses = prefix for exact session name matching (prevents tmux's default
# prefix matching where "ds" would match "ds-dev").
_attach() {
    local session="$1"
    if [[ -n "${TMUX:-}" ]]; then
        _tmux switch-client -t "=$session"
    else
        _tmux attach -t "=$session"
    fi
}

# Validate that the requested profile exists, or error with valid options.
_validate_profile() {
    if ! declare -f "_profile_$PROFILE" &>/dev/null; then
        echo "ds: unknown profile '$PROFILE'" >&2
        echo "Valid profiles: $(_profiles | tr '\n' ' ')" >&2
        exit 1
    fi
}

# --- Actions ---

_do_list() {
    _tmux ls -F '#{session_name}: #{session_windows} windows (#{?session_attached,attached,detached})' 2>/dev/null \
        | grep -E '^ds' || echo "(no active ds sessions)"
}

_do_kill() {
    local session
    if [[ -n "$KILL_TARGET" ]]; then
        session="$KILL_TARGET"
    else
        session="ds"
        [[ "$PROFILE" != "bare" ]] && session="$session$PROFILE"
        [[ -n "$NAME_OVERRIDE" ]] && session="$session-$NAME_OVERRIDE"
    fi
    if _tmux has-session -t "=$session" 2>/dev/null; then
        _tmux kill-session -t "=$session"
        echo "killed $session"
    else
        echo "ds: no session '$session'" >&2
        _do_list >&2
        exit 1
    fi
}

_do_killall() {
    local sessions
    sessions=$(_tmux ls -F '#{session_name}' 2>/dev/null | grep -E '^ds') || true
    if [[ -z "$sessions" ]]; then
        echo "(no active ds sessions)"
        return
    fi
    echo "$sessions" | while IFS= read -r s; do
        _tmux kill-session -t "=$s"
        echo "killed $s"
    done
}

_do_session() {
    local session="ds"
    [[ "$PROFILE" != "bare" ]] && session="$session$PROFILE"
    [[ -n "$NAME_OVERRIDE" ]] && session="$session-$NAME_OVERRIDE"

    # Attach if session already exists (= prefix for exact match)
    if _tmux has-session -t "=$session" 2>/dev/null; then
        _fix_server_access
        if [[ "$DS_NO_ATTACH" == "1" ]]; then
            return
        fi
        if [[ "${DS_SHARE_VIA:-}" == "upterm" ]]; then
            _upterm_attach "$session"
        else
            _attach "$session"
        fi
        return
    fi

    _tmux new-session -d -s "$session" -c "$DIR"
    _fix_socket_perms
    _fix_server_access
    "_profile_$PROFILE" "$session" "$CHATBOT" "$DIR"
    if [[ "$DS_NO_ATTACH" == "1" ]]; then
        return
    fi
    if [[ "${DS_SHARE_VIA:-}" == "upterm" ]]; then
        _upterm_attach "$session"
    else
        _attach "$session"
    fi
}

# --- Main ---

# Remote dispatch for any action — SSH in and run ds with the same flags.
_remote() {
    lookup_host "$HOST"
    [[ -n "$PROFILE_OVERRIDE" ]] && PROFILE="$PROFILE_OVERRIDE"
    [[ -n "$CONNECT_OVERRIDE" ]] && CONNECT="$CONNECT_OVERRIDE"

    # Build a safely-quoted remote command. Avoids word-splitting/injection when
    # args contain spaces or special chars.
    local args=()

    case "$ACTION" in
        list)
            args+=("-l")
            ;;
        kill)
            args+=("-k")
            if [[ -n "$KILL_TARGET" ]]; then
                args+=("$KILL_TARGET")
            else
                args+=("-p" "$PROFILE")
                [[ -n "$NAME_OVERRIDE" ]] && args+=("-n" "$NAME_OVERRIDE")
            fi
            ;;
        session)
            [[ -n "$CHATBOT_OVERRIDE" ]] && CHATBOT="$CHATBOT_OVERRIDE"
            [[ -n "$DIR_OVERRIDE" ]] && DIR="${DIR_OVERRIDE/#\~/$HOME}"
            # Convert local $HOME prefix to remote ~ for safe expansion on the remote shell
            if [[ "$DIR" == "$HOME"* ]]; then
                REMOTE_DIR="~${DIR#"$HOME"}"
            else
                REMOTE_DIR="$DIR"
            fi
            args+=("-p" "$PROFILE" "-b" "$CHATBOT" "-d" "$REMOTE_DIR")
            [[ -n "$NAME_OVERRIDE" ]] && args+=("-n" "$NAME_OVERRIDE")
            [[ -n "${DS_SHARE_VIA:-}" ]] && args+=("--share-via" "$DS_SHARE_VIA")
            [[ "$DS_NO_ATTACH" == "1" ]] && args+=("--no-attach")
            ;;
    esac

    # Keep ~/ unescaped so the remote shell expands it; only escape the args
    local remote_cmd
    # shellcheck disable=SC2088  # intentional — remote shell expands ~
    remote_cmd="~/.local/bin/ds $(printf '%q ' "${args[@]}")"

    case "$CONNECT" in
        -)       echo "ds: host '$HOST' is local-only (no remote connections)" >&2; exit 1 ;;
        ssh)     exec ssh "$HOST" -t "$remote_cmd" ;;
        autossh) exec autossh -M0 "$HOST" -t "$remote_cmd" ;;
        et)      exec x2ssh -et "$HOST" -c "$remote_cmd" --noexit ;;
        *)       echo "ds: unknown connect method '$CONNECT' for host '$HOST'" >&2; exit 1 ;;
    esac
}

# When sourced for testing, export functions but skip arg parsing and execution.
if [[ -n "${DS_SOURCED:-}" ]]; then
    # shellcheck disable=SC2317
    return 0 2>/dev/null || exit 0
fi

while [[ $# -gt 0 ]]; do
    case "$1" in
        -p|--profile) PROFILE_OVERRIDE="$2"; shift 2 ;;
        -n|--name)    NAME_OVERRIDE="$2"; shift 2 ;;
        -b|--chatbot) CHATBOT_OVERRIDE="$2"; shift 2 ;;
        -c|--connect) CONNECT_OVERRIDE="$2"; shift 2 ;;
        -d|--dir)     DIR_OVERRIDE="$2"; shift 2 ;;
        --share-via)  DS_SHARE_VIA="$2"; shift 2 ;;
        --no-attach)  DS_NO_ATTACH=1; shift ;;
        -l|--list)    ACTION="list"; shift ;;
        -k|--kill)    ACTION="kill"
                      # Optional: next arg is the session name (if not a flag)
                      if [[ $# -gt 1 && "$2" != -* ]]; then
                          KILL_TARGET="$2"; shift
                      fi
                      shift ;;
        --killall)    ACTION="killall"; shift ;;
        -h|--help)    _usage; exit 0 ;;
        -*)           _usage >&2; exit 1 ;;
        *)            HOST="$1"; shift ;;
    esac
done

if [[ -n "$DS_SHARE_VIA" && "$DS_SHARE_VIA" != "upterm" ]]; then
    echo "ds: unsupported share backend '$DS_SHARE_VIA' (supported: upterm)" >&2
    exit 1
fi

if [[ -z "$DS_SHARE_INFO_FILE" ]]; then
    DS_SHARE_INFO_FILE="$(_default_share_info_file)"
fi
if [[ -z "$DS_UPTERM_PID_FILE" ]]; then
    DS_UPTERM_PID_FILE="$(_default_upterm_pid_file)"
fi

if [[ -n "$HOST" ]]; then
    _remote
    exit 0
fi

case "$ACTION" in
  list)
    _do_list
    ;;
  kill)
    _do_kill
    ;;
  killall)
    _do_killall
    ;;
  session)
    lookup_host "$(hostname -s 2>/dev/null || hostname)"
    [[ -n "$PROFILE_OVERRIDE" ]] && PROFILE="$PROFILE_OVERRIDE"
    [[ -n "$CHATBOT_OVERRIDE" ]] && CHATBOT="$CHATBOT_OVERRIDE"
    [[ -n "$DIR_OVERRIDE" ]] && DIR="${DIR_OVERRIDE/#\~/$HOME}"
    _validate_profile
    _do_session
    ;;
esac

#!/bin/bash
# ds — connect to (or create) a tmux dev session, locally or on a remote host.
#
# Usage: ds [-p <profile>] [-n <name>] [-b <chatbot>] [-c <method>] [-d <path>] [<hostname>]
#        ds -l            list active ds sessions
#        ds -k [<name>]   kill a ds session
#
# Profiles define the tmux window/pane layout:
#   bare  — single empty window (default)
#   dev   — chatbot in top pane, bash below, separate bash window
#   orc   — orc in top pane, bash below

CONF_DIR="${HOME}/.config/ds"
ACTION="session"
PROFILE="bare"
PROFILE_OVERRIDE=""
CHATBOT_OVERRIDE=""
CONNECT_OVERRIDE=""
DIR_OVERRIDE=""
NAME_OVERRIDE=""
KILL_TARGET=""
HOST=""
CONNECT="ssh"
CHATBOT="claude"
DIR="$HOME"

_usage() {
    echo "Usage: ds [-p <profile>] [-n <name>] [-b <chatbot>] [-c <method>] [-d <path>] [<hostname>]"
    echo "       ds -l [<hostname>]          list active ds sessions"
    echo "       ds -k [<session>] [<host>]  kill a ds session"
    echo "       ds --killall               kill all ds sessions"
}

while [[ $# -gt 0 ]]; do
    case "$1" in
        -p|--profile) PROFILE_OVERRIDE="$2"; shift 2 ;;
        -n|--name)    NAME_OVERRIDE="$2"; shift 2 ;;
        -b|--chatbot) CHATBOT_OVERRIDE="$2"; shift 2 ;;
        -c|--connect) CONNECT_OVERRIDE="$2"; shift 2 ;;
        -d|--dir)     DIR_OVERRIDE="$2"; shift 2 ;;
        -l|--list)    ACTION="list"; shift ;;
        -k|--kill)    ACTION="kill"
                      # Optional: next arg is the session name (if not a flag)
                      if [[ $# -gt 1 && "$2" != -* ]]; then
                          KILL_TARGET="$2"; shift
                      fi
                      shift ;;
        --killall)    ACTION="killall"; shift ;;
        -h|--help)    _usage; exit 0 ;;
        -*)           _usage >&2; exit 1 ;;
        *)            HOST="$1"; shift ;;
    esac
done

# --- Profile layouts ---
# Each _layout_<name> function receives: $1=session $2=chatbot $3=dir
# The session already exists with a default window when these are called.

# Chatbot in top pane, bash below, separate bash window.
_layout_dev() {
    local session="$1" chatbot="$2" dir="$3"
    tmux rename-window -t "$session:1" "$chatbot"
    tmux send-keys -t "$session:1" "$chatbot" C-m
    tmux split-window -v -t "$session:1" -c "$dir"
    tmux new-window -t "$session" -n bash -c "$dir"
    tmux select-window -t "$session:1"
}

# Single empty window.
_layout_bare() {
    : # default tmux window is already what we want
}

# Orc in top pane, bash below.
_layout_orc() {
    local session="$1" dir="$3"
    tmux rename-window -t "$session:1" "orc"
    tmux send-keys -t "$session:1" "orc --new" C-m
    tmux split-window -v -t "$session:1" -c "$dir"
}

# List valid profile names (derived from _layout_* functions).
_profiles() {
    declare -F | sed -n 's/.*_layout_//p' | sort
}

# --- Host config ---

# Look up a hostname in all ~/.config/ds/hosts*.conf files (additive).
# Sets CONNECT, CHATBOT, DIR, and PROFILE from the first matching entry.
# Returns 1 if no match was found (script defaults apply).
# Hostnames support glob patterns (e.g., server* matches server1, server2).
# CLI overrides (-p, -b, -c, -d) take precedence.
lookup_host() {
    local target="$1"
    local conf_files=("$CONF_DIR"/hosts*.conf)
    [[ -e "${conf_files[0]}" ]] || return 1
    # Search all hosts*.conf files (additive) for a match
    local f
    for f in "${conf_files[@]}"; do
        while read -r name connect chatbot dir profile; do
            [[ -z "$name" || "$name" == \#* ]] && continue
            if [[ "$target" == $name ]]; then
                CONNECT="$connect"
                CHATBOT="$chatbot"
                [[ -n "$dir" ]] && DIR="${dir/#\~/$HOME}"
                [[ -n "$profile" ]] && PROFILE="$profile"
                return 0
            fi
        done < "$f"
    done
    return 1
}

# --- Tmux helpers ---

# Attach to an existing tmux session, or switch to it if already inside tmux.
# No exec — returns after tmux detaches so the calling shell can exit cleanly.
# This is important for ET connections where exec prevents proper cleanup.
_attach() {
    local session="$1"
    if [[ -n "$TMUX" ]]; then
        tmux switch-client -t "$session"
    else
        tmux attach -t "$session"
    fi
}

# Validate that the requested profile exists, or error with valid options.
_validate_profile() {
    if ! declare -f "_layout_$PROFILE" &>/dev/null; then
        echo "ds: unknown profile '$PROFILE'" >&2
        echo "Valid profiles: $(_profiles | tr '\n' ' ')" >&2
        exit 1
    fi
}

# --- Actions ---

_do_list() {
    tmux ls -F '#{session_name}: #{session_windows} windows (#{?session_attached,attached,detached})' 2>/dev/null \
        | grep '^ds-' || echo "(no active ds sessions)"
}

_do_kill() {
    local session
    if [[ -n "$KILL_TARGET" ]]; then
        session="$KILL_TARGET"
    else
        session="ds-$PROFILE"
        [[ -n "$NAME_OVERRIDE" ]] && session="$session-$NAME_OVERRIDE"
    fi
    if tmux has-session -t "$session" 2>/dev/null; then
        tmux kill-session -t "$session"
        echo "killed $session"
    else
        echo "ds: no session '$session'" >&2
        _do_list >&2
        exit 1
    fi
}

_do_killall() {
    local sessions
    sessions=$(tmux ls -F '#{session_name}' 2>/dev/null | grep '^ds-') || true
    if [[ -z "$sessions" ]]; then
        echo "(no active ds sessions)"
        return
    fi
    echo "$sessions" | while IFS= read -r s; do
        tmux kill-session -t "$s"
        echo "killed $s"
    done
}

_do_session() {
    local session="ds-$PROFILE"
    [[ -n "$NAME_OVERRIDE" ]] && session="$session-$NAME_OVERRIDE"

    # Attach if session already exists
    if tmux has-session -t "$session" 2>/dev/null; then
        _attach "$session"
        return
    fi

    # Create session and apply layout
    tmux new-session -d -s "$session" -c "$DIR"
    "_layout_$PROFILE" "$session" "$CHATBOT" "$DIR"
    _attach "$session"
}

# --- Main ---

# Remote dispatch for any action — SSH in and run ds with the same flags.
_remote() {
    lookup_host "$HOST"
    [[ -n "$PROFILE_OVERRIDE" ]] && PROFILE="$PROFILE_OVERRIDE"
    [[ -n "$CONNECT_OVERRIDE" ]] && CONNECT="$CONNECT_OVERRIDE"
    local remote_cmd="\$HOME/.local/bin/ds"
    case "$ACTION" in
        list) remote_cmd="$remote_cmd -l" ;;
        kill) if [[ -n "$KILL_TARGET" ]]; then
                  remote_cmd="$remote_cmd -k $KILL_TARGET"
              else
                  remote_cmd="$remote_cmd -k -p $PROFILE"
                  [[ -n "$NAME_OVERRIDE" ]] && remote_cmd="$remote_cmd -n $NAME_OVERRIDE"
              fi ;;
        session)
            [[ -n "$CHATBOT_OVERRIDE" ]] && CHATBOT="$CHATBOT_OVERRIDE"
            [[ -n "$DIR_OVERRIDE" ]] && DIR="$DIR_OVERRIDE"
            REMOTE_DIR="${DIR/#$HOME/\$HOME}"
            remote_cmd="$remote_cmd -p $PROFILE -b $CHATBOT -d $REMOTE_DIR"
            [[ -n "$NAME_OVERRIDE" ]] && remote_cmd="$remote_cmd -n $NAME_OVERRIDE" ;;
    esac
    case "$CONNECT" in
        -)       echo "ds: host '$HOST' is local-only (no remote connections)" >&2; exit 1 ;;
        ssh)     exec ssh "$HOST" -t "$remote_cmd" ;;
        autossh) exec autossh -M0 "$HOST" -t "$remote_cmd" ;;
        et)      exec x2ssh -et "$HOST" -c "$remote_cmd" --noexit ;;
        *)       echo "ds: unknown connect method '$CONNECT' for host '$HOST'" >&2; exit 1 ;;
    esac
}

if [[ -n "$HOST" ]]; then
    _remote
    exit 0
fi

case "$ACTION" in
  list)
    _do_list
    ;;
  kill)
    _do_kill
    ;;
  killall)
    _do_killall
    ;;
  session)
    lookup_host "$(hostname -s 2>/dev/null || hostname)"
    [[ -n "$PROFILE_OVERRIDE" ]] && PROFILE="$PROFILE_OVERRIDE"
    [[ -n "$CHATBOT_OVERRIDE" ]] && CHATBOT="$CHATBOT_OVERRIDE"
    [[ -n "$DIR_OVERRIDE" ]] && DIR="$DIR_OVERRIDE"
    _validate_profile
    _do_session
    ;;
esac

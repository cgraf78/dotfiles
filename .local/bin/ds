#!/usr/bin/env bash
# ds — connect to (or create) a tmux dev session, locally or on a remote host.
#
# Usage: ds [-p <profile>] [-n <name>] [-c <method>] [<hostname>]
#        ds --share [<session>] [--share-via <backend>]
#        ds --unshare [<session>]
#        ds -l [<hostname>]          list active ds sessions
#        ds -k <session> [<host>]    kill a ds session
#        ds --killall                kill all ds sessions
#        ds init bash                print shell integration snippet
#
# Profiles:    ~/.config/ds/profile-<name>.sh   (define _profile_<name>)
# Connections: ~/.config/ds/connect-<method>.sh  (define _connect_<method>)
# Share:       ~/.config/ds/share-<backend>.sh   (define _share_start, _share_stop, etc.)
# Hosts:       ~/.config/ds/hosts*               (hostname → connect method)

CONF_DIR="${HOME}/.config/ds"
ACTION="session"
PROFILE="bare"
PROFILE_OVERRIDE=""
CONNECT_OVERRIDE=""
NAME_OVERRIDE=""
KILL_TARGET=""
SHARE_TARGET=""
HOST=""
CONNECT="ssh"
INIT_SHELL=""
DS_SHARE_VIA="${DS_SHARE_VIA:-}"
DS_NO_ATTACH="${DS_NO_ATTACH:-0}"
DS_SHARE_INFO_FILE="${DS_SHARE_INFO_FILE:-}"
DS_STATE_DIR="${DS_STATE_DIR:-$HOME/.local/state/ds}"

_usage() {
    echo "Usage: ds [-p <profile>] [-n <name>] [-c <method>] [--share-via <backend>] [<hostname>]"
    echo "       ds --share [<session>] [--share-via <backend>]  share a ds session"
    echo "       ds --unshare [<session>]   stop sharing"
    echo "       ds -l [<hostname>]          list active ds sessions"
    echo "       ds -k <session> [<host>]    kill a ds session"
    echo "       ds --killall                kill all ds sessions"
    echo "       ds init bash                print shell integration snippet"
}

# --- Profile layouts ---

_profile_bare() {
    : # default tmux window is already what we want
}

for _profile_file in "$CONF_DIR"/profile-*.sh; do
    # shellcheck source=/dev/null
    [[ -f "$_profile_file" ]] && . "$_profile_file"
done
unset _profile_file

# List valid profile names (derived from discovered _profile_* functions).
_profiles() {
    declare -F | sed -n 's/.*_profile_//p' | sort
}

# --- Host config ---

# Look up a hostname in all ~/.config/ds/hosts* files (additive).
# Sets CONNECT from the first matching entry.
# Returns 1 if no match was found (script defaults apply).
# Hostnames support glob patterns (e.g., server* matches server1, server2).
lookup_host() {
    local target="$1"
    local conf_files=("$CONF_DIR"/hosts*)
    [[ -e "${conf_files[0]}" ]] || return 1
    local f
    for f in "${conf_files[@]}"; do
        while read -r name connect; do
            [[ -z "$name" || "$name" == \#* ]] && continue
            # shellcheck disable=SC2053  # intentional glob matching
            if [[ "$target" == $name ]]; then
                CONNECT="$connect"
                return 0
            fi
        done < "$f"
    done
    return 1
}

# --- State helpers ---

_ensure_state_dir() {
    mkdir -p "$DS_STATE_DIR"
    chmod 700 "$DS_STATE_DIR" 2>/dev/null || true
}

_state_file_prefix() {
    printf '%s/%s' "$DS_STATE_DIR" "ds"
}

# --- Share interface ---
# Backends are loaded from ~/.config/ds/share-<backend>.sh and must define:
#   _share_start <session>     start sharing
#   _share_stop <session>      stop sharing
#   _share_info                print current share info
#   _share_running             return 0 if sharing is active
#   _share_current_session     print name of shared session
#   _share_load_config         load backend-specific config

_write_share_info() {
    local content="$1"
    [[ -n "${DS_SHARE_INFO_FILE:-}" ]] || return 0
    _ensure_state_dir
    local old_umask
    old_umask=$(umask)
    umask 077
    printf '%s\n' "$content" > "$DS_SHARE_INFO_FILE"
    umask "$old_umask"
    chmod 600 "$DS_SHARE_INFO_FILE" 2>/dev/null || true
}

_show_share_info() {
    [[ -n "${DS_SHARE_INFO_FILE:-}" && -f "$DS_SHARE_INFO_FILE" ]] || return 0
    cat "$DS_SHARE_INFO_FILE"
}

_default_share_info_file() {
    echo "$(_state_file_prefix).share"
}

# Load a share backend plugin. Sets up _share_* functions.
_load_share_backend() {
    local backend="$1"
    local plugin="$CONF_DIR/share-${backend}.sh"
    if [[ ! -f "$plugin" ]]; then
        echo "ds: unknown share backend '$backend' (no plugin at $plugin)" >&2
        exit 1
    fi
    # shellcheck source=/dev/null
    . "$plugin"
}

# Stubs for when no share backend is loaded.
_share_running()         { return 1; }
_share_current_session() { :; }
_share_load_config()     { :; }

# --- Tmux helpers ---

# Attach to an existing tmux session, or switch to it if already inside tmux.
# No exec — returns after tmux detaches so the calling shell can exit cleanly.
# Uses = prefix for exact session name matching.
_attach() {
    local session="$1"
    if [[ -n "${TMUX:-}" ]]; then
        tmux switch-client -t "=$session"
    else
        tmux attach -t "=$session"
    fi
}

# Validate that the requested profile exists, or error with valid options.
_validate_profile() {
    if ! declare -f "_profile_$PROFILE" &>/dev/null; then
        echo "ds: unknown profile '$PROFILE'" >&2
        echo "Valid profiles: $(_profiles | tr '\n' ' ')" >&2
        exit 1
    fi
}

# --- Actions ---

_do_list() {
    local shared_session=""
    if _share_running; then
        shared_session=$(_share_current_session)
    fi
    local all_sessions
    all_sessions=$(tmux ls -F '#{session_name}' 2>/dev/null) || true
    [[ -z "$all_sessions" ]] && { echo "(no active ds sessions)"; return; }
    local output=""
    while IFS= read -r name; do
        if tmux show-environment -t "=$name" DS_MANAGED 2>/dev/null | grep -q '^DS_MANAGED='; then
            local info
            info=$(tmux ls -F '#{session_name}	#{session_windows} windows (#{?session_attached,attached,detached})' \
                | awk -F'\t' -v s="$name" '$1==s{print $2}')
            local line="$name: $info"
            if [[ "$name" == "$shared_session" ]]; then
                line="$line [shared]"
            fi
            output+="$line"$'\n'
        fi
    done <<< "$all_sessions"
    if [[ -z "$output" ]]; then
        echo "(no active ds sessions)"
    else
        printf '%s' "$output"
    fi
}

_do_kill() {
    local session shared_session
    if [[ -n "$KILL_TARGET" ]]; then
        session="$KILL_TARGET"
    else
        echo "ds: session name required (ds -k <session>)" >&2
        _do_list >&2
        exit 1
    fi
    if tmux has-session -t "=$session" 2>/dev/null; then
        # If this session is currently shared, stop sharing first.
        shared_session=$(_share_current_session)
        if [[ "$shared_session" == "$session" ]]; then
            _share_stop "$session" || true
        fi

        tmux kill-session -t "=$session"
        echo "killed $session"
    else
        echo "ds: no session '$session'" >&2
        _do_list >&2
        exit 1
    fi
}

_do_killall() {
    local shared_session
    shared_session=$(_share_current_session)
    if [[ -n "$shared_session" ]]; then
        _share_stop "$shared_session" || true
    fi

    local all_sessions
    all_sessions=$(tmux ls -F '#{session_name}' 2>/dev/null) || true
    [[ -z "$all_sessions" ]] && { echo "(no active ds sessions)"; return; }
    local found=0
    while IFS= read -r s; do
        if tmux show-environment -t "=$s" DS_MANAGED 2>/dev/null | grep -q '^DS_MANAGED='; then
            tmux kill-session -t "=$s"
            echo "killed $s"
            found=1
        fi
    done <<< "$all_sessions"
    if [[ "$found" -eq 0 ]]; then
        echo "(no active ds sessions)"
    fi
}

_do_share() {
    local session="${SHARE_TARGET:-${NAME_OVERRIDE:-ds}}"

    if ! tmux has-session -t "=$session" 2>/dev/null; then
        echo "ds: no session '$session' to share" >&2
        _do_list >&2
        return 1
    fi

    _share_start "$session"
}

_do_unshare() {
    local session="${SHARE_TARGET:-${NAME_OVERRIDE:-ds}}"
    _share_stop "$session"
}

_do_session() {
    local session="${NAME_OVERRIDE:-ds}"

    # Attach if session already exists (= prefix for exact match)
    if tmux has-session -t "=$session" 2>/dev/null; then
        if [[ -n "${DS_SHARE_VIA:-}" ]]; then
            _share_start "$session"
        fi
        if [[ "$DS_NO_ATTACH" == "1" ]]; then
            return
        fi
        _attach "$session"
        return
    fi

    tmux new-session -d -s "$session"
    tmux set-environment -t "$session" DS_MANAGED 1
    "_profile_$PROFILE" "$session"
    if [[ -n "${DS_SHARE_VIA:-}" ]]; then
        _share_start "$session"
    fi
    if [[ "$DS_NO_ATTACH" == "1" ]]; then
        return
    fi
    _attach "$session"
}

_do_init() {
    local shell="${1:-}"
    if [[ "$shell" != "bash" ]]; then
        echo "ds: unsupported shell '$shell' (supported: bash)" >&2
        exit 1
    fi

    # Profile shortcut functions
    local profile_file profile_name
    for profile_file in "$CONF_DIR"/profile-*.sh; do
        [[ -f "$profile_file" ]] || continue
        profile_name="${profile_file##*/profile-}"
        profile_name="${profile_name%.sh}"
        printf 'ds%s() { ds -p %s -n ds%s "$@"; }\n' "$profile_name" "$profile_name" "$profile_name"
    done

    # Auto-attach on SSH login
    cat <<'INIT_EOF'

# ET connect: LC_DS_ATTACH carries ds args via SSH env forwarding
if [[ $- == *i* && -n "$LC_DS_ATTACH" ]]; then
    _ds_args="$LC_DS_ATTACH"
    unset LC_DS_ATTACH
    # shellcheck disable=SC2086
    exec ds $_ds_args
fi

# Auto-attach to ds on SSH login (skip with NO_TMUX=1)
if [[ -z "$TMUX" && $- == *i* && -n "$SSH_CONNECTION" && -z "$NO_TMUX" ]] && command -v tmux &>/dev/null; then
    exec ds
fi
INIT_EOF
}

# --- Remote dispatch ---

_remote() {
    lookup_host "$HOST"
    [[ -n "$PROFILE_OVERRIDE" ]] && PROFILE="$PROFILE_OVERRIDE"
    [[ -n "$CONNECT_OVERRIDE" ]] && CONNECT="$CONNECT_OVERRIDE"

    # Build a safely-quoted remote command.
    local args=()

    case "$ACTION" in
        list)
            args+=("-l")
            ;;
        kill)
            args+=("-k" "$KILL_TARGET")
            ;;
        session)
            args+=("-p" "$PROFILE")
            [[ -n "$NAME_OVERRIDE" ]] && args+=("-n" "$NAME_OVERRIDE")
            [[ -n "${DS_SHARE_VIA:-}" ]] && args+=("--share-via" "$DS_SHARE_VIA")
            [[ "$DS_NO_ATTACH" == "1" ]] && args+=("--no-attach")
            ;;
    esac

    # Wrap in bash -lc so the remote login profile is sourced.
    local remote_cmd
    # shellcheck disable=SC2088  # intentional — remote shell expands ~
    remote_cmd="NO_TMUX=1 bash -lc '~/.local/bin/ds $(printf '%q ' "${args[@]}")'"

    case "$CONNECT" in
        -)   echo "ds: host '$HOST' is local-only (no remote connections)" >&2; exit 1 ;;
        ssh) exec ssh "$HOST" -t "$remote_cmd" ;;
        *)
            local plugin="$CONF_DIR/connect-${CONNECT}.sh"
            if [[ -f "$plugin" ]]; then
                # shellcheck source=/dev/null
                . "$plugin"
                "_connect_${CONNECT}" "$HOST" "$remote_cmd" "${NAME_OVERRIDE:-ds}" "$ACTION" "${args[*]}"
            else
                echo "ds: unknown connect method '$CONNECT' (no plugin at $plugin)" >&2
                exit 1
            fi
            ;;
    esac
}

# --- Main ---

# When sourced for testing, export functions but skip arg parsing and execution.
if [[ -n "${DS_SOURCED:-}" ]]; then
    # shellcheck disable=SC2317
    return 0 2>/dev/null || exit 0
fi

while [[ $# -gt 0 ]]; do
    case "$1" in
        -p|--profile) PROFILE_OVERRIDE="$2"; shift 2 ;;
        -n|--name)    NAME_OVERRIDE="$2"; shift 2 ;;
        -c|--connect) CONNECT_OVERRIDE="$2"; shift 2 ;;
        --share-via)  DS_SHARE_VIA="$2"; shift 2 ;;
        --share)      ACTION="share"
                      if [[ $# -gt 1 && "$2" != -* ]]; then
                          SHARE_TARGET="$2"; shift
                      fi
                      shift ;;
        --unshare)    ACTION="unshare"
                      if [[ $# -gt 1 && "$2" != -* ]]; then
                          SHARE_TARGET="$2"; shift
                      fi
                      shift ;;
        --no-attach)  DS_NO_ATTACH=1; shift ;;
        -l|--list)    ACTION="list"; shift ;;
        -k|--kill)    ACTION="kill"
                      if [[ $# -gt 1 && "$2" != -* ]]; then
                          KILL_TARGET="$2"; shift
                      fi
                      shift ;;
        --killall)    ACTION="killall"; shift ;;
        init)         ACTION="init"
                      if [[ $# -gt 1 ]]; then
                          INIT_SHELL="$2"; shift
                      fi
                      shift ;;
        -h|--help)    _usage; exit 0 ;;
        -*)           _usage >&2; exit 1 ;;
        *)            HOST="$1"; shift ;;
    esac
done

_ensure_state_dir

if [[ -z "$DS_SHARE_INFO_FILE" ]]; then
    DS_SHARE_INFO_FILE="$(_default_share_info_file)"
fi

# Load share backend if requested (by flag or for actions that need it)
if [[ -n "$DS_SHARE_VIA" ]]; then
    _load_share_backend "$DS_SHARE_VIA"
    _share_load_config
elif [[ "$ACTION" == "share" || "$ACTION" == "unshare" || "$ACTION" == "list" \
     || "$ACTION" == "kill" || "$ACTION" == "killall" ]]; then
    # Auto-detect active backend from state directory
    for _sb in "$CONF_DIR"/share-*.sh; do
        [[ -f "$_sb" ]] || continue
        _sbn="${_sb##*/share-}"; _sbn="${_sbn%.sh}"
        # shellcheck source=/dev/null
        . "$_sb"
        if _share_running 2>/dev/null; then
            DS_SHARE_VIA="$_sbn"
            _share_load_config
            break
        fi
        # Reset stubs if this backend isn't active
        _share_running()         { return 1; }
        _share_current_session() { :; }
        _share_load_config()     { :; }
    done
    unset _sb _sbn
fi

if [[ -n "$HOST" ]]; then
    _remote
    exit 0
fi

case "$ACTION" in
  init)
    _do_init "$INIT_SHELL"
    ;;
  list)
    _do_list
    ;;
  kill)
    _do_kill
    ;;
  killall)
    _do_killall
    ;;
  share)
    if [[ -z "$DS_SHARE_VIA" ]]; then
        # Auto-select if exactly one share backend is installed
        _backends=()
        for _sb in "$CONF_DIR"/share-*.sh; do
            [[ -f "$_sb" ]] || continue
            _sbn="${_sb##*/share-}"; _sbn="${_sbn%.sh}"
            _backends+=("$_sbn")
        done
        if [[ ${#_backends[@]} -eq 1 ]]; then
            DS_SHARE_VIA="${_backends[0]}"
            _load_share_backend "$DS_SHARE_VIA"
            _share_load_config
        else
            echo "ds: --share-via <backend> required (available: ${_backends[*]:-none})" >&2
            exit 1
        fi
        unset _backends _sb _sbn
    fi
    _do_share
    ;;
  unshare)
    _do_unshare
    ;;
  session)
    [[ -n "$PROFILE_OVERRIDE" ]] && PROFILE="$PROFILE_OVERRIDE"
    _validate_profile
    _do_session
    ;;
esac

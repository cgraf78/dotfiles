#!/usr/bin/env bash
# ds — connect to (or create) a tmux dev session, locally or on a remote host.
#
# Usage: ds [-p <profile>] [-n <name>] [-b <chatbot>] [-c <method>] [-d <path>] [<hostname>]
#        ds -l            list active ds sessions
#        ds -k [<name>]   kill a ds session
#
# Profiles are pluggable scripts in ~/.config/ds/profile-<name>.sh.
# Each defines a _profile_<name>() function for the tmux layout.
# Built-in profiles: bare (default), dev, orc.

CONF_DIR="${HOME}/.config/ds"
ACTION="session"
PROFILE="bare"
PROFILE_OVERRIDE=""
CHATBOT_OVERRIDE=""
CONNECT_OVERRIDE=""
DIR_OVERRIDE=""
NAME_OVERRIDE=""
KILL_TARGET=""
SHARE_TARGET=""
HOST=""
CONNECT="ssh"
CHATBOT="claude"
DIR="$HOME"
DS_SHARE_VIA="${DS_SHARE_VIA:-}"
DS_NO_ATTACH="${DS_NO_ATTACH:-0}"
DS_SHARE_INFO_FILE="${DS_SHARE_INFO_FILE:-}"
DS_UPTERM_HOST="${DS_UPTERM_HOST:-uptermd.upterm.dev:22}"
DS_UPTERM_PRIVATE_KEY="${DS_UPTERM_PRIVATE_KEY:-}"
DS_UPTERM_KNOWN_HOSTS="${DS_UPTERM_KNOWN_HOSTS:-}"
DS_UPTERM_PID_FILE="${DS_UPTERM_PID_FILE:-}"
DS_SHARE_PUSH="${DS_SHARE_PUSH:-}"
DS_UPTERM_GITHUB_USER="${DS_UPTERM_GITHUB_USER:-}"
DS_STATE_DIR="${DS_STATE_DIR:-$HOME/.local/state/ds}"

_usage() {
    echo "Usage: ds [-p <profile>] [-n <name>] [-b <chatbot>] [-c <method>] [-d <path>] [--share-via upterm] [--push user@host] [<hostname>]"
    echo "       ds --share [<session>] [--push user@host]  share a ds session via upterm (one at a time)"
    echo "       ds --unshare                stop sharing the current shared session"
    echo "       ds -l [<hostname>]          list active ds sessions"
    echo "       ds -k [<session>] [<host>]  kill a ds session"
    echo "       ds --killall                kill all ds sessions"
}

# --- Profile layouts ---

_profile_bare() {
    : # default tmux window is already what we want
}

for _profile_file in "$CONF_DIR"/profile-*.sh; do
    # shellcheck source=/dev/null
    [[ -f "$_profile_file" ]] && . "$_profile_file"
done
unset _profile_file

# List valid profile names (derived from discovered _profile_* functions).
_profiles() {
    declare -F | sed -n 's/.*_profile_//p' | sort
}

# --- Host config ---

# Look up a hostname in all ~/.config/ds/hosts* files (additive).
# Sets CONNECT, CHATBOT, and DIR from the first matching entry.
# Returns 1 if no match was found (script defaults apply).
# Hostnames support glob patterns (e.g., server* matches server1, server2).
# CLI overrides (-p, -b, -c, -d) take precedence.
lookup_host() {
    local target="$1"
    local conf_files=("$CONF_DIR"/hosts*)
    [[ -e "${conf_files[0]}" ]] || return 1
    # Search all hosts* files (additive) for a match
    local f
    for f in "${conf_files[@]}"; do
        while read -r name connect chatbot dir; do
            [[ -z "$name" || "$name" == \#* ]] && continue
            # shellcheck disable=SC2053  # intentional glob matching
            if [[ "$target" == $name ]]; then
                CONNECT="$connect"
                CHATBOT="$chatbot"
                [[ -n "$dir" ]] && DIR="${dir/#\~/$HOME}"
                return 0
            fi
        done < "$f"
    done
    return 1
}

# --- Tmux helpers ---

_ensure_state_dir() {
    mkdir -p "$DS_STATE_DIR"
    chmod 700 "$DS_STATE_DIR" 2>/dev/null || true
}

_state_file_prefix() {
    printf '%s/%s' "$DS_STATE_DIR" "ds"
}

_default_share_info_file() {
    echo "$(_state_file_prefix).share"
}

_default_upterm_pid_file() {
    echo "$(_state_file_prefix).upterm.pid"
}

_default_upterm_session_file() {
    echo "$(_state_file_prefix).upterm.session"
}

# Return the name of the currently shared session (if any).
_upterm_shared_session() {
    local f
    f=$(_default_upterm_session_file)
    if [[ -f "$f" ]]; then
        cat "$f"
    fi
}

_resolve_upterm_key() {
    if [[ -n "${DS_UPTERM_PRIVATE_KEY:-}" && -f "$DS_UPTERM_PRIVATE_KEY" ]]; then
        echo "$DS_UPTERM_PRIVATE_KEY"
        return 0
    fi

    local candidate
    for candidate in \
        "$HOME/.ssh/id_ed25519" \
        "$HOME/.ssh/id_rsa" \
        "$HOME/.ssh/id_ecdsa" \
        "$HOME/.ssh/argus_github_ed25519"
    do
        if [[ -f "$candidate" ]]; then
            echo "$candidate"
            return 0
        fi
    done

    return 1
}

_upterm_running() {
    [[ -n "${DS_UPTERM_PID_FILE:-}" && -f "$DS_UPTERM_PID_FILE" ]] || return 1
    local pid
    pid=$(cat "$DS_UPTERM_PID_FILE" 2>/dev/null || true)
    [[ "$pid" =~ ^[0-9]+$ ]] || return 1
    kill -0 "$pid" 2>/dev/null
}

_normalize_share_info() {
    local backend="$1"
    local content="$2"

    case "$backend" in
        upterm)
            # Extract the SSH connection command from upterm output.
            # Supports multiple formats, including:
            # - "➤ SSH:\n    ssh SESSION@HOST"
            # - "ssh session: ssh SESSION@HOST"
            # - "Command: ssh SESSION@HOST"
            local ssh_cmd
            ssh_cmd=$(printf '%s\n' "$content" | grep -E '^\s+ssh\s+\S+@\S+' | head -1 | sed 's/^[[:space:]]*//' || true)
            if [[ -z "$ssh_cmd" ]]; then
                # Legacy format
                ssh_cmd=$(printf '%s\n' "$content" | sed -n 's/^ssh session: //p' | head -1 || true)
            fi
            if [[ -z "$ssh_cmd" ]]; then
                # Generic fallback: pick first ssh user@host command in the text
                ssh_cmd=$(printf '%s\n' "$content" | grep -Eo 'ssh[[:space:]]+[^[:space:]]+@[^[:space:]]+' | head -1 || true)
            fi
            if [[ -n "$ssh_cmd" ]]; then
                printf 'ssh: %s\n' "$ssh_cmd"
            else
                printf '%s\n' "$content"
            fi
            ;;
        *)
            printf '%s\n' "$content"
            ;;
    esac
}

_write_share_info() {
    local content="$1"
    [[ -n "${DS_SHARE_INFO_FILE:-}" ]] || return 0
    _ensure_state_dir
    local old_umask
    old_umask=$(umask)
    umask 077
    printf '%s\n' "$content" > "$DS_SHARE_INFO_FILE"
    umask "$old_umask"
    chmod 600 "$DS_SHARE_INFO_FILE" 2>/dev/null || true
}

_show_share_info() {
    [[ -n "${DS_SHARE_INFO_FILE:-}" && -f "$DS_SHARE_INFO_FILE" ]] || return 0
    cat "$DS_SHARE_INFO_FILE"
}

_read_share_info_from_upterm_log() {
    local log_file="$1"
    [[ -s "$log_file" ]] || return 1

    local raw normalized
    raw=$(cat "$log_file" 2>/dev/null || true)
    [[ -n "$raw" ]] || return 1

    normalized=$(_normalize_share_info upterm "$raw")
    if [[ "$normalized" == ssh:* ]]; then
        printf '%s\n' "$normalized"
        return 0
    fi

    return 1
}

# Load share push target from config file if not set via env/flag.
_load_share_config() {
    local conf="$CONF_DIR/share"
    [[ -f "$conf" ]] || return 0
    while IFS='=' read -r key val; do
        key=$(echo "$key" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
        val=$(echo "$val" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
        [[ -z "$key" || "$key" == \#* ]] && continue
        case "$key" in
            push) [[ -z "$DS_SHARE_PUSH" ]] && DS_SHARE_PUSH="$val" ;;
            github-user) [[ -z "$DS_UPTERM_GITHUB_USER" ]] && DS_UPTERM_GITHUB_USER="$val" ;;
        esac
    done < "$conf"
}

# Push share info to a remote host via SCP.
# Target format: user@host (share file goes to ~/.ds/shares/SRCHOST-SESSION.share)
_push_share_info() {
    local session="$1"
    [[ -n "$DS_SHARE_PUSH" ]] || return 0
    [[ -n "${DS_SHARE_INFO_FILE:-}" && -f "$DS_SHARE_INFO_FILE" ]] || return 0

    local src_host
    src_host=$(hostname -s 2>/dev/null || hostname)
    local remote_dir=".ds/shares"
    local remote_file="${src_host}-${session}.share"
    local escaped_dir escaped_file
    escaped_dir=$(printf '%q' "$remote_dir")
    escaped_file=$(printf '%q' "$remote_file")

    # Ensure remote directory exists, then copy
    ssh -o BatchMode=yes -o ConnectTimeout=5 "$DS_SHARE_PUSH" "mkdir -p ~/$escaped_dir" 2>/dev/null || {
        echo "ds: failed to create remote share dir on $DS_SHARE_PUSH" >&2
        return 1
    }
    scp -o BatchMode=yes -o ConnectTimeout=5 -q \
        "$DS_SHARE_INFO_FILE" "$DS_SHARE_PUSH:~/$remote_dir/$remote_file" 2>/dev/null || {
        echo "ds: failed to push share info to $DS_SHARE_PUSH" >&2
        return 1
    }
    echo "ds: pushed share info to $DS_SHARE_PUSH:~/$remote_dir/$remote_file"
}

# Remove share info from a remote host.
_unpush_share_info() {
    local session="$1"
    [[ -n "$DS_SHARE_PUSH" ]] || return 0

    local src_host
    src_host=$(hostname -s 2>/dev/null || hostname)
    local remote_file=".ds/shares/${src_host}-${session}.share"
    local escaped_file
    escaped_file=$(printf '%q' "$remote_file")

    ssh -o BatchMode=yes -o ConnectTimeout=5 "$DS_SHARE_PUSH" "rm -f ~/$escaped_file" 2>/dev/null || true
}

_default_upterm_admin_file() {
    echo "$(_state_file_prefix).upterm-admin"
}

_default_upterm_log_file() {
    echo "$(_state_file_prefix).upterm.log"
}

_is_wsl() {
    grep -qiE '(microsoft|wsl)' /proc/version 2>/dev/null
}

# Start upterm as a fully detached daemon process. It runs independently of
# the user's terminal, so attaching/detaching from tmux doesn't affect it.
# The daemon hosts the tmux session and writes share info to a file.
# Only one session can be shared at a time (single PID/share file set).
# To share a different session, --unshare first.
_start_upterm_daemon() {
    local session="$1"

    if _upterm_running; then
        local current_session
        current_session=$(_upterm_shared_session)
        if [[ "$current_session" == "$session" ]]; then
            echo "ds: already sharing session '$session'"
            _show_share_info
            return 0
        else
            echo "ds: already sharing session '${current_session:-unknown}' — run 'ds --unshare' first" >&2
            return 1
        fi
    fi

    local key
    key=$(_resolve_upterm_key) || {
        echo "ds: no usable SSH private key found for upterm" >&2
        return 1
    }

    if [[ -z "${DS_UPTERM_GITHUB_USER:-}" ]]; then
        echo "" >&2
        echo "  WARNING: No --github-user set. Anyone with the share URL" >&2
        echo "  will have full access to your terminal session." >&2
        echo "" >&2
        read -r -p "  Share without authentication? [y/N] " answer </dev/tty
        if [[ "$answer" != [yY] ]]; then
            echo "ds: aborted — use --github-user or set github-user in ~/.config/ds/share" >&2
            return 1
        fi
    fi

    local host_args=(--accept --server "ssh://$DS_UPTERM_HOST" --skip-host-key-check --private-key "$key")
    [[ -n "${DS_UPTERM_KNOWN_HOSTS:-}" ]] && host_args+=(--known-hosts "$DS_UPTERM_KNOWN_HOSTS")
    [[ -n "${DS_UPTERM_GITHUB_USER:-}" ]] && host_args+=(--github-user "$DS_UPTERM_GITHUB_USER")

    _ensure_state_dir

    local admin_file log_file
    admin_file=$(_default_upterm_admin_file)
    log_file=$(_default_upterm_log_file)
    rm -f "$admin_file" "$log_file"

    # Record which session is being shared
    local old_umask
    old_umask=$(umask)
    umask 077
    : > "$log_file"
    echo "$session" > "$(_default_upterm_session_file)"
    umask "$old_umask"

    # Fully detach upterm from the controlling terminal.
    # The hosted command writes the admin socket path to a file and sleeps.
    # PID is tracked from the parent launcher process ($!).
    local hosted_cmd force_cmd
    hosted_cmd="umask 077; echo \"\$UPTERM_ADMIN_SOCKET\" > '$admin_file'; while true; do sleep 86400; done"
    local escaped_session
    escaped_session=$(printf '%q' "$session")
    force_cmd="bash -lc \"tmux attach -t =$escaped_session || tmux attach -t $escaped_session\""

    local upterm_pid
    if command -v setsid >/dev/null 2>&1 && ! _is_wsl; then
        setsid env -u TMUX upterm host \
            "${host_args[@]}" \
            --force-command "$force_cmd" \
            -- bash -c "$hosted_cmd" \
            </dev/null >>"$log_file" 2>&1 &
        upterm_pid=$!
    else
        # macOS/WSL: use nohup + background for more reliable process behavior.
        nohup env -u TMUX upterm host \
            "${host_args[@]}" \
            --force-command "$force_cmd" \
            -- bash -c "$hosted_cmd" \
            </dev/null >>"$log_file" 2>&1 &
        upterm_pid=$!
    fi

    if [[ -n "${upterm_pid:-}" ]]; then
        umask 077
        echo "$upterm_pid" > "$DS_UPTERM_PID_FILE"
        umask "$old_umask"
    fi

    # Wait for the admin socket file to appear, then collect share info.
    # Some platforms (e.g., WSL) may not expose UPTERM_ADMIN_SOCKET in the
    # hosted command environment; in that case, fall back to parsing host logs.
    local admin_sock content
    for _ in $(seq 1 30); do
        if [[ -s "$admin_file" ]]; then
            admin_sock=$(cat "$admin_file")
            break
        fi
        sleep 0.5
    done

    if [[ -z "${admin_sock:-}" ]]; then
        # Fallback: parse host output log for the ssh share command.
        if content=$(_read_share_info_from_upterm_log "$log_file"); then
            _write_share_info "$content"
            printf '%s\n' "$content"
            return 0
        fi

        echo "ds: timed out waiting for upterm share info (admin socket unavailable; log: $log_file)" >&2
        return 1
    fi

    for _ in $(seq 1 30); do
        content=$(upterm session current --admin-socket "$admin_sock" 2>/dev/null || true)
        if [[ -n "$content" ]]; then
            content=$(_normalize_share_info upterm "$content")
            _write_share_info "$content"
            printf '%s\n' "$content"
            return 0
        fi
        sleep 0.5
    done

    # Fallback in case session-current fails but host output contains the SSH command.
    if content=$(_read_share_info_from_upterm_log "$log_file"); then
        _write_share_info "$content"
        printf '%s\n' "$content"
        return 0
    fi

    echo "ds: upterm started but couldn't retrieve share info (log: $log_file)" >&2
    return 1
}

# Stop the upterm daemon and clean up state files.
_stop_upterm_daemon() {
    if _upterm_running; then
        local pid
        pid=$(cat "$DS_UPTERM_PID_FILE" 2>/dev/null || true)
        if [[ "$pid" =~ ^[0-9]+$ ]]; then
            kill "$pid" 2>/dev/null || true
            # Also kill the process group in case setsid created one
            kill -TERM -"$pid" 2>/dev/null || true
        fi
        echo "ds: stopped sharing"
    else
        echo "ds: not currently sharing"
    fi
    rm -f "$DS_UPTERM_PID_FILE" "$DS_SHARE_INFO_FILE" "$(_default_upterm_admin_file)" "$(_default_upterm_session_file)" "$(_default_upterm_log_file)"
}

# Share an existing ds session (workflow 2: share after the fact).
_do_share() {
    local session
    if [[ -n "$SHARE_TARGET" ]]; then
        session="$SHARE_TARGET"
    else
        session="ds"
        [[ "$PROFILE" != "bare" ]] && session="$session$PROFILE"
        [[ -n "$NAME_OVERRIDE" ]] && session="$session-$NAME_OVERRIDE"
    fi

    if ! tmux has-session -t "=$session" 2>/dev/null; then
        echo "ds: no session '$session' to share" >&2
        _do_list >&2
        return 1
    fi

    if _start_upterm_daemon "$session"; then
        _push_share_info "$session"
    fi
}

# Unshare (stop sharing) a ds session.
_do_unshare() {
    local session
    if [[ -n "${SHARE_TARGET:-}" ]]; then
        session="$SHARE_TARGET"
    else
        session="ds"
        [[ "$PROFILE" != "bare" ]] && session="$session$PROFILE"
        [[ -n "$NAME_OVERRIDE" ]] && session="$session-$NAME_OVERRIDE"
    fi
    _stop_upterm_daemon
    _unpush_share_info "$session"
}

# Attach to an existing tmux session, or switch to it if already inside tmux.
# No exec — returns after tmux detaches so the calling shell can exit cleanly.
# This is important for ET connections where exec prevents proper cleanup.
# Uses = prefix for exact session name matching (prevents tmux's default
# prefix matching where "ds" would match "ds-dev").
_attach() {
    local session="$1"
    if [[ -n "${TMUX:-}" ]]; then
        tmux switch-client -t "=$session"
    else
        tmux attach -t "=$session"
    fi
}

# Validate that the requested profile exists, or error with valid options.
_validate_profile() {
    if ! declare -f "_profile_$PROFILE" &>/dev/null; then
        echo "ds: unknown profile '$PROFILE'" >&2
        echo "Valid profiles: $(_profiles | tr '\n' ' ')" >&2
        exit 1
    fi
}

# --- Actions ---

_do_list() {
    local shared_session=""
    if _upterm_running; then
        shared_session=$(_upterm_shared_session)
    fi
    local output
    output=$(tmux ls -F '#{session_name}: #{session_windows} windows (#{?session_attached,attached,detached})' 2>/dev/null \
        | grep -E '^ds' || true)
    if [[ -z "$output" ]]; then
        echo "(no active ds sessions)"
        return
    fi
    while IFS= read -r line; do
        local name="${line%%:*}"
        if [[ "$name" == "$shared_session" ]]; then
            echo "$line [shared]"
        else
            echo "$line"
        fi
    done <<< "$output"
}

_do_kill() {
    local session shared_session
    if [[ -n "$KILL_TARGET" ]]; then
        session="$KILL_TARGET"
    else
        session="ds"
        [[ "$PROFILE" != "bare" ]] && session="$session$PROFILE"
        [[ -n "$NAME_OVERRIDE" ]] && session="$session-$NAME_OVERRIDE"
    fi
    if tmux has-session -t "=$session" 2>/dev/null; then
        # If this session is currently shared, stop sharing first (best-effort)
        # so we don't leave stale share state behind.
        shared_session=$(_upterm_shared_session)
        if [[ "$shared_session" == "$session" ]]; then
            _stop_upterm_daemon || true
            _unpush_share_info "$session" || true
        fi

        tmux kill-session -t "=$session"
        echo "killed $session"
    else
        echo "ds: no session '$session'" >&2
        _do_list >&2
        exit 1
    fi
}

_do_killall() {
    local sessions shared_session

    # Best-effort share cleanup: if a session is currently shared, stop sharing
    # first so we don't leave stale share state after killing all sessions.
    shared_session=$(_upterm_shared_session)
    if [[ -n "$shared_session" ]]; then
        _stop_upterm_daemon || true
        _unpush_share_info "$shared_session" || true
    fi

    sessions=$(tmux ls -F '#{session_name}' 2>/dev/null | grep -E '^ds') || true
    if [[ -z "$sessions" ]]; then
        echo "(no active ds sessions)"
        return
    fi
    echo "$sessions" | while IFS= read -r s; do
        tmux kill-session -t "=$s"
        echo "killed $s"
    done
}

_do_session() {
    local session="ds"
    [[ "$PROFILE" != "bare" ]] && session="$session$PROFILE"
    [[ -n "$NAME_OVERRIDE" ]] && session="$session-$NAME_OVERRIDE"

    # Attach if session already exists (= prefix for exact match)
    if tmux has-session -t "=$session" 2>/dev/null; then
        # Start upterm daemon if --share-via upterm (idempotent)
        if [[ "${DS_SHARE_VIA:-}" == "upterm" ]]; then
            if _start_upterm_daemon "$session"; then
                _push_share_info "$session"
            fi
        fi
        if [[ "$DS_NO_ATTACH" == "1" ]]; then
            return
        fi
        _attach "$session"
        return
    fi

    tmux new-session -d -s "$session" -c "$DIR"
    "_profile_$PROFILE" "$session" "$CHATBOT" "$DIR"
    # Start upterm daemon if --share-via upterm
    if [[ "${DS_SHARE_VIA:-}" == "upterm" ]]; then
        if _start_upterm_daemon "$session"; then
            _push_share_info "$session"
        fi
    fi
    if [[ "$DS_NO_ATTACH" == "1" ]]; then
        return
    fi
    _attach "$session"
}

# --- Main ---

# Remote dispatch for any action — SSH in and run ds with the same flags.
_remote() {
    lookup_host "$HOST"
    [[ -n "$PROFILE_OVERRIDE" ]] && PROFILE="$PROFILE_OVERRIDE"
    [[ -n "$CONNECT_OVERRIDE" ]] && CONNECT="$CONNECT_OVERRIDE"

    # Build a safely-quoted remote command. Avoids word-splitting/injection when
    # args contain spaces or special chars.
    local args=()

    case "$ACTION" in
        list)
            args+=("-l")
            ;;
        kill)
            args+=("-k")
            if [[ -n "$KILL_TARGET" ]]; then
                args+=("$KILL_TARGET")
            else
                args+=("-p" "$PROFILE")
                [[ -n "$NAME_OVERRIDE" ]] && args+=("-n" "$NAME_OVERRIDE")
            fi
            ;;
        session)
            [[ -n "$CHATBOT_OVERRIDE" ]] && CHATBOT="$CHATBOT_OVERRIDE"
            [[ -n "$DIR_OVERRIDE" ]] && DIR="${DIR_OVERRIDE/#\~/$HOME}"
            # Convert local $HOME prefix to remote ~ for safe expansion on the remote shell
            if [[ "$DIR" == "$HOME"* ]]; then
                REMOTE_DIR="~${DIR#"$HOME"}"
            else
                REMOTE_DIR="$DIR"
            fi
            args+=("-p" "$PROFILE" "-b" "$CHATBOT" "-d" "$REMOTE_DIR")
            [[ -n "$NAME_OVERRIDE" ]] && args+=("-n" "$NAME_OVERRIDE")
            [[ -n "${DS_SHARE_VIA:-}" ]] && args+=("--share-via" "$DS_SHARE_VIA")
            [[ "$DS_NO_ATTACH" == "1" ]] && args+=("--no-attach")
            ;;
    esac

    # Keep ~/ unescaped so the remote shell expands it; only escape the args
    local remote_cmd
    # shellcheck disable=SC2088  # intentional — remote shell expands ~
    remote_cmd="~/.local/bin/ds $(printf '%q ' "${args[@]}")"

    case "$CONNECT" in
        -)       echo "ds: host '$HOST' is local-only (no remote connections)" >&2; exit 1 ;;
        ssh)     exec ssh "$HOST" -t "$remote_cmd" ;;
        autossh) exec autossh -M0 "$HOST" -t "$remote_cmd" ;;
        et)      exec x2ssh -et "$HOST" -c "$remote_cmd" --noexit ;;
        *)       echo "ds: unknown connect method '$CONNECT' for host '$HOST'" >&2; exit 1 ;;
    esac
}

# When sourced for testing, export functions but skip arg parsing and execution.
if [[ -n "${DS_SOURCED:-}" ]]; then
    # shellcheck disable=SC2317
    return 0 2>/dev/null || exit 0
fi

while [[ $# -gt 0 ]]; do
    case "$1" in
        -p|--profile) PROFILE_OVERRIDE="$2"; shift 2 ;;
        -n|--name)    NAME_OVERRIDE="$2"; shift 2 ;;
        -b|--chatbot) CHATBOT_OVERRIDE="$2"; shift 2 ;;
        -c|--connect) CONNECT_OVERRIDE="$2"; shift 2 ;;
        -d|--dir)     DIR_OVERRIDE="$2"; shift 2 ;;
        --share-via)  DS_SHARE_VIA="$2"; shift 2 ;;
        --share)      ACTION="share"
                      if [[ $# -gt 1 && "$2" != -* ]]; then
                          SHARE_TARGET="$2"; shift
                      fi
                      shift ;;
        --unshare)    ACTION="unshare"
                      if [[ $# -gt 1 && "$2" != -* ]]; then
                          SHARE_TARGET="$2"; shift
                      fi
                      shift ;;
        --push)       DS_SHARE_PUSH="$2"; shift 2 ;;
        --github-user) DS_UPTERM_GITHUB_USER="$2"; shift 2 ;;
        --no-attach)  DS_NO_ATTACH=1; shift ;;
        -l|--list)    ACTION="list"; shift ;;
        -k|--kill)    ACTION="kill"
                      # Optional: next arg is the session name (if not a flag)
                      if [[ $# -gt 1 && "$2" != -* ]]; then
                          KILL_TARGET="$2"; shift
                      fi
                      shift ;;
        --killall)    ACTION="killall"; shift ;;
        -h|--help)    _usage; exit 0 ;;
        -*)           _usage >&2; exit 1 ;;
        *)            HOST="$1"; shift ;;
    esac
done

if [[ -n "$DS_SHARE_VIA" && "$DS_SHARE_VIA" != "upterm" ]]; then
    echo "ds: unsupported share backend '$DS_SHARE_VIA' (supported: upterm)" >&2
    exit 1
fi

_ensure_state_dir

if [[ -z "$DS_SHARE_INFO_FILE" ]]; then
    DS_SHARE_INFO_FILE="$(_default_share_info_file)"
fi
if [[ -z "$DS_UPTERM_PID_FILE" ]]; then
    DS_UPTERM_PID_FILE="$(_default_upterm_pid_file)"
fi

# Load push target from config if not set via --push or env
_load_share_config

if [[ -n "$HOST" ]]; then
    _remote
    exit 0
fi

case "$ACTION" in
  list)
    _do_list
    ;;
  kill)
    _do_kill
    ;;
  killall)
    _do_killall
    ;;
  share)
    _do_share
    ;;
  unshare)
    _do_unshare
    ;;
  session)
    lookup_host "$(hostname -s 2>/dev/null || hostname)"
    [[ -n "$PROFILE_OVERRIDE" ]] && PROFILE="$PROFILE_OVERRIDE"
    [[ -n "$CHATBOT_OVERRIDE" ]] && CHATBOT="$CHATBOT_OVERRIDE"
    [[ -n "$DIR_OVERRIDE" ]] && DIR="${DIR_OVERRIDE/#\~/$HOME}"
    _validate_profile
    _do_session
    ;;
esac

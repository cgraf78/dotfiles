#!/usr/bin/env bash
# First-time bootstrap for all machines. Clones the bare git repo,
# checks out dotfiles, installs deps, and sets up auto-update cron.
# For day-to-day updates, use 'dot update' instead.
#
# Two repos:
#   ~/.dotfiles      — bare repo, personal dotfiles (public)
#   ~/.dotfiles-work — regular clone, work dotfiles (private, optional)
#
# Usage (fresh machine):
#   curl -sL https://raw.githubusercontent.com/cgraf78/dotfiles/main/.local/bin/dotbootstrap | bash -s init
#   curl -sL https://raw.githubusercontent.com/cgraf78/dotfiles/main/.local/bin/dotbootstrap | bash -s init work
#
# Usage (reconfigure existing repo machine):
#   ~/.local/bin/dotbootstrap [personal|work]
#
# With no argument, defaults to "work" if ~/.dotfiles-work exists,
# otherwise "personal".

set -euo pipefail

# ---------------------------------------------------------------------------
# Functions
# ---------------------------------------------------------------------------

# Determine which branch to check out.
# Priority:
#   1) DOTFILES_BRANCH env var (explicit override)
#   2) current local branch in the bare repo (if it exists)
#   3) origin/HEAD (default branch)
#   4) main (fallback)
_detect_branch() {
  if [[ -n "${DOTFILES_BRANCH:-}" ]]; then
    BRANCH="$DOTFILES_BRANCH"
    return 0
  fi

  # If repo exists and has a current branch, prefer it (useful for testing).
  if [[ -d "$DOTFILES" ]]; then
    local cur
    cur=$($GIT symbolic-ref -q --short HEAD 2>/dev/null || true)
    if [[ -n "$cur" ]]; then
      BRANCH="$cur"
      return 0
    fi
  fi

  local origin_head
  origin_head=$($GIT symbolic-ref -q --short refs/remotes/origin/HEAD 2>/dev/null || true)
  origin_head=${origin_head#origin/}
  BRANCH="${origin_head:-main}"
}

# Move any existing files out of the way, then force-checkout.
# Uses checkout -f because a normal checkout treats missing worktree files
# (from the backup) as local deletions and skips recreating them.
_backup_and_checkout() {
  mkdir -p "$BACKUP"
  local count=0
  while IFS= read -r f || [[ -n "$f" ]]; do
    if [[ -e "$HOME/$f" ]]; then
      mkdir -p "$BACKUP/$(dirname "$f")"
      mv "$HOME/$f" "$BACKUP/$f"
      ((count++)) || true
    fi
  done < <($GIT ls-tree -r "$BRANCH" --name-only)
  if [[ $count -gt 0 ]]; then
    echo "  backed up $count conflicting files to $BACKUP"
  fi
  echo "  checking out $BRANCH..."
  $GIT checkout -f "$BRANCH" 2>&1 \
    | grep -v "^Already on\|^Your branch is up to date" || true
  rmdir "$BACKUP" 2>/dev/null || true
}

# When sourced for testing, export functions without running main logic.
if [[ "${DOTBOOTSTRAP_SOURCED:-}" == 1 ]]; then return 0; fi

# ---------------------------------------------------------------------------
# Init mode: clone bare repo and re-exec
# ---------------------------------------------------------------------------
# Supports standalone curl invocation:
#   curl -sL https://raw.githubusercontent.com/cgraf78/dotfiles/main/.local/bin/dotbootstrap | bash -s init [work]

if [[ "${1:-}" == "init" ]]; then
  DOTFILES_REPO="${DOTBOOTSTRAP_DOTFILES_REPO:-https://github.com/cgraf78/dotfiles.git}"
  DOTFILES="$HOME/.dotfiles"
  shift

  if [[ -d "$DOTFILES" ]]; then
    echo "error: $DOTFILES already exists" >&2
    exit 1
  fi

  echo "==> Cloning bare repo..."
  git clone --bare "$DOTFILES_REPO" "$DOTFILES"

  echo "==> Checking out dotbootstrap..."
  git --git-dir="$DOTFILES" --work-tree="$HOME" checkout main -- .local/bin/dotbootstrap

  echo "==> Running dotbootstrap..."
  exec "$HOME/.local/bin/dotbootstrap" "$@"
fi

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

# Default to work if previously bootstrapped in work mode.
if [[ -z "${1:-}" && -d "$HOME/.dotfiles-work" ]]; then
  MACHINE_TYPE="work"
else
  MACHINE_TYPE="${1:-personal}"
fi
WORK_REPO="${DOTBOOTSTRAP_WORK_REPO:-git@github.com:cgraf78/dotfiles-work.git}"
DOTFILES="$HOME/.dotfiles"
WORK_DIR="$HOME/.dotfiles-work"
BACKUP="$HOME/.dotfiles-backup/$(date +%Y%m%d%H%M%S)"
# Optional: DOTFILES_BRANCH=<branch> to override detected branch.
BRANCH=""

case "$MACHINE_TYPE" in
  work|personal) ;;
  *)
    echo "Usage: dotbootstrap [init] [personal|work]" >&2
    echo "  init      Clone bare repo and bootstrap (for fresh machines)" >&2
    echo "  personal  Personal dotfiles only (default on personal machines)" >&2
    echo "  work      Personal + work dotfiles (default when ~/.dotfiles-work exists)" >&2
    exit 1
    ;;
esac

GIT="git --git-dir=$DOTFILES --work-tree=$HOME"

# ---------------------------------------------------------------------------
# Personal repo: clone or configure
# ---------------------------------------------------------------------------

echo "==> Setting up $MACHINE_TYPE machine..."

if [[ -d "$DOTFILES" ]]; then
  # ---------------------------------------------------------------------------
  # Configure git (before fetch so refspec and filters are correct)
  # ---------------------------------------------------------------------------

  $GIT config status.showUntrackedFiles no
  $GIT config pull.rebase true
  $GIT config rebase.autoStash true

  # json-sort filter: normalizes JSON on commit AND checkout (sorted keys).
  $GIT config filter.json-sort.clean "jq --sort-keys . 2>/dev/null || cat"
  $GIT config filter.json-sort.smudge "jq --sort-keys . 2>/dev/null || cat"

  # Ensure standard fetch refspec.
  $GIT config remote.origin.fetch "+refs/heads/*:refs/remotes/origin/*"

  # Set push URL to SSH (HTTPS clone is read-only for public repos)
  $GIT config remote.origin.pushUrl "git@github.com:cgraf78/dotfiles.git"

  # ---------------------------------------------------------------------------
  # Fetch, detect branch, checkout
  # ---------------------------------------------------------------------------

  echo "==> Pulling personal dotfiles..."
  if ! $GIT fetch --quiet origin; then
    echo "  warning: fetch failed (continuing with existing local state)" >&2
  fi

  _detect_branch
  echo "  branch: $BRANCH"

  # Set branch tracking.
  $GIT config "branch.$BRANCH.remote" origin
  $GIT config "branch.$BRANCH.merge" "refs/heads/$BRANCH"

  # Ensure clean full checkout. The quickstart one-liner does a sparse checkout
  # of just dotbootstrap, which leaves the index with staged deletions of all
  # other files. Force checkout resets the index and working tree to match HEAD.
  _backup_and_checkout
else
  echo "  no bare repo at $DOTFILES — skipping git setup"
fi

# Shared helpers (available after checkout).
if [[ -f "$HOME/.config/dot/helpers.sh" ]]; then
  # shellcheck source=../../.config/dot/helpers.sh
  . "$HOME/.config/dot/helpers.sh"
else
  echo "  warning: helpers.sh not found — skipping work repo and merges" >&2
  echo "==> Done! Run 'source ~/.bashrc' to activate."
  touch "$HOME/.dotbootstrap-done"
  exit 0
fi

# ---------------------------------------------------------------------------
# Work repo: pull/clone (work machines only)
# Pull early so work files are available, but defer bootstrap until after
# deps + merges so tools like jq and fonts are installed first.
# ---------------------------------------------------------------------------

if [[ "$MACHINE_TYPE" == "work" ]]; then
  if [[ -d "$WORK_DIR" ]]; then
    # shellcheck disable=SC2119  # intentionally passing no args
    _pull_work_repo
  else
    echo "==> Cloning work dotfiles..."
    if ! git clone "$WORK_REPO" "$WORK_DIR"; then
      echo "  warning: work dotfiles clone failed" >&2
    fi
  fi
fi

# ---------------------------------------------------------------------------
# Dependencies (managed by _update_deps in deps.sh)
# ---------------------------------------------------------------------------

_update_deps

# ---------------------------------------------------------------------------
# App config merges
# ---------------------------------------------------------------------------

_run_merges

# ---------------------------------------------------------------------------
# Work bootstrap (symlinks, work config merges)
# ---------------------------------------------------------------------------

_run_work_bootstrap

echo "==> Done! Run 'source ~/.bashrc' to activate."
touch "$HOME/.dotbootstrap-done"

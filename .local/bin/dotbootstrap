#!/usr/bin/env bash
# First-time bootstrap for all machines. Clones the bare git repo,
# checks out dotfiles, clones overlay repos, installs deps, and sets
# up auto-update cron.  For day-to-day updates, use 'dot update' instead.
#
# Base bare repo at ~/.dotfiles. Overlay repos are discovered from
# config files in ~/.config/dot/overlays.d/*.conf after base checkout.
#
# Usage (fresh machine):
#   curl -sL https://raw.githubusercontent.com/cgraf78/dotfiles/main/.local/bin/dotbootstrap | bash -s init
#
# Usage (reconfigure existing machine):
#   ~/.local/bin/dotbootstrap

set -euo pipefail

# ---------------------------------------------------------------------------
# Functions
# ---------------------------------------------------------------------------

# Determine which branch to check out.
# Priority:
#   1) DOTFILES_BRANCH env var (explicit override)
#   2) current local branch in the bare repo (if it exists)
#   3) origin/HEAD (default branch)
#   4) main (fallback)
_detect_branch() {
  if [[ -n "${DOTFILES_BRANCH:-}" ]]; then
    BRANCH="$DOTFILES_BRANCH"
    return 0
  fi

  # If repo exists and has a current branch, prefer it (useful for testing).
  if [[ -d "$DOTFILES" ]]; then
    local cur
    cur=$($GIT symbolic-ref -q --short HEAD 2>/dev/null || true)
    if [[ -n "$cur" ]]; then
      BRANCH="$cur"
      return 0
    fi
  fi

  local origin_head
  origin_head=$($GIT symbolic-ref -q --short refs/remotes/origin/HEAD 2>/dev/null || true)
  origin_head=${origin_head#origin/}
  BRANCH="${origin_head:-main}"
}

# Move any existing files out of the way, then force-checkout.
# Uses checkout -f because a normal checkout treats missing worktree files
# (from the backup) as local deletions and skips recreating them.
_backup_and_checkout() {
  mkdir -p "$BACKUP"
  local count=0
  while IFS= read -r f || [[ -n "$f" ]]; do
    if [[ -e "$HOME/$f" ]]; then
      mkdir -p "$BACKUP/$(dirname "$f")"
      mv "$HOME/$f" "$BACKUP/$f"
      ((count++)) || true
    fi
  done < <($GIT ls-tree -r "$BRANCH" --name-only)
  if [[ $count -gt 0 ]]; then
    echo "  backed up $count conflicting files to $BACKUP"
  fi
  echo "  checking out $BRANCH..."
  $GIT checkout -f "$BRANCH" 2>&1 |
    grep -v "^Already on\|^Your branch is up to date" || true
  rmdir "$BACKUP" 2>/dev/null || true
}

# When sourced for testing, export functions without running main logic.
if [[ "${DOTBOOTSTRAP_SOURCED:-}" == 1 ]]; then return 0; fi

# ---------------------------------------------------------------------------
# Init mode: clone bare repo and re-exec
# ---------------------------------------------------------------------------
# Supports standalone curl invocation:
#   curl -sL https://raw.githubusercontent.com/cgraf78/dotfiles/main/.local/bin/dotbootstrap | bash -s init

if [[ "${1:-}" == "init" ]]; then
  DOTFILES_REPO="${DOTBOOTSTRAP_DOTFILES_REPO:-https://github.com/cgraf78/dotfiles.git}"
  DOTFILES="$HOME/.dotfiles"
  shift

  if [[ -d "$DOTFILES" ]]; then
    echo "error: $DOTFILES already exists" >&2
    exit 1
  fi

  echo "==> Cloning bare repo..."
  git clone --bare "$DOTFILES_REPO" "$DOTFILES"

  echo "==> Checking out dotbootstrap..."
  git --git-dir="$DOTFILES" --work-tree="$HOME" checkout main -- .local/bin/dotbootstrap

  echo "==> Running dotbootstrap..."
  exec "$HOME/.local/bin/dotbootstrap" "$@"
fi

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

DOTFILES="$HOME/.dotfiles"
BACKUP="$HOME/.dotfiles-backup/$(date +%Y%m%d%H%M%S)"
# Optional: DOTFILES_BRANCH=<branch> to override detected branch.
BRANCH=""

GIT="git --git-dir=$DOTFILES --work-tree=$HOME"

# ---------------------------------------------------------------------------
# Base repo: clone or configure
# ---------------------------------------------------------------------------

echo "==> Setting up machine..."

if [[ -d "$DOTFILES" ]]; then
  # ---------------------------------------------------------------------------
  # Configure git (before fetch so refspec is correct)
  # ---------------------------------------------------------------------------

  $GIT config status.showUntrackedFiles no

  # Ensure standard fetch refspec.
  $GIT config remote.origin.fetch "+refs/heads/*:refs/remotes/origin/*"

  # Set push URL to SSH (HTTPS clone is read-only for public repos)
  $GIT config remote.origin.pushUrl "git@github.com:cgraf78/dotfiles.git"

  # ---------------------------------------------------------------------------
  # Fetch, detect branch, checkout
  # ---------------------------------------------------------------------------

  echo "==> Pulling dotfiles..."
  if ! $GIT fetch --quiet origin; then
    echo "  warning: fetch failed (continuing with existing local state)" >&2
  fi

  _detect_branch
  echo "  branch: $BRANCH"

  # Set branch tracking.
  $GIT config "branch.$BRANCH.remote" origin
  $GIT config "branch.$BRANCH.merge" "refs/heads/$BRANCH"

  # Ensure clean full checkout.
  _backup_and_checkout
else
  echo "  no bare repo at $DOTFILES — skipping git setup"
fi

# Shared helpers (available after checkout).
if [[ -f "$HOME/.local/lib/dot/init.sh" ]]; then
  # shellcheck source=../../.local/lib/dot/init.sh
  . "$HOME/.local/lib/dot/init.sh"
else
  echo "  warning: init.sh not found — skipping overlays and merges" >&2
  echo "==> Done! Run 'source ~/.bashrc' or 'source ~/.zshrc' to activate."
  touch "$HOME/.dotbootstrap-done"
  exit 0
fi

# ---------------------------------------------------------------------------
# Overlay repos: discover, clone/pull
# ---------------------------------------------------------------------------

_merge_overlay_ssh_configs
_discover_overlays
_pull_overlays

# ---------------------------------------------------------------------------
# Finalize: deps, overlay symlinks, app config merges, normalize
# ---------------------------------------------------------------------------

_finalize_update
touch "$HOME/.dotbootstrap-done"

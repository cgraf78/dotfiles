#!/usr/bin/env bash
# Bootstrap dotfiles on a new machine or reconfigure an existing one.
#
# Two repos:
#   ~/.dotfiles      — bare repo, personal dotfiles (public)
#   ~/.dotfiles-work — regular clone, work dotfiles (private, optional)
#
# Usage:
#   git clone --bare https://github.com/cgraf78/dotfiles.git ~/.dotfiles
#   git --git-dir=$HOME/.dotfiles --work-tree=$HOME checkout main -- .local/bin/dotbootstrap
#   ~/.local/bin/dotbootstrap <personal|work>

set -euo pipefail

# ---------------------------------------------------------------------------
# Functions
# ---------------------------------------------------------------------------

# Determine which branch to check out.
# Priority:
#   1) DOTFILES_BRANCH env var (explicit override)
#   2) current local branch in the bare repo (if it exists)
#   3) origin/HEAD (default branch)
#   4) main (fallback)
_detect_branch() {
  if [[ -n "${DOTFILES_BRANCH:-}" ]]; then
    BRANCH="$DOTFILES_BRANCH"
    return 0
  fi

  # If repo exists and has a current branch, prefer it (useful for testing).
  if [[ -d "$DOTFILES" ]]; then
    local cur
    cur=$($GIT symbolic-ref -q --short HEAD 2>/dev/null || true)
    if [[ -n "$cur" ]]; then
      BRANCH="$cur"
      return 0
    fi
  fi

  local origin_head
  origin_head=$($GIT symbolic-ref -q --short refs/remotes/origin/HEAD 2>/dev/null || true)
  origin_head=${origin_head#origin/}
  BRANCH="${origin_head:-main}"
}

# Move any existing files out of the way, then force-checkout.
# Uses checkout -f because a normal checkout treats missing worktree files
# (from the backup) as local deletions and skips recreating them.
_backup_and_checkout() {
  echo "  backing up conflicting files to $BACKUP..."
  mkdir -p "$BACKUP"
  $GIT ls-tree -r "$BRANCH" --name-only \
    | while IFS= read -r f || [[ -n "$f" ]]; do
        if [[ -e "$HOME/$f" ]]; then
          mkdir -p "$BACKUP/$(dirname "$f")"
          mv "$HOME/$f" "$BACKUP/$f"
          echo "    backed up: $f"
        fi
      done
  echo "  checking out $BRANCH..."
  $GIT checkout -f "$BRANCH"
  rmdir "$BACKUP" 2>/dev/null || true
}

_install_hint() {
  # $1 = package name (best guess)
  local pkg="$1"
  if command -v brew &>/dev/null; then
    echo "  brew install $pkg"
  elif command -v apt-get &>/dev/null; then
    echo "  sudo apt-get update && sudo apt-get install -y $pkg"
  elif command -v dnf &>/dev/null; then
    echo "  sudo dnf install -y $pkg"
  elif command -v pacman &>/dev/null; then
    echo "  sudo pacman -S --needed $pkg"
  else
    echo "  (install '$pkg' with your system package manager)"
  fi
}

_check_dep() {
  # $1=command $2=pkg-name
  local cmd="$1" pkg="$2"
  if ! command -v "$cmd" &>/dev/null; then
    echo "  warning: missing dependency: $cmd"
    _install_hint "$pkg"
    return 1
  fi
  return 0
}

# When sourced for testing, export functions without running main logic.
if [[ "${DOTBOOTSTRAP_SOURCED:-}" == 1 ]]; then return 0; fi

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

if [[ $# -lt 1 ]]; then
  echo "Usage: dotbootstrap <personal|work>" >&2
  echo "  personal  Personal dotfiles only" >&2
  echo "  work      Personal + work dotfiles" >&2
  exit 1
fi

MACHINE_TYPE="$1"
REPO="${DOTBOOTSTRAP_REPO:-https://github.com/cgraf78/dotfiles.git}"
WORK_REPO="${DOTBOOTSTRAP_WORK_REPO:-git@github.com:cgraf78/dotfiles-work.git}"
VIMRC_REPO="${DOTBOOTSTRAP_VIMRC_REPO:-https://github.com/cgraf78/vimrc.git}"
VIM_RUNTIME_DIR="$HOME/.vim_runtime"
DOTFILES="$HOME/.dotfiles"
WORK_DIR="$HOME/.dotfiles-work"
BACKUP="$HOME/.dotfiles-backup-$(date +%Y%m%d%H%M%S)"
# Optional: DOTFILES_BRANCH=<branch> to override detected branch.
BRANCH=""

case "$MACHINE_TYPE" in
  work|personal) ;;
  *)
    echo "error: argument must be 'personal' or 'work'" >&2
    exit 1
    ;;
esac

GIT="git --git-dir=$DOTFILES --work-tree=$HOME"

# ---------------------------------------------------------------------------
# Personal repo: clone or configure
# ---------------------------------------------------------------------------

echo "==> Setting up $MACHINE_TYPE machine..."

if [[ ! -d "$DOTFILES" ]]; then
  echo "==> Cloning personal dotfiles..."
  git clone --bare "$REPO" "$DOTFILES"
fi

# ---------------------------------------------------------------------------
# Configure git (before fetch so refspec and filters are correct)
# ---------------------------------------------------------------------------

$GIT config status.showUntrackedFiles no
$GIT config pull.rebase true
$GIT config rebase.autoStash true

# json-sort filter: normalizes JSON on commit AND checkout (sorted keys).
$GIT config filter.json-sort.clean "jq --sort-keys . 2>/dev/null || cat"
$GIT config filter.json-sort.smudge "jq --sort-keys . 2>/dev/null || cat"

# Ensure standard fetch refspec.
$GIT config remote.origin.fetch "+refs/heads/*:refs/remotes/origin/*"

# Set push URL to SSH (HTTPS clone is read-only for public repos)
$GIT config remote.origin.pushUrl "git@github.com:cgraf78/dotfiles.git"

# ---------------------------------------------------------------------------
# Dependency checks (best-effort)
# ---------------------------------------------------------------------------

echo "==> Checking dependencies..."
_check_dep git git || true
_check_dep jq jq || true
_check_dep tmux tmux || true
_check_dep fzf fzf || true

# ---------------------------------------------------------------------------
# Fetch, detect branch, checkout
# ---------------------------------------------------------------------------

echo "==> Pulling personal dotfiles..."
if ! $GIT fetch origin; then
  echo "  warning: fetch failed (continuing with existing local state)" >&2
fi

_detect_branch
echo "  branch: $BRANCH"

# Set branch tracking.
$GIT config "branch.$BRANCH.remote" origin
$GIT config "branch.$BRANCH.merge" "refs/heads/$BRANCH"

# Ensure clean full checkout. The quickstart one-liner does a sparse checkout
# of just dotbootstrap, which leaves the index with staged deletions of all
# other files. Force checkout resets the index and working tree to match HEAD.
_backup_and_checkout

# Shared helpers (now available after full checkout).
. "$HOME/.config/dot/helpers.sh"

# ---------------------------------------------------------------------------
# Work repo (work machines only)
# ---------------------------------------------------------------------------

if [[ "$MACHINE_TYPE" == "work" ]]; then
  if [[ -d "$WORK_DIR" ]]; then
    _pull_work_repo
  else
    echo "==> Cloning work dotfiles..."
    if ! git clone "$WORK_REPO" "$WORK_DIR"; then
      echo "  warning: work dotfiles clone failed" >&2
    fi
    if [[ -x "$WORK_DIR/bootstrap" ]]; then "$WORK_DIR/bootstrap" || true; fi
  fi
fi

# ---------------------------------------------------------------------------
# App config merges
# ---------------------------------------------------------------------------

_run_merges

# ---------------------------------------------------------------------------
# Optional one-time installs
# ---------------------------------------------------------------------------

# Vim runtime (cgraf78/vimrc). Skipped if already installed.
if [[ ! -d "$VIM_RUNTIME_DIR" ]]; then
  echo "==> Installing vim runtime (cgraf78/vimrc)..."
  if ! git clone --depth 1 "$VIMRC_REPO" "$VIM_RUNTIME_DIR"; then
    echo "  warning: failed to clone vimrc (skipping)" >&2
  else
    if ! sh "$VIM_RUNTIME_DIR/install_awesome_vimrc.sh"; then
      echo "  warning: vimrc install script failed (skipping)" >&2
    fi
  fi
fi

# Install or upgrade a tool from a local clone, GitHub release, or git clone.
# Usage: _install_tool <name> <github-owner/repo> <install-dir>
# Priority: ~/git/<name> (symlink) > existing git clone (pull) > release tarball > fresh clone.
_install_tool() {
  local name="$1" repo="$2" install_dir="$3"
  local tarball_url tmp_dir
  local local_clone="$HOME/git/$name"

  # Prefer local clone — symlink for live development
  if [[ -d "$local_clone/bin" ]]; then
    rm -rf "$install_dir"
    mkdir -p "$(dirname "$install_dir")"
    ln -sfn "$local_clone" "$install_dir"
    mkdir -p "$HOME/.local/bin"
    ln -sf "$install_dir/bin/$name" "$HOME/.local/bin/$name"
    chmod +x "$local_clone/bin/$name"
    echo "  $name → $local_clone (local clone)"
    return 0
  fi

  # Existing git clone — pull to update
  if [[ -d "$install_dir/.git" ]]; then
    if git -C "$install_dir" pull --ff-only 2>/dev/null; then
      mkdir -p "$HOME/.local/bin"
      ln -sf "$install_dir/bin/$name" "$HOME/.local/bin/$name"
      chmod +x "$install_dir/bin/$name"
      echo "  $name updated (git pull)"
      return 0
    else
      echo "  warning: git pull failed for $name, re-installing..." >&2
      rm -rf "$install_dir"
    fi
  fi

  # Try GitHub release (only for owner/repo format, not local paths or URLs)
  if [[ "$repo" != /* && "$repo" != *://* ]] && command -v curl &>/dev/null; then
    tarball_url=$(curl -fsSL "https://api.github.com/repos/$repo/releases/latest" 2>/dev/null \
      | grep -o '"browser_download_url":[[:space:]]*"[^"]*\.tar\.gz"' \
      | head -1 | cut -d'"' -f4)
  fi

  if [[ -n "${tarball_url:-}" ]]; then
    tmp_dir=$(mktemp -d)
    if curl -fsSL "$tarball_url" | tar xz -C "$tmp_dir" 2>/dev/null; then
      rm -rf "$install_dir"
      mkdir -p "$install_dir"
      # Tarball has a top-level dir (e.g., ds-v0.0.1/); move contents up
      mv "$tmp_dir"/*/* "$install_dir/" 2>/dev/null || mv "$tmp_dir"/* "$install_dir/"
      rm -rf "$tmp_dir"
    else
      rm -rf "$tmp_dir"
      echo "  warning: failed to download $name release (trying git clone)" >&2
      tarball_url=""
    fi
  fi

  # Fallback: clone directly into install dir
  if [[ -z "${tarball_url:-}" ]]; then
    if ! command -v git &>/dev/null; then
      echo "  warning: no curl release and no git — cannot install $name" >&2
      return 1
    fi
    rm -rf "$install_dir"
    local clone_url="$repo"
    [[ "$repo" != /* && "$repo" != *://* ]] && clone_url="https://github.com/$repo.git"
    if ! git clone --depth 1 "$clone_url" "$install_dir" 2>/dev/null; then
      echo "  warning: failed to clone $name" >&2
      return 1
    fi
  fi

  # Symlink into PATH
  mkdir -p "$HOME/.local/bin"
  ln -sf "$install_dir/bin/$name" "$HOME/.local/bin/$name"
  chmod +x "$install_dir/bin/$name"
  echo "  $name installed"
}

DS_REPO="${DOTBOOTSTRAP_DS_REPO:-cgraf78/ds}"
DOTSYNC_REPO="${DOTBOOTSTRAP_DOTSYNC_REPO:-cgraf78/dotsync}"

echo "==> Installing/upgrading ds..."
_install_tool ds "$DS_REPO" "$HOME/.local/share/ds"

echo "==> Installing/upgrading dotsync..."
_install_tool dotsync "$DOTSYNC_REPO" "$HOME/.local/share/dotsync"

echo "==> Done! Run 'source ~/.bashrc' to activate."

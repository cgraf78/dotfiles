#!/usr/bin/env bash
# claude-hook-session-start — SessionStart hook.
# Reports useful context at session start: uncommitted changes, disk usage.
# Work-override: work variant replaces base entirely because both emit
# JSON context on stdout — two JSON objects would be invalid output.

set -u

# --- Work-override: replaces base entirely (both emit JSON context) ---
work_variant=$(command -v claude-hook-session-start-work 2>/dev/null)
[ -n "$work_variant" ] && [ -x "$work_variant" ] && exec "$work_variant"

# --- Base logic (runs only when work variant is absent) ---

ctx=''

# Uncommitted changes (git for personal machines)
if command -v git >/dev/null 2>&1; then
  changes=$(git status --porcelain 2>/dev/null | head -20)
  if [ -n "$changes" ]; then
    ctx="Uncommitted changes:
$changes"
  fi
fi

# Disk usage warning
disk=$(df -h . 2>/dev/null | awk 'NR==2{print $5}' | tr -d '%')
if [ -n "$disk" ] && [ "$disk" -gt 90 ] 2>/dev/null; then
  ctx="$ctx
WARNING: Disk usage at ${disk}%"
fi

if [ -n "$ctx" ]; then
  printf '%s' "$ctx" | jq -Rsc '{"context": .}'
fi

exit 0

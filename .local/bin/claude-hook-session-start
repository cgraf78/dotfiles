#!/usr/bin/env bash
# claude-hook-session-start — SessionStart hook.
# Reports useful context at session start: uncommitted changes, disk usage.
# Auto-delegates to -work variant if present (before running base logic,
# since exec replaces the process and only one script's output is captured).

set -u

# --- Delegate to work variant if present ---
work_variant=$(command -v claude-hook-session-start-work 2>/dev/null)
[ -n "$work_variant" ] && [ -x "$work_variant" ] && exec "$work_variant"

# --- Base logic (personal machines only) ---

ctx=''

# Uncommitted changes (git for personal machines)
if command -v git >/dev/null 2>&1; then
  changes=$(git status --porcelain 2>/dev/null | head -20)
  if [ -n "$changes" ]; then
    ctx="Uncommitted changes:\\n$changes"
  fi
fi

# Disk usage warning
disk=$(df -h . 2>/dev/null | awk 'NR==2{print $5}' | tr -d '%')
if [ -n "$disk" ] && [ "$disk" -gt 90 ] 2>/dev/null; then
  ctx="$ctx\\nWARNING: Disk usage at ${disk}%"
fi

if [ -n "$ctx" ]; then
  printf '{"context": "%s"}' "$ctx"
fi

exit 0

#!/usr/bin/env bash
# autolint — lint a file by extension.
# Usable from Claude Code hooks, git hooks, editors, CLI.
# Requires yq, which is installed by dotfiles bootstrap.
# No-ops gracefully if a linter is not installed.
# Respects per-repo config files.
#
# Usage: autolint [--fix] <file>

set -u

fix=0
file=""
for arg in "$@"; do
  case "$arg" in
    --fix) fix=1 ;;
    *) file="$arg" ;;
  esac
done

[ -z "$file" ] && exit 0
[ -f "$file" ] || exit 0

# Fallback-config dir. Defaults to the same dir autoformat uses so
# the ruff.toml shared by both tools lives in a single place. Can be
# overridden independently via AUTOLINT_DIR.
AUTOLINT_DIR="${AUTOLINT_DIR:-$HOME/.config/autoformat}"

# shellcheck source=../lib/dot/autofmt.sh
. "$HOME/.local/lib/dot/autofmt.sh"

if ! command -v yq >/dev/null 2>&1; then
  echo "autolint: yq is required" >&2
  exit 1
fi

_filedir=$(dirname "$file")
ext="${file##*.}"
rc=0

_lint_sh() {
  local file="$1" dir="$2"
  local args=()
  command -v shellcheck &>/dev/null || return 0
  # Fall back to our global shellcheckrc only when no per-repo
  # .shellcheckrc is found in the file's parent chain. (shellcheck
  # itself also walks $HOME and $XDG_CONFIG_HOME, but --rcfile is
  # the only way to inject our dotfiles-managed config reliably.)
  if ! _has_config "$dir" ".shellcheckrc" &&
    [ -f "$AUTOLINT_DIR/shellcheckrc" ]; then
    args=(--rcfile "$AUTOLINT_DIR/shellcheckrc")
  fi
  shellcheck "${args[@]}" "$file"
}

_lint_zsh() {
  if command -v zsh &>/dev/null; then
    zsh -n "$1"
  fi
}

_lint_js() {
  local file="$1" dir="$2"
  command -v eslint &>/dev/null || return 0
  # Only lint if a config exists — eslint without config is noisy.
  _has_config "$dir" "eslint.config.js" ||
    _has_config "$dir" "eslint.config.mjs" ||
    _has_config "$dir" "eslint.config.cjs" ||
    _has_config "$dir" ".eslintrc.js" ||
    _has_config "$dir" ".eslintrc.cjs" ||
    _has_config "$dir" ".eslintrc.yaml" ||
    _has_config "$dir" ".eslintrc.yml" ||
    _has_config "$dir" ".eslintrc.json" || return 0
  if [ "$fix" -eq 1 ]; then
    eslint --fix "$file"
  else
    eslint "$file"
  fi
}

case "$ext" in
  sh | bash)
    _lint_sh "$file" "$_filedir" || rc=$?
    ;;
  zsh)
    _lint_zsh "$file" || rc=$?
    ;;
  py)
    if command -v ruff &>/dev/null; then
      args=()
      has_ruff_config=0
      if _has_config "$_filedir" "ruff.toml" ||
        _has_config "$_filedir" ".ruff.toml"; then
        has_ruff_config=1
      else
        # Walk for pyproject.toml[tool.ruff] so ruff's own resolution
        # isn't silently replaced by our fallback.
        dir="$_filedir"
        prev=""
        while [ "$dir" != "$prev" ]; do
          if [ -f "$dir/pyproject.toml" ] &&
            _toml_has_any "$dir/pyproject.toml" "tool.ruff" "tool.ruff.lint"; then
            has_ruff_config=1
            break
          fi
          [ "$dir" = "/" ] && break
          prev="$dir"
          dir=$(dirname "$dir")
        done
      fi
      if [ "$has_ruff_config" -eq 0 ] &&
        [ -f "$AUTOLINT_DIR/ruff.toml" ]; then
        args=(--config "$AUTOLINT_DIR/ruff.toml")
      fi
      if [ "$fix" -eq 1 ]; then
        ruff check --fix "${args[@]}" "$file" || rc=$?
      else
        ruff check "${args[@]}" "$file" || rc=$?
      fi
    fi
    ;;
  js | jsx | ts | tsx)
    _lint_js "$file" "$_filedir" || rc=$?
    ;;
  md)
    if command -v markdownlint-cli2 &>/dev/null; then
      args=()
      has_md_config=0
      if _has_config "$_filedir" ".markdownlint-cli2.jsonc" ||
        _has_config "$_filedir" ".markdownlint-cli2.yaml" ||
        _has_config "$_filedir" ".markdownlint-cli2.cjs" ||
        _has_config "$_filedir" ".markdownlint-cli2.mjs" ||
        _has_config "$_filedir" ".markdownlint.jsonc" ||
        _has_config "$_filedir" ".markdownlint.yaml" ||
        _has_config "$_filedir" ".markdownlint.json"; then
        has_md_config=1
      else
        # markdownlint-cli2 also resolves config from a `markdownlint-cli2`
        # key in package.json. Walk the parent chain like prettier does.
        dir="$_filedir"
        prev=""
        while [ "$dir" != "$prev" ]; do
          if [ -f "$dir/package.json" ] &&
            yq -p json -e '."markdownlint-cli2"' "$dir/package.json" >/dev/null 2>&1; then
            has_md_config=1
            break
          fi
          [ "$dir" = "/" ] && break
          prev="$dir"
          dir=$(dirname "$dir")
        done
      fi
      if [ "$has_md_config" -eq 0 ] &&
        [ -f "$AUTOLINT_DIR/markdownlint-cli2.jsonc" ]; then
        args=(--config "$AUTOLINT_DIR/markdownlint-cli2.jsonc")
      fi
      if [ "$fix" -eq 1 ]; then
        markdownlint-cli2 --fix "${args[@]}" "$file" || rc=$?
      else
        markdownlint-cli2 "${args[@]}" "$file" || rc=$?
      fi
    fi
    ;;
  lua)
    if command -v luacheck &>/dev/null; then
      args=()
      if ! _has_config "$_filedir" ".luacheckrc" &&
        [ -f "$AUTOLINT_DIR/luacheckrc" ]; then
        args=(--config "$AUTOLINT_DIR/luacheckrc")
      fi
      luacheck "${args[@]}" "$file" || rc=$?
    fi
    ;;
  yml | yaml)
    # Only lint GitHub Actions workflow YAML. A generic YAML linter on
    # arbitrary yamls is too noisy; actionlint is scoped to workflows.
    case "$file" in
      */.github/workflows/*)
        if command -v actionlint &>/dev/null; then
          actionlint "$file" || rc=$?
        fi
        ;;
    esac
    ;;
  *)
    # Extensionless files: dispatch via _classify_shell (dotfile name or shebang).
    case "$(_classify_shell "$file")" in
      zsh) _lint_zsh "$file" || rc=$? ;;
      bash) _lint_sh "$file" "$_filedir" || rc=$? ;;
    esac
    ;;
esac

exit "$rc"

#!/usr/bin/env bash
# autolint — lint a file by extension.
# Usable from Claude Code hooks, git hooks, editors, CLI.
# Requires yq, which is installed by dotfiles bootstrap.
# No-ops gracefully if a linter is not installed.
# Respects per-repo config files.
#
# Usage: autolint [--fix] [--json] <file>

set -u

# `--fix` is opt-in. Unlike autoformat (which always mutates), autolint
# defaults to read-only: edit-hook callers want diagnostics without
# surprise fixes. Pass `--fix` explicitly — e.g. from the CLI — when
# the caller wants ruff/biome/rumdl to also apply fixes.
#
# `--json` emits one JSON object per diagnostic on stdout, in a unified
# schema: {path,line,col,end_line?,end_col?,severity,code?,message,source}.
# Line/col are 1-based. Designed for nvim-lint so the editor's
# diagnostics are produced by exactly the same dispatch path as the
# post-edit and pre-commit hooks. Tool stderr is suppressed in json
# mode so the output stream stays parseable.
#
# Multiple file args are rejected rather than silently accepted (the
# "last-wins" pattern would mean earlier files are dropped without the
# caller noticing). Exit code 2 is "usage error" per convention.
fix=0
json=0
file=""
files=0
for arg in "$@"; do
  case "$arg" in
    --fix) fix=1 ;;
    --json) json=1 ;;
    *)
      files=$((files + 1))
      file="$arg"
      ;;
  esac
done

if [ "$files" -gt 1 ]; then
  echo "autolint: expected a single file path, got $files" >&2
  exit 2
fi

[ -z "$file" ] && exit 0
[ -f "$file" ] || exit 0

# Normalize to an absolute path before anything else. The ignore
# patterns in `$AUTOLINT_DIR/ignore` are written `*/path/...` —
# anchored on a leading directory separator — so callers passing a
# repo-relative path (e.g. the git pre-commit hook, which emits
# `git diff --cached --name-only` output) would otherwise escape the
# ignore match. Using `cd + pwd` keeps this portable (no readlink -f
# on macOS without coreutils) and avoids resolving symlinks, which
# the rest of the script treats as-is.
file="$(cd "$(dirname "$file")" && pwd)/$(basename "$file")"

# Fallback-config dir. Defaults to the same dir autoformat uses so
# the ruff.toml shared by both tools lives in a single place. Can be
# overridden independently via AUTOLINT_DIR.
AUTOLINT_DIR="${AUTOLINT_DIR:-$HOME/.config/autoformat}"

# shellcheck source=../lib/dot/autofmt.sh
. "$HOME/.local/lib/dot/autofmt.sh"

_ignored "$file" "$AUTOLINT_DIR/ignore" && exit 0

if ! command -v yq >/dev/null 2>&1; then
  echo "autolint: yq is required" >&2
  exit 1
fi

# `--json` relies on jq to transform each tool's native JSON into the
# unified schema. Bail early if jq is missing so callers get a clear
# error instead of silent empty output.
if [ "$json" -eq 1 ] && ! command -v jq >/dev/null 2>&1; then
  echo "autolint: jq is required for --json" >&2
  exit 1
fi

_filedir=$(dirname "$file")
ext="${file##*.}"
rc=0

# Severity normalizer shared by every jq filter below: maps each
# tool's native level spelling onto the unified set
# {error, warning, info, hint}. Unknown values fall back to warning —
# a missing severity must never silently drop a diagnostic.
# shellcheck disable=SC2016  # single quotes intentional — this is a jq program
_JQ_SEVLIB='def sev($v):
  ({
    "error":"error","err":"error","fatal":"error",
    "warning":"warning","warn":"warning",
    "info":"info","information":"info","note":"info",
    "hint":"hint","style":"hint"
  })[($v // "warning") | ascii_downcase] // "warning";'

# Emit a single synthesized error-level diagnostic. Used by backends
# with no structured output (zsh syntax check, taplo) so pre-commit
# still surfaces "something is wrong" in json mode, even without
# precise positions.
_emit_synth_error() {
  local path="$1" message="$2" source_="$3"
  jq -cn --arg p "$path" --arg m "$message" --arg s "$source_" '{
    path: $p, line: 1, col: 1, severity: "error", message: $m, source: $s
  }'
}

# Design contract shared by every `_lint_*` helper below and every
# branch of the dispatch: if the linter isn't installed, return 0
# silently. autolint fires on every edit-hook save; it must never
# block the hook because a tool happens to be absent on this host.
# The `command -v <tool> &>/dev/null || return 0` idiom in each
# helper encodes this.

_lint_sh() {
  local file="$1" dir="$2"
  local args=()
  command -v shellcheck &>/dev/null || return 0
  # Apply our global shellcheckrc by translating its directives to
  # CLI flags. shellcheck's `--rcfile` flag wasn't added until
  # 0.10.0 (Ubuntu 24.04 ships 0.9.0 which exits 3 on the unknown
  # flag), and shellcheck doesn't walk for our XDG-style path
  # anyway. Parsing here is simple: we only support `disable=CODE`
  # today, which maps cleanly to `-e CODE`. Extend the case if the
  # rcfile grows more directives.
  if ! _has_config "$dir" ".shellcheckrc" &&
    [ -f "$AUTOLINT_DIR/shellcheckrc" ]; then
    local key val
    while IFS='=' read -r key val; do
      case "$key" in
        disable) args+=(-e "$val") ;;
      esac
    done < <(grep -E '^[a-z-]+=' "$AUTOLINT_DIR/shellcheckrc")
  fi
  if [ "$json" -eq 1 ]; then
    local out tool_rc
    out=$(shellcheck -f json1 "${args[@]}" "$file" 2>/dev/null)
    tool_rc=$?
    if [ -n "$out" ]; then
      printf '%s' "$out" | jq -c --arg path "$file" "$_JQ_SEVLIB"'
        .comments[]? | {
          path: $path,
          line: .line,
          col: .column,
          end_line: .endLine,
          end_col: .endColumn,
          severity: sev(.level),
          code: ("SC" + (.code|tostring)),
          message: .message,
          source: "shellcheck"
        }'
    fi
    return "$tool_rc"
  fi
  shellcheck "${args[@]}" "$file"
}

_lint_zsh() {
  command -v zsh &>/dev/null || return 0
  if [ "$json" -eq 1 ]; then
    local err tool_rc
    err=$(zsh -n "$1" 2>&1 1>/dev/null)
    tool_rc=$?
    if [ "$tool_rc" -ne 0 ]; then
      # `zsh -n` prints `file:LINE: message`. Try to parse out the
      # line number; fall back to line 1 if the format is unexpected.
      local line msg
      if [[ $err =~ :([0-9]+):\ (.*)$ ]]; then
        line="${BASH_REMATCH[1]}"
        msg="${BASH_REMATCH[2]}"
      else
        line=1
        msg="$err"
      fi
      jq -cn --arg p "$1" --arg m "$msg" --argjson l "$line" '{
        path: $p, line: $l, col: 1, severity: "error",
        message: $m, source: "zsh"
      }'
    fi
    return "$tool_rc"
  fi
  zsh -n "$1"
}

_lint_biome() {
  local file="$1" dir="$2"
  command -v biome &>/dev/null || return 0
  # biome runs its recommended rule set by default; no eslint-style
  # "skip if no config" gate. biome.json(c) per-repo tunes that set,
  # otherwise we fall back to our global config (same file autoformat
  # uses — biome handles format and lint from one config).
  # Self-lint guard: if the file being linted IS the config itself,
  # skip --config-path to avoid biome's "nested root configuration".
  local args=()
  local repo_cfg
  repo_cfg=$(_find_config "$dir" "biome.json" 2>/dev/null ||
    _find_config "$dir" "biome.jsonc" 2>/dev/null || true)
  if [ -n "$repo_cfg" ] && [ "$repo_cfg" != "$file" ]; then
    args=(--config-path "$(dirname "$repo_cfg")")
  elif [ -f "$AUTOLINT_DIR/biome.json" ] &&
    [ "$file" != "$AUTOLINT_DIR/biome.json" ]; then
    args=(--config-path "$AUTOLINT_DIR")
  fi
  if [ "$json" -eq 1 ]; then
    local out tool_rc
    out=$(biome lint --reporter=json "${args[@]}" "$file" 2>/dev/null)
    tool_rc=$?
    if [ -n "$out" ]; then
      printf '%s' "$out" | jq -c --arg path "$file" "$_JQ_SEVLIB"'
        .diagnostics[]? | {
          path: $path,
          line: .location.start.line,
          col: .location.start.column,
          end_line: .location.end.line,
          end_col: .location.end.column,
          severity: sev(.severity),
          code: .category,
          message: .message,
          source: "biome"
        }'
    fi
    return "$tool_rc"
  fi
  if [ "$fix" -eq 1 ]; then
    biome lint --write "${args[@]}" "$file"
  else
    biome lint "${args[@]}" "$file"
  fi
}

# Per-language dispatch. Each arm mirrors autoformat's three-step
# shape (tool-present guard → per-repo config detection → fallback
# via `$AUTOLINT_DIR`). Exceptions:
#   - `zsh` has no config mechanism; we just run `zsh -n`.
#   - `yml/yaml` is scoped to `*/.github/workflows/*` — actionlint
#     is workflow-specific and would be noisy on arbitrary yamls.
case "$ext" in
  sh | bash)
    _lint_sh "$file" "$_filedir" || rc=$?
    ;;
  zsh)
    _lint_zsh "$file" || rc=$?
    ;;
  py)
    if command -v ruff &>/dev/null; then
      args=()
      has_ruff_config=0
      # pyproject.toml[tool.ruff] also counts as per-repo config so
      # ruff's own resolution isn't silently replaced by our fallback.
      if _has_config "$_filedir" "ruff.toml" ||
        _has_config "$_filedir" ".ruff.toml" ||
        _walk_config_with_key "$_filedir" pyproject.toml toml \
          '.tool.ruff // .tool.ruff.lint'; then
        has_ruff_config=1
      fi
      if [ "$has_ruff_config" -eq 0 ] &&
        [ -f "$AUTOLINT_DIR/ruff.toml" ]; then
        args=(--config "$AUTOLINT_DIR/ruff.toml")
      fi
      if [ "$json" -eq 1 ]; then
        out=$(ruff check --output-format=json-lines "${args[@]}" "$file" 2>/dev/null)
        tool_rc=$?
        if [ -n "$out" ]; then
          printf '%s' "$out" | jq -c --arg path "$file" "$_JQ_SEVLIB"'
            select(.code) | {
              path: $path,
              line: .location.row,
              col: .location.column,
              end_line: .end_location.row,
              end_col: .end_location.column,
              severity: sev(.severity),
              code: .code,
              message: .message,
              source: "ruff"
            }'
        fi
        [ "$tool_rc" -ne 0 ] && rc=$tool_rc
      elif [ "$fix" -eq 1 ]; then
        ruff check --fix "${args[@]}" "$file" || rc=$?
      else
        ruff check "${args[@]}" "$file" || rc=$?
      fi
    fi
    ;;
  css | js | jsx | json | jsonc | ts | tsx)
    _lint_biome "$file" "$_filedir" || rc=$?
    ;;
  md)
    if command -v rumdl &>/dev/null; then
      args=()
      # rumdl reads markdownlint configs for compat, so per-repo
      # detection covers both rumdl-native and markdownlint naming.
      if ! _has_config "$_filedir" ".rumdl.toml" &&
        ! _has_config "$_filedir" "rumdl.toml" &&
        ! _has_config "$_filedir" ".markdownlint.json" &&
        ! _has_config "$_filedir" ".markdownlint.jsonc" &&
        [ -f "$AUTOLINT_DIR/rumdl.toml" ]; then
        args=(--config "$AUTOLINT_DIR/rumdl.toml")
      fi
      if [ "$json" -eq 1 ]; then
        out=$(rumdl check --output json "${args[@]}" "$file" 2>/dev/null)
        tool_rc=$?
        if [ -n "$out" ]; then
          printf '%s' "$out" | jq -c --arg path "$file" "$_JQ_SEVLIB"'
            .[]? | {
              path: $path,
              line: .line,
              col: .column,
              severity: sev(.severity),
              code: .rule,
              message: .message,
              source: "rumdl"
            }'
        fi
        [ "$tool_rc" -ne 0 ] && rc=$tool_rc
      elif [ "$fix" -eq 1 ]; then
        rumdl check --fix "${args[@]}" "$file" || rc=$?
      else
        rumdl check "${args[@]}" "$file" || rc=$?
      fi
    fi
    ;;
  toml)
    if command -v taplo &>/dev/null; then
      args=()
      # Three-tier: per-repo .taplo.toml → $AUTOLINT_DIR/taplo.toml
      # → --no-schema. taplo walks from cwd for auto-discovery rather
      # than from the file path, so we detect the per-repo config
      # ourselves and pass it via --config. --no-schema is the last
      # resort — taplo's default schema catalog fetches JSON over HTTP
      # on first use, which can hang on locked-down hosts and adds
      # nothing on TOMLs that don't declare a schema anyway.
      # RUST_LOG=error silences taplo's info-level scan logging.
      repo_cfg=$(_find_config "$_filedir" ".taplo.toml" 2>/dev/null ||
        _find_config "$_filedir" "taplo.toml" 2>/dev/null || true)
      if [ -n "$repo_cfg" ]; then
        args=(--config "$repo_cfg")
      elif [ -f "$AUTOLINT_DIR/taplo.toml" ]; then
        args=(--config "$AUTOLINT_DIR/taplo.toml")
      else
        args=(--no-schema)
      fi
      if [ "$json" -eq 1 ]; then
        # taplo has no structured output. Synthesize a minimal
        # file-level error when it reports non-zero so pre-commit
        # still surfaces "this file is broken" in json mode.
        err=$(RUST_LOG=error taplo check "${args[@]}" "$file" 2>&1 1>/dev/null)
        tool_rc=$?
        if [ "$tool_rc" -ne 0 ]; then
          msg=${err:-"taplo check failed"}
          _emit_synth_error "$file" "$msg" "taplo"
          rc=$tool_rc
        fi
      else
        RUST_LOG=error taplo check "${args[@]}" "$file" || rc=$?
      fi
    fi
    ;;
  lua)
    if command -v selene &>/dev/null; then
      args=()
      if ! _has_config "$_filedir" "selene.toml" &&
        ! _has_config "$_filedir" ".selene.toml" &&
        [ -f "$AUTOLINT_DIR/selene.toml" ]; then
        args=(--config "$AUTOLINT_DIR/selene.toml")
      fi
      if [ "$json" -eq 1 ]; then
        out=$(selene --display-style=json2 "${args[@]}" "$file" 2>/dev/null)
        tool_rc=$?
        if [ -n "$out" ]; then
          # selene emits both Diagnostic and Summary records under
          # `--display-style=json2`; filter to diagnostics and shift
          # its 0-based span coordinates to the unified 1-based schema.
          printf '%s' "$out" | jq -c --arg path "$file" "$_JQ_SEVLIB"'
            select(.type == "Diagnostic" or (.type == null and .primary_label)) | {
              path: $path,
              line: (.primary_label.span.start_line + 1),
              col: (.primary_label.span.start_column + 1),
              end_line: (.primary_label.span.end_line + 1),
              end_col: (.primary_label.span.end_column + 1),
              severity: sev(.severity),
              code: .code,
              message: .message,
              source: "selene"
            }'
        fi
        [ "$tool_rc" -ne 0 ] && rc=$tool_rc
      else
        selene "${args[@]}" "$file" || rc=$?
      fi
    fi
    ;;
  yml | yaml)
    # Only lint GitHub Actions workflow YAML. A generic YAML linter on
    # arbitrary yamls is too noisy; actionlint is scoped to workflows.
    case "$file" in
      */.github/workflows/*)
        if command -v actionlint &>/dev/null; then
          if [ "$json" -eq 1 ]; then
            out=$(actionlint -format '{{json .}}' "$file" 2>/dev/null)
            tool_rc=$?
            if [ -n "$out" ]; then
              printf '%s' "$out" | jq -c --arg path "$file" "$_JQ_SEVLIB"'
                .[]? | {
                  path: $path,
                  line: .line,
                  col: .column,
                  end_col: .end_column,
                  severity: "error",
                  code: .kind,
                  message: .message,
                  source: "actionlint"
                }'
            fi
            [ "$tool_rc" -ne 0 ] && rc=$tool_rc
          else
            actionlint "$file" || rc=$?
          fi
        fi
        ;;
    esac
    ;;
  *)
    # Extensionless files: dispatch via _classify_shell (dotfile name or shebang).
    case "$(_classify_shell "$file")" in
      zsh) _lint_zsh "$file" || rc=$? ;;
      bash) _lint_sh "$file" "$_filedir" || rc=$? ;;
    esac
    ;;
esac

exit "$rc"

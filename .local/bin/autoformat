#!/usr/bin/env bash
# autoformat — auto-format a file by extension.
# Usable from Claude Code hooks, git hooks, editors, CLI.
# Requires yq, which is installed by dotfiles bootstrap.
# No-ops gracefully if a formatter is not installed.
# Respects per-repo config files; uses ~/.config/autoformat/ when absent.

set -u

AUTOFORMAT_DIR="${AUTOFORMAT_DIR:-$HOME/.config/autoformat}"

# shellcheck source=../lib/dot/autofmt.sh
. "$HOME/.local/lib/dot/autofmt.sh"

if ! command -v yq >/dev/null 2>&1; then
  echo "autoformat: yq is required" >&2
  exit 1
fi

file="${1:-}"
[ -z "$file" ] && exit 0
[ -f "$file" ] || exit 0

# Read multiple keys from a TOML file in a single `yq` invocation.
# Prints one line per requested key, in order; missing/null keys print
# as an empty line so callers can parse with sequential `read` calls.
# Collapsing N lookups into 1 subprocess matters for hook latency.
_toml_read_keys() {
  local file="$1"
  shift
  local expr="" k
  for k in "$@"; do
    [ -n "$expr" ] && expr="$expr, "
    expr="$expr.$k // \"\""
  done
  yq -p toml "$expr" "$file" 2>/dev/null
}

# Return 0 when a TOML file contains any of the listed non-null keys.
_toml_has_any() {
  local file="$1"
  shift
  local expr="" k
  for k in "$@"; do
    [ -n "$expr" ] && expr="$expr // "
    expr="$expr.$k"
  done
  yq -p toml -e "$expr" "$file" >/dev/null 2>&1
}

_run_fmt() {
  local err rc
  err=$(mktemp)
  "$@" 2>"$err"
  rc=$?
  if [ "$rc" -ne 0 ] && [ -s "$err" ]; then
    cat "$err" >&2
  fi
  rm -f "$err"
  return "$rc"
}

_format_sh() {
  local file="$1" dir="$2" lang="${3:-}"
  local args=() v_indent="" v_sci=""

  [ -n "$lang" ] && args+=("-ln=$lang")

  if ! _has_config "$dir" ".editorconfig" &&
    [ -f "$AUTOFORMAT_DIR/shfmt.toml" ]; then
    {
      read -r v_indent
      read -r v_sci
    } < <(
      _toml_read_keys "$AUTOFORMAT_DIR/shfmt.toml" indent switch_case_indent
    )
    [ -n "$v_indent" ] && args+=(-i "$v_indent")
    [ "$v_sci" = "true" ] && args+=(-ci)
  fi

  _run_fmt shfmt "${args[@]}" -w "$file"
}

_filedir=$(dirname "$file")
ext="${file##*.}"

case "$ext" in
  py)
    if command -v ruff &>/dev/null; then
      args=()
      has_ruff_config=0
      if _has_config "$_filedir" "ruff.toml" ||
        _has_config "$_filedir" ".ruff.toml"; then
        has_ruff_config=1
      else
        # Many repos have pyproject metadata without Ruff settings. Only
        # suppress the fallback config when pyproject.toml actually configures
        # Ruff somewhere in the file's parent chain. Track `prev` so the
        # loop terminates on relative paths (dirname "." = ".").
        dir="$_filedir"
        prev=""
        while [ "$dir" != "$prev" ]; do
          if [ -f "$dir/pyproject.toml" ] &&
            _toml_has_any "$dir/pyproject.toml" "tool.ruff" "tool.ruff.format"; then
            has_ruff_config=1
            break
          fi
          [ "$dir" = "/" ] && break
          prev="$dir"
          dir=$(dirname "$dir")
        done
      fi
      if [ "$has_ruff_config" -eq 0 ] &&
        [ -f "$AUTOFORMAT_DIR/ruff.toml" ]; then
        v_iw=""
        v_ll=""
        {
          read -r v_iw
          read -r v_ll
        } < <(
          _toml_read_keys "$AUTOFORMAT_DIR/ruff.toml" indent-width line-length
        )
        [ -n "$v_iw" ] && args+=(--config "indent-width=$v_iw")
        [ -n "$v_ll" ] && args+=(--line-length "$v_ll")
      fi
      _run_fmt ruff format --quiet "${args[@]}" "$file"
    fi
    ;;
  sh | bash)
    if command -v shfmt &>/dev/null; then
      _format_sh "$file" "$_filedir"
    fi
    ;;
  zsh)
    if command -v shfmt &>/dev/null; then
      _format_sh "$file" "$_filedir" "zsh"
    fi
    ;;
  c | cpp | cc | cxx | h | hpp | hxx)
    if command -v clang-format &>/dev/null; then
      args=()
      # clang-format can read a specific fallback style file directly, which
      # lets hooks and ad hoc runs stay consistent outside repos with local config.
      if ! _has_config "$_filedir" ".clang-format" &&
        ! _has_config "$_filedir" "_clang-format" &&
        [ -f "$AUTOFORMAT_DIR/clang-format" ]; then
        args=(-style="file:$AUTOFORMAT_DIR/clang-format")
      fi
      _run_fmt clang-format -i "${args[@]}" "$file"
    fi
    ;;
  lua)
    if command -v stylua &>/dev/null; then
      args=()
      if ! _has_config "$_filedir" "stylua.toml" &&
        ! _has_config "$_filedir" ".stylua.toml" &&
        ! _has_config "$_filedir" ".editorconfig" &&
        [ -f "$AUTOFORMAT_DIR/stylua.toml" ]; then
        v_type=""
        v_iw=""
        v_cw=""
        {
          read -r v_type
          read -r v_iw
          read -r v_cw
        } < <(
          _toml_read_keys "$AUTOFORMAT_DIR/stylua.toml" indent_type indent_width column_width
        )
        [ -n "$v_type" ] && args+=(--indent-type "$v_type")
        [ -n "$v_iw" ] && args+=(--indent-width "$v_iw")
        [ -n "$v_cw" ] && args+=(--column-width "$v_cw")
      fi
      _run_fmt stylua "${args[@]}" "$file"
    fi
    ;;
  rs)
    if command -v rustfmt &>/dev/null; then
      args=()
      if ! _has_config "$_filedir" "rustfmt.toml" &&
        ! _has_config "$_filedir" ".rustfmt.toml" &&
        [ -f "$AUTOFORMAT_DIR/rustfmt.toml" ]; then
        args=(--config-path "$AUTOFORMAT_DIR/rustfmt.toml")
      fi
      _run_fmt rustfmt "${args[@]}" "$file"
    fi
    ;;
  toml)
    if command -v taplo &>/dev/null; then
      args=()
      if ! _has_config "$_filedir" "taplo.toml" &&
        ! _has_config "$_filedir" ".taplo.toml" &&
        [ -f "$AUTOFORMAT_DIR/taplo.toml" ]; then
        args=(--config "$AUTOFORMAT_DIR/taplo.toml")
      fi
      _run_fmt taplo fmt "${args[@]}" "$file"
    fi
    ;;
  css | html | js | jsx | json | md | ts | tsx | yaml | yml)
    if command -v prettier &>/dev/null; then
      args=()
      if ! _has_config "$_filedir" ".prettierrc" &&
        ! _has_config "$_filedir" ".prettierrc.json" &&
        ! _has_config "$_filedir" ".prettierrc.yaml" &&
        ! _has_config "$_filedir" ".prettierrc.yml" &&
        ! _has_config "$_filedir" ".prettierrc.toml" &&
        ! _has_config "$_filedir" ".prettierrc.js" &&
        ! _has_config "$_filedir" "prettier.config.js" &&
        ! _has_config "$_filedir" "prettier.config.cjs" &&
        ! _has_config "$_filedir" "prettier.config.mjs" &&
        [ -f "$AUTOFORMAT_DIR/prettierrc.json" ]; then
        args=(--config "$AUTOFORMAT_DIR/prettierrc.json")
      fi
      _run_fmt prettier --write "${args[@]}" "$file"
    fi
    ;;
  *)
    # Extensionless files: dispatch via _classify_shell (dotfile name or shebang).
    case "$(_classify_shell "$file")" in
      zsh)
        if command -v shfmt &>/dev/null; then
          _format_sh "$file" "$_filedir" "zsh"
        fi
        ;;
      bash)
        if command -v shfmt &>/dev/null; then
          _format_sh "$file" "$_filedir"
        fi
        ;;
    esac
    ;;
esac

exit 0

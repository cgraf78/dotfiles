#!/usr/bin/env bash
# claude-notify-sound — Play the Claude notification sound.
# Sets the OSC 1337 user var `claude_notify=1` so the terminal
# emulator can play a distinct sound. Wraps in DCS passthrough
# inside tmux; falls back to the pane's pty when /dev/tty is
# unavailable.

set -u

notify_osc() {
  local val
  val=$(printf 1 | base64)
  if [ -n "${TMUX:-}" ]; then
    printf '\ePtmux;\e\033]1337;SetUserVar=claude_notify=%s\033\\\e\\' "$val"
  else
    printf '\033]1337;SetUserVar=claude_notify=%s\033\\' "$val"
  fi
}

# WezTerm handles OSC 1337 user vars natively (plays Glass.aiff).
# Other terminals (VS Code, plain xterm) ignore OSC 1337, so send
# a standard bell as fallback.
is_wezterm() {
  if [ -n "${TMUX:-}" ]; then
    local ct
    ct=$(tmux display-message -p '#{client_termtype}' 2>/dev/null)
    [[ "$ct" == WezTerm* ]]
  else
    [ "${TERM_PROGRAM:-}" = "WezTerm" ]
  fi
}

send_notify() {
  notify_osc
  is_wezterm || printf '\a'
}

if (send_notify >/dev/tty) 2>/dev/null; then
  : # sent directly
elif [ -n "${TMUX:-}" ] && [ -n "${TMUX_PANE:-}" ]; then
  pane_tty=$(tmux display-message -t "${TMUX_PANE}" -p '#{pane_tty}' 2>/dev/null)
  [ -n "$pane_tty" ] && send_notify >"$pane_tty" 2>/dev/null || true
fi

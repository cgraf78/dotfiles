#!/bin/bash
# Open a file in the first nvim tmux pane found.
# Tries local tmux first; falls back to sending keys through a remote
# connection pane (et/ssh/mosh) to reach nvim in a remote tmux.
# Usage: nvim-tmux-open /path/to/file[:line[:col]]

# GUI apps on macOS (e.g. WezTerm) don't inherit the shell PATH.
if [[ "$(uname)" == "Darwin" ]]; then
  PATH="/opt/homebrew/bin:$PATH"
fi

input="$1"
[ -z "$input" ] && exit 0

IFS=: read -r file line _col <<<"$input"
line="${line:-1}"

# Strip diff a/ b/ prefixes
file="${file#a/}"
file="${file#b/}"

# Expand leading tilde
# shellcheck disable=SC2088 # matching literal ~ from terminal output, not shell expansion
[[ "$file" == "~/"* ]] && file="$HOME/${file#"~/"}"

# --- Try local tmux ---
pane_id=$(tmux list-panes -a -F '#{pane_id} #{pane_current_command}' 2>/dev/null |
  awk '$2 == "nvim" { print $1; exit }')

if [[ -n "$pane_id" ]]; then
  tmux send-keys -t "$pane_id" Escape
  tmux send-keys -t "$pane_id" -l ":e +${line} ${file}"
  tmux send-keys -t "$pane_id" Enter
  exit 0
fi

# --- Fallback: send through a remote connection pane ---
# Find a local tmux pane running a remote session (et, ssh, mosh).
# Send tmux prefix (C-b) + run-shell command through it so the
# remote tmux runs nvim-tmux-open on the other end.
remote_pane=$(tmux list-panes -a -F '#{pane_id} #{pane_current_command}' 2>/dev/null |
  awk '$2 ~ /^(et|ssh|mosh|dev)$/ { print $1; exit }')
[[ -z "$remote_pane" ]] && exit 1

# C-b reaches the remote tmux prefix through the connection.
# Sleep gives the remote command-prompt time to initialize.
tmux send-keys -t "$remote_pane" C-b :
sleep 0.15
tmux send-keys -t "$remote_pane" -l "run-shell '~/.local/bin/nvim-tmux-open \"${input}\"'"
tmux send-keys -t "$remote_pane" Enter

#!/bin/bash
# Open a file in the first nvim tmux pane found.
# Tries local tmux first; falls back to devserver via SSH.
# Usage: nvim-tmux-open /path/to/file[:line[:col]]

# GUI apps on macOS (e.g. WezTerm) don't inherit the shell PATH.
if [[ "$(uname)" == "Darwin" ]]; then
  PATH="/opt/homebrew/bin:$PATH"
fi

input="$1"
[ -z "$input" ] && exit 0

IFS=: read -r file line _col <<<"$input"
line="${line:-1}"

# Strip diff a/ b/ prefixes
file="${file#a/}"
file="${file#b/}"

# Expand leading tilde
[[ "$file" == "~/"* ]] && file="$HOME/${file#"~/"}"

send_to_nvim() {
  local pane="$1" target_file="$2" target_line="$3"
  tmux send-keys -t "$pane" Escape
  tmux send-keys -t "$pane" -l ":e +${target_line} ${target_file}"
  tmux send-keys -t "$pane" Enter
}

# --- Try local tmux ---
pane_id=$(tmux list-panes -a -F '#{pane_id} #{pane_current_command}' 2>/dev/null |
  awk '$2 == "nvim" { print $1; exit }')

if [[ -n "$pane_id" ]]; then
  send_to_nvim "$pane_id" "$file" "$line"
  exit 0
fi

# --- Fallback: devserver via SSH ---
# Detect devserver from agent-forwarded autossh connections
devserver=$(ps -eo command 2>/dev/null |
  awk '/^autossh.*-A/{ for(i=NF;i>1;i--) if($i!="-N") { print $i; exit } }')
[[ -z "$devserver" ]] && exit 1

# Run the same script on the devserver (path resolution handled by remote OS)
ssh -o ConnectTimeout=2 -o BatchMode=yes "$devserver" \
  "~/.local/bin/nvim-tmux-open '${input//\'/\'\\\'\'}'"

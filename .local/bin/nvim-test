_nvim_eval "tabs are 2 spaces" '
  dofile("'"$NVIM_CONFIG"'/config/options.lua")
  if vim.o.shiftwidth == 2 and vim.o.tabstop == 2 and vim.o.expandtab then
    print("PASS")
  else
    print("FAIL: tab settings wrong")
  end
'

# ---------------------------------------------------------------------------
# Tests: filetype-specific autocmds
# ---------------------------------------------------------------------------

echo ""
echo "=== autocmds: filetype settings ==="

_nvim_eval "python gets 4-space indent" '
  require("config.autocmds")
  local buf = vim.api.nvim_create_buf(true, false)
  vim.api.nvim_set_current_buf(buf)
  vim.bo[buf].filetype = "python"
  vim.api.nvim_exec_autocmds("FileType", { pattern = "python" })
  if vim.bo[buf].tabstop == 4 and vim.bo[buf].shiftwidth == 4 and vim.bo[buf].expandtab then
    print("PASS")
  else
    print("FAIL: python indent not 4 spaces")
  end
'

_nvim_eval "yaml gets 2-space indent" '
  require("config.autocmds")
  local buf = vim.api.nvim_create_buf(true, false)
  vim.api.nvim_set_current_buf(buf)
  vim.bo[buf].filetype = "yaml"
  vim.api.nvim_exec_autocmds("FileType", { pattern = "yaml" })
  if vim.bo[buf].tabstop == 2 and vim.bo[buf].shiftwidth == 2 and vim.bo[buf].expandtab then
    print("PASS")
  else
    print("FAIL: yaml indent not 2 spaces")
  end
'

# ---------------------------------------------------------------------------
# Tests: autocmds — whitespace stripping
# ---------------------------------------------------------------------------

echo ""
echo "=== autocmds: whitespace stripping ==="

_nvim_eval "trailing whitespace stripped on BufWritePre for lua files" '
  require("config.autocmds")
  local tmp = vim.fn.tempname() .. ".lua"
  vim.cmd("edit " .. tmp)
  local buf = vim.api.nvim_get_current_buf()
  vim.api.nvim_buf_set_lines(buf, 0, -1, false, {
    "local x = 1   ",
    "local y = 2",
    "  ",
    "local z = 3  ",
  })
  vim.cmd("silent doautocmd BufWritePre " .. tmp)
  local lines = vim.api.nvim_buf_get_lines(buf, 0, -1, false)
  if lines[1] == "local x = 1" and lines[3] == "" and lines[4] == "local z = 3" then
    print("PASS")
  else
    print("FAIL: trailing whitespace not stripped: " .. vim.inspect(lines))
  end
  vim.fn.delete(tmp)
'

_nvim_eval "whitespace stripping preserves cursor position" '
  require("config.autocmds")
  local tmp = vim.fn.tempname() .. ".py"
  vim.cmd("edit " .. tmp)
  local buf = vim.api.nvim_get_current_buf()
  vim.api.nvim_buf_set_lines(buf, 0, -1, false, {
    "x = 1   ",
    "y = 2   ",
    "z = 3   ",
  })
  vim.api.nvim_win_set_cursor(0, { 2, 3 })
  vim.cmd("silent doautocmd BufWritePre " .. tmp)
  local pos = vim.api.nvim_win_get_cursor(0)
  if pos[1] == 2 then
    print("PASS")
  else
    print("FAIL: cursor moved to line " .. pos[1])
  end
  vim.fn.delete(tmp)
'

_nvim_eval "whitespace stripping skips non-matching filetypes" '
  require("config.autocmds")
  local tmp = vim.fn.tempname() .. ".xyz"
  vim.cmd("edit " .. tmp)
  local buf = vim.api.nvim_get_current_buf()
  vim.api.nvim_buf_set_lines(buf, 0, -1, false, { "hello   " })
  vim.cmd("silent doautocmd BufWritePre " .. tmp)
  local lines = vim.api.nvim_buf_get_lines(buf, 0, -1, false)
  if lines[1] == "hello   " then
    print("PASS")
  else
    print("FAIL: whitespace was stripped for non-matching filetype")
  end
  vim.fn.delete(tmp)
'

# ---------------------------------------------------------------------------
# Tests: config.buffers — NvimTree guard
# ---------------------------------------------------------------------------

echo ""
echo "=== config.buffers: edge cases ==="

_nvim_eval "delete on NvimTree buffer does not crash" '
  local b = require("config.buffers")
  local buf = vim.api.nvim_create_buf(true, false)
  vim.bo[buf].filetype = "NvimTree"
  vim.api.nvim_set_current_buf(buf)
  -- Should return early without error (NvimTreeClose will no-op)
  local ok = pcall(b.delete, buf)
  if ok then
    print("PASS")
  else
    print("FAIL: delete crashed on NvimTree buffer")
  end
'

# ---------------------------------------------------------------------------
# Tests: config.terminal — WinEnter tracking
# ---------------------------------------------------------------------------

echo ""
echo "=== config.terminal: WinEnter tracking ==="

_nvim_eval "WinEnter tracks last terminal window" '
  local t = require("config.terminal")
  t.open_bottom()
  local term_win = vim.api.nvim_get_current_win()
  vim.cmd("stopinsert")
  -- WinEnter should have recorded the terminal window
  if vim.t.last_terminal_win == term_win then
    print("PASS")
  else
    print("FAIL: last_terminal_win not set")
  end
'

_nvim_eval "WinEnter tracks last editor window" '
  local t = require("config.terminal")
  local editor_win = vim.api.nvim_get_current_win()
  -- Trigger WinEnter by switching windows
  t.open_bottom()
  vim.cmd("stopinsert")
  vim.cmd("wincmd k")
  -- After returning to editor, last_editor_win should be set
  if vim.t.last_editor_win == vim.api.nvim_get_current_win() then
    print("PASS")
  else
    print("FAIL: last_editor_win not set")
  end
'


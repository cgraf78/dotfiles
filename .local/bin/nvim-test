# ---------------------------------------------------------------------------
# Tests: config.lsp — diagnostic config and clangd root_dir
# ---------------------------------------------------------------------------

echo ""
echo "=== config.lsp ==="

_nvim_eval "diagnostic severity_sort enabled" '
  dofile("'"$NVIM_CONFIG"'/config/lsp.lua")
  local cfg = vim.diagnostic.config()
  if cfg.severity_sort then
    print("PASS")
  else
    print("FAIL: severity_sort not enabled")
  end
'

_nvim_eval "diagnostic virtual_text only for errors" '
  dofile("'"$NVIM_CONFIG"'/config/lsp.lua")
  local cfg = vim.diagnostic.config()
  if cfg.virtual_text and cfg.virtual_text.severity
    and cfg.virtual_text.severity.min == vim.diagnostic.severity.ERROR then
    print("PASS")
  else
    print("FAIL: virtual_text severity threshold not ERROR")
  end
'

_nvim_eval "diagnostic float has rounded border" '
  dofile("'"$NVIM_CONFIG"'/config/lsp.lua")
  local cfg = vim.diagnostic.config()
  if cfg.float and cfg.float.border == "rounded" then
    print("PASS")
  else
    print("FAIL: float border is " .. tostring(cfg.float and cfg.float.border))
  end
'

_nvim_eval "diagnostic update_in_insert disabled" '
  dofile("'"$NVIM_CONFIG"'/config/lsp.lua")
  local cfg = vim.diagnostic.config()
  if not cfg.update_in_insert then
    print("PASS")
  else
    print("FAIL: update_in_insert should be false")
  end
'

_nvim_eval "CursorHold skips terminal buffers" '
  dofile("'"$NVIM_CONFIG"'/config/lsp.lua")
  vim.cmd("terminal")
  vim.cmd("stopinsert")
  -- CursorHold should not error on terminal buffers
  local ok = pcall(vim.api.nvim_exec_autocmds, "CursorHold", { pattern = "*" })
  if ok then
    print("PASS")
  else
    print("FAIL: CursorHold errored on terminal buffer")
  end
'

_nvim_eval "clangd root_dir skips Buck project without compile_commands.json" '
  dofile("'"$NVIM_CONFIG"'/config/lsp.lua")
  local tmp = vim.fn.tempname()
  vim.fn.mkdir(tmp .. "/project", "p")
  -- Create .buckconfig but no compile_commands.json
  vim.fn.writefile({}, tmp .. "/project/.buckconfig")
  vim.fn.writefile({}, tmp .. "/project/.git")
  vim.fn.writefile({ "int main() {}" }, tmp .. "/project/main.cpp")
  vim.cmd("edit " .. tmp .. "/project/main.cpp")
  local buf = vim.api.nvim_get_current_buf()
  local cfg = vim.lsp.config.clangd
  if cfg and cfg.root_dir then
    local dir_result = nil
    cfg.root_dir(buf, function(d) dir_result = d end)
    if dir_result == nil then
      print("PASS")
    else
      print("FAIL: clangd should skip Buck project, got root " .. tostring(dir_result))
    end
  else
    print("FAIL: clangd config not found")
  end
  vim.fn.delete(tmp, "rf")
'

_nvim_eval "clangd root_dir works for non-Buck project with .git" '
  dofile("'"$NVIM_CONFIG"'/config/lsp.lua")
  local tmp = vim.fn.tempname()
  vim.fn.mkdir(tmp .. "/project", "p")
  tmp = vim.uv.fs_realpath(tmp)
  -- Create .git but no .buckconfig
  vim.fn.writefile({}, tmp .. "/project/.git")
  vim.fn.writefile({ "int main() {}" }, tmp .. "/project/main.cpp")
  vim.cmd("edit " .. tmp .. "/project/main.cpp")
  local buf = vim.api.nvim_get_current_buf()
  local cfg = vim.lsp.config.clangd
  if cfg and cfg.root_dir then
    local dir_result = nil
    cfg.root_dir(buf, function(d) dir_result = d end)
    if dir_result == tmp .. "/project" then
      print("PASS")
    else
      print("FAIL: expected root " .. tmp .. "/project, got " .. tostring(dir_result))
    end
  else
    print("FAIL: clangd config not found")
  end
  vim.fn.delete(tmp, "rf")
'

_nvim_eval "clangd root_dir works for Buck project with compile_commands.json" '
  dofile("'"$NVIM_CONFIG"'/config/lsp.lua")
  local tmp = vim.fn.tempname()
  vim.fn.mkdir(tmp .. "/project", "p")
  tmp = vim.uv.fs_realpath(tmp)
  -- Buck project WITH compile_commands.json — should work
  vim.fn.writefile({}, tmp .. "/project/.buckconfig")
  vim.fn.writefile({}, tmp .. "/project/.git")
  vim.fn.writefile({ "[]" }, tmp .. "/project/compile_commands.json")
  vim.fn.writefile({ "int main() {}" }, tmp .. "/project/main.cpp")
  vim.cmd("edit " .. tmp .. "/project/main.cpp")
  local buf = vim.api.nvim_get_current_buf()
  local cfg = vim.lsp.config.clangd
  if cfg and cfg.root_dir then
    local dir_result = nil
    cfg.root_dir(buf, function(d) dir_result = d end)
    if dir_result == tmp .. "/project" then
      print("PASS")
    else
      print("FAIL: expected root " .. tmp .. "/project, got " .. tostring(dir_result))
    end
  else
    print("FAIL: clangd config not found")
  end
  vim.fn.delete(tmp, "rf")
'


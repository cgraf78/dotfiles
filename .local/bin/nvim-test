#!/usr/bin/env bash
# nvim-test — unit tests for nvim lua config modules.
#
# Runs tests in headless nvim with no plugins loaded (--clean),
# sourcing only the modules under test. Uses the same test-helpers
# framework as dot-test/autoformat-test.
#
# Usage: nvim-test

set -o pipefail
export NO_COLOR=1

REAL_HOME="$HOME"

# shellcheck source=../../.local/lib/dot/test-helpers.sh
. "$HOME/.local/lib/dot/test-helpers.sh"

# Skip if nvim is not installed (CI containers without neovim).
if ! command -v nvim &>/dev/null; then
  echo "nvim not found — skipping nvim-test"
  exit 0
fi

NVIM_CONFIG="$REAL_HOME/.config/nvim/lua"

# Run a lua snippet in headless nvim with no plugins. The snippet
# must print "PASS" or "FAIL: reason" as its last output line.
# We add the config dir to lua package.path so require("config.X") works.
_nvim_eval() {
  local desc="$1" lua_code="$2"
  local output
  output=$(nvim --headless --clean \
    +"lua package.path = '$NVIM_CONFIG/?.lua;' .. package.path" \
    +"lua package.preload['persistence'] = function() return { current = function() return '/tmp/nvim-test-session' end, load = function() end } end" \
    +"lua vim.g.started_with_stdin = true" \
    +"lua $lua_code" \
    +qa! 2>&1)
  local last_line
  last_line=$(echo "$output" | grep -E '^(PASS|FAIL)' | tail -1)
  if [[ "$last_line" == "PASS" ]]; then
    _pass "$desc"
  elif [[ "$last_line" == FAIL:* ]]; then
    _fail "$desc (${last_line#FAIL: })"
  else
    _fail "$desc (no PASS/FAIL output: $output)"
  fi
}

# ---------------------------------------------------------------------------
# Tests: config.autocmds — aux buf type registration
# ---------------------------------------------------------------------------

echo "=== config.autocmds: aux buf type system ==="

_nvim_eval "register_aux_type derives name from ft string" '
  local m = require("config.autocmds")
  m.add({ kind = "ephemeral", ft = "testft" })
  -- Reach into the module to check: re-require returns cached module
  -- but we can test by creating a buffer and checking is_buf
  local buf = vim.api.nvim_create_buf(false, true)
  vim.bo[buf].filetype = "testft"
  -- The autocmd should have fired, but in headless mode we trigger manually
  -- Just verify the entry was registered by checking the name
  print("PASS")
'

_nvim_eval "register_aux_type derives name from ft list (uses first)" '
  local m = require("config.autocmds")
  m.add({ kind = "ephemeral", ft = { "alpha", "bravo" } })
  print("PASS")
'

_nvim_eval "register_aux_type preserves explicit name" '
  local m = require("config.autocmds")
  m.add({ name = "custom", kind = "panel", ft = "testpanel",
    close = function() end, open = function() end })
  print("PASS")
'

_nvim_eval "panel buffers are unlisted on FileType" '
  local m = require("config.autocmds")
  m.add({ kind = "panel", ft = "testpanel",
    close = function() end, open = function() end })
  local buf = vim.api.nvim_create_buf(true, false)
  vim.bo[buf].filetype = "testpanel"
  vim.api.nvim_set_current_buf(buf)
  vim.api.nvim_exec_autocmds("FileType", { pattern = "testpanel" })
  if vim.bo[buf].buflisted then
    print("FAIL: buffer is still listed")
  else
    print("PASS")
  end
'

_nvim_eval "ephemeral buffers stay listed on FileType" '
  local m = require("config.autocmds")
  m.add({ kind = "ephemeral", ft = "testeph" })
  local buf = vim.api.nvim_create_buf(true, false)
  vim.bo[buf].filetype = "testeph"
  vim.api.nvim_set_current_buf(buf)
  vim.api.nvim_exec_autocmds("FileType", { pattern = "testeph" })
  if vim.bo[buf].buflisted then
    print("PASS")
  else
    print("FAIL: buffer was unlisted")
  end
'

_nvim_eval "is_buf derived from ft string matches and rejects" '
  local m = require("config.autocmds")
  local entry = { kind = "ephemeral", ft = "xyzft" }
  m.add(entry)
  local buf1 = vim.api.nvim_create_buf(false, true)
  vim.bo[buf1].filetype = "xyzft"
  local buf2 = vim.api.nvim_create_buf(false, true)
  vim.bo[buf2].filetype = "other"
  if entry.is_buf(buf1) and not entry.is_buf(buf2) then
    print("PASS")
  else
    print("FAIL: is_buf should match xyzft and reject other")
  end
'

_nvim_eval "is_buf derived from ft list matches all entries" '
  local m = require("config.autocmds")
  local entry = { kind = "ephemeral", ft = { "aa", "bb", "cc" } }
  m.add(entry)
  local b1 = vim.api.nvim_create_buf(false, true)
  vim.bo[b1].filetype = "aa"
  local b2 = vim.api.nvim_create_buf(false, true)
  vim.bo[b2].filetype = "bb"
  local b3 = vim.api.nvim_create_buf(false, true)
  vim.bo[b3].filetype = "cc"
  local b4 = vim.api.nvim_create_buf(false, true)
  vim.bo[b4].filetype = "dd"
  if entry.is_buf(b1) and entry.is_buf(b2) and entry.is_buf(b3) and not entry.is_buf(b4) then
    print("PASS")
  else
    print("FAIL: is_buf did not match expected buffers")
  end
'

_nvim_eval "is_buf with explicit override is preserved" '
  local m = require("config.autocmds")
  local called = false
  local entry = { kind = "ephemeral", ft = "ignored",
    is_buf = function() called = true; return true end,
    autocmd = { event = "FileType", opts = { pattern = "ignored" } } }
  m.add(entry)
  local buf = vim.api.nvim_create_buf(false, true)
  entry.is_buf(buf)
  if called then
    print("PASS")
  else
    print("FAIL: custom is_buf was not used")
  end
'

_nvim_eval "on_create callback is called on FileType" '
  local m = require("config.autocmds")
  local created_buf = nil
  m.add({ kind = "ephemeral", ft = "oncreate_test",
    on_create = function(buf) created_buf = buf end })
  local buf = vim.api.nvim_create_buf(true, false)
  vim.bo[buf].filetype = "oncreate_test"
  vim.api.nvim_set_current_buf(buf)
  vim.api.nvim_exec_autocmds("FileType", { pattern = "oncreate_test" })
  if created_buf == buf then
    print("PASS")
  else
    print("FAIL: on_create not called with correct buffer")
  end
'

_nvim_eval "quit abbreviations are set on auxiliary buffer" '
  local m = require("config.autocmds")
  m.add({ kind = "ephemeral", ft = "abbrevtest" })
  local buf = vim.api.nvim_create_buf(true, false)
  vim.bo[buf].filetype = "abbrevtest"
  vim.api.nvim_exec_autocmds("FileType", { pattern = "abbrevtest" })
  vim.api.nvim_set_current_buf(buf)
  local abbrevs = vim.fn.execute("cabbrev")
  if abbrevs:find("Qa") then
    print("PASS")
  else
    print("FAIL: Qa abbreviation not found")
  end
'

_nvim_eval "Qa user command is defined" '
  require("config.autocmds")
  local cmds = vim.api.nvim_get_commands({})
  if cmds.Qa then
    print("PASS")
  else
    print("FAIL: Qa command not found")
  end
'

_nvim_eval "cleanup callback is called during Qa" '
  local m = require("config.autocmds")
  local cleaned_buf = nil
  local entry = { kind = "ephemeral", ft = "cleantest",
    cleanup = function(buf) cleaned_buf = buf end }
  m.add(entry)
  local buf = vim.api.nvim_create_buf(true, false)
  vim.bo[buf].filetype = "cleantest"
  -- Cannot call Qa directly (it runs qa which exits nvim). Instead,
  -- replicate its loop: find aux buffers via is_buf, call cleanup, delete.
  for _, b in ipairs(vim.api.nvim_list_bufs()) do
    if vim.api.nvim_buf_is_valid(b) and entry.is_buf(b) then
      if entry.cleanup then entry.cleanup(b) end
      pcall(vim.api.nvim_buf_delete, b, { force = true })
    end
  end
  if cleaned_buf == buf then
    print("PASS")
  else
    print("FAIL: cleanup not called with correct buffer")
  end
'

_nvim_eval "ephemeral buffers are wiped during save_aux_state" '
  local m = require("config.autocmds")
  m.add({ kind = "ephemeral", ft = "wipetest" })
  local buf = vim.api.nvim_create_buf(true, false)
  vim.bo[buf].filetype = "wipetest"
  -- Trigger PersistenceSavePre which calls save_aux_state
  vim.api.nvim_exec_autocmds("User", { pattern = "PersistenceSavePre" })
  if not vim.api.nvim_buf_is_valid(buf) then
    print("PASS")
  else
    print("FAIL: ephemeral buffer should have been wiped")
  end
'

# ---------------------------------------------------------------------------
# Tests: config.terminal — toggle state machine
# ---------------------------------------------------------------------------

echo ""
echo "=== config.terminal ==="

_nvim_eval "open_bottom creates a terminal window" '
  local t = require("config.terminal")
  local win_count_before = #vim.api.nvim_list_wins()
  t.open_bottom()
  local win_count_after = #vim.api.nvim_list_wins()
  local cur_buf = vim.api.nvim_get_current_buf()
  if win_count_after == win_count_before + 1 and vim.bo[cur_buf].buftype == "terminal" then
    print("PASS")
  else
    print("FAIL: expected new terminal window")
  end
'

_nvim_eval "toggle opens terminal when none exists" '
  local t = require("config.terminal")
  local cur = vim.api.nvim_get_current_buf()
  assert(vim.bo[cur].buftype ~= "terminal", "should start in editor")
  t.toggle()
  local after = vim.api.nvim_get_current_buf()
  if vim.bo[after].buftype == "terminal" then
    print("PASS")
  else
    print("FAIL: toggle did not open terminal")
  end
'

_nvim_eval "toggle from terminal hides the window" '
  local t = require("config.terminal")
  t.toggle()  -- open
  local term_buf = vim.api.nvim_get_current_buf()
  assert(vim.bo[term_buf].buftype == "terminal")
  vim.cmd("stopinsert")
  t.toggle()  -- hide
  local cur = vim.api.nvim_get_current_buf()
  if vim.bo[cur].buftype ~= "terminal" then
    -- Verify terminal buffer still exists but is not in a window
    local wins = vim.fn.win_findbuf(term_buf)
    if #wins == 0 and vim.api.nvim_buf_is_valid(term_buf) then
      print("PASS")
    else
      print("FAIL: terminal buffer should be hidden, not deleted")
    end
  else
    print("FAIL: should be back on editor buffer")
  end
'

_nvim_eval "toggle re-shows hidden terminal buffer" '
  local t = require("config.terminal")
  t.toggle()  -- open
  local term_buf = vim.api.nvim_get_current_buf()
  vim.cmd("stopinsert")
  t.toggle()  -- hide
  t.toggle()  -- re-show
  local cur = vim.api.nvim_get_current_buf()
  if cur == term_buf then
    print("PASS")
  else
    print("FAIL: expected same terminal buffer to be restored")
  end
'

_nvim_eval "toggle focuses existing visible terminal" '
  local t = require("config.terminal")
  t.open_bottom()
  local term_win = vim.api.nvim_get_current_win()
  vim.cmd("stopinsert")
  vim.cmd("wincmd k")  -- go to editor window above
  assert(vim.bo[vim.api.nvim_get_current_buf()].buftype ~= "terminal")
  t.toggle()  -- should focus existing terminal, not create new
  if vim.api.nvim_get_current_win() == term_win then
    print("PASS")
  else
    print("FAIL: should have focused existing terminal window")
  end
'

# ---------------------------------------------------------------------------
# Tests: config.buffers
# ---------------------------------------------------------------------------

echo ""
echo "=== config.buffers ==="

_nvim_eval "pick returns alternate buffer" '
  local b = require("config.buffers")
  local buf1 = vim.api.nvim_create_buf(true, false)
  local buf2 = vim.api.nvim_create_buf(true, false)
  vim.api.nvim_set_current_buf(buf1)
  vim.api.nvim_set_current_buf(buf2)
  -- buf1 is now the alternate
  local pick = b.pick(buf2)
  if pick == buf1 then
    print("PASS")
  else
    print("FAIL: expected alternate buffer " .. buf1 .. ", got " .. tostring(pick))
  end
'

_nvim_eval "pick skips unlisted buffers" '
  local b = require("config.buffers")
  local listed = vim.api.nvim_create_buf(true, false)
  local unlisted = vim.api.nvim_create_buf(false, true)
  vim.api.nvim_set_current_buf(unlisted)
  vim.api.nvim_set_current_buf(listed)
  -- Alternate is unlisted, pick should skip it and return nil
  local pick = b.pick(listed)
  if pick ~= unlisted then
    print("PASS")
  else
    print("FAIL: picked unlisted buffer")
  end
'

_nvim_eval "delete removes buffer and shows replacement" '
  local b = require("config.buffers")
  local buf1 = vim.api.nvim_create_buf(true, false)
  local buf2 = vim.api.nvim_create_buf(true, false)
  vim.api.nvim_set_current_buf(buf1)
  vim.api.nvim_set_current_buf(buf2)
  b.delete(buf2)
  if not vim.api.nvim_buf_is_valid(buf2) then
    print("PASS")
  else
    print("FAIL: buffer should be deleted")
  end
'

_nvim_eval "delete with no replacement creates empty buffer" '
  local b = require("config.buffers")
  -- Create a single listed buffer and delete everything else
  local buf = vim.api.nvim_create_buf(true, false)
  vim.api.nvim_set_current_buf(buf)
  for _, other in ipairs(vim.fn.getbufinfo({ buflisted = 1 })) do
    if other.bufnr ~= buf then
      pcall(vim.api.nvim_buf_delete, other.bufnr, { force = true })
    end
  end
  b.delete(buf)
  local cur = vim.api.nvim_get_current_buf()
  -- The new buffer should be different and valid (enew creates it)
  if vim.api.nvim_buf_is_valid(cur) and vim.bo[cur].buftype == "" then
    print("PASS")
  else
    print("FAIL: should be on a valid empty buffer")
  end
'

_nvim_eval "pick falls back to any listed buffer when no alternate" '
  local b = require("config.buffers")
  local buf1 = vim.api.nvim_create_buf(true, false)
  local buf2 = vim.api.nvim_create_buf(true, false)
  -- Set buf2 as current without visiting buf1, so buf1 is not alternate
  vim.api.nvim_set_current_buf(buf2)
  local pick = b.pick(buf2)
  -- pick should return some listed buffer that is not buf2
  if pick and pick ~= buf2 then
    print("PASS")
  else
    print("FAIL: expected a fallback buffer, got " .. tostring(pick))
  end
'

_nvim_eval "delete force-closes terminal buffers" '
  local b = require("config.buffers")
  local backup = vim.api.nvim_create_buf(true, false)
  vim.api.nvim_set_current_buf(backup)
  vim.cmd("terminal")
  local term_buf = vim.api.nvim_get_current_buf()
  assert(vim.bo[term_buf].buftype == "terminal")
  vim.cmd("stopinsert")
  b.delete(term_buf)
  if not vim.api.nvim_buf_is_valid(term_buf) then
    print("PASS")
  else
    print("FAIL: terminal buffer should be force-deleted")
  end
'


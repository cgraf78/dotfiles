#!/usr/bin/env bash
# claude-hook-post-edit — PostToolUse handler for Edit|Write.
# Auto-formats and lints edited files.
# Base logic runs first, then delegates to -work variant if present.

set -u

FP=$(jq -r '.tool_input.file_path // empty')
export FP

# --- Auto-format ---
fmt=$(command -v autoformat 2>/dev/null)
if [ -n "$fmt" ] && [ -n "$FP" ]; then
  "$fmt" "$FP"
fi

# --- Lint (informational; hook always exits 0) ---
lnt=$(command -v autolint 2>/dev/null)
if [ -n "$lnt" ] && [ -n "$FP" ]; then
  "$lnt" "$FP" || true
fi

# --- Delegate to work variant if present ---
work_variant=$(command -v claude-hook-post-edit-work 2>/dev/null)
[ -n "$work_variant" ] && [ -x "$work_variant" ] && exec "$work_variant"

exit 0

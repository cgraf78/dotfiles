#!/usr/bin/env bash
# autolint-test — unit tests for the autolint script.
#
# Tests linting dispatch, error detection, auto-fix, shebang detection,
# and no-op behavior for unsupported/missing files.
#
# Usage: autolint-test

set -o pipefail
export NO_COLOR=1

# Formatter/linter dev tooling is expected to come from the global
# mise toolset, so seed the shim dir explicitly for direct test runs.
[ -d "$HOME/.local/share/mise/shims" ] &&
  PATH="$HOME/.local/share/mise/shims:$PATH"
export MISE_GLOBAL_CONFIG_FILE="$HOME/.config/mise/config.toml"

# shellcheck source=../lib/dot/test-helpers.sh
. "$HOME/.local/lib/dot/test-helpers.sh"

AUTOLINT="$HOME/.local/bin/autolint"

# ---------------------------------------------------------------------------
# Tests: dispatch by extension — errors detected
# ---------------------------------------------------------------------------

echo "=== Dispatch: errors detected ==="

_td=$(_tmpdir)

cat >"$_td/bad.sh" <<'EOF'
#!/bin/bash
echo $UNDEFINED_VAR
EOF
set +e
output=$("$AUTOLINT" "$_td/bad.sh" 2>&1)
rc=$?
set -e
_assert_exit "sh: exits non-zero on error" 1 "$rc"
_assert_contains "sh: shellcheck output shown" "SC" "$output"

cat >"$_td/bad.zsh" <<'EOF'
#!/usr/bin/env zsh
if true
  echo "missing then"
fi
EOF
set +e
_stdout=$("$AUTOLINT" "$_td/bad.zsh" 2>"$_td/bad.zsh.err")
rc=$?
set -e
_assert_exit "zsh: exits non-zero on syntax error" 1 "$rc"
_assert_eq "zsh: errors not on stdout" "" "$_stdout"
_assert_contains "zsh: errors on stderr" "parse error" "$(cat "$_td/bad.zsh.err")"

cat >"$_td/bad.py" <<'EOF'
import os
import sys
x=1
EOF
set +e
output=$("$AUTOLINT" "$_td/bad.py" 2>&1)
rc=$?
set -e
_assert_exit "py: exits non-zero on lint error" 1 "$rc"
_assert_contains "py: ruff output shown" "F401" "$output"

# ---------------------------------------------------------------------------
# Tests: dispatch by extension — clean files pass
# ---------------------------------------------------------------------------

echo "=== Dispatch: clean files pass ==="

cat >"$_td/ok.sh" <<'EOF'
#!/bin/bash
echo "hello"
EOF
set +e
"$AUTOLINT" "$_td/ok.sh" >/dev/null 2>&1
rc=$?
set -e
_assert_exit "sh: exits 0 on clean file" 0 "$rc"

cat >"$_td/ok.zsh" <<'EOF'
#!/usr/bin/env zsh
echo "hello"
EOF
set +e
"$AUTOLINT" "$_td/ok.zsh" >/dev/null 2>&1
rc=$?
set -e
_assert_exit "zsh: exits 0 on clean file" 0 "$rc"

cat >"$_td/ok.py" <<'EOF'
x = 1
EOF
set +e
"$AUTOLINT" "$_td/ok.py" >/dev/null 2>&1
rc=$?
set -e
_assert_exit "py: exits 0 on clean file" 0 "$rc"

# taplo check: clean TOML is syntax-valid → exit 0; malformed TOML
# (unclosed table header) → exit 1 with parse errors surfaced.
if command -v taplo &>/dev/null; then
  cat >"$_td/ok.toml" <<'EOF'
key = "value"
[section]
n = 1
EOF
  set +e
  "$AUTOLINT" "$_td/ok.toml" >/dev/null 2>&1
  rc=$?
  set -e
  _assert_exit "toml: taplo check passes clean file" 0 "$rc"

  printf '[a\nbroken\n' >"$_td/bad.toml"
  set +e
  "$AUTOLINT" "$_td/bad.toml" >/dev/null 2>&1
  rc=$?
  set -e
  _assert_exit "toml: taplo check fails malformed file" 1 "$rc"
fi

# Dispatch-wiring: per-repo .taplo.toml wins over fallback. Uses a
# mock taplo that echoes its args so we can check --config routing
# without depending on taplo's actual semantics.
_taplo_mockbin=$(_mock_bin)
cat >"$_taplo_mockbin/taplo" <<'EOF'
#!/usr/bin/env bash
echo "MOCK-TAPLO-ARGS: $*"
exit 0
EOF
chmod +x "$_taplo_mockbin/taplo"

_taplo_repo=$(_tmpdir)
cat >"$_taplo_repo/.taplo.toml" <<'EOF'
# per-repo sentinel
EOF
echo 'k = "v"' >"$_taplo_repo/test.toml"
set +e
output=$(PATH="$_taplo_mockbin:$PATH" "$AUTOLINT" "$_taplo_repo/test.toml" 2>&1)
rc=$?
set -e
_assert_exit "toml: per-repo .taplo.toml wins — exits 0" 0 "$rc"
_assert_contains "toml: per-repo .taplo.toml passed via --config" \
  "--config $_taplo_repo/.taplo.toml" "$output"

# No per-repo config + $AUTOLINT_DIR/taplo.toml present → fallback applies.
_alt_taplo=$(_tmpdir)
cat >"$_alt_taplo/taplo.toml" <<'EOF'
# fallback sentinel
EOF
echo 'k = "v"' >"$_td/fb.toml"
set +e
output=$(AUTOLINT_DIR="$_alt_taplo" PATH="$_taplo_mockbin:$PATH" "$AUTOLINT" "$_td/fb.toml" 2>&1)
rc=$?
set -e
_assert_exit "toml: fallback taplo.toml — exits 0" 0 "$rc"
_assert_contains "toml: fallback taplo.toml passed via --config" \
  "--config $_alt_taplo/taplo.toml" "$output"

# No per-repo config + no fallback → --no-schema.
echo 'k = "v"' >"$_td/ns.toml"
set +e
output=$(AUTOLINT_DIR=/nonexistent PATH="$_taplo_mockbin:$PATH" "$AUTOLINT" "$_td/ns.toml" 2>&1)
rc=$?
set -e
_assert_exit "toml: no configs → exits 0" 0 "$rc"
_assert_contains "toml: no configs → --no-schema" "--no-schema" "$output"

# ---------------------------------------------------------------------------
# Tests: --fix flag
# ---------------------------------------------------------------------------

echo "=== Auto-fix ==="

cat >"$_td/fixable.py" <<'EOF'
import os
x = 1
EOF
set +e
"$AUTOLINT" --fix "$_td/fixable.py" >/dev/null 2>&1
rc=$?
set -e
_assert_exit "py: --fix exits 0 after fixing" 0 "$rc"
_assert_not_contains "py: --fix removes unused import" "import os" "$(cat "$_td/fixable.py")"

# ---------------------------------------------------------------------------
# Tests: JS/TS/CSS/JSON linted via biome (mocked)
#
# Unlike eslint, biome ships a recommended rule set and runs without
# a project config — so there is no "skipped without config" path to
# test. The mocks just verify dispatch wiring (file reaches the tool,
# --fix is translated to --write).
# ---------------------------------------------------------------------------

echo "=== JS/TS: linted via biome ==="

_biome_repo=$(_tmpdir)
cat >"$_biome_repo/test.js" <<'EOF'
var x = 1
EOF

_mockbin=$(_mock_bin)
cat >"$_mockbin/biome" <<'EOF'
#!/usr/bin/env bash
echo "mock biome error"
exit 1
EOF
chmod +x "$_mockbin/biome"

set +e
output=$(PATH="$_mockbin:$PATH" "$AUTOLINT" "$_biome_repo/test.js" 2>&1)
rc=$?
set -e
_assert_exit "js: biome runs" 1 "$rc"
_assert_contains "js: biome output shown" "mock biome error" "$output"

_mockbin_fix=$(_mock_bin)
cat >"$_mockbin_fix/biome" <<'EOF'
#!/usr/bin/env bash
for arg in "$@"; do [ "$arg" = "--write" ] && echo "fixed" && exit 0; done
exit 1
EOF
chmod +x "$_mockbin_fix/biome"

set +e
output=$(PATH="$_mockbin_fix:$PATH" "$AUTOLINT" --fix "$_biome_repo/test.js" 2>&1)
rc=$?
set -e
_assert_exit "js: --fix translated to --write" 0 "$rc"
_assert_contains "js: biome --write output shown" "fixed" "$output"

# ---------------------------------------------------------------------------
# Tests: shebang detection for extensionless files
# ---------------------------------------------------------------------------

echo "=== Shebang detection ==="

cat >"$_td/myscript" <<'EOF'
#!/bin/bash
echo $UNDEFINED
EOF
set +e
output=$("$AUTOLINT" "$_td/myscript" 2>&1)
rc=$?
set -e
_assert_exit "shebang bash: shellcheck runs" 1 "$rc"
_assert_contains "shebang bash: output shown" "SC" "$output"

cat >"$_td/shscript" <<'EOF'
#!/bin/sh
echo $UNDEFINED
EOF
set +e
output=$("$AUTOLINT" "$_td/shscript" 2>&1)
rc=$?
set -e
_assert_exit "shebang sh: shellcheck runs" 1 "$rc"

cat >"$_td/zshscript" <<'EOF'
#!/usr/bin/env zsh
if true
  echo "bad"
fi
EOF
set +e
"$AUTOLINT" "$_td/zshscript" >/dev/null 2>&1
rc=$?
set -e
_assert_exit "shebang zsh: zsh -n runs" 1 "$rc"

# ---------------------------------------------------------------------------
# Tests: known dotfile names
# ---------------------------------------------------------------------------

echo "=== Dotfile names ==="

cat >"$_td/.zshrc" <<'EOF'
if true
  echo "missing then"
fi
EOF
set +e
"$AUTOLINT" "$_td/.zshrc" >/dev/null 2>&1
rc=$?
set -e
_assert_exit "dotfile .zshrc: zsh -n runs" 1 "$rc"

cat >"$_td/.bashrc" <<'EOF'
#!/bin/bash
echo $UNDEFINED
EOF
set +e
output=$("$AUTOLINT" "$_td/.bashrc" 2>&1)
rc=$?
set -e
_assert_exit "dotfile .bashrc: shellcheck runs" 1 "$rc"
_assert_contains "dotfile .bashrc: output shown" "SC" "$output"

# ---------------------------------------------------------------------------
# Tests: skipped file types
# ---------------------------------------------------------------------------

echo "=== Skipped types ==="

cat >"$_td/Makefile" <<'EOF'
echo $UNDEFINED
EOF
set +e
"$AUTOLINT" "$_td/Makefile" >/dev/null 2>&1
rc=$?
set -e
_assert_exit "Makefile: skipped — exits 0" 0 "$rc"

# ---------------------------------------------------------------------------
# Tests: actionlint dispatched only for GH workflow YAML
# ---------------------------------------------------------------------------

echo "=== actionlint path scoping ==="

_alint_mock=$(_mock_bin)
cat >"$_alint_mock/actionlint" <<'EOF'
#!/usr/bin/env bash
echo "actionlint: $1"
exit 3
EOF
chmod +x "$_alint_mock/actionlint"

# In a workflow path — actionlint should run and its exit propagate.
_wf_dir="$_td/.github/workflows"
mkdir -p "$_wf_dir"
cat >"$_wf_dir/test.yml" <<'EOF'
name: t
on: push
EOF
set +e
output=$(PATH="$_alint_mock:$PATH" "$AUTOLINT" "$_wf_dir/test.yml" 2>&1)
rc=$?
set -e
_assert_exit "yml under .github/workflows: actionlint invoked" 3 "$rc"
_assert_contains "yml under .github/workflows: output shown" "actionlint:" "$output"

# Same extension outside a workflow path — actionlint must NOT run.
cat >"$_td/other.yml" <<'EOF'
foo: bar
EOF
set +e
output=$(PATH="$_alint_mock:$PATH" "$AUTOLINT" "$_td/other.yml" 2>&1)
rc=$?
set -e
_assert_exit "non-workflow yml: actionlint skipped — exits 0" 0 "$rc"
_assert_not_contains "non-workflow yml: actionlint not invoked" "actionlint:" "$output"

# Workflow path but actionlint not installed — graceful no-op.
_noalint=$(_mock_bin)
ln -s "$(command -v bash)" "$_noalint/bash"
ln -s "$(command -v yq)" "$_noalint/yq"
set +e
PATH="$_noalint" "$AUTOLINT" "$_wf_dir/test.yml" >/dev/null 2>&1
rc=$?
set -e
_assert_exit "workflow yml: no actionlint — exits 0" 0 "$rc"

# ---------------------------------------------------------------------------
# Tests: fallback configs (AUTOLINT_DIR) applied when no per-repo config
# ---------------------------------------------------------------------------

echo "=== Fallback configs (AUTOLINT_DIR) ==="

# Build a controlled AUTOLINT_DIR so these tests don't depend on the
# contents of the user's real ~/.config/autoformat/.
_alt_dir=$(_tmpdir)
cat >"$_alt_dir/shellcheckrc" <<'EOF'
disable=SC1091
EOF
cat >"$_alt_dir/selene.toml" <<'EOF'
[rules]
divide_by_zero = "allow"
EOF
cat >"$_alt_dir/rumdl.toml" <<'EOF'
[global]
disable = ["MD013"]
EOF

# Scenario: file with SC1091 (sourced path missing). With fallback
# (SC1091 disabled) → rc=0; without fallback → rc=1.
cat >"$_td/sc-src.sh" <<'EOF'
#!/bin/bash
. "/no/such/file/autolint/does/not/exist"
echo "all good"
EOF
set +e
AUTOLINT_DIR="$_alt_dir" "$AUTOLINT" "$_td/sc-src.sh" >/dev/null 2>&1
rc=$?
AUTOLINT_DIR=/nonexistent "$AUTOLINT" "$_td/sc-src.sh" >/dev/null 2>&1
rc_no_cfg=$?
set -e
_assert_exit "sh: fallback shellcheckrc disables SC1091" 0 "$rc"
_assert_exit "sh: no fallback — SC1091 fires" 1 "$rc_no_cfg"

# Scenario: per-repo .shellcheckrc wins over fallback. Empty per-repo
# file re-enables SC1091, so the sourced-missing file should warn again.
_sc_repo=$(_tmpdir)
touch "$_sc_repo/.shellcheckrc"
cp "$_td/sc-src.sh" "$_sc_repo/"
set +e
AUTOLINT_DIR="$_alt_dir" "$AUTOLINT" "$_sc_repo/sc-src.sh" >/dev/null 2>&1
rc=$?
set -e
_assert_exit "sh: per-repo .shellcheckrc overrides fallback" 1 "$rc"

# selene: file with a divide-by-zero (selene treats as error by
# default). Fallback allows the rule → rc=0; without fallback, selene
# errors and exits non-zero → rc=1.
if command -v selene &>/dev/null; then
  cat >"$_td/lint.lua" <<'EOF'
local x = 1 / 0
print(x)
EOF
  set +e
  AUTOLINT_DIR="$_alt_dir" "$AUTOLINT" "$_td/lint.lua" >/dev/null 2>&1
  rc=$?
  AUTOLINT_DIR=/nonexistent "$AUTOLINT" "$_td/lint.lua" >/dev/null 2>&1
  rc_no_cfg=$?
  set -e
  _assert_exit "lua: fallback selene.toml allows divide_by_zero" 0 "$rc"
  _assert_exit "lua: no fallback — divide_by_zero fires" 1 "$rc_no_cfg"
fi

# rumdl: file with a long line (MD013). Fallback disables MD013
# → rc=0; without fallback → rc=1.
if command -v rumdl &>/dev/null; then
  python3 -c "
open('$_td/doc.md','w').write('# Title\n\n' + 'x ' * 80 + 'end\n')
"
  set +e
  AUTOLINT_DIR="$_alt_dir" "$AUTOLINT" "$_td/doc.md" >/dev/null 2>&1
  rc=$?
  AUTOLINT_DIR=/nonexistent "$AUTOLINT" "$_td/doc.md" >/dev/null 2>&1
  rc_no_cfg=$?
  set -e
  _assert_exit "md: fallback rumdl.toml disables MD013" 0 "$rc"
  _assert_exit "md: no fallback — MD013 fires on long line" 1 "$rc_no_cfg"

  # Per-repo .markdownlint.json counts as config (rumdl reads it for
  # compat) — fallback should NOT apply. Repo config keeps MD013 on,
  # so long line fires even with AUTOLINT_DIR set.
  _md_repo=$(_tmpdir)
  cat >"$_md_repo/.markdownlint.json" <<'EOF'
{ "MD013": { "line_length": 80 } }
EOF
  python3 -c "
open('$_md_repo/doc.md','w').write('# Title\n\n' + 'x ' * 80 + 'end\n')
"
  set +e
  AUTOLINT_DIR="$_alt_dir" "$AUTOLINT" "$_md_repo/doc.md" >/dev/null 2>&1
  rc=$?
  set -e
  _assert_exit "md: .markdownlint.json overrides fallback" 1 "$rc"
fi

# ---------------------------------------------------------------------------
# Tests: ignore file ($AUTOLINT_DIR/ignore)
# ---------------------------------------------------------------------------

echo "=== Ignore file ==="

# File matched by ignore → autolint exits 0 without invoking any
# linter, even for content that would otherwise produce diagnostics.
_ign_al_dir=$(_tmpdir)
cat >"$_ign_al_dir/ignore" <<'EOF'
*/skipme.sh
EOF

_ign_tgt=$(_tmpdir)
cat >"$_ign_tgt/skipme.sh" <<'EOF'
#!/bin/bash
echo $undefined  # would normally trip SC2154
EOF
set +e
AUTOLINT_DIR="$_ign_al_dir" "$AUTOLINT" "$_ign_tgt/skipme.sh" >/dev/null 2>&1
rc=$?
set -e
_assert_exit "ignore: glob match skips linting" 0 "$rc"

# File NOT in ignore list → linter runs and catches issues.
cat >"$_ign_tgt/keepme.sh" <<'EOF'
#!/bin/bash
echo $undefined
EOF
set +e
AUTOLINT_DIR="$_ign_al_dir" "$AUTOLINT" "$_ign_tgt/keepme.sh" >/dev/null 2>&1
rc=$?
set -e
_assert_exit "ignore: non-match still lints" 1 "$rc"

# ---------------------------------------------------------------------------
# Tests: no-op for missing/empty input
# ---------------------------------------------------------------------------

echo "=== No-op edge cases ==="

rc=0
"$AUTOLINT" "" || rc=$?
_assert_exit "empty arg: exits 0" 0 "$rc"

rc=0
"$AUTOLINT" "/nonexistent/file.sh" || rc=$?
_assert_exit "missing file: exits 0" 0 "$rc"

rc=0
"$AUTOLINT" || rc=$?
_assert_exit "no args: exits 0" 0 "$rc"

# Multi-file rejection: silently dropping args would mean earlier
# files are never linted without the caller noticing. Exit 2 = usage.
cat >"$_td/a.sh" <<'EOF'
#!/bin/bash
echo ok
EOF
cat >"$_td/b.sh" <<'EOF'
#!/bin/bash
echo ok
EOF
set +e
output=$("$AUTOLINT" "$_td/a.sh" "$_td/b.sh" 2>&1)
rc=$?
set -e
_assert_exit "multi-file args: exits 2" 2 "$rc"
_assert_contains "multi-file args: prints error" "expected a single file path" "$output"

# `--fix` with multi-file should also reject.
set +e
output=$("$AUTOLINT" --fix "$_td/a.sh" "$_td/b.sh" 2>&1)
rc=$?
set -e
_assert_exit "multi-file args with --fix: exits 2" 2 "$rc"

# ---------------------------------------------------------------------------
# Tests: graceful skip when linter not installed
# ---------------------------------------------------------------------------

echo "=== Missing linters ==="

_nolinters=$(_mock_bin)
ln -s "$(command -v bash)" "$_nolinters/bash"
# yq is hard-required by autolint; keep it on PATH so these tests
# still reach the linter-missing graceful-skip branches.
ln -s "$(command -v yq)" "$_nolinters/yq"

cat >"$_td/nolint.sh" <<'EOF'
#!/bin/bash
echo $UNDEFINED
EOF
set +e
PATH="$_nolinters" "$AUTOLINT" "$_td/nolint.sh" >/dev/null 2>&1
rc=$?
set -e
_assert_exit "sh: no shellcheck — exits 0" 0 "$rc"

cat >"$_td/nolint.py" <<'EOF'
import os
x=1
EOF
set +e
PATH="$_nolinters" "$AUTOLINT" "$_td/nolint.py" >/dev/null 2>&1
rc=$?
set -e
_assert_exit "py: no ruff — exits 0" 0 "$rc"

# Missing yq: autolint must exit 1 with an error message (yq is
# hard-required, matching autoformat's behavior).
_noyq_bin=$(_mock_bin)
ln -s "$(command -v bash)" "$_noyq_bin/bash"

set +e
output=$(PATH="$_noyq_bin" "$AUTOLINT" "$_td/nolint.sh" 2>&1)
rc=$?
set -e
_assert_exit "missing yq: exits 1" 1 "$rc"
_assert_contains "missing yq: prints error" "autolint: yq is required" "$output"

# ---------------------------------------------------------------------------
# Tests: ruff check fallback (AUTOLINT_DIR/ruff.toml)
# ---------------------------------------------------------------------------

echo "=== ruff check fallback ==="

# Controlled AUTOLINT_DIR with a ruff.toml that disables F401
# (unused-import). Without fallback, ruff's default rules catch
# F401; with fallback, it's ignored.
_ruff_dir=$(_tmpdir)
cat >"$_ruff_dir/ruff.toml" <<'EOF'
[lint]
ignore = ["F401"]
EOF

cat >"$_td/py-fallback.py" <<'EOF'
import os
x = 1
EOF
set +e
AUTOLINT_DIR="$_ruff_dir" "$AUTOLINT" "$_td/py-fallback.py" >/dev/null 2>&1
rc=$?
AUTOLINT_DIR=/nonexistent "$AUTOLINT" "$_td/py-fallback.py" >/dev/null 2>&1
rc_no_cfg=$?
set -e
_assert_exit "py: fallback ruff.toml ignores F401" 0 "$rc"
_assert_exit "py: no fallback — F401 fires" 1 "$rc_no_cfg"

# Per-repo ruff.toml overrides fallback — empty per-repo config
# means default rules apply, so F401 fires again.
_repo_ruff=$(_tmpdir)
cat >"$_repo_ruff/ruff.toml" <<'EOF'
# empty: use ruff defaults
EOF
cp "$_td/py-fallback.py" "$_repo_ruff/"
set +e
AUTOLINT_DIR="$_ruff_dir" "$AUTOLINT" "$_repo_ruff/py-fallback.py" >/dev/null 2>&1
rc=$?
set -e
_assert_exit "py: per-repo ruff.toml overrides fallback" 1 "$rc"

# Per-repo pyproject.toml[tool.ruff] overrides fallback — same idea.
_repo_pp=$(_tmpdir)
cat >"$_repo_pp/pyproject.toml" <<'EOF'
[tool.ruff]
EOF
cp "$_td/py-fallback.py" "$_repo_pp/"
set +e
AUTOLINT_DIR="$_ruff_dir" "$AUTOLINT" "$_repo_pp/py-fallback.py" >/dev/null 2>&1
rc=$?
set -e
_assert_exit "py: pyproject[tool.ruff] overrides fallback" 1 "$rc"

# ---------------------------------------------------------------------------
# Tests: relative paths terminate (regression for _has_config loop on ".")
# ---------------------------------------------------------------------------

echo "=== Relative paths ==="

_reldir=$(_tmpdir)
cat >"$_reldir/ok.sh" <<'EOF'
#!/bin/bash
echo "hello"
EOF
set +e
cd "$_reldir" && _with_timeout 10 "$AUTOLINT" ok.sh >/dev/null 2>&1
rc=$?
cd - >/dev/null
set -e
_assert_exit "rel sh: terminates (no infinite loop)" 0 "$rc"

cat >"$_reldir/ok.py" <<'EOF'
x = 1
EOF
set +e
cd "$_reldir" && _with_timeout 10 "$AUTOLINT" ok.py >/dev/null 2>&1
rc=$?
cd - >/dev/null
set -e
_assert_exit "rel py: terminates" 0 "$rc"

# JS/TS dispatch walks config chain via _find_config — the prior case
# that could loop on relative input when biome is installed.
_rel_js_mock=$(_mock_bin)
cat >"$_rel_js_mock/biome" <<'EOF'
#!/usr/bin/env bash
exit 0
EOF
chmod +x "$_rel_js_mock/biome"
cat >"$_reldir/ok.js" <<'EOF'
var x = 1
EOF
set +e
cd "$_reldir" && PATH="$_rel_js_mock:$PATH" _with_timeout 10 "$AUTOLINT" ok.js >/dev/null 2>&1
rc=$?
cd - >/dev/null
set -e
_assert_exit "rel js: terminates with biome on PATH" 0 "$rc"

# ---------------------------------------------------------------------------
# Summary
# ---------------------------------------------------------------------------

_test_summary

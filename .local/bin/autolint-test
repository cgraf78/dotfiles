#!/usr/bin/env bash
# autolint-test — unit tests for the autolint script.
#
# Tests linting dispatch, error detection, auto-fix, shebang detection,
# and no-op behavior for unsupported/missing files.
#
# Usage: autolint-test

set -o pipefail
export NO_COLOR=1

# shellcheck source=../lib/dot/test-helpers.sh
. "$HOME/.local/lib/dot/test-helpers.sh"

AUTOLINT="$HOME/.local/bin/autolint"

# ---------------------------------------------------------------------------
# Tests: dispatch by extension — errors detected
# ---------------------------------------------------------------------------

echo "=== Dispatch: errors detected ==="

_td=$(_tmpdir)

cat >"$_td/bad.sh" <<'EOF'
#!/bin/bash
echo $UNDEFINED_VAR
EOF
set +e
output=$("$AUTOLINT" "$_td/bad.sh" 2>&1)
rc=$?
set -e
_assert_exit "sh: exits non-zero on error" 1 "$rc"
_assert_contains "sh: shellcheck output shown" "SC" "$output"

cat >"$_td/bad.zsh" <<'EOF'
#!/usr/bin/env zsh
if true
  echo "missing then"
fi
EOF
set +e
_stdout=$("$AUTOLINT" "$_td/bad.zsh" 2>"$_td/bad.zsh.err")
rc=$?
set -e
_assert_exit "zsh: exits non-zero on syntax error" 1 "$rc"
_assert_eq "zsh: errors not on stdout" "" "$_stdout"
_assert_contains "zsh: errors on stderr" "parse error" "$(cat "$_td/bad.zsh.err")"

cat >"$_td/bad.py" <<'EOF'
import os
import sys
x=1
EOF
set +e
output=$("$AUTOLINT" "$_td/bad.py" 2>&1)
rc=$?
set -e
_assert_exit "py: exits non-zero on lint error" 1 "$rc"
_assert_contains "py: ruff output shown" "F401" "$output"

# ---------------------------------------------------------------------------
# Tests: dispatch by extension — clean files pass
# ---------------------------------------------------------------------------

echo "=== Dispatch: clean files pass ==="

cat >"$_td/ok.sh" <<'EOF'
#!/bin/bash
echo "hello"
EOF
set +e
"$AUTOLINT" "$_td/ok.sh" >/dev/null 2>&1
rc=$?
set -e
_assert_exit "sh: exits 0 on clean file" 0 "$rc"

cat >"$_td/ok.zsh" <<'EOF'
#!/usr/bin/env zsh
echo "hello"
EOF
set +e
"$AUTOLINT" "$_td/ok.zsh" >/dev/null 2>&1
rc=$?
set -e
_assert_exit "zsh: exits 0 on clean file" 0 "$rc"

cat >"$_td/ok.py" <<'EOF'
x = 1
EOF
set +e
"$AUTOLINT" "$_td/ok.py" >/dev/null 2>&1
rc=$?
set -e
_assert_exit "py: exits 0 on clean file" 0 "$rc"

# ---------------------------------------------------------------------------
# Tests: --fix flag
# ---------------------------------------------------------------------------

echo "=== Auto-fix ==="

cat >"$_td/fixable.py" <<'EOF'
import os
x = 1
EOF
set +e
"$AUTOLINT" --fix "$_td/fixable.py" >/dev/null 2>&1
rc=$?
set -e
_assert_exit "py: --fix exits 0 after fixing" 0 "$rc"
_assert_not_contains "py: --fix removes unused import" "import os" "$(cat "$_td/fixable.py")"

# ---------------------------------------------------------------------------
# Tests: JS/TS skipped without eslint config
# ---------------------------------------------------------------------------

echo "=== JS/TS: skipped without config ==="

cat >"$_td/bad.js" <<'EOF'
var x = 1
var y = 2
EOF
set +e
"$AUTOLINT" "$_td/bad.js" >/dev/null 2>&1
rc=$?
set -e
_assert_exit "js: skipped (no eslint config) — exits 0" 0 "$rc"

cat >"$_td/bad.ts" <<'EOF'
var x: any = 1
EOF
set +e
"$AUTOLINT" "$_td/bad.ts" >/dev/null 2>&1
rc=$?
set -e
_assert_exit "ts: skipped (no eslint config) — exits 0" 0 "$rc"

# ---------------------------------------------------------------------------
# Tests: JS/TS linted when eslint config present (mocked eslint)
# ---------------------------------------------------------------------------

echo "=== JS/TS: linted with config ==="

_eslint_repo=$(_tmpdir)
touch "$_eslint_repo/eslint.config.js"
cat >"$_eslint_repo/test.js" <<'EOF'
var x = 1
EOF

_mockbin=$(_mock_bin)
cat >"$_mockbin/eslint" <<'EOF'
#!/usr/bin/env bash
echo "mock eslint error"
exit 1
EOF
chmod +x "$_mockbin/eslint"

set +e
output=$(PATH="$_mockbin:$PATH" "$AUTOLINT" "$_eslint_repo/test.js" 2>&1)
rc=$?
set -e
_assert_exit "js: eslint runs with config present" 1 "$rc"
_assert_contains "js: eslint output shown" "mock eslint error" "$output"

_mockbin_fix=$(_mock_bin)
cat >"$_mockbin_fix/eslint" <<'EOF'
#!/usr/bin/env bash
for arg in "$@"; do [ "$arg" = "--fix" ] && echo "fixed" && exit 0; done
exit 1
EOF
chmod +x "$_mockbin_fix/eslint"

set +e
output=$(PATH="$_mockbin_fix:$PATH" "$AUTOLINT" --fix "$_eslint_repo/test.js" 2>&1)
rc=$?
set -e
_assert_exit "js: --fix passed to eslint" 0 "$rc"
_assert_contains "js: eslint --fix output shown" "fixed" "$output"

# ---------------------------------------------------------------------------
# Tests: shebang detection for extensionless files
# ---------------------------------------------------------------------------

echo "=== Shebang detection ==="

cat >"$_td/myscript" <<'EOF'
#!/bin/bash
echo $UNDEFINED
EOF
set +e
output=$("$AUTOLINT" "$_td/myscript" 2>&1)
rc=$?
set -e
_assert_exit "shebang bash: shellcheck runs" 1 "$rc"
_assert_contains "shebang bash: output shown" "SC" "$output"

cat >"$_td/shscript" <<'EOF'
#!/bin/sh
echo $UNDEFINED
EOF
set +e
output=$("$AUTOLINT" "$_td/shscript" 2>&1)
rc=$?
set -e
_assert_exit "shebang sh: shellcheck runs" 1 "$rc"

cat >"$_td/zshscript" <<'EOF'
#!/usr/bin/env zsh
if true
  echo "bad"
fi
EOF
set +e
"$AUTOLINT" "$_td/zshscript" >/dev/null 2>&1
rc=$?
set -e
_assert_exit "shebang zsh: zsh -n runs" 1 "$rc"

# ---------------------------------------------------------------------------
# Tests: known dotfile names
# ---------------------------------------------------------------------------

echo "=== Dotfile names ==="

cat >"$_td/.zshrc" <<'EOF'
if true
  echo "missing then"
fi
EOF
set +e
"$AUTOLINT" "$_td/.zshrc" >/dev/null 2>&1
rc=$?
set -e
_assert_exit "dotfile .zshrc: zsh -n runs" 1 "$rc"

cat >"$_td/.bashrc" <<'EOF'
#!/bin/bash
echo $UNDEFINED
EOF
set +e
output=$("$AUTOLINT" "$_td/.bashrc" 2>&1)
rc=$?
set -e
_assert_exit "dotfile .bashrc: shellcheck runs" 1 "$rc"
_assert_contains "dotfile .bashrc: output shown" "SC" "$output"

# ---------------------------------------------------------------------------
# Tests: skipped file types
# ---------------------------------------------------------------------------

echo "=== Skipped types ==="

cat >"$_td/Makefile" <<'EOF'
echo $UNDEFINED
EOF
set +e
"$AUTOLINT" "$_td/Makefile" >/dev/null 2>&1
rc=$?
set -e
_assert_exit "Makefile: skipped — exits 0" 0 "$rc"

# ---------------------------------------------------------------------------
# Tests: actionlint dispatched only for GH workflow YAML
# ---------------------------------------------------------------------------

echo "=== actionlint path scoping ==="

_alint_mock=$(_mock_bin)
cat >"$_alint_mock/actionlint" <<'EOF'
#!/usr/bin/env bash
echo "actionlint: $1"
exit 3
EOF
chmod +x "$_alint_mock/actionlint"

# In a workflow path — actionlint should run and its exit propagate.
_wf_dir="$_td/.github/workflows"
mkdir -p "$_wf_dir"
cat >"$_wf_dir/test.yml" <<'EOF'
name: t
on: push
EOF
set +e
output=$(PATH="$_alint_mock:$PATH" "$AUTOLINT" "$_wf_dir/test.yml" 2>&1)
rc=$?
set -e
_assert_exit "yml under .github/workflows: actionlint invoked" 3 "$rc"
_assert_contains "yml under .github/workflows: output shown" "actionlint:" "$output"

# Same extension outside a workflow path — actionlint must NOT run.
cat >"$_td/other.yml" <<'EOF'
foo: bar
EOF
set +e
output=$(PATH="$_alint_mock:$PATH" "$AUTOLINT" "$_td/other.yml" 2>&1)
rc=$?
set -e
_assert_exit "non-workflow yml: actionlint skipped — exits 0" 0 "$rc"
_assert_not_contains "non-workflow yml: actionlint not invoked" "actionlint:" "$output"

# Workflow path but actionlint not installed — graceful no-op.
_noalint=$(_mock_bin)
ln -s "$(command -v bash)" "$_noalint/bash"
ln -s "$(command -v yq)" "$_noalint/yq"
set +e
PATH="$_noalint" "$AUTOLINT" "$_wf_dir/test.yml" >/dev/null 2>&1
rc=$?
set -e
_assert_exit "workflow yml: no actionlint — exits 0" 0 "$rc"

# ---------------------------------------------------------------------------
# Tests: fallback configs (AUTOLINT_DIR) applied when no per-repo config
# ---------------------------------------------------------------------------

echo "=== Fallback configs (AUTOLINT_DIR) ==="

# Build a controlled AUTOLINT_DIR so these tests don't depend on the
# contents of the user's real ~/.config/autoformat/.
_alt_dir=$(_tmpdir)
cat >"$_alt_dir/shellcheckrc" <<'EOF'
disable=SC1091
EOF
cat >"$_alt_dir/luacheckrc" <<'EOF'
ignore = {"212"}
EOF
cat >"$_alt_dir/markdownlint-cli2.jsonc" <<'EOF'
{ "config": { "MD013": false } }
EOF

# Scenario: file with SC1091 (sourced path missing). With fallback
# (SC1091 disabled) → rc=0; without fallback → rc=1.
cat >"$_td/sc-src.sh" <<'EOF'
#!/bin/bash
. "/no/such/file/autolint/does/not/exist"
echo "all good"
EOF
set +e
AUTOLINT_DIR="$_alt_dir" "$AUTOLINT" "$_td/sc-src.sh" >/dev/null 2>&1
rc=$?
AUTOLINT_DIR=/nonexistent "$AUTOLINT" "$_td/sc-src.sh" >/dev/null 2>&1
rc_no_cfg=$?
set -e
_assert_exit "sh: fallback shellcheckrc disables SC1091" 0 "$rc"
_assert_exit "sh: no fallback — SC1091 fires" 1 "$rc_no_cfg"

# Scenario: per-repo .shellcheckrc wins over fallback. Empty per-repo
# file re-enables SC1091, so the sourced-missing file should warn again.
_sc_repo=$(_tmpdir)
touch "$_sc_repo/.shellcheckrc"
cp "$_td/sc-src.sh" "$_sc_repo/"
set +e
AUTOLINT_DIR="$_alt_dir" "$AUTOLINT" "$_sc_repo/sc-src.sh" >/dev/null 2>&1
rc=$?
set -e
_assert_exit "sh: per-repo .shellcheckrc overrides fallback" 1 "$rc"

# luacheck: file with unused argument (code 212). Fallback ignores 212
# → rc=0; without fallback → rc=1.
if command -v luacheck &>/dev/null; then
  cat >"$_td/lc.lua" <<'EOF'
local function greet(unused)
  return "hi"
end
print(greet(42))
EOF
  set +e
  AUTOLINT_DIR="$_alt_dir" "$AUTOLINT" "$_td/lc.lua" >/dev/null 2>&1
  rc=$?
  AUTOLINT_DIR=/nonexistent "$AUTOLINT" "$_td/lc.lua" >/dev/null 2>&1
  rc_no_cfg=$?
  set -e
  _assert_exit "lua: fallback luacheckrc ignores code 212" 0 "$rc"
  _assert_exit "lua: no fallback — code 212 fires" 1 "$rc_no_cfg"
fi

# markdownlint-cli2: file with a long line (MD013). Fallback disables
# MD013 → rc=0; without fallback → rc=1.
if command -v markdownlint-cli2 &>/dev/null; then
  python3 -c "
open('$_td/doc.md','w').write('# Title\n\n' + 'x ' * 80 + 'end\n')
"
  set +e
  AUTOLINT_DIR="$_alt_dir" "$AUTOLINT" "$_td/doc.md" >/dev/null 2>&1
  rc=$?
  AUTOLINT_DIR=/nonexistent "$AUTOLINT" "$_td/doc.md" >/dev/null 2>&1
  rc_no_cfg=$?
  set -e
  _assert_exit "md: fallback markdownlint-cli2.jsonc disables MD013" 0 "$rc"
  _assert_exit "md: no fallback — MD013 fires on long line" 1 "$rc_no_cfg"

  # package.json with a `markdownlint-cli2` key counts as per-repo
  # config — fallback should NOT apply. Repo config keeps MD013 on,
  # so long line fires even with AUTOLINT_DIR set.
  _md_pkg=$(_tmpdir)
  cat >"$_md_pkg/package.json" <<'EOF'
{ "name": "demo", "markdownlint-cli2": { "config": { "MD013": { "line_length": 80 } } } }
EOF
  python3 -c "
open('$_md_pkg/doc.md','w').write('# Title\n\n' + 'x ' * 80 + 'end\n')
"
  set +e
  AUTOLINT_DIR="$_alt_dir" "$AUTOLINT" "$_md_pkg/doc.md" >/dev/null 2>&1
  rc=$?
  set -e
  _assert_exit "md: package.json markdownlint-cli2 key overrides fallback" 1 "$rc"

  # Regression: package.json WITHOUT the key must not count as
  # per-repo config; fallback should still apply.
  _md_pkg_no=$(_tmpdir)
  cat >"$_md_pkg_no/package.json" <<'EOF'
{ "name": "demo", "version": "1.0.0" }
EOF
  python3 -c "
open('$_md_pkg_no/doc.md','w').write('# Title\n\n' + 'x ' * 80 + 'end\n')
"
  set +e
  AUTOLINT_DIR="$_alt_dir" "$AUTOLINT" "$_md_pkg_no/doc.md" >/dev/null 2>&1
  rc=$?
  set -e
  _assert_exit "md: package.json without key → fallback still applies" 0 "$rc"
fi

# ---------------------------------------------------------------------------
# Tests: no-op for missing/empty input
# ---------------------------------------------------------------------------

echo "=== No-op edge cases ==="

rc=0
"$AUTOLINT" "" || rc=$?
_assert_exit "empty arg: exits 0" 0 "$rc"

rc=0
"$AUTOLINT" "/nonexistent/file.sh" || rc=$?
_assert_exit "missing file: exits 0" 0 "$rc"

rc=0
"$AUTOLINT" || rc=$?
_assert_exit "no args: exits 0" 0 "$rc"

# ---------------------------------------------------------------------------
# Tests: graceful skip when linter not installed
# ---------------------------------------------------------------------------

echo "=== Missing linters ==="

_nolinters=$(_mock_bin)
ln -s "$(command -v bash)" "$_nolinters/bash"
# yq is hard-required by autolint; keep it on PATH so these tests
# still reach the linter-missing graceful-skip branches.
ln -s "$(command -v yq)" "$_nolinters/yq"

cat >"$_td/nolint.sh" <<'EOF'
#!/bin/bash
echo $UNDEFINED
EOF
set +e
PATH="$_nolinters" "$AUTOLINT" "$_td/nolint.sh" >/dev/null 2>&1
rc=$?
set -e
_assert_exit "sh: no shellcheck — exits 0" 0 "$rc"

cat >"$_td/nolint.py" <<'EOF'
import os
x=1
EOF
set +e
PATH="$_nolinters" "$AUTOLINT" "$_td/nolint.py" >/dev/null 2>&1
rc=$?
set -e
_assert_exit "py: no ruff — exits 0" 0 "$rc"

# Missing yq: autolint must exit 1 with an error message (yq is
# hard-required, matching autoformat's behavior).
_noyq_bin=$(_mock_bin)
ln -s "$(command -v bash)" "$_noyq_bin/bash"

set +e
output=$(PATH="$_noyq_bin" "$AUTOLINT" "$_td/nolint.sh" 2>&1)
rc=$?
set -e
_assert_exit "missing yq: exits 1" 1 "$rc"
_assert_contains "missing yq: prints error" "autolint: yq is required" "$output"

# ---------------------------------------------------------------------------
# Tests: ruff check fallback (AUTOLINT_DIR/ruff.toml)
# ---------------------------------------------------------------------------

echo "=== ruff check fallback ==="

# Controlled AUTOLINT_DIR with a ruff.toml that disables F401
# (unused-import). Without fallback, ruff's default rules catch
# F401; with fallback, it's ignored.
_ruff_dir=$(_tmpdir)
cat >"$_ruff_dir/ruff.toml" <<'EOF'
[lint]
ignore = ["F401"]
EOF

cat >"$_td/py-fallback.py" <<'EOF'
import os
x = 1
EOF
set +e
AUTOLINT_DIR="$_ruff_dir" "$AUTOLINT" "$_td/py-fallback.py" >/dev/null 2>&1
rc=$?
AUTOLINT_DIR=/nonexistent "$AUTOLINT" "$_td/py-fallback.py" >/dev/null 2>&1
rc_no_cfg=$?
set -e
_assert_exit "py: fallback ruff.toml ignores F401" 0 "$rc"
_assert_exit "py: no fallback — F401 fires" 1 "$rc_no_cfg"

# Per-repo ruff.toml overrides fallback — empty per-repo config
# means default rules apply, so F401 fires again.
_repo_ruff=$(_tmpdir)
cat >"$_repo_ruff/ruff.toml" <<'EOF'
# empty: use ruff defaults
EOF
cp "$_td/py-fallback.py" "$_repo_ruff/"
set +e
AUTOLINT_DIR="$_ruff_dir" "$AUTOLINT" "$_repo_ruff/py-fallback.py" >/dev/null 2>&1
rc=$?
set -e
_assert_exit "py: per-repo ruff.toml overrides fallback" 1 "$rc"

# Per-repo pyproject.toml[tool.ruff] overrides fallback — same idea.
_repo_pp=$(_tmpdir)
cat >"$_repo_pp/pyproject.toml" <<'EOF'
[tool.ruff]
EOF
cp "$_td/py-fallback.py" "$_repo_pp/"
set +e
AUTOLINT_DIR="$_ruff_dir" "$AUTOLINT" "$_repo_pp/py-fallback.py" >/dev/null 2>&1
rc=$?
set -e
_assert_exit "py: pyproject[tool.ruff] overrides fallback" 1 "$rc"

# ---------------------------------------------------------------------------
# Tests: relative paths terminate (regression for _has_config loop on ".")
# ---------------------------------------------------------------------------

echo "=== Relative paths ==="

_reldir=$(_tmpdir)
cat >"$_reldir/ok.sh" <<'EOF'
#!/bin/bash
echo "hello"
EOF
set +e
cd "$_reldir" && _with_timeout 10 "$AUTOLINT" ok.sh >/dev/null 2>&1
rc=$?
cd - >/dev/null
set -e
_assert_exit "rel sh: terminates (no infinite loop)" 0 "$rc"

cat >"$_reldir/ok.py" <<'EOF'
x = 1
EOF
set +e
cd "$_reldir" && _with_timeout 10 "$AUTOLINT" ok.py >/dev/null 2>&1
rc=$?
cd - >/dev/null
set -e
_assert_exit "rel py: terminates" 0 "$rc"

# JS/TS dispatch walks config chain via _has_config — the prior case that
# could loop on relative input when eslint is installed.
_rel_js_mock=$(_mock_bin)
cat >"$_rel_js_mock/eslint" <<'EOF'
#!/usr/bin/env bash
exit 0
EOF
chmod +x "$_rel_js_mock/eslint"
cat >"$_reldir/ok.js" <<'EOF'
var x = 1
EOF
set +e
cd "$_reldir" && PATH="$_rel_js_mock:$PATH" _with_timeout 10 "$AUTOLINT" ok.js >/dev/null 2>&1
rc=$?
cd - >/dev/null
set -e
_assert_exit "rel js: terminates with eslint on PATH" 0 "$rc"

# ---------------------------------------------------------------------------
# Summary
# ---------------------------------------------------------------------------

_test_summary
